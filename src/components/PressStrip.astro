---
// Press / "As featured in" strip with marquee ticker
---

<section class="py-14 border-b border-[color:var(--line)]" style="border-color: var(--line);">
  <div class="max-w-[1400px] mx-auto px-8">
    <div class="text-center mb-8" style="font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted);">
      As featured in
    </div>
    <div class="overflow-hidden relative">
      <div class="flex gap-16 ticker whitespace-nowrap" style="display: flex; gap: 4rem; animation: tk 30s linear infinite; white-space: nowrap;">
        {[
          'The NY Times', 'WIRED', 'The Atlantic', 'Healthline',
          'Medical News Today', 'PsyPost', 'Brain & Life', 'AJMC',
          'The NY Times', 'WIRED', 'The Atlantic', 'Healthline',
          'Medical News Today', 'PsyPost', 'Brain & Life', 'AJMC',
        ].map((name, i) => (
          <span
            key={i}
            class="inline-block"
            style="font-size: 22px; color: var(--ink); opacity: 0.45;"
          >{name}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes tk {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .ticker:hover {
    animation-play-state: paused;
  }
</style>