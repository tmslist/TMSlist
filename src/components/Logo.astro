---
interface Props {
    className?: string;
}
const { className = "h-8 w-auto" } = Astro.props;
---

<div class="flex items-center gap-2.5 group cursor-pointer">
    <svg
        class={className}
        viewBox="0 0 100 100"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
    >
        <defs>
            <linearGradient id="tmsBrandGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#7C3AED"/>
                <stop offset="100%" stop-color="#D946EF"/>
            </linearGradient>
        </defs>
        <!-- Magnetic wave arcs representing brain signal -->
        <path
            d="M50 15 C 30 15, 15 35, 15 55 C 15 75, 30 85, 50 85"
            stroke="url(#tmsBrandGradient)"
            stroke-width="8"
            stroke-linecap="round"
            class="transition-transform group-hover:scale-105 origin-center duration-300"
        ></path>
        <path
            d="M65 25 C 45 25, 35 40, 35 55 C 35 70, 45 75, 65 75"
            stroke="url(#tmsBrandGradient)"
            stroke-width="8"
            stroke-linecap="round"
            opacity="0.7"
            class="transition-transform group-hover:scale-105 origin-center duration-300 delay-75"
        ></path>
        <path
            d="M80 35 C 65 35, 55 45, 55 55 C 55 65, 65 65, 80 65"
            stroke="url(#tmsBrandGradient)"
            stroke-width="8"
            stroke-linecap="round"
            opacity="0.4"
            class="transition-transform group-hover:scale-105 origin-center duration-300 delay-150"
        ></path>
    </svg>
    <span class="text-xl font-extrabold tracking-tight text-slate-900 dark:text-white font-display">
        TMS<span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-600 to-fuchsia-600">List</span>
    </span>
</div>
