---
interface Props {
  variant?: 'inline' | 'banner';
  source?: string;
}

const { variant = 'inline', source = 'footer' } = Astro.props;
---

{variant === 'banner' ? (
  <section class="bg-[var(--ink)] py-12">
    <div class="container mx-auto px-6 lg:px-12">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="text-white">
          <h2 class="text-2xl font-bold mb-2">Stay Updated on TMS Therapy</h2>
          <p class="text-white/80 font-light">Get weekly updates on new clinics, insurance coverage, and treatment advances.</p>

        </div>
        <form class="newsletter-form flex gap-3 w-full md:w-auto" data-source={source}>
          <input type="email" name="email" required placeholder="your@email.com"
            class="flex-1 md:w-72 px-5 py-3.5 rounded-xl text-sm bg-white/10 backdrop-blur border border-white/20 text-white placeholder-white/50 focus:bg-white/20 focus:border-white/40 focus:ring-0 transition-all" />
          <button type="submit" class="px-6 py-3.5 bg-white text-[var(--accent)] font-bold rounded-xl text-sm hover:bg-white/90 transition-all shrink-0">
            Subscribe
          </button>
        </form>
      </div>
      <p class="newsletter-success hidden text-emerald-200 font-medium mt-4 text-center md:text-left">Subscribed! Check your inbox for a welcome email.</p>
      <p class="newsletter-error hidden text-red-200 font-medium mt-4 text-center md:text-left"></p>
    </div>
  </section>
) : (
  <div class="bg-[var(--paper2)] rounded-2xl border border-[var(--line)] p-6">
    <h3 class="text-lg font-bold text-[var(--ink)] mb-2">TMS Newsletter</h3>
    <p class="text-sm text-[var(--muted)] mb-4">Weekly updates on clinics, insurance, and research.</p>
    <form class="newsletter-form flex gap-2" data-source={source}>
      <input type="email" name="email" required placeholder="your@email.com"
        class="flex-1 px-4 py-2.5 rounded-xl border border-[var(--line)] text-sm focus:border-[rgba(10,22,40,0.2)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] transition-all" />
      <button type="submit" class="px-5 py-2.5 bg-[var(--accent)] hover:bg-[var(--accent)] text-white font-bold rounded-xl text-sm transition-all shrink-0">
        Join
      </button>
    </form>
    <p class="newsletter-success hidden text-emerald-600 text-sm font-medium mt-3">Subscribed!</p>
    <p class="newsletter-error hidden text-red-600 text-sm font-medium mt-3"></p>
  </div>
)}

<script>
  document.querySelectorAll('.newsletter-form').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const parent = f.closest('section, div')!;
      const email = (f.querySelector('[name="email"]') as HTMLInputElement).value;
      const source = f.dataset.source || 'website';

      try {
        const res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source }),
        });

        if (res.ok) {
          f.classList.add('hidden');
          parent.querySelector('.newsletter-success')?.classList.remove('hidden');
        } else {
          const { error } = await res.json();
          const errEl = parent.querySelector('.newsletter-error') as HTMLElement;
          errEl.textContent = error || 'Something went wrong';
          errEl.classList.remove('hidden');
        }
      } catch {
        const errEl = parent.querySelector('.newsletter-error') as HTMLElement;
        errEl.textContent = 'Network error. Try again.';
        errEl.classList.remove('hidden');
      }
    });
  });
</script>
