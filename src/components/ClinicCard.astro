---
import { type Clinic } from "../types/clinic";
import {
    getClinicRating,
    getClinicReviewCount,
    getClinicPhoto,
    hasRealClinicImage,
    COUNTRY_FLAGS,
} from "../utils/dataHelpers";
import { getReviewSnippet, getSnippetSentiment } from "../utils/reviewSnippets";
import SaveClinicButton from "./react/SaveClinicButton";
import BrandLogo from "./BrandLogo.astro";
import { resolveBrandSlug } from "../utils/brandLogos";

interface Props {
    clinic: Clinic;
}

const { clinic } = Astro.props;
const rating = getClinicRating(clinic);
const reviewCount = getClinicReviewCount(clinic);
const mainImage = getClinicPhoto(clinic);
const reviewSnippet = getReviewSnippet({
    name: clinic.name,
    rating,
    reviewCount,
    machines: clinic.machines,
    insurances: clinic.insurances,
    verified: clinic.verified,
    city: clinic.city,
    state: clinic.state,
});
const sentiment = getSnippetSentiment(rating);

// Trust Signals (Mocked for Demo Purpose based on verified status)
const isVerified = clinic.verified;

// Availability badges derived from clinic data
const availability = clinic.availability || {};
const isNewlyVerified = isVerified && (() => {
    const created = new Date(clinic.createdAt);
    const twoWeeksAgo = new Date();
    twoWeeksAgo.setDate(twoWeeksAgo.getDate() - 14);
    return created > twoWeeksAgo;
})();
const isAvailableThisWeek = availability.same_week_available || availability.accepting_new_patients;
const isAcceptingNew = availability.accepting_new_patients !== false;
const waitTime = availability.wait_time_weeks;

// Compute trust badges
const trustBadges: { label: string; class: string; icon: string }[] = [];
if (isAcceptingNew && isAvailableThisWeek) {
    trustBadges.push({ label: 'Available This Week', class: 'bg-emerald-50 text-emerald-700 border-emerald-100', icon: 'check-circle' });
}
if (isNewlyVerified) {
    trustBadges.push({ label: 'Newly Verified', class: 'bg-[rgba(10,22,40,0.10)] text-[var(--ink)] border-[rgba(10,22,40,0.15)]', icon: 'sparkles' });
}
if (isAcceptingNew && !isAvailableThisWeek && waitTime) {
    trustBadges.push({ label: `Wait: ${waitTime}wk`, class: 'bg-amber-50 text-amber-700 border-amber-100', icon: 'clock' });
} else if (isAcceptingNew && !isAvailableThisWeek) {
    trustBadges.push({ label: 'Accepting New Patients', class: 'bg-[var(--paper2)] text-[var(--accent)] border-[var(--line)]', icon: 'user-plus' });
}
---

<article
    class="group bg-white rounded-2xl border border-[var(--line)] shadow-xl shadow-[rgba(10,22,40,0.1)] hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col h-full"
    data-rating={rating.toFixed(2)}
    data-name={clinic.name}
    data-reviews={reviewCount}
>
    <!-- Image Header -->
    <div class="relative h-56 overflow-hidden">
        <img
            src={mainImage}
            alt={`${clinic.name} - TMS Clinic in ${clinic.city}, ${clinic.state}`}
            width="800"
            height="500"
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy"
            decoding="async"
            onerror="this.src='/images/tms_hero.svg';this.onerror=null;"
        />
        <div
            class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-80"
        >
        </div>

        <!-- Badges -->
        <div class="absolute top-4 left-4 flex flex-wrap gap-2">
            {
                clinic.hero_image_url && (
                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-white/90 backdrop-blur text-[10px] font-semibold text-emerald-700 shadow-sm border border-emerald-100">
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/></svg>
                        Real Photo
                    </span>
                )
            }
            {
                isVerified && (
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-white/95 backdrop-blur text-xs font-semibold text-[var(--ink)] shadow-sm border border-[rgba(10,22,40,0.15)]">
                        <svg
                            class="w-3.5 h-3.5 text-[var(--accent2)]"
                            fill="currentColor"
                            viewBox="0 0 20 20"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                clip-rule="evenodd"
                            />
                        </svg>
                        Verified Clinic
                    </span>
                )
            }
            {
                clinic.provider_type && (
                    <span class="inline-flex items-center px-3 py-1 rounded-full bg-white/80 backdrop-blur text-xs font-semibold text-[var(--ink)] shadow-sm border border-[var(--line)]">
                        {clinic.provider_type}
                    </span>
                )
            }
            {trustBadges.map(badge => (
                <span class={`inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-white/90 backdrop-blur text-[10px] font-semibold shadow-sm border ${badge.class}`}>
                    {badge.icon === 'check-circle' && (
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    )}
                    {badge.icon === 'sparkles' && (
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zM12 2a1 1 0 01.967.744L14.146 7.2 17.5 9.134a1 1 0 010 1.732l-3.354 1.935-1.18 4.455a1 1 0 01-1.933 0L9.854 12.8 6.5 10.866a1 1 0 010-1.732l3.354-1.935 1.18-4.455A1 1 0 0112 2z" clip-rule="evenodd"/></svg>
                    )}
                    {badge.icon === 'clock' && (
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    )}
                    {badge.icon === 'user-plus' && (
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/></svg>
                    )}
                    {badge.label}
                </span>
            ))}
        </div>

        <!-- Save Button (top-right) -->
        <div class="absolute top-4 right-4">
            <SaveClinicButton clinicId={clinic.id} clinicName={clinic.name} client:idle />
        </div>

        <!-- Rating Overlay & Location -->
        <div class="absolute bottom-4 left-4 right-4 text-white">
            <h3
                class="font-semibold text-lg leading-tight mb-1.5 drop-shadow-md line-clamp-2"
            >
                {clinic.name}
            </h3>
            <p
                class="text-sm text-white/90 flex items-center gap-1.5 font-medium"
            >
                <svg
                    class="w-4 h-4 shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                    ></path><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
                >
                {clinic.city}, {clinic.state}{clinic.country && clinic.country !== 'US' ? <span role="img" aria-label={clinic.country} set:html={COUNTRY_FLAGS[clinic.country] || ''} /> : ''}
            </p>
        </div>
    </div>

    <!-- Content Body -->
    <div class="p-5 flex-1 flex flex-col">
        <!-- Trust Stats Row -->
        <div
            class="flex items-center gap-4 mb-5 text-xs font-medium text-[var(--muted)] border-b border-[var(--line)] pb-4"
        >
            <div
                class="flex items-center gap-1.5 text-emerald-700 bg-emerald-50 px-2 py-1 rounded-md border border-emerald-100"
            >
                <svg
                    class="w-3.5 h-3.5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                    ></path></svg
                >
                {(!clinic.country || clinic.country === 'US') ? 'FDA Cleared' : 'Approved'}
            </div>
            <div class="flex items-center gap-1.5 px-2 py-1">
                <svg
                    class="w-4 h-4 text-amber-400"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                    ><path
                        d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                    ></path></svg
                >
                <span class="text-[var(--ink)] font-semibold text-sm"
                    >{rating.toFixed(1)}</span
                >
                <span class="text-[var(--muted)]">({reviewCount})</span>
            </div>
        </div>

        <!-- Features List -->
        <div class="space-y-3 mb-6 flex-1">
            <div class="flex items-start gap-2.5">
                <div
                    class="w-5 h-5 rounded-full bg-[rgba(10,22,40,0.10)] flex items-center justify-center shrink-0 mt-0.5"
                >
                    <svg
                        class="w-3 h-3 text-[var(--accent)]"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
                    >
                </div>
                <div class="text-xs text-[var(--ink2)] leading-relaxed min-w-0">
                    <span class="font-semibold text-[var(--ink)] block mb-1">Technology</span>
                    {(clinic.machines && clinic.machines.length > 0) ? (
                        <span class="inline-flex flex-wrap items-center gap-1.5">
                            {clinic.machines.slice(0, 3).map((m: string) => (
                                <span class="inline-flex items-center gap-1 bg-[var(--paper2)] border border-[var(--line)] rounded px-1.5 py-0.5">
                                    <BrandLogo slug={resolveBrandSlug(m)} name={m} size={14} />
                                    <span class="text-[11px] font-medium">{m}</span>
                                </span>
                            ))}
                            {clinic.machines.length > 3 && (
                                <span class="text-[11px] text-[var(--muted)]">+{clinic.machines.length - 3}</span>
                            )}
                        </span>
                    ) : (
                        <span class="line-clamp-2">Standard TMS</span>
                    )}
                </div>
            </div>
            <div class="flex items-start gap-2.5">
                <div
                    class="w-5 h-5 rounded-full bg-[var(--paper2)] flex items-center justify-center shrink-0 mt-0.5"
                >
                    <svg
                        class="w-3 h-3 text-[var(--accent)]"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 011.414.586l4 4a1 1 0 01.586 1.414V19a2 2 0 01-2 2z"
                        ></path></svg
                    >
                </div>
                <div class="text-xs text-[var(--ink2)] leading-relaxed min-w-0">
                    <span class="font-semibold text-[var(--ink)] block mb-1">Insurance accepted</span>
                    {(clinic.insurances && clinic.insurances.length > 0) ? (
                        <span class="inline-flex flex-wrap items-center gap-1.5">
                            {clinic.insurances.slice(0, 3).map((ins: string) => (
                                <span class="inline-flex items-center gap-1 bg-[var(--paper2)] border border-[var(--line)] rounded px-1.5 py-0.5">
                                    <BrandLogo slug={resolveBrandSlug(ins)} name={ins} size={14} />
                                    <span class="text-[11px] font-medium">{ins}</span>
                                </span>
                            ))}
                            {clinic.insurances.length > 3 && (
                                <span class="text-[11px] text-[var(--muted)]">+{clinic.insurances.length - 3}</span>
                            )}
                        </span>
                    ) : (
                        <span class="text-[var(--muted)]">Contact clinic</span>
                    )}
                </div>
            </div>
        </div>

        <!-- Review Snippet -->
        {reviewSnippet && (
            <div class={`flex items-start gap-2 px-3 py-2.5 rounded-xl mb-4 text-xs leading-relaxed ${
                sentiment === 'excellent' ? 'bg-emerald-50 text-emerald-700 border border-emerald-100' :
                sentiment === 'good' ? 'bg-[var(--paper2)] text-[var(--accent)] border border-[var(--line)]' :
                'bg-[var(--paper2)] text-[var(--ink2)] border border-[var(--line)]'
            }`}>
                <svg class="w-3.5 h-3.5 shrink-0 mt-0.5 opacity-60" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 13V5a2 2 0 00-2-2H4a2 2 0 00-2 2v8a2 2 0 002 2h3l3 3 3-3h3a2 2 0 002-2zM5 7a1 1 0 011-1h8a1 1 0 110 2H6a1 1 0 01-1-1zm1 3a1 1 0 100 2h3a1 1 0 100-2H6z" clip-rule="evenodd" />
                </svg>
                <p class="italic line-clamp-2">"{reviewSnippet}"</p>
            </div>
        )}

        <!-- CTA Actions -->
        <div class="mt-auto flex flex-col gap-2">
            <!-- Primary CTA: Book Free Consult — warm terracotta, full-width -->
            <a
                href={`/clinic/${clinic.slug}/#enquiry`}
                class="w-full text-center py-2.5 px-4 text-white text-sm font-semibold rounded-xl transition-all shadow-md focus-visible:ring-2 focus-visible:ring-offset-2"
                style="background:var(--warm); box-shadow:0 2px 12px rgba(201,101,74,0.3);"
                aria-label={`Book free consultation at ${clinic.name}`}
            >
                Book Free Consult →
            </a>
            <!-- Secondary row: View Profile + Phone -->
            <div class="flex gap-2">
                <a
                    href={`/clinic/${clinic.slug}`}
                    class="flex-1 text-center py-2.5 px-4 text-[var(--ink2)] text-sm font-semibold rounded-xl transition-all border focus-visible:ring-2 focus-visible:ring-offset-2"
                    style="background:var(--paper2); border-color:var(--line);"
                    aria-label={`View ${clinic.name} profile`}
                >
                    View Profile
                </a>
                {clinic.phone && (
                    <a
                        href={`tel:${clinic.phone.replace(/\D/g,'')}`}
                        class="px-3.5 py-2.5 text-[var(--ink2)] rounded-xl transition-colors border cursor-pointer"
                        style="background:var(--paper2); border-color:var(--line);"
                        aria-label={`Call ${clinic.phone}`}
                    >
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    </a>
                )}
            </div>
        </div>
    </div>
</article>
