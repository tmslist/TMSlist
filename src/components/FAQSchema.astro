---
interface Props {
  faqs: { question: string; answer: string }[];
}

const { faqs } = Astro.props;

const schema = faqs.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer,
    },
  })),
}) : null;
---

{schema && <script type="application/ld+json" set:html={schema} />}
