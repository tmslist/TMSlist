---
interface MetaStat {
  value: string;
  label: string;
  color?: 'violet' | 'emerald' | 'blue' | 'amber' | 'cyan' | 'rose';
}

interface Props {
  metaStats: MetaStat[];
  reviewerName?: string;
  reviewerTitle?: string;
  reviewerImage?: string;
  reviewerBio?: string;
}

const {
  metaStats = [],
  reviewerName = 'Dr. Karan Narwal',
  reviewerTitle = 'Mental Health Specialist & Consultant',
  reviewerImage = 'https://img1.wsimg.com/isteam/ip/f791d9b9-2f6c-4539-b9b3-61b4c8a8a446/Screenshot%202024-11-16%20at%204.26.32%E2%80%AFPM.png/:/cr=t:0%25,l:6.95%25,w:86.1%25,h:100%25/rs=w:600,h:600,cg:true',
  reviewerBio = 'Dr. Narwal reviews all clinical content on TMS List for medical accuracy and has extensive experience in neuromodulation therapies.',
} = Astro.props;

const colorMap: Record<string, { bg: string; text: string; border: string; label: string }> = {
  violet: { bg: 'bg-violet-50', text: 'text-violet-700', border: 'border-violet-100', label: 'text-violet-700/80' },
  emerald: { bg: 'bg-emerald-50', text: 'text-emerald-700', border: 'border-emerald-100', label: 'text-emerald-700/80' },
  blue: { bg: 'bg-blue-50', text: 'text-blue-700', border: 'border-blue-100', label: 'text-blue-700/80' },
  amber: { bg: 'bg-amber-50', text: 'text-amber-700', border: 'border-amber-100', label: 'text-amber-700/80' },
  cyan: { bg: 'bg-cyan-50', text: 'text-cyan-700', border: 'border-cyan-100', label: 'text-cyan-700/80' },
  rose: { bg: 'bg-rose-50', text: 'text-rose-700', border: 'border-rose-100', label: 'text-rose-700/80' },
};
---

<section class="container mx-auto px-4 mb-12">
  <div class="flex flex-col lg:flex-row gap-4 items-start">
    <!-- Meta stats compact row -->
    {metaStats.length > 0 && (
      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-2 xl:grid-cols-4 gap-3 flex-1">
        {metaStats.map((stat) => {
          const c = colorMap[stat.color || 'violet'];
          return (
            <div class={`relative overflow-hidden ${c.bg} border ${c.border} rounded-2xl p-4 text-center hover:shadow-md transition-all duration-200`}>
              <div class={`text-2xl font-extrabold font-display ${c.text} leading-tight`}>{stat.value}</div>
              <div class={`text-[11px] font-medium mt-1 ${c.label}`}>{stat.label}</div>
            </div>
          );
        })}
      </div>
    )}

    <!-- Medical reviewer card -->
    <div class="bg-white border border-slate-100 rounded-2xl p-5 shadow-sm w-full lg:w-72 shrink-0">
      <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-4">Medically Reviewed By</div>
      <div class="flex items-center gap-3 mb-3">
        <img
          src={reviewerImage}
          alt={reviewerName}
          class="w-12 h-12 rounded-full object-cover border-2 border-violet-100"
          width="48"
          height="48"
          loading="lazy"
        />
        <div>
          <div class="font-semibold text-slate-900 text-sm">{reviewerName}</div>
          <div class="text-xs text-slate-500">{reviewerTitle}</div>
        </div>
      </div>
      <p class="text-xs text-slate-500 leading-relaxed">{reviewerBio}</p>
    </div>
  </div>
</section>
