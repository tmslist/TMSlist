---
// Editorial-warm shared page hero — replaces the older blue-gradient hero
// to cascade the elegant style across all pages still using PageHero.

interface BreadcrumbItem {
    label: string;
    href: string;
}

interface Props {
    title: string;
    titleAccent?: string;
    subtitle?: string;
    badge?: string;
    badgeColor?: 'violet' | 'emerald' | 'blue' | 'amber';
    breadcrumbs?: BreadcrumbItem[];
    stats?: { value: string; label: string }[];
}

const { title, titleAccent, subtitle, badge, badgeColor = 'violet', breadcrumbs, stats } = Astro.props;

const dotColors: Record<string, string> = {
    violet: 'var(--accent)',
    emerald: '#22c55e',
    blue: 'var(--accent2, #1E2A3B)',
    amber: 'var(--warm)',
};

const dot = dotColors[badgeColor] || dotColors.violet;
---

<section class="page-hero">
    <div class="page-hero-dotgrid" aria-hidden="true"></div>
    <div class="page-hero-blob" aria-hidden="true"></div>

    <div class="page-hero-inner">
        {breadcrumbs && breadcrumbs.length > 0 && (
            <nav class="page-hero-crumb" aria-label="Breadcrumb">
                {breadcrumbs.map((item, i) => (
                    <>
                        {i > 0 && <span>/</span>}
                        {i < breadcrumbs.length - 1 ? (
                            <a href={item.href} class="page-hero-crumb-link">{item.label}</a>
                        ) : (
                            <span class="page-hero-crumb-current">{item.label}</span>
                        )}
                    </>
                ))}
            </nav>
        )}

        <div class={stats && stats.length > 0 ? "page-hero-grid page-hero-grid-stats" : "page-hero-grid"}>
            <div class="page-hero-content">
                {badge && (
                    <div class="page-hero-eyebrow">
                        <span class="page-hero-eyebrow-dot" style={`background:${dot}`}></span>
                        <span>{badge}</span>
                    </div>
                )}

                <h1 class="serif page-hero-title">
                    {title}
                    {titleAccent && (
                        <>
                            <br />
                            <span class="italic page-hero-title-accent">{titleAccent}</span>
                        </>
                    )}
                </h1>

                {subtitle && <p class="page-hero-subtitle">{subtitle}</p>}

                <slot />
            </div>

            {stats && stats.length > 0 && (
                <div class="page-hero-stats">
                    {stats.map(stat => (
                        <div class="page-hero-stat">
                            <div class="serif page-hero-stat-value">{stat.value}</div>
                            <div class="page-hero-stat-label">{stat.label}</div>
                        </div>
                    ))}
                </div>
            )}
        </div>
    </div>
</section>

<style>
    .page-hero {
        position: relative;
        background: var(--paper);
        padding: 8rem 0 4rem;
        border-bottom: 1px solid var(--line);
        overflow: hidden;
    }

    .page-hero-dotgrid {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background-image: radial-gradient(var(--line) 1px, transparent 1px);
        background-size: 40px 40px;
        opacity: 0.5;
    }

    .page-hero-blob {
        position: absolute;
        top: 0;
        left: 10%;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        filter: blur(150px);
        background: rgba(201,101,74,0.08);
        pointer-events: none;
    }

    .page-hero-inner {
        position: relative;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    @media (min-width: 1024px) {
        .page-hero-inner { padding: 0 2rem; }
    }

    .page-hero-crumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-bottom: 2rem;
        color: var(--muted);
    }

    .page-hero-crumb-link {
        color: inherit;
        text-decoration: none;
        transition: color 0.15s ease;
    }
    .page-hero-crumb-link:hover { color: var(--ink); }
    .page-hero-crumb-current { color: var(--ink); }

    .page-hero-grid {
        display: grid;
        gap: 3rem;
        align-items: end;
    }

    @media (min-width: 1024px) {
        .page-hero-grid-stats { grid-template-columns: 1fr 1fr; }
    }

    .page-hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 2rem;
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.075em;
        color: var(--muted);
    }

    .page-hero-eyebrow-dot {
        width: 0.375rem;
        height: 0.375rem;
        border-radius: 50%;
    }

    .page-hero-title {
        font-size: clamp(2.25rem, 5vw, 4rem);
        line-height: 1.05;
        letter-spacing: -0.02em;
        color: var(--ink);
        margin: 0 0 1.5rem;
    }

    .page-hero-title-accent {
        color: var(--warm);
    }

    .page-hero-subtitle {
        font-size: 17px;
        line-height: 1.65;
        max-width: 36rem;
        color: var(--muted);
        margin: 0;
    }

    .page-hero-stats {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        align-items: flex-start;
    }

    @media (min-width: 1024px) {
        .page-hero-stats { justify-content: flex-end; }
    }

    .page-hero-stat {
        background: var(--paper2);
        border: 1px solid var(--line);
        border-radius: 1rem;
        padding: 1rem 1.25rem;
        text-align: center;
        min-width: 7rem;
    }

    .page-hero-stat-value {
        font-size: 1.875rem;
        line-height: 1;
        color: var(--ink);
    }

    .page-hero-stat-label {
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.075em;
        margin-top: 0.25rem;
        color: var(--muted);
    }
</style>
