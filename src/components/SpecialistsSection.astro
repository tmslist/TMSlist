---
import type { Clinic } from '../types/clinic';

interface Props {
    featuredDoctorsByCountry: Record<string, any[]>;
    countryCode?: string;
}

const { featuredDoctorsByCountry, countryCode = 'US' } = Astro.props as Props;
---

<!-- MEET SPECIALISTS - New Section -->
<section class="py-16 bg-[var(--paper)] relative overflow-hidden" data-clinic-country={countryCode}>
    <!-- Decoration -->
    <div class="absolute top-0 right-0 w-64 h-64 bg-[var(--paper2)] rounded-bl-full opacity-50 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-40 h-40 bg-[#C9654A]/10 rounded-tr-full opacity-50 pointer-events-none"></div>

    <div class="container mx-auto px-4 relative z-10">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
            <div>
                 <span class="inline-block px-3 py-1 bg-[var(--paper2)] text-[var(--accent)] rounded-full text-xs font-semibold uppercase tracking-wider mb-3">
                    Expert Care
                </span>
                <h2 class="text-3xl md:text-5xl font-semibold tracking-tight text-[var(--ink)] leading-tight">
                    Meet Leading <br/>
                    <span class="italic text-[var(--warm)]">TMS Specialists</span>
                </h2>
            </div>
            <div class="flex items-center gap-4">
                 <p class="hidden md:block text-[var(--muted)] max-w-xs text-sm text-right leading-relaxed">
                    Connect with board-certified psychiatrists specializing in interventional mental health.
                </p>
                <a
                    href="/specialists/"
                    class="px-6 py-3 bg-[var(--ink)] hover:bg-[var(--ink2)] text-white rounded-xl font-semibold transition-colors shadow-lg hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] flex items-center gap-2 whitespace-nowrap"
                >
                    Find a Specialist
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </a>
            </div>
        </div>

        {Object.entries(featuredDoctorsByCountry).map(([gridCountry, doctors]) => (
            <div class={`specialist-country-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 ${gridCountry !== countryCode ? 'hidden' : ''}`} data-country={gridCountry}>
                {doctors.map((doctor: any) => (
                    <a href={`/specialist/${doctor.slug}/`} class="group relative bg-[var(--paper)] rounded-2xl overflow-hidden border border-[var(--line)] hover:border-[rgba(10,22,40,0.30)] hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[rgba(10,22,40,0.2)] transition-all duration-300 flex flex-col h-full">
                        <!-- Image -->
                        <div class="aspect-[4/3] relative overflow-hidden bg-[var(--paper2)]">
                             <img
                                src={doctor.image}
                                alt={doctor.name}
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                                loading="lazy"
                                width="400"
                                height="300"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-white/80 via-transparent to-transparent opacity-60"></div>
                            <div class="absolute bottom-0 left-0 right-0 p-4">
                                <h3 class="text-[var(--ink)] text-lg font-semibold leading-tight focus-visible:ring-2 focus-visible:ring-[rgba(10,22,40,0.15)] focus-visible:ring-offset-2">{doctor.name}</h3>
                                <p class="text-[var(--ink2)] text-xs font-medium">{doctor.title}</p>
                            </div>
                        </div>

                        <!-- Content -->
                        <div class="p-5 flex flex-col flex-1">
                             <div class="flex items-start gap-2 mb-3 text-xs text-[var(--muted)]">
                                <svg class="w-4 h-4 shrink-0 text-[var(--accent2)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                <span class="line-clamp-2">{doctor.clinicName}, {doctor.clinicCity}, {doctor.clinicState}</span>
                            </div>

                            <div class="mt-auto">
                                <div class="flex flex-wrap gap-1.5 mb-4">
                                     {doctor.specialties?.slice(0, 2).map((s: string) => (
                                        <span class="px-2 py-0.5 bg-[var(--paper2)] text-[var(--ink2)] rounded text-[10px] font-semibold border border-[var(--line)]">
                                            {s}
                                        </span>
                                     ))}
                                     {(doctor.specialties?.length || 0) > 2 && (
                                        <span class="px-2 py-0.5 bg-[var(--paper2)] text-[var(--muted)] rounded text-[10px] font-semibold border border-[var(--line)]">
                                            +{doctor.specialties.length - 2}
                                        </span>
                                     )}
                                </div>

                                <span class="block w-full text-center py-2.5 rounded-lg border border-[var(--line)] text-[var(--ink2)] text-sm font-semibold group-hover:bg-[rgba(201,101,74,0.08)] group-hover:border-[var(--warm)] group-hover:text-[var(--warm)] transition-all">
                                    View Profile
                                </span>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        ))}
    </div>
</section>