---
import type { InferSelectModel } from 'drizzle-orm';
import type { doctors } from '../db/schema';

type Doctor = InferSelectModel<typeof doctors>;

interface Props {
  doctor: Doctor;
  reviewCount?: number;
  hasAvailability?: boolean;
  /** Compact = sidebar, full = dashboard. */
  variant?: 'full' | 'compact';
}

const { doctor, reviewCount = 0, hasAvailability = false, variant = 'full' } = Astro.props;

interface Check {
  key: string;
  label: string;
  done: boolean;
  weight: number;
  href?: string;
  hint?: string;
}

const checks: Check[] = [
  { key: 'name', label: 'Display name', done: !!doctor.name, weight: 5, href: '/doctor/profile/' },
  { key: 'photo', label: 'Profile photo', done: !!doctor.imageUrl, weight: 15, href: '/doctor/profile/', hint: 'Profiles with photos get 7× more clicks' },
  { key: 'credential', label: 'Credentials (MD, DO, etc.)', done: !!doctor.credential, weight: 10, href: '/doctor/profile/' },
  { key: 'title', label: 'Job title / role', done: !!doctor.title, weight: 5, href: '/doctor/profile/' },
  { key: 'school', label: 'Medical school', done: !!doctor.school, weight: 5, href: '/doctor/profile/' },
  { key: 'experience', label: 'Years of experience', done: typeof doctor.yearsExperience === 'number' && doctor.yearsExperience > 0, weight: 5, href: '/doctor/profile/' },
  { key: 'specialties', label: 'Specialties (≥1)', done: !!doctor.specialties && doctor.specialties.length > 0, weight: 10, href: '/doctor/profile/' },
  { key: 'bio', label: 'Bio (≥150 characters)', done: !!doctor.bio && doctor.bio.length >= 150, weight: 15, href: '/doctor/profile/', hint: 'Long bios convert 3× better' },
  { key: 'slug', label: 'SEO-friendly URL slug', done: !!doctor.slug, weight: 10, href: '/doctor/profile/' },
  { key: 'reviews', label: 'Has at least 1 review', done: reviewCount > 0, weight: 10, href: '/doctor/reviews/' },
  { key: 'availability', label: 'Availability set', done: hasAvailability, weight: 10, href: '/doctor/availability/' },
];

const totalWeight = checks.reduce((s, c) => s + c.weight, 0);
const earned = checks.filter(c => c.done).reduce((s, c) => s + c.weight, 0);
const score = Math.round((earned / totalWeight) * 100);
const remaining = checks.filter(c => !c.done);
const tone = score >= 90 ? 'success' : score >= 60 ? 'warn' : 'danger';
const toneColor = tone === 'success' ? '#059669' : tone === 'warn' ? '#d97706' : '#dc2626';
const toneBg = tone === 'success' ? '#ecfdf5' : tone === 'warn' ? '#fffbeb' : '#fef2f2';
const message = score === 100
  ? "Profile complete — you're ranking at the top tier."
  : score >= 90
  ? "Almost there — finish the last items to unlock priority ranking."
  : score >= 60
  ? "Good start. Profiles ≥90% rank higher in search."
  : "Incomplete profiles get filtered down. Add the items below.";
---

{variant === 'full' ? (
  <section class="bg-white rounded-xl border border-[var(--line)] shadow-sm p-6 mb-6">
    <div class="flex items-center justify-between gap-4 flex-wrap mb-4">
      <div>
        <p class="text-[11px] uppercase tracking-wider font-semibold text-[var(--muted)]">Profile completeness</p>
        <h2 class="text-xl font-bold text-[var(--ink)] mt-0.5">{score}% complete</h2>
        <p class="text-sm text-[var(--muted)] mt-1">{message}</p>
      </div>
      <div
        class="rounded-full w-20 h-20 flex items-center justify-center shrink-0 font-bold text-2xl"
        style={`background:${toneBg};color:${toneColor};border:3px solid ${toneColor};`}
      >
        {score}
      </div>
    </div>

    <div class="w-full h-2 rounded-full overflow-hidden mb-5" style="background: var(--paper2);">
      <div class="h-full transition-all" style={`width:${score}%; background:${toneColor};`}></div>
    </div>

    <ul class="grid grid-cols-1 md:grid-cols-2 gap-y-2 gap-x-4">
      {checks.map(c => (
        <li class="flex items-start gap-3 text-sm">
          <span
            class="w-5 h-5 rounded-full flex items-center justify-center shrink-0 mt-0.5"
            style={c.done ? 'background:#d1fae5;color:#065f46;' : 'background:var(--paper2);color:var(--muted);'}
            aria-hidden="true"
          >
            {c.done ? (
              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            ) : (
              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/></svg>
            )}
          </span>
          <div class="flex-1 min-w-0">
            <div class="flex items-baseline gap-2">
              <a
                href={c.href || '#'}
                class={`${c.done ? 'text-[var(--muted)] line-through' : 'text-[var(--ink)] font-medium hover:underline'}`}
              >
                {c.label}
              </a>
              <span class="text-[10px] uppercase tracking-wider text-[var(--muted)]">+{c.weight}%</span>
            </div>
            {!c.done && c.hint && <p class="text-xs text-[var(--muted)] italic">{c.hint}</p>}
          </div>
        </li>
      ))}
    </ul>

    {remaining.length > 0 && (
      <div class="mt-5 pt-4 border-t border-[var(--line)] flex items-center justify-between gap-3 flex-wrap">
        <p class="text-xs text-[var(--muted)]">
          <strong class="text-[var(--ink2)]">{remaining.length}</strong> item{remaining.length === 1 ? '' : 's'} left to reach 100%.
        </p>
        <a
          href={remaining[0].href || '/doctor/profile/'}
          class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-xs font-semibold text-white transition-opacity hover:opacity-90"
          style={`background:${toneColor}`}
        >
          Complete: {remaining[0].label}
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    )}
  </section>
) : (
  <a
    href={remaining[0]?.href || '/doctor/profile/'}
    class="block bg-white rounded-xl border border-[var(--line)] shadow-sm p-4 hover:shadow-md transition-shadow"
  >
    <div class="flex items-center gap-3">
      <div
        class="rounded-full w-12 h-12 flex items-center justify-center shrink-0 font-bold text-sm"
        style={`background:${toneBg};color:${toneColor};border:2px solid ${toneColor};`}
      >
        {score}%
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold text-[var(--ink)]">Profile {score}% complete</p>
        <p class="text-xs text-[var(--muted)] truncate">
          {remaining.length === 0 ? 'All set!' : `Next: ${remaining[0].label}`}
        </p>
      </div>
    </div>
  </a>
)}
