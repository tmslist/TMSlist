---
// Lead Magnet Modal Component for capturing emails in exchange for resources
---

<!-- Lead Magnet Modal -->
<div
    id="lead-magnet-modal"
    class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4 backdrop-blur-sm"
>
    <div
        class="bg-white rounded-2xl max-w-md w-full max-h-[90vh] flex flex-col overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.04)] animate-fade-in-up"
    >
        <!-- Header -->
        <div
            class="bg-[var(--ink)] p-6 rounded-t-2xl shrink-0"
        >
            <div class="flex items-start justify-between">
                <div>
                    <h2 class="text-2xl font-semibold mb-2 text-white">Free TMS Guide</h2>
                    <p class="text-white/80 text-sm">
                        Get instant access to our comprehensive guide
                    </p>
                </div>
                <button
                    id="close-lead-magnet"
                    class="text-white/80 hover:text-white transition-colors"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Body -->
        <div class="p-6 overflow-y-auto flex-1 min-h-0">
            <div class="mb-6">
                <h3 class="font-semibold text-[var(--ink)] mb-3">
                    Choose Your Free Resource:
                </h3>
                <div class="space-y-2">
                    <label
                        class="flex items-start gap-3 p-3 rounded-lg border-2 border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] cursor-pointer transition-colors"
                    >
                        <input
                            type="radio"
                            name="lead-magnet"
                            value="tms-buyers-guide"
                            checked
                            class="mt-1"
                        />
                        <div>
                            <div class="font-semibold text-[var(--ink)]">
                                TMS Buyer's Guide
                            </div>
                            <div class="text-sm text-[var(--ink2)]">
                                Complete guide to choosing the right TMS
                                provider
                            </div>
                        </div>
                    </label>
                    <label
                        class="flex items-start gap-3 p-3 rounded-lg border-2 border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] cursor-pointer transition-colors"
                    >
                        <input
                            type="radio"
                            name="lead-magnet"
                            value="tms-vs-medication"
                            class="mt-1"
                        />
                        <div>
                            <div class="font-semibold text-[var(--ink)]">
                                TMS vs Medication Chart
                            </div>
                            <div class="text-sm text-[var(--ink2)]">
                                Side-by-side comparison to help you decide
                            </div>
                        </div>
                    </label>
                    <label
                        class="flex items-start gap-3 p-3 rounded-lg border-2 border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] cursor-pointer transition-colors"
                    >
                        <input
                            type="radio"
                            name="lead-magnet"
                            value="insurance-checklist"
                            class="mt-1"
                        />
                        <div>
                            <div class="font-semibold text-[var(--ink)]">
                                Insurance Coverage Checklist
                            </div>
                            <div class="text-sm text-[var(--ink2)]">
                                Step-by-step guide to getting TMS covered
                            </div>
                        </div>
                    </label>
                    <label
                        class="flex items-start gap-3 p-3 rounded-lg border-2 border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] cursor-pointer transition-colors"
                    >
                        <input
                            type="radio"
                            name="lead-magnet"
                            value="tms-billing-cpt-codes-2026"
                            class="mt-1"
                        />
                        <div>
                            <div class="font-semibold text-[var(--ink)]">
                                TMS Billing & CPT Codes 2026
                            </div>
                            <div class="text-sm text-[var(--ink2)]">
                                Complete billing guide with CPT codes & reimbursement strategies
                            </div>
                        </div>
                    </label>
                    <label
                        class="flex items-start gap-3 p-3 rounded-lg border-2 border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] cursor-pointer transition-colors"
                    >
                        <input
                            type="radio"
                            name="lead-magnet"
                            value="tms-patient-acquisition-playbook"
                            class="mt-1"
                        />
                        <div>
                            <div class="font-semibold text-[var(--ink)]">
                                Patient Acquisition Playbook
                            </div>
                            <div class="text-sm text-[var(--ink2)]">
                                Proven strategies to fill your TMS schedule
                            </div>
                        </div>
                    </label>
                    <label
                        class="flex items-start gap-3 p-3 rounded-lg border-2 border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] cursor-pointer transition-colors"
                    >
                        <input
                            type="radio"
                            name="lead-magnet"
                            value="tms-prior-authorization-template-kit"
                            class="mt-1"
                        />
                        <div>
                            <div class="font-semibold text-[var(--ink)]">
                                Prior Authorization Template Kit
                            </div>
                            <div class="text-sm text-[var(--ink2)]">
                                Ready-to-use templates to streamline insurance approvals
                            </div>
                        </div>
                    </label>
                    <label
                        class="flex items-start gap-3 p-3 rounded-lg border-2 border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] cursor-pointer transition-colors"
                    >
                        <input
                            type="radio"
                            name="lead-magnet"
                            value="starting-a-tms-clinic-business-plan"
                            class="mt-1"
                        />
                        <div>
                            <div class="font-semibold text-[var(--ink)]">
                                TMS Clinic Business Plan
                            </div>
                            <div class="text-sm text-[var(--ink2)]">
                                Complete guide to starting a profitable TMS practice
                            </div>
                        </div>
                    </label>
                    <label
                        class="flex items-start gap-3 p-3 rounded-lg border-2 border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] cursor-pointer transition-colors"
                    >
                        <input
                            type="radio"
                            name="lead-magnet"
                            value="tms-patient-outcome-tracking-system"
                            class="mt-1"
                        />
                        <div>
                            <div class="font-semibold text-[var(--ink)]">
                                Patient Outcome Tracking System
                            </div>
                            <div class="text-sm text-[var(--ink2)]">
                                Measure and demonstrate TMS treatment results
                            </div>
                        </div>
                    </label>
                    <label
                        class="flex items-start gap-3 p-3 rounded-lg border-2 border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] cursor-pointer transition-colors"
                    >
                        <input
                            type="radio"
                            name="lead-magnet"
                            value="tms-technician-training-checklist"
                            class="mt-1"
                        />
                        <div>
                            <div class="font-semibold text-[var(--ink)]">
                                TMS Technician Training Checklist
                            </div>
                            <div class="text-sm text-[var(--ink2)]">
                                Comprehensive training guide for TMS technicians
                            </div>
                        </div>
                    </label>
                    <label
                        class="flex items-start gap-3 p-3 rounded-lg border-2 border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] cursor-pointer transition-colors"
                    >
                        <input
                            type="radio"
                            name="lead-magnet"
                            value="tms-state-regulations-guide-2026"
                            class="mt-1"
                        />
                        <div>
                            <div class="font-semibold text-[var(--ink)]">
                                State Regulations Guide 2026
                            </div>
                            <div class="text-sm text-[var(--ink2)]">
                                Navigating TMS regulations across all 50 states
                            </div>
                        </div>
                    </label>
                    <label
                        class="flex items-start gap-3 p-3 rounded-lg border-2 border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] cursor-pointer transition-colors"
                    >
                        <input
                            type="radio"
                            name="lead-magnet"
                            value="building-tms-referral-network"
                            class="mt-1"
                        />
                        <div>
                            <div class="font-semibold text-[var(--ink)]">
                                Building a TMS Referral Network
                            </div>
                            <div class="text-sm text-[var(--ink2)]">
                                Strategies to build sustainable referral channels
                            </div>
                        </div>
                    </label>
                </div>
            </div>

            <!-- Form -->
            <form id="lead-magnet-form" class="space-y-4">
                <div>
                    <label
                        class="block text-sm font-semibold text-[var(--ink2)] mb-2"
                        >Full Name *</label
                    >
                    <input
                        type="text"
                        name="name"
                        required
                        placeholder="John Doe"
                        class="w-full px-4 py-2.5 border border-[var(--line)] rounded-lg focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-[rgba(10,22,40,0.2)]"
                    />
                </div>
                <div>
                    <label
                        class="block text-sm font-semibold text-[var(--ink2)] mb-2"
                        >Email Address *</label
                    >
                    <input
                        type="email"
                        name="email"
                        required
                        placeholder="john@example.com"
                        class="w-full px-4 py-2.5 border border-[var(--line)] rounded-lg focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-[rgba(10,22,40,0.2)]"
                    />
                </div>
                <div>
                    <label class="flex items-start gap-2 text-xs text-[var(--ink2)]">
                        <input
                            type="checkbox"
                            name="subscribe"
                            checked
                            class="mt-0.5"
                        />
                        <span
                            >I agree to receive helpful TMS information and
                            resources via email</span
                        >
                    </label>
                </div>
                <button
                    type="submit"
                    class="w-full py-3 bg-[var(--ink)] text-white font-semibold rounded-lg hover:bg-[var(--ink2)] transition-all shadow-lg"
                >
                    Download Free Guide ->
                </button>
                <p class="text-xs text-[var(--muted)] text-center">
                    We respect your privacy. View our <a
                        href="/legal/privacy-policy/"
                        class="text-[var(--accent)] hover:underline">Privacy Policy</a
                    >
                </p>
            </form>
        </div>
    </div>
</div>

<script>
    // Lead magnet modal functionality
    const modal = document.getElementById("lead-magnet-modal");
    const closeBtn = document.getElementById("close-lead-magnet");
    const form = document.getElementById("lead-magnet-form") as HTMLFormElement;

    // Open modal on event. Optional event.detail.slug preselects a magnet radio.
    document.addEventListener("open-lead-magnet", (e: Event) => {
        const detail = (e as CustomEvent).detail as { slug?: string } | undefined;
        if (detail?.slug) {
            const radio = modal?.querySelector(
                `input[name="lead-magnet"][value="${detail.slug}"]`
            ) as HTMLInputElement | null;
            if (radio) radio.checked = true;
        }
        modal?.classList.remove("hidden");
        document.body.style.overflow = "hidden";
    });

    // Close modal
    function closeModal() {
        modal?.classList.add("hidden");
        document.body.style.overflow = "auto";
    }

    closeBtn?.addEventListener("click", closeModal);

    // Close on outside click
    modal?.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
    });

    // Close on Escape
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !modal?.classList.contains("hidden")) {
            closeModal();
        }
    });

    // Handle form submission
    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        // Get button to show loading state
        const submitBtn = form.querySelector(
            'button[type="submit"]',
        ) as HTMLButtonElement;
        const originalBtnText = submitBtn.innerText;
        submitBtn.disabled = true;
        submitBtn.innerText = "Processing...";

        const formData = new FormData(form);
        const selectedResource = (
            document.querySelector(
                'input[name="lead-magnet"]:checked',
            ) as HTMLInputElement
        )?.value;

        const leadData = {
            type: "lead-magnet",
            name: formData.get("name"),
            email: formData.get("email"),
            resource: selectedResource,
            subscribe: formData.get("subscribe") === "on",
            source: window.location.href,
        };

        try {
            // Send lead to API (fire-and-forget) AND store locally as backup
            const apiPromise = fetch('/api/leads', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    type: 'lead_magnet',
                    name: leadData.name,
                    email: leadData.email,
                    sourceUrl: leadData.source,
                    metadata: {
                        resource: leadData.resource,
                        guide_type: ({
                            'tms-buyers-guide': 'buyers-guide',
                            'tms-vs-medication': 'vs-medication',
                            'insurance-checklist': 'insurance-checklist',
                            'tms-billing-cpt-codes-2026': 'billing-cpt',
                            'tms-patient-acquisition-playbook': 'patient-acquisition',
                            'tms-prior-authorization-template-kit': 'prior-auth',
                            'starting-a-tms-clinic-business-plan': 'business-plan',
                            'tms-patient-outcome-tracking-system': 'outcome-tracking',
                            'tms-technician-training-checklist': 'technician-training',
                            'tms-state-regulations-guide-2026': 'state-regulations',
                            'building-tms-referral-network': 'referral-network',
                        }[leadData.resource] || 'other'),
                        guide_title: getResourceName(leadData.resource),
                        subscribed: leadData.subscribe,
                    },
                }),
            }).catch(err => {
                console.warn('[LeadMagnet] API failed, storing locally:', err);
            });

            // Also keep localStorage backup
            const localLeads = JSON.parse(localStorage.getItem("tms-leads") || "[]");
            localLeads.push({ ...leadData, id: `lead-${Date.now()}`, timestamp: new Date().toISOString() });
            localStorage.setItem("tms-leads", JSON.stringify(localLeads));

            // Don't wait for API - proceed immediately for UX
            void apiPromise;

            // Show success and trigger download
            const resourceName = getResourceName(selectedResource);

            // Replace form with success message
            form.innerHTML = `
                <div class="text-center py-8 animate-fade-in-up">
                    <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-semibold text-[var(--ink)] mb-2">Success!</h3>
                    <p class="text-[var(--ink2)] mb-6">Your <strong>${resourceName}</strong> is downloading now.</p>
                    <p class="text-sm text-[var(--muted)]">Check your email for more helpful TMS resources.</p>
                    <button onclick="closeModal()" class="mt-6 px-6 py-2 bg-[var(--paper2)] text-[var(--ink2)] font-semibold rounded-lg hover:bg-[var(--paper2)] transition-colors">
                        Close Window
                    </button>
                </div>
            `;

            // Trigger PDF download
            const downloadUrl = `/downloads/${selectedResource}.pdf`;
            const link = document.createElement("a");
            link.href = downloadUrl;
            link.download = `${selectedResource}.pdf`;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        } catch {
            showToast("Something went wrong. Please try again.");
            submitBtn.disabled = false;
            submitBtn.innerText = originalBtnText;
        }
    });

    function getResourceName(value: string): string {
        const names: Record<string, string> = {
            "tms-buyers-guide": "TMS Buyer's Guide",
            "tms-vs-medication": "TMS vs Medication Comparison",
            "insurance-checklist": "Insurance Coverage Checklist",
            "tms-billing-cpt-codes-2026": "TMS Billing & CPT Codes 2026",
            "tms-patient-acquisition-playbook": "Patient Acquisition Playbook",
            "tms-prior-authorization-template-kit": "Prior Authorization Template Kit",
            "starting-a-tms-clinic-business-plan": "TMS Clinic Business Plan",
            "tms-patient-outcome-tracking-system": "Patient Outcome Tracking System",
            "tms-technician-training-checklist": "Technician Training Checklist",
            "tms-state-regulations-guide-2026": "State Regulations Guide 2026",
            "building-tms-referral-network": "Building a TMS Referral Network",
        };
        return names[value] || "guide";
    }
</script>

<style>
    @keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        animation: fade-in-up 0.3s ease-out;
    }
</style>
