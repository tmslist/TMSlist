---
---
<section class="py-16 bg-slate-900 relative overflow-hidden">
    <!-- Ambient glow -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-violet-600/15 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute top-0 right-1/4 w-[300px] h-[300px] bg-cyan-500/10 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="container mx-auto px-4 max-w-6xl relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

            <!-- Left: Text + CTA -->
            <div>
                <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-violet-500/15 border border-violet-500/25 rounded-full mb-6">
                    <div class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></div>
                    <span class="text-xs font-semibold text-cyan-300 uppercase tracking-widest">Interactive Demo</span>
                </div>

                <h2 class="text-4xl lg:text-5xl font-display font-extrabold text-white mb-4 leading-tight">
                    See Exactly How <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 via-fuchsia-400 to-cyan-400">TMS Works</span>
                </h2>

                <p class="text-lg text-slate-400 leading-relaxed mb-6">
                    Our interactive 3D simulation lets you explore transcranial magnetic stimulation in real time — adjust protocols, visualize the electromagnetic field, and understand what happens during a treatment session.
                </p>

                <div class="flex flex-col sm:flex-row gap-3 mb-8">
                    <a
                        href="/simulation"
                        class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl shadow-lg shadow-violet-600/30 transition-all"
                    >
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" strokeWidth={2} d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                            <path stroke-linecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Launch Simulation
                    </a>
                    <a
                        href="/research"
                        class="inline-flex items-center justify-center gap-2 px-6 py-3 border border-slate-600 hover:border-slate-500 text-slate-300 hover:text-white font-semibold rounded-xl transition-all"
                    >
                        View Clinical Evidence
                    </a>
                </div>

                <!-- Feature pills -->
                <div class="flex flex-wrap gap-2">
                    {[
                        '6 clinical protocols',
                        'Real-time E-field heatmap',
                        'MEP waveform display',
                        'Brain region labels',
                        'Safety pre-screening',
                    ].map(feature => (
                        <div class="flex items-center gap-1.5 bg-slate-800/60 border border-slate-700/50 rounded-full px-3 py-1.5">
                            <svg class="w-3 h-3 text-cyan-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                            </svg>
                            <span class="text-xs text-slate-400">{feature}</span>
                        </div>
                    ))}
                </div>
            </div>

            <!-- Right: Visual preview -->
            <div class="relative">
                <div class="rounded-2xl overflow-hidden border border-slate-700/50 shadow-2xl shadow-black/40 bg-slate-800/80">
                    <!-- Simulated 3D canvas preview -->
                    <div class="relative bg-gradient-to-b from-slate-900 to-slate-800" style="height: 320px;">
                        <!-- Brain sphere representation -->
                        <div class="absolute inset-0 flex items-center justify-center">
                            <div class="relative">
                                <!-- Brain glow -->
                                <div class="absolute inset-0 rounded-full bg-violet-500/20 blur-xl scale-110"></div>
                                <!-- Brain sphere -->
                                <div class="w-36 h-28 rounded-full bg-gradient-to-br from-pink-300/80 to-violet-400/60 shadow-lg shadow-violet-500/30 flex items-center justify-center">
                                    <!-- E-field overlay effect -->
                                    <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-cyan-400/40 via-transparent to-orange-400/30 animate-pulse"></div>
                                </div>
                                <!-- Coil -->
                                <div class="absolute -top-6 left-1/2 -translate-x-1/2 flex flex-col items-center">
                                    <div class="w-16 h-2 bg-slate-700 rounded-full mb-0.5"></div>
                                    <div class="flex gap-0.5">
                                        <div class="w-6 h-6 rounded-full border-2 border-cyan-400 bg-cyan-400/10 shadow-lg shadow-cyan-400/50"></div>
                                        <div class="w-6 h-6 rounded-full border-2 border-violet-400 bg-violet-400/10 shadow-lg shadow-violet-400/50"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Heatmap color bar -->
                        <div class="absolute bottom-3 right-3 flex items-center gap-1.5 bg-slate-900/70 backdrop-blur-sm border border-slate-600/40 rounded-lg px-2 py-1">
                            <span class="text-[9px] text-slate-300">E-field</span>
                            <div class="w-16 h-2 rounded-full bg-gradient-to-r from-blue-500 via-cyan-400 via-green-400 via-yellow-400 to-orange-500"></div>
                        </div>
                        <!-- Badge -->
                        <div class="absolute top-3 left-3 flex items-center gap-1.5 bg-slate-900/70 backdrop-blur-sm border border-slate-600/40 rounded-lg px-2 py-1">
                            <div class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse"></div>
                            <span class="text-[9px] font-medium text-slate-200 uppercase tracking-wider">TMS Simulation</span>
                        </div>
                    </div>
                    <!-- Controls preview strip -->
                    <div class="bg-slate-800/90 border-t border-slate-700/50 p-4 flex items-center gap-3">
                        <div class="flex-1 space-y-1.5">
                            <div class="h-1.5 bg-slate-700 rounded-full overflow-hidden">
                                <div class="h-full bg-cyan-400/60 rounded-full" style="width: 65%"></div>
                            </div>
                            <div class="flex gap-1">
                                <div class="flex-1 h-1 bg-slate-700 rounded-full overflow-hidden">
                                    <div class="h-full bg-violet-500/80 rounded-full" style="width: 80%"></div>
                                </div>
                                <div class="flex-1 h-1 bg-slate-700 rounded-full overflow-hidden">
                                    <div class="h-full bg-cyan-500/80 rounded-full" style="width: 60%"></div>
                                </div>
                            </div>
                        </div>
                        <div class="w-8 h-8 rounded-lg bg-violet-600 flex items-center justify-center shadow-lg shadow-violet-600/30">
                            <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M8 5v14l11-7z"/>
                            </svg>
                        </div>
                    </div>
                </div>
                <!-- Floating badges -->
                <div class="absolute -top-3 -right-3 bg-slate-800/90 border border-slate-600/50 rounded-xl px-3 py-2 shadow-xl">
                    <div class="text-[9px] font-semibold text-slate-300 mb-0.5">Standard rTMS</div>
                    <div class="text-[9px] text-cyan-400">10 Hz · 120% MT</div>
                </div>
                <div class="absolute -bottom-3 -left-3 bg-slate-800/90 border border-slate-600/50 rounded-xl px-3 py-2 shadow-xl">
                    <div class="text-[9px] font-semibold text-slate-300 mb-0.5">Session 12 / 36</div>
                    <div class="text-[9px] text-emerald-400">1,000 pulses · 33%</div>
                </div>
            </div>
        </div>
    </div>
</section>
