---
// Editorial card matching the treatments/ index condition cards.
// Use either the full slot for custom body, or pass title/desc/stats props.

interface Stat {
    label: string;
    value: string | number;
    color?: "ink" | "accent" | "warm";
}

interface Props {
    href: string;
    /** Optional pill tag rendered top-left. */
    tag?: string;
    /** Tag tone. */
    tagTone?: "success" | "accent" | "warm" | "muted";
    /** Card heading. */
    title: string;
    /** Body paragraph. */
    description?: string;
    /** Bottom stats grid (3-col). Omit to skip footer. */
    stats?: Stat[];
    /** "lg" makes the title and padding bigger (matching FDA-cleared cards). */
    size?: "sm" | "lg";
    /** Background. */
    background?: "paper" | "paper2";
}

const {
    href,
    tag,
    tagTone = "accent",
    title,
    description,
    stats = [],
    size = "lg",
    background = "paper2",
} = Astro.props;

const tagBg =
    tagTone === "success" ? "rgba(34,197,94,0.12)" :
    tagTone === "warm" ? "rgba(201,101,74,0.12)" :
    tagTone === "muted" ? "rgba(90,107,130,0.12)" :
    "rgba(10,22,40,0.1)";
const tagColor =
    tagTone === "success" ? "#16a34a" :
    tagTone === "warm" ? "var(--warm)" :
    tagTone === "muted" ? "var(--muted)" :
    "var(--accent)";
const tagBorder =
    tagTone === "success" ? "rgba(34,197,94,0.2)" :
    tagTone === "warm" ? "rgba(201,101,74,0.2)" :
    tagTone === "muted" ? "rgba(90,107,130,0.2)" :
    "rgba(10,22,40,0.2)";

const bg = background === "paper" ? "var(--paper)" : "var(--paper2)";
---

<a
    href={href}
    class={`cond-card cond-card-${size}`}
    style={`background:${bg}; border:1px solid var(--line); display:block;`}
>
    <div class={size === "lg" ? "card-body card-body-lg" : "card-body card-body-sm"}>
        <div class="card-top">
            {tag ? (
                <span
                    class="card-tag"
                    style={`background:${tagBg}; color:${tagColor}; border:1px solid ${tagBorder};`}
                >
                    {tag}
                </span>
            ) : <span></span>}
            <svg
                class={size === "lg" ? "card-arrow card-arrow-lg" : "card-arrow card-arrow-sm"}
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
        </div>

        <h3 class={size === "lg" ? "serif card-title card-title-lg" : "serif card-title card-title-sm"}>
            {title}
        </h3>

        {description && (
            <p class={size === "lg" ? "card-desc card-desc-lg" : "card-desc card-desc-sm"}>
                {description}
            </p>
        )}

        <slot />

        {stats.length > 0 && (
            <div class={size === "lg" ? "card-stats card-stats-lg" : "card-stats card-stats-sm"}>
                {size === "lg" ? (
                    <div class="card-stats-grid">
                        {stats.map((s) => (
                            <div>
                                <div class="card-stat-label">{s.label}</div>
                                <div class={`card-stat-value card-stat-${s.color || "ink"}`}>{s.value}</div>
                            </div>
                        ))}
                    </div>
                ) : (
                    <div class="card-stats-inline">
                        {stats.map((s) => (
                            <div>
                                <span class="card-stat-label-inline">{s.label} </span>
                                <span class={`card-stat-value-inline card-stat-${s.color || "ink"}`}>{s.value}</span>
                            </div>
                        ))}
                    </div>
                )}
            </div>
        )}
    </div>
</a>

<style>
    @reference "../../styles/global.css";

    .cond-card {
        transition: box-shadow 0.2s ease, transform 0.2s ease;
        border-radius: 1.5rem;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
    }

    .cond-card:hover {
        box-shadow: 0 20px 60px -15px rgba(10,22,40,0.15);
        transform: translateY(-2px);
    }

    .cond-card:hover .card-arrow { transform: translateX(4px); }

    .card-body-lg { padding: 1.75rem; }
    .card-body-sm { padding: 1.5rem; }

    .card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

    .card-body-sm .card-top { margin-bottom: 1rem; }

    .card-tag {
        font-size: 10px;
        font-weight: 600;
        padding: 0.25rem 0.625rem;
        border-radius: 0.375rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .card-arrow {
        color: var(--muted);
        transition: transform 0.2s ease;
        flex-shrink: 0;
    }

    .card-arrow-lg { width: 1.25rem; height: 1.25rem; }
    .card-arrow-sm { width: 1rem; height: 1rem; }

    .card-title {
        line-height: 1.15;
        color: var(--ink);
        margin: 0 0 0.75rem;
    }

    .card-title-lg { font-size: 1.5rem; }
    .card-title-sm { font-size: 1.25rem; margin-bottom: 0.5rem; }

    .card-desc {
        line-height: 1.65;
        color: var(--muted);
        margin: 0 0 1.25rem;
    }

    .card-desc-lg { font-size: 14px; }
    .card-desc-sm { font-size: 13px; line-height: 1.6; margin-bottom: 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    .card-stats {
        padding-top: 1.25rem;
        border-top: 1px solid var(--line);
    }

    .card-stats-sm { padding-top: 1rem; }

    .card-stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
    }

    .card-stats-inline {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 11px;
    }

    .card-stat-label {
        font-size: 10px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.075em;
        margin-bottom: 0.125rem;
        color: var(--muted);
    }

    .card-stat-label-inline {
        color: var(--muted);
    }

    .card-stat-value {
        font-size: 15px;
        font-weight: 700;
    }

    .card-stat-value-inline {
        font-weight: 500;
    }

    .card-stat-ink { color: var(--ink); }
    .card-stat-accent { color: var(--accent); }
    .card-stat-warm { color: var(--warm); }
</style>
