---
// Section wrapper matching the treatments/ index "FDA-Cleared" / "Research & Emerging" sections.
// Renders an icon block + serif heading + intro line, then yields children for the body.

interface Props {
    /** Optional icon as raw SVG path content (paths only). */
    icon?: string;
    /** Tone for the icon background — affects color. */
    tone?: "accent" | "warm" | "success" | "muted";
    /** Section heading. */
    title: string;
    /** Optional intro paragraph below heading. */
    intro?: string;
    /** Optional right-aligned link/CTA in the section header. */
    actionLabel?: string;
    actionHref?: string;
    /** Background paper or paper2. */
    background?: "paper" | "paper2";
    /** Hide bottom border. */
    noBorder?: boolean;
}

const {
    icon,
    tone = "accent",
    title,
    intro,
    actionLabel,
    actionHref,
    background = "paper",
    noBorder = false,
} = Astro.props;

const iconBg =
    tone === "warm" ? "rgba(201,101,74,0.1)" :
    tone === "success" ? "rgba(34,197,94,0.1)" :
    tone === "muted" ? "rgba(90,107,130,0.1)" :
    "rgba(10,22,40,0.1)";

const iconColor =
    tone === "warm" ? "var(--warm)" :
    tone === "success" ? "#22c55e" :
    tone === "muted" ? "var(--muted)" :
    "var(--accent)";

const bg = background === "paper2" ? "var(--paper2)" : "var(--paper)";
---

<section
    class="editorial-section"
    style={`background:${bg}; ${noBorder ? '' : 'border-bottom:1px solid var(--line);'}`}
>
    <div class="editorial-section-inner">
        <div class="editorial-section-header">
            <div>
                <div class="editorial-section-title-row">
                    {icon && (
                        <div class="editorial-section-icon" style={`background:${iconBg}; color:${iconColor}`}>
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={icon} />
                        </div>
                    )}
                    <h2 class="serif editorial-section-title">{title}</h2>
                </div>
                {intro && <p class="editorial-section-intro">{intro}</p>}
            </div>
            {actionLabel && actionHref && (
                <a href={actionHref} class="editorial-section-action">
                    {actionLabel}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                    </svg>
                </a>
            )}
        </div>

        <slot />
    </div>
</section>

<style>
    @reference "../../styles/global.css";

    .editorial-section {
        padding: 4rem 0;
    }

    .editorial-section-inner {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    @media (min-width: 1024px) {
        .editorial-section-inner { padding: 0 2rem; }
    }

    .editorial-section-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2.5rem;
    }

    .editorial-section-title-row {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .editorial-section-icon {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .editorial-section-title {
        font-size: clamp(1.75rem, 3vw, 2.25rem);
        color: var(--ink);
        margin: 0;
    }

    .editorial-section-intro {
        font-size: 15px;
        color: var(--muted);
        margin: 0;
    }

    .editorial-section-action {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 13px;
        font-weight: 500;
        color: var(--accent);
        text-decoration: none;
        transition: gap 0.2s ease;
    }

    .editorial-section-action:hover {
        gap: 0.625rem;
    }
</style>
