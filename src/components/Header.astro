<script>
    // ===== MEGA MENU SYSTEM =====
    const overlay = document.getElementById('mega-overlay');
    const allPanels = document.querySelectorAll('.mega-panel') as NodeListOf<HTMLElement>;
    const allTriggers = document.querySelectorAll('.mega-trigger') as NodeListOf<HTMLElement>;
    let activePanel: HTMLElement | null = null;
    let closeTimeout: ReturnType<typeof setTimeout> | null = null;

    function openMegaPanel(id: string) {
        if (closeTimeout) { clearTimeout(closeTimeout); closeTimeout = null; }
        const panel = document.getElementById(id);
        if (!panel || panel === activePanel) return;

        // Close any open panel first
        closeMegaPanel(true);

        activePanel = panel;
        panel.classList.remove('opacity-0', 'invisible', '-translate-y-2');
        panel.classList.add('opacity-100', 'visible', 'translate-y-0');
        overlay?.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
        overlay?.classList.add('opacity-100', 'visible', 'pointer-events-auto');

        // Update trigger states
        allTriggers.forEach(t => {
            const parent = t.closest('[data-mega]') as HTMLElement;
            const megaId = parent?.dataset.mega;
            if (`mega-${megaId}` === id) {
                t.classList.add('text-violet-600');
                t.setAttribute('aria-expanded', 'true');
                t.querySelector('.mega-chevron')?.classList.add('rotate-180', 'text-violet-500');
            }
        });
    }

    function closeMegaPanel(immediate = false) {
        if (!activePanel) return;
        const panel = activePanel;
        panel.classList.add('opacity-0', 'invisible', '-translate-y-2');
        panel.classList.remove('opacity-100', 'visible', 'translate-y-0');
        overlay?.classList.add('opacity-0', 'invisible', 'pointer-events-none');
        overlay?.classList.remove('opacity-100', 'visible', 'pointer-events-auto');

        allTriggers.forEach(t => {
            t.classList.remove('text-violet-600');
            t.setAttribute('aria-expanded', 'false');
            t.querySelector('.mega-chevron')?.classList.remove('rotate-180', 'text-violet-500');
        });

        activePanel = null;
    }

    // Hover triggers with delay
    document.querySelectorAll('[data-mega]').forEach(triggerWrap => {
        const megaId = `mega-${(triggerWrap as HTMLElement).dataset.mega}`;

        triggerWrap.addEventListener('mouseenter', () => {
            openMegaPanel(megaId);
        });

        triggerWrap.addEventListener('mouseleave', () => {
            closeTimeout = setTimeout(() => closeMegaPanel(), 150);
        });
    });

    // Keep panel open when hovering the panel itself
    allPanels.forEach(panel => {
        panel.addEventListener('mouseenter', () => {
            if (closeTimeout) { clearTimeout(closeTimeout); closeTimeout = null; }
        });
        panel.addEventListener('mouseleave', () => {
            closeTimeout = setTimeout(() => closeMegaPanel(), 150);
        });
    });

    // Close on overlay click
    overlay?.addEventListener('click', () => closeMegaPanel());

    // Close on Escape
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMegaPanel();
    });

    // Click triggers (for keyboard / touch)
    allTriggers.forEach(trigger => {
        trigger.addEventListener('click', (e) => {
            const parent = trigger.closest('[data-mega]') as HTMLElement;
            const megaId = `mega-${parent?.dataset.mega}`;
            const isOpen = activePanel?.id === megaId;

            if (isOpen) {
                closeMegaPanel();
                e.preventDefault();
            } else if (trigger.tagName === 'BUTTON') {
                openMegaPanel(megaId);
                e.preventDefault();
            }
            // For <a> triggers: first click opens mega, second navigates
        });
    });

    // ===== MOBILE MENU =====
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileMenuPanel = document.getElementById("mobile-menu-panel");
    const mobileMenuClose = document.getElementById("mobile-menu-close");

    function openMenu() {
        mobileMenu?.classList.remove("opacity-0", "invisible");
        mobileMenu?.classList.add("opacity-100", "visible");
        mobileMenuPanel?.classList.remove("translate-x-full");
        document.body.style.overflow = "hidden";
    }

    function closeMenu() {
        mobileMenu?.classList.add("opacity-0", "invisible");
        mobileMenu?.classList.remove("opacity-100", "visible");
        mobileMenuPanel?.classList.add("translate-x-full");
        document.body.style.overflow = "";
    }

    mobileMenuBtn?.addEventListener("click", openMenu);
    mobileMenuClose?.addEventListener("click", closeMenu);
    mobileMenu?.addEventListener("click", (e) => {
        if (e.target === mobileMenu) closeMenu();
    });

    // Mobile accordion toggle
    document.querySelectorAll('.mobile-accordion-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const content = btn.nextElementSibling as HTMLElement;
            const chevron = btn.querySelector('.accordion-chevron') as HTMLElement;
            const isOpen = !content.classList.contains('hidden');

            if (isOpen) {
                content.classList.add('hidden');
                chevron?.classList.remove('rotate-180');
                btn.setAttribute('aria-expanded', 'false');
            } else {
                content.classList.remove('hidden');
                chevron?.classList.add('rotate-180');
                btn.setAttribute('aria-expanded', 'true');
            }
        });
    });

    // ===== COUNTRY SELECTOR =====
    const geo = (window as any).TMS_GEO;
    const detectedCountry = geo?.country || 'US';

    const flagEl = document.getElementById('country-flag');
    if (flagEl && geo?.flag) {
        flagEl.textContent = geo.flag;
    }

    document.querySelectorAll('.country-option').forEach(el => {
        if ((el as HTMLElement).dataset.country === detectedCountry) {
            el.classList.add('bg-violet-50', 'text-violet-700', 'font-semibold');
        }
    });
</script>
