<script is:inline>
    // =============================================
    // MEGAMENU — Per-hub dropdown (Desktop)
    // Hover-intent open with a small delay; click toggles.
    // =============================================
    (function() {
        var container = document.getElementById('megamenu-container');
        var backdrop = document.getElementById('megamenu-backdrop');
        var triggers = document.querySelectorAll('.hub-trigger');
        var panels = document.querySelectorAll('.megamenu-panel');
        var openTimer = null;
        var closeTimer = null;
        var currentKey = null;

        function clearTimers() {
            if (openTimer) { clearTimeout(openTimer); openTimer = null; }
            if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
        }

        function openHub(key) {
            clearTimers();
            currentKey = key;
            triggers.forEach(function(t) {
                var isActive = t.dataset.hub === key;
                t.classList.toggle('active', isActive);
                t.setAttribute('aria-expanded', isActive ? 'true' : 'false');
            });
            panels.forEach(function(p) {
                p.classList.toggle('active', p.dataset.hub === key);
            });
            container.classList.add('open');
            container.setAttribute('aria-hidden', 'false');
        }

        function closeHub() {
            clearTimers();
            currentKey = null;
            triggers.forEach(function(t) {
                t.classList.remove('active');
                t.setAttribute('aria-expanded', 'false');
            });
            panels.forEach(function(p) {
                p.classList.remove('active');
            });
            container.classList.remove('open');
            container.setAttribute('aria-hidden', 'true');
        }

        triggers.forEach(function(trigger) {
            var key = trigger.dataset.hub;

            trigger.addEventListener('click', function() {
                if (currentKey === key) {
                    closeHub();
                } else {
                    openHub(key);
                }
            });

            trigger.addEventListener('mouseenter', function() {
                clearTimers();
                openTimer = setTimeout(function() {
                    openHub(key);
                }, 100);
            });

            trigger.addEventListener('mouseleave', function() {
                clearTimers();
                closeTimer = setTimeout(function() {
                    if (currentKey === key) closeHub();
                }, 200);
            });
        });

        // Keep open while hovering the panel
        panels.forEach(function(panel) {
            panel.addEventListener('mouseenter', function() {
                clearTimers();
            });
            panel.addEventListener('mouseleave', function() {
                clearTimers();
                closeTimer = setTimeout(closeHub, 200);
            });
        });

        if (backdrop) backdrop.addEventListener('click', closeHub);

        // Close menu when a link is clicked
        document.querySelectorAll('.megamenu-item, .megamenu-cta, .megamenu-secondary').forEach(function(link) {
            link.addEventListener('click', closeHub);
        });

        // Keyboard: Escape closes panel
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeHub();
                closeMobileMenu();
                closeMobileExplore();
            }
        });
    })();

    // =============================================
    // MOBILE EXPLORE MODAL
    // =============================================
    (function() {
        var exploreBtn = document.getElementById('mobile-explore-btn');
        var exploreModal = document.getElementById('mobile-explore');
        var exploreClose = document.getElementById('mobile-explore-close');
        var mobileSearch = document.getElementById('mobile-hub-search');

        if (exploreBtn && exploreModal) {
            exploreBtn.addEventListener('click', function() {
                exploreModal.classList.add('open');
                exploreModal.setAttribute('aria-hidden', 'false');
                document.body.style.overflow = 'hidden';
            });
        }

        if (exploreClose) {
            exploreClose.addEventListener('click', closeMobileExplore);
        }

        // Accordion
        document.querySelectorAll('.explore-category-header').forEach(function(header) {
            header.addEventListener('click', function() {
                var category = header.closest('.explore-category');
                var expanded = category.classList.toggle('expanded');
                header.setAttribute('aria-expanded', expanded ? 'true' : 'false');
            });
        });

        // Mobile search filter
        function filterMobileExplore(query) {
            var q = query.toLowerCase().trim();
            document.querySelectorAll('.explore-item-link').forEach(function(item) {
                var label = (item.dataset.label || '').toLowerCase();
                item.classList.toggle('hidden', q !== '' && !label.includes(q));
            });
            // Auto-expand all categories during search
            if (q !== '') {
                document.querySelectorAll('.explore-category').forEach(function(c) {
                    c.classList.add('expanded');
                });
            }
        }

        if (mobileSearch) {
            mobileSearch.addEventListener('input', function() {
                filterMobileExplore(mobileSearch.value);
            });
        }
    })();

    function closeMobileExplore() {
        var modal = document.getElementById('mobile-explore');
        if (modal) {
            modal.classList.remove('open');
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }
    }

    // =============================================
    // MOBILE MENU DRAWER
    // =============================================
    function toggleMobileMenu() {
        var overlay = document.getElementById('mobile-menu');
        var isOpen = overlay.classList.contains('open');
        overlay.classList.toggle('open');
        overlay.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
        document.body.style.overflow = isOpen ? '' : 'hidden';
    }

    function closeMobileMenu() {
        var overlay = document.getElementById('mobile-menu');
        overlay.classList.remove('open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
    }

    window.toggleMobileMenu = toggleMobileMenu;
    window.closeMobileMenu = closeMobileMenu;
    window.closeMobileExplore = closeMobileExplore;

    document.getElementById('mobile-menu-btn').addEventListener('click', toggleMobileMenu);
    document.getElementById('mobile-backdrop').addEventListener('click', closeMobileMenu);

    // ── Country switcher ───────────────────────────────────────
    (function() {
        var trigger = document.getElementById('country-trigger');
        var menu = document.getElementById('country-menu');
        if (!trigger || !menu) return;

        function open() { menu.hidden = false; trigger.setAttribute('aria-expanded', 'true'); }
        function close() { menu.hidden = true; trigger.setAttribute('aria-expanded', 'false'); }

        trigger.addEventListener('click', function(e) {
            e.stopPropagation();
            menu.hidden ? open() : close();
        });

        // Click-away close
        document.addEventListener('click', function(e) {
            if (!menu.hidden && !menu.contains(e.target) && e.target !== trigger) close();
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && !menu.hidden) close();
        });

        // Selecting a country: persist cookie, clear the auto-sync flag, navigate to that country's home
        menu.addEventListener('click', function(e) {
            var btn = e.target.closest('.country-option');
            if (!btn) return;
            var cc = btn.getAttribute('data-country');
            if (!cc) return;
            document.cookie = 'x-country=' + cc + '; path=/; max-age=' + (60 * 60 * 24 * 365) + '; SameSite=Lax';
            try { sessionStorage.setItem('tms_geo_synced', '1'); } catch (e2) {}
            var urls = (window.TMS_GEO && window.TMS_GEO.urls) || { US: '/us/' };
            location.assign(urls[cc] || '/');
        });
    })();
</script>
