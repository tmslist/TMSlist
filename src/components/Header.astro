---
import {
    TREATMENT_SLUGS,
    INSURANCE_SLUGS,
    TECHNOLOGY_SLUGS,
    PROTOCOL_SLUGS,
    DEMOGRAPHIC_SLUGS,
    COMPARE_SLUGS,
    COMMERCIAL_SLUGS,
} from "../utils/seo_slugs";

const conditions = TREATMENT_SLUGS.slice(0, 10);
const insurance = INSURANCE_SLUGS.slice(0, 8);
const technology = [
    ...TECHNOLOGY_SLUGS.slice(0, 6),
    { slug: "exomind", title: "Exomind Wellness" },
];
const protocols = PROTOCOL_SLUGS.slice(0, 5);
const demographics = DEMOGRAPHIC_SLUGS;
const comparisons = COMPARE_SLUGS.slice(0, 6);
---

<header
    class="bg-white/80 backdrop-blur-md border-b border-slate-200/60 sticky top-0 z-[100] transition-all duration-300"
    id="main-header"
>
    <div
        class="container mx-auto px-4 lg:px-8 h-16 flex items-center justify-between"
    >
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 z-50 group">
            <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-indigo-600 text-white shadow-lg shadow-indigo-600/20 group-hover:bg-indigo-700 transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <span class="text-xl font-semibold tracking-tight text-slate-900 tracking-tight">
                TMS<span class="text-indigo-600">List</span>
            </span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-0.5 xl:gap-1">
            <!-- Find Care Dropdown -->
            <div class="group relative px-2 py-4">
                <button
                    class="flex items-center gap-1.5 text-sm font-semibold text-slate-700 hover:text-indigo-600 transition-colors tracking-wide group-hover:text-indigo-600"
                >
                    Find Care
                    <svg
                        class="w-3.5 h-3.5 text-slate-500 transition-transform duration-300 group-hover:rotate-180 group-hover:text-indigo-500"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>

                <div
                    class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform group-hover:translate-y-0 translate-y-1 w-[320px]"
                >
                    <div
                        class="bg-white rounded-xl shadow-[0_4px_20px_rgb(0,0,0,0.03)] shadow-slate-900/8 ring-1 ring-slate-200/60 p-1.5 overflow-hidden"
                    >
                        <a href="/us/" class="flex items-center gap-3 px-3.5 py-2.5 rounded-lg hover:bg-slate-50 transition-colors group/item">
                            <div class="w-8 h-8 rounded-md bg-indigo-50 flex items-center justify-center text-indigo-600 shrink-0">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            </div>
                            <div>
                                <div class="text-sm font-semibold text-slate-800 group-hover/item:text-indigo-700">Find a Clinic</div>
                                <div class="text-xs text-slate-500 mt-0.5">Browse by state and city</div>
                            </div>
                        </a>
                        <a href="/verified-clinics/" class="flex items-center gap-3 px-3.5 py-2.5 rounded-lg hover:bg-slate-50 transition-colors group/item">
                            <div class="w-8 h-8 rounded-md bg-emerald-50 flex items-center justify-center text-emerald-600 shrink-0">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                            </div>
                            <div>
                                <div class="text-sm font-semibold text-slate-800 group-hover/item:text-indigo-700">Verified Clinics</div>
                                <div class="text-xs text-slate-500 mt-0.5">Quality-checked providers</div>
                            </div>
                        </a>
                        <a href="/specialists/" class="flex items-center gap-3 px-3.5 py-2.5 rounded-lg hover:bg-slate-50 transition-colors group/item">
                            <div class="w-8 h-8 rounded-md bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            </div>
                            <div>
                                <div class="text-sm font-semibold text-slate-800 group-hover/item:text-indigo-700">Find a Specialist</div>
                                <div class="text-xs text-slate-500 mt-0.5">Psychiatrists and neurologists</div>
                            </div>
                        </a>
                        <a href="/compare-clinics/" class="flex items-center gap-3 px-3.5 py-2.5 rounded-lg hover:bg-slate-50 transition-colors group/item">
                            <div class="w-8 h-8 rounded-md bg-violet-50 flex items-center justify-center text-violet-600 shrink-0">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                            </div>
                            <div>
                                <div class="text-sm font-semibold text-slate-800 group-hover/item:text-indigo-700">Compare Clinics</div>
                                <div class="text-xs text-slate-500 mt-0.5">Side-by-side comparison</div>
                            </div>
                        </a>
                        <a href="/near-me/tms-near-me/" class="flex items-center gap-3 px-3.5 py-2.5 rounded-lg hover:bg-slate-50 transition-colors group/item">
                            <div class="w-8 h-8 rounded-md bg-amber-50 flex items-center justify-center text-amber-600 shrink-0">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                            </div>
                            <div>
                                <div class="text-sm font-semibold text-slate-800 group-hover/item:text-indigo-700">TMS Near Me</div>
                                <div class="text-xs text-slate-500 mt-0.5">Location-based search</div>
                            </div>
                        </a>

                        <div class="border-t border-slate-100 mt-1.5 pt-1.5">
                            <a href="/quiz/am-i-a-candidate/" class="flex items-center gap-3 px-3.5 py-2.5 rounded-lg bg-indigo-50/60 hover:bg-indigo-50 transition-colors group/item">
                                <div class="w-8 h-8 rounded-md bg-indigo-100 flex items-center justify-center text-indigo-600 shrink-0">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                                </div>
                                <div>
                                    <div class="text-sm font-semibold text-indigo-700">Am I a Candidate?</div>
                                    <div class="text-xs text-indigo-500 mt-0.5">Take the assessment</div>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Conditions Mega Menu -->
            <div class="group relative px-2 py-4">
                <a
                    href="/treatments/"
                    class="flex items-center gap-1.5 text-sm font-semibold text-slate-700 hover:text-indigo-600 transition-colors tracking-wide group-hover:text-indigo-600"
                >
                    Conditions
                    <svg
                        class="w-3.5 h-3.5 text-slate-500 transition-transform duration-300 group-hover:rotate-180 group-hover:text-indigo-500"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M19 9l-7 7-7-7"></path>
                    </svg>
                </a>

                <div
                    class="absolute left-1/2 -translate-x-1/2 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform group-hover:translate-y-0 translate-y-1 w-[520px] max-w-[90vw]"
                >
                    <div
                        class="bg-white rounded-xl shadow-[0_4px_20px_rgb(0,0,0,0.03)] shadow-slate-900/8 ring-1 ring-slate-200/60 p-5"
                    >
                        <div class="flex items-center justify-between mb-3 pb-3 border-b border-slate-100">
                            <div>
                                <h3 class="text-sm font-semibold text-slate-800">Treatable Conditions</h3>
                                <p class="text-xs text-slate-500 mt-0.5">FDA-cleared and researched protocols</p>
                            </div>
                            <a href="/treatments/" class="text-xs font-semibold text-indigo-600 hover:text-indigo-700 bg-indigo-50 hover:bg-indigo-100 px-3 py-1.5 rounded-full transition-colors">
                                View All
                            </a>
                        </div>

                        <div class="grid grid-cols-2 gap-x-4 gap-y-1">
                            {conditions.map((item) => (
                                <a
                                    href={`/treatments/${item.slug}/`}
                                    class="flex items-center gap-2.5 py-2 px-2 rounded-lg hover:bg-slate-50 transition-colors group/item"
                                >
                                    <div class="w-1.5 h-1.5 rounded-full bg-indigo-300 group-hover/item:bg-indigo-500 transition-colors shrink-0" />
                                    <span class="text-sm text-slate-600 group-hover/item:text-slate-900 transition-colors">
                                        {item.title.replace("TMS for ", "")}
                                    </span>
                                </a>
                            ))}
                        </div>

                        <div class="mt-4 pt-3 border-t border-slate-100 grid grid-cols-2 gap-2">
                            <a href="/compare/" class="text-xs font-medium text-slate-500 hover:text-indigo-600 px-2 py-1.5 rounded hover:bg-slate-50 transition-colors">
                                Compare Treatments
                            </a>
                            <a href="/alternative-treatments/" class="text-xs font-medium text-slate-500 hover:text-indigo-600 px-2 py-1.5 rounded hover:bg-slate-50 transition-colors">
                                Alternative Treatments
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Insurance Mega Menu -->
            <div class="group relative px-2 py-4">
                <a
                    href="/insurance/"
                    class="flex items-center gap-1.5 text-sm font-semibold text-slate-700 hover:text-indigo-600 transition-colors tracking-wide group-hover:text-indigo-600"
                >
                    Insurance
                    <svg
                        class="w-3.5 h-3.5 text-slate-500 transition-transform duration-300 group-hover:rotate-180 group-hover:text-indigo-500"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M19 9l-7 7-7-7"></path>
                    </svg>
                </a>

                <div
                    class="absolute left-1/2 -translate-x-1/2 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform group-hover:translate-y-0 translate-y-1 w-[440px]"
                >
                    <div
                        class="bg-white rounded-xl shadow-[0_4px_20px_rgb(0,0,0,0.03)] shadow-slate-900/8 ring-1 ring-slate-200/60 p-5"
                    >
                        <div class="flex items-center justify-between mb-3 border-b border-slate-100 pb-3">
                            <h3 class="text-sm font-semibold text-slate-800">Insurance Coverage Guides</h3>
                        </div>
                        <div class="grid grid-cols-2 gap-1">
                            {insurance.map((item) => (
                                <a
                                    href={`/insurance/${item.slug}/`}
                                    class="px-3 py-2 text-sm text-slate-600 hover:text-indigo-700 hover:bg-indigo-50 rounded-lg transition-colors truncate"
                                >
                                    {item.title
                                        .replace(" TMS Coverage", "")
                                        .replace(" Coverage for TMS", "")}
                                </a>
                            ))}
                        </div>
                        <div class="mt-3 pt-3 border-t border-slate-100 text-center">
                            <a
                                href="/insurance/"
                                class="inline-flex items-center gap-1.5 text-xs font-semibold text-indigo-600 hover:text-indigo-700"
                            >
                                View All Coverage Guides
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Technology Mega Menu -->
            <div class="group relative px-2 py-4">
                <a
                    href="/technology/"
                    class="flex items-center gap-1.5 text-sm font-semibold text-slate-700 hover:text-indigo-600 transition-colors tracking-wide group-hover:text-indigo-600"
                >
                    Technology
                    <svg
                        class="w-3.5 h-3.5 text-slate-500 transition-transform duration-300 group-hover:rotate-180 group-hover:text-indigo-500"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M19 9l-7 7-7-7"></path>
                    </svg>
                </a>

                <div
                    class="absolute left-1/2 -translate-x-1/2 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform group-hover:translate-y-0 translate-y-1 w-[600px] max-w-[90vw]"
                >
                    <div
                        class="bg-white rounded-xl shadow-[0_4px_20px_rgb(0,0,0,0.03)] shadow-slate-900/8 ring-1 ring-slate-200/60 p-6 grid grid-cols-12 gap-6"
                    >
                        <div class="col-span-7">
                            <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-3">TMS Devices</h4>
                            <div class="grid grid-cols-2 gap-1">
                                {technology.map((item) => (
                                    <a
                                        href={`/technology/${item.slug}/`}
                                        class="px-3 py-2 rounded-lg hover:bg-slate-50 transition-colors group/tech"
                                    >
                                        <span class="text-sm font-medium text-slate-700 group-hover/tech:text-indigo-600">
                                            {item.title}
                                        </span>
                                    </a>
                                ))}
                            </div>
                        </div>

                        <div class="col-span-5 border-l border-slate-100 pl-6">
                            <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-3">Treatment Protocols</h4>
                            <div class="space-y-0.5">
                                {protocols.map((item) => (
                                    <a
                                        href={`/protocols/${item.slug}/`}
                                        class="flex items-center justify-between px-3 py-2 text-sm text-slate-600 hover:text-indigo-700 hover:bg-indigo-50 rounded-lg transition-colors"
                                    >
                                        <span class="font-medium">{item.title}</span>
                                    </a>
                                ))}
                            </div>
                            <div class="mt-4 pt-3 border-t border-slate-100">
                                <a
                                    href="/compare/neurostar-vs-brainsway/"
                                    class="block w-full py-2 text-center text-xs font-semibold text-slate-900 bg-white rounded-lg hover:bg-slate-50 transition-colors"
                                >
                                    Compare Devices
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Resources Dropdown -->
            <div class="group relative px-2 py-4">
                <button
                    class="flex items-center gap-1.5 text-sm font-semibold text-slate-700 hover:text-indigo-600 transition-colors tracking-wide group-hover:text-indigo-600"
                >
                    Resources
                    <svg
                        class="w-3.5 h-3.5 text-slate-500 transition-transform duration-300 group-hover:rotate-180 group-hover:text-indigo-500"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2.5"
                            d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>

                <div
                    class="absolute right-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform group-hover:translate-y-0 translate-y-1 w-[520px]"
                >
                    <div class="bg-white rounded-xl shadow-[0_4px_20px_rgb(0,0,0,0.03)] shadow-slate-900/8 ring-1 ring-slate-200/60 p-5">
                        <div class="grid grid-cols-2 gap-6">
                            <div>
                                <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-3">Learn</h4>
                                <div class="space-y-0.5">
                                    <a href="/blog/" class="block px-3 py-2 text-sm font-medium text-slate-600 hover:text-indigo-600 hover:bg-slate-50 rounded-lg transition-colors">Blog</a>
                                    <a href="/questions/" class="block px-3 py-2 text-sm font-medium text-slate-600 hover:text-indigo-600 hover:bg-slate-50 rounded-lg transition-colors">FAQs</a>
                                    <a href="/resources/" class="block px-3 py-2 text-sm font-medium text-slate-600 hover:text-indigo-600 hover:bg-slate-50 rounded-lg transition-colors">eBooks and Guides</a>
                                    <a href="/stories/" class="block px-3 py-2 text-sm font-medium text-slate-600 hover:text-indigo-600 hover:bg-slate-50 rounded-lg transition-colors">Patient Stories</a>
                                    <a href="/research/" class="block px-3 py-2 text-sm font-medium text-slate-600 hover:text-indigo-600 hover:bg-slate-50 rounded-lg transition-colors">Research and Trials</a>
                                </div>
                            </div>
                            <div>
                                <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-3">Compare</h4>
                                <div class="space-y-0.5">
                                    {comparisons.map((item) => (
                                        <a
                                            href={`/compare/${item.slug}/`}
                                            class="block px-3 py-2 text-sm text-slate-600 hover:text-indigo-600 hover:bg-slate-50 rounded-lg transition-colors"
                                        >
                                            {item.title}
                                        </a>
                                    ))}
                                    <a href="/compare/" class="block px-3 py-2 text-xs font-semibold text-indigo-600 hover:text-indigo-700 rounded-lg transition-colors">
                                        View All Comparisons
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4 pt-3 border-t border-slate-100 flex items-center gap-4">
                            <a href="/demographic/" class="text-xs font-medium text-slate-500 hover:text-indigo-600 transition-colors">Patient Demographics</a>
                            <span class="text-slate-200">|</span>
                            <a href="/alternative-treatments/" class="text-xs font-medium text-slate-500 hover:text-indigo-600 transition-colors">Alternative Treatments</a>
                            <span class="text-slate-200">|</span>
                            <a href="/about-us/" class="text-xs font-medium text-slate-500 hover:text-indigo-600 transition-colors">About Us</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Providers Link -->
            <a
                href="/providers/"
                class="px-2 py-2 text-sm font-semibold text-slate-500 hover:text-indigo-600 transition-colors tracking-wide ml-1 border-l border-slate-200 pl-4"
            >
                Providers
            </a>
        </nav>

        <!-- CTA -->
        <div class="flex items-center gap-3">
            <a
                href="/add-listing/"
                class="hidden sm:inline-flex items-center justify-center px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg shadow-sm hover:shadow transition-all"
            >
                List Your Clinic
            </a>
            <button
                class="lg:hidden p-2 text-slate-600 hover:text-indigo-600 transition-colors"
                id="mobile-menu-btn"
                aria-label="Open menu"
            >
                <svg
                    class="w-6 h-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </div>
</header>

<!-- Mobile Menu Panel -->
<div
    id="mobile-menu"
    class="fixed inset-0 z-[100] bg-black/50 opacity-0 invisible transition-opacity duration-300 lg:hidden"
>
    <div
        id="mobile-menu-panel"
        class="absolute right-0 top-0 h-full w-80 max-w-full bg-white shadow-[0_8px_30px_rgb(0,0,0,0.04)] transform translate-x-full transition-transform duration-300 overflow-y-auto"
    >
        <div class="flex items-center justify-between p-4 border-b border-slate-100 sticky top-0 bg-white z-10">
            <span class="text-base font-semibold text-slate-900">Menu</span>
            <button id="mobile-menu-close" class="p-2 text-slate-500 hover:text-slate-900" aria-label="Close menu">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <nav class="p-4 space-y-1">
            <!-- Find Care Section -->
            <div class="pb-3 mb-3 border-b border-slate-100">
                <p class="px-3 mb-2 text-[10px] font-semibold text-slate-500 uppercase tracking-widest">Find Care</p>
                <a href="/us/" class="block px-3 py-2.5 text-slate-700 font-medium hover:bg-indigo-50 hover:text-indigo-600 rounded-lg transition-colors">Find a Clinic</a>
                <a href="/verified-clinics/" class="block px-3 py-2.5 text-slate-700 font-medium hover:bg-indigo-50 hover:text-indigo-600 rounded-lg transition-colors">Verified Clinics</a>
                <a href="/specialists/" class="block px-3 py-2.5 text-slate-700 font-medium hover:bg-indigo-50 hover:text-indigo-600 rounded-lg transition-colors">Find a Specialist</a>
