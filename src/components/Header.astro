---
import Logo from "./Logo.astro";
import UserMenu from "./react/UserMenu";
import { getVisitorCountry, SUPPORTED_COUNTRIES } from "../utils/visitorCountry";
import { COUNTRY_NAMES, COUNTRY_FLAGS, COUNTRY_URL_PREFIXES } from "../utils/dataHelpers";

const VISITOR_COUNTRY = getVisitorCountry(Astro.isPrerendered ? null : Astro.cookies, Astro.url);
const visitorCountryUrl = `/${COUNTRY_URL_PREFIXES[VISITOR_COUNTRY] || VISITOR_COUNTRY.toLowerCase()}/`;
const visitorCountryName = COUNTRY_NAMES[VISITOR_COUNTRY] || 'United States';
const visitorCountryFlag = COUNTRY_FLAGS[VISITOR_COUNTRY] || COUNTRY_FLAGS.US;

// ============================================================
// MEGAMENU NAVIGATION — One panel per heading, fully populated.
// Each hub has its own megamenu with categorized columns.
// ============================================================

const hubItems = {
    findCare: {
        label: "Find Care",
        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
        cta: { label: "View all 200+ clinics", href: "/us/" },
        columns: [
            {
                title: "Directories",
                items: [
                    { label: "All Clinics (US)", href: "/us/", desc: "200+ verified providers" },
                    { label: "Best TMS Clinics", href: "/best-tms-clinics/" },
                    { label: "Verified Clinics", href: "/verified-clinics/" },
                    { label: "Compare Clinics", href: "/compare-clinics/" },
                    { label: "Map View", href: "/map/" },
                    { label: "Search All Pages", href: "/search/" },
                ],
            },
            {
                title: "By Filter",
                items: [
                    { label: "By Condition", href: "/treatments/", desc: "Depression, anxiety, OCD" },
                    { label: "By Device", href: "/technology/", desc: "TMS systems compared" },
                    { label: "By Insurance", href: "/insurance/", desc: "Coverage by provider" },
                    { label: "TMS Near Me", href: "/near-me/tms-near-me/" },
                    { label: "By Demographic", href: "/demographic/" },
                ],
            },
            {
                title: "Find a Specialist",
                items: [
                    { label: "All Specialists", href: "/specialists/" },
                    { label: "Psychiatrists", href: "/psychiatrists/" },
                    { label: "Psychologists", href: "/psychologists/" },
                    { label: "Therapists", href: "/therapists/" },
                    { label: "Provider Directory", href: "/providers/" },
                ],
            },
            {
                title: "Eligibility & Tools",
                featured: true,
                items: [
                    { label: "Which Treatment Is Right?", href: "/quiz/which-treatment-is-right/", desc: "TMS vs Spravato vs Ketamine vs ECT", primary: true },
                    { label: "Am I a Candidate? (TMS)", href: "/quiz/am-i-a-candidate/" },
                    { label: "Spravato Eligibility", href: "/quiz/spravato-eligibility/" },
                    { label: "Ketamine Eligibility", href: "/quiz/ketamine-eligibility/" },
                    { label: "ECT Eligibility", href: "/quiz/ect-eligibility/" },
                    { label: "Insurance & Cost Calculator", href: "/tms-cost-calculator/" },
                    { label: "All Quizzes", href: "/quiz/" },
                ],
            },
            {
                title: "Severity Tests",
                items: [
                    { label: "Depression (PHQ-9)", href: "/quiz/depression-severity-test/" },
                    { label: "Anxiety (GAD-7)", href: "/quiz/anxiety-severity-test/" },
                    { label: "PTSD (PCL-5)", href: "/quiz/ptsd-severity-test/" },
                    { label: "OCD (Y-BOCS Style)", href: "/quiz/ocd-severity-test/" },
                    { label: "Bipolar Screener (MDQ)", href: "/quiz/bipolar-screener/" },
                ],
            },
        ],
    },
    learn: {
        label: "Learn",
        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>`,
        cta: { label: "Read the latest blog posts", href: "/blog/" },
        columns: [
            {
                title: "Conditions",
                items: [
                    { label: "Major Depression", href: "/treatments/depression/" },
                    { label: "Anxiety", href: "/treatments/anxiety/" },
                    { label: "OCD", href: "/treatments/ocd/" },
                    { label: "PTSD", href: "/treatments/ptsd/" },
                    { label: "Migraines", href: "/treatments/migraines/" },
                    { label: "All Conditions", href: "/treatments/", primary: true },
                ],
            },
            {
                title: "Technology & Protocols",
                items: [
                    { label: "How rTMS Works", href: "/answers/what-is-tms-therapy/" },
                    { label: "Deep TMS", href: "/technology/brainsway-deep-tms/" },
                    { label: "Theta Burst (TBS)", href: "/protocols/theta-burst-stimulation/" },
                    { label: "All Devices", href: "/technology/" },
                    { label: "All Protocols", href: "/protocols/" },
                    { label: "TMS Simulation", href: "/simulation/" },
                ],
            },
            {
                title: "Stories & Research",
                items: [
                    { label: "Patient Stories", href: "/stories/" },
                    { label: "Research & Trials", href: "/research/" },
                    { label: "Education Hub", href: "/education/" },
                    { label: "Wellness", href: "/wellness/" },
                    { label: "Community", href: "/community/" },
                    { label: "Timeline of TMS", href: "/timeline/" },
                ],
            },
            {
                title: "Articles & Q&A",
                featured: true,
                items: [
                    { label: "Blog", href: "/blog/", desc: "News, guides & explainers", primary: true },
                    { label: "TMS News", href: "/news/" },
                    { label: "FAQs", href: "/questions/" },
                    { label: "Quick Answers", href: "/answers/what-is-tms-therapy/" },
                    { label: "TMS Glossary", href: "/glossary/" },
                    { label: "Resources & Guides", href: "/resources/" },
                ],
            },
        ],
    },
    compare: {
        label: "Compare",
        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>`,
        cta: { label: "Calculate your TMS cost", href: "/tms-cost-calculator/" },
        columns: [
            {
                title: "TMS vs Alternatives",
                items: [
                    { label: "TMS vs Medication", href: "/compare/tms-vs-antidepressants/" },
                    { label: "TMS vs ECT", href: "/compare/tms-vs-ect/" },
                    { label: "TMS vs Psychotherapy", href: "/compare/tms-vs-psychotherapy/" },
                    { label: "TMS vs Ketamine", href: "/compare/tms-vs-ketamine/" },
                    { label: "Spravato vs Ketamine", href: "/compare/spravato-vs-ketamine/" },
                    { label: "TMS vs SGB (Trauma)", href: "/compare/tms-vs-stellate-ganglion-block/" },
                    { label: "Insurance vs Cash-Pay", href: "/compare/insurance-vs-cash-pay/" },
                    { label: "TMS vs VNS", href: "/compare/tms-vs-vns/" },
                    { label: "All Comparisons", href: "/compare/", primary: true },
                ],
            },
            {
                title: "Device Comparisons",
                items: [
                    { label: "NeuroStar", href: "/technology/neurostar/" },
                    { label: "BrainsWay Deep TMS", href: "/technology/brainsway-deep-tms/" },
                    { label: "Neuronavigation Protocol", href: "/protocols/neuronavigation/" },
                    { label: "All Devices", href: "/technology/", primary: true },
                ],
            },
            {
                title: "Alternatives",
                items: [
                    { label: "Alternative Treatments", href: "/alternatives/" },
                    { label: "Drug-Free Options", href: "/alternative-treatments/" },
                    { label: "Wellness Approaches", href: "/wellness/" },
                ],
            },
            {
                title: "Costs & Tools",
                featured: true,
                items: [
                    { label: "Cost Calculator", href: "/tms-cost-calculator/", desc: "Estimate your costs", primary: true },
                    { label: "TMS Cost Guide 2026", href: "/tms-cost-guide/" },
                    { label: "Pricing Plans", href: "/pricing/" },
                    { label: "Outcome Checker", href: "/tools/treatment-response/" },
                    { label: "All Tools", href: "/tools/" },
                ],
            },
        ],
    },
    forProviders: {
        label: "For Providers",
        icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>`,
        cta: { label: "List your clinic — free", href: "/add-listing/" },
        columns: [
            {
                title: "Get Listed",
                items: [
                    { label: "List Your Clinic", href: "/add-listing/", desc: "Free directory listing", primary: true },
                    { label: "Claim Existing Listing", href: "/claim-listing/" },
                    { label: "For Clinics", href: "/for-clinics/" },
                    { label: "For Specialists", href: "/for-specialists/" },
                    { label: "Provider Login", href: "/admin/login/" },
                ],
            },
            {
                title: "Resources",
                items: [
                    { label: "Provider Directory", href: "/providers/" },
                    { label: "Clinical Resources", href: "/resources/for-providers/" },
                    { label: "Provider FAQ", href: "/questions/" },
                    { label: "Clinical Protocols", href: "/protocols/" },
                    { label: "Insurance & Billing", href: "/tms-cpt-codes/" },
                ],
            },
            {
                title: "Legal & Compliance",
                items: [
                    { label: "FDA Clearance History", href: "/research/fda-clearance-history/" },
                    { label: "Who Can Administer TMS", href: "/legal/who-can-administer-tms-by-state/" },
                    { label: "Malpractice Insurance", href: "/legal/tms-malpractice-insurance-guide/" },
                    { label: "TMS CPT Codes 2026", href: "/tms-cpt-codes/" },
                    { label: "Starting a TMS Clinic", href: "/starting-a-tms-clinic/" },
                    { label: "All Legal Guides", href: "/legal/" },
                ],
            },
            {
                title: "Grow Your Practice",
                featured: true,
                items: [
                    { label: "Advertise", href: "/advertise/", desc: "Promote your practice", primary: true },
                    { label: "Pricing Plans", href: "/pricing/" },
                    { label: "How We Rank", href: "/how-we-rank/" },
                    { label: "Editorial Policy", href: "/editorial-policy/" },
                    { label: "Careers", href: "/careers/" },
                ],
            },
        ],
    },
};

const hubKeys = Object.keys(hubItems);
---

<header class="header-root" id="main-header">
    <!-- Primary bar: logo + hub triggers + actions -->
    <div class="header-bar">
        <div class="header-inner">
            <!-- Left: Logo -->
            <a href="/" class="header-logo" aria-label="TMS List home">
                <Logo />
            </a>

            <!-- Center: Hub Trigger Buttons -->
            <nav class="header-hubs" aria-label="Main navigation">
                {hubKeys.map((key) => {
                    const hub = hubItems[key];
                    return (
                        <button
                            class="hub-trigger"
                            data-hub={key}
                            aria-label={hub.label}
                            aria-expanded="false"
                            aria-controls={`megamenu-${key}`}
                            aria-haspopup="true"
                        >
                            <svg class="hub-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" set:html={hub.icon} />
                            <span class="hub-label">{hub.label}</span>
                            <svg class="hub-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>
                    );
                })}
            </nav>

            <!-- Right: Actions -->
            <div class="header-actions">
                <!-- Search -->
                <a href="/search/" class="action-btn" aria-label="Search">
                    <svg class="action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </a>

                <!-- Country switcher -->
                <div class="country-switcher" id="country-switcher">
                    <button class="action-btn country-trigger" id="country-trigger" aria-label={`Change country (currently ${visitorCountryName})`} aria-haspopup="listbox" aria-expanded="false">
                        <span class="country-flag" set:html={visitorCountryFlag} />
                        <svg class="country-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="country-menu" id="country-menu" role="listbox" aria-label="Select country" hidden>
                        <div class="country-menu-header">Select your country</div>
                        <ul class="country-list">
                            {SUPPORTED_COUNTRIES.map((cc) => (
                                <li>
                                    <button
                                        class={`country-option ${cc === VISITOR_COUNTRY ? 'is-active' : ''}`}
                                        data-country={cc}
                                        type="button"
                                        role="option"
                                        aria-selected={cc === VISITOR_COUNTRY ? 'true' : 'false'}
                                    >
                                        <span class="country-flag" set:html={COUNTRY_FLAGS[cc] || ''} />
                                        <span class="country-name">{COUNTRY_NAMES[cc] || cc}</span>
                                        {cc === VISITOR_COUNTRY && (
                                            <svg class="country-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                                        )}
                                    </button>
                                </li>
                            ))}
                        </ul>
                    </div>
                </div>

                <!-- User menu -->
                <div class="header-user">
                    <UserMenu client:load />
                </div>

                <!-- CTA pill -->
                <a href="/add-listing/" class="cta-pill">
                    <svg class="cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                    </svg>
                    List Your Clinic
                </a>

                <!-- Mobile menu -->
                <button class="action-btn mobile-menu-btn" id="mobile-menu-btn" aria-label="Open menu">
                    <svg class="action-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile bottom tab bar -->
    <nav class="mobile-tabs" aria-label="Mobile navigation">
        <a href="/" class="mobile-tab">
            <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            <span class="tab-label">Home</span>
        </a>
        <a href={visitorCountryUrl} class="mobile-tab">
            <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="tab-label">Find Care</span>
        </a>
        <button class="mobile-tab mobile-explore-btn" id="mobile-explore-btn" aria-label="Explore clinics">
            <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <span class="tab-label">Explore</span>
        </button>
        <a href="/compare/" class="mobile-tab">
            <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
            </svg>
            <span class="tab-label">Compare</span>
        </a>
        <a href="/providers/" class="mobile-tab">
            <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
            <span class="tab-label">Providers</span>
        </a>
    </nav>
</header>

<!-- Megamenu Container (Desktop) — one panel per hub -->
<div id="megamenu-container" class="megamenu-container" aria-hidden="true">
    <div class="megamenu-backdrop" id="megamenu-backdrop"></div>
    {hubKeys.map((key) => {
        const hub = hubItems[key];
        return (
            <div class="megamenu-panel" id={`megamenu-${key}`} data-hub={key} role="menu" aria-label={hub.label}>
                <div class="megamenu-inner">
                    <div class="megamenu-grid">
                        {hub.columns.map((col) => (
                            <div class={`megamenu-column${col.featured ? ' megamenu-column-featured' : ''}`}>
                                <h3 class="megamenu-column-title">{col.title}</h3>
                                <ul class="megamenu-list">
                                    {col.items.map((item) => (
                                        <li>
                                            <a
                                                href={item.href}
                                                class={`megamenu-item${item.primary ? ' megamenu-item-primary' : ''}`}
                                                role="menuitem"
                                            >
                                                <span class="megamenu-item-label">{item.label}</span>
                                                {item.desc && <span class="megamenu-item-desc">{item.desc}</span>}
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        ))}
                    </div>
                    {hub.cta && (
                        <div class="megamenu-footer">
                            <a href={hub.cta.href} class="megamenu-cta">
                                {hub.cta.label}
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                                </svg>
                            </a>
                            <a href="/sitemap.html" class="megamenu-secondary">View full sitemap</a>
                        </div>
                    )}
                </div>
            </div>
        );
    })}
</div>

<!-- Mobile Full-Screen Explore Modal -->
<div id="mobile-explore" class="mobile-explore" aria-hidden="true">
    <div class="mobile-explore-header">
        <a href="/" class="mobile-explore-logo">
            <Logo />
        </a>
        <button class="mobile-explore-close" id="mobile-explore-close" aria-label="Close">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
    </div>

    <!-- Mobile Search -->
    <div class="mobile-explore-search">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input
            type="text"
            id="mobile-hub-search"
            class="hub-search-input"
            placeholder="Search pages..."
            autocomplete="off"
            aria-label="Search pages"
        />
    </div>

    <!-- Mobile Accordion Categories -->
    <div class="mobile-explore-content" id="mobile-explore-content">
        {hubKeys.map((key) => {
            const hub = hubItems[key];
            const totalItems = hub.columns.reduce((sum, c) => sum + c.items.length, 0);
            return (
                <div class="explore-category" data-hub={key}>
                    <button class="explore-category-header" aria-expanded="false" aria-label={`${hub.label} category`}>
                        <svg class="category-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" set:html={hub.icon} />
                        <span class="category-label">{hub.label}</span>
                        <span class="category-count">{totalItems}</span>
                        <svg class="category-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </button>
                    <div class="explore-category-items">
                        {hub.columns.map((col) => (
                            <div class="explore-subgroup">
                                <h4 class="explore-subgroup-title">{col.title}</h4>
                                {col.items.map((item) => (
                                    <a href={item.href} class="explore-item-link" data-label={item.label.toLowerCase()}>
                                        <span class="explore-item-label">{item.label}</span>
                                        {item.desc && <span class="explore-item-desc">{item.desc}</span>}
                                    </a>
                                ))}
                            </div>
                        ))}
                    </div>
                </div>
            );
        })}
    </div>
</div>

<!-- Mobile Menu Drawer -->
<div id="mobile-menu" class="mobile-overlay" aria-hidden="true">
    <div class="mobile-backdrop-drawer" id="mobile-backdrop"></div>
    <div class="mobile-drawer" id="mobile-drawer" role="dialog" aria-label="Navigation menu">
        <div class="mobile-drawer-header">
            <a href="/" onclick="closeMobileMenu()">
                <Logo />
            </a>
            <button class="close-btn" onclick="closeMobileMenu()" aria-label="Close menu">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <div class="mobile-nav">
            <a href={visitorCountryUrl} class="mobile-nav-item" onclick="closeMobileMenu()">Find a Clinic</a>
            <a href="/treatments/" class="mobile-nav-item" onclick="closeMobileMenu()">Treatments</a>
            <a href="/technology/" class="mobile-nav-item" onclick="closeMobileMenu()">Technology</a>
            <a href="/compare/" class="mobile-nav-item" onclick="closeMobileMenu()">Compare</a>
            <a href="/insurance/" class="mobile-nav-item" onclick="closeMobileMenu()">Insurance</a>
            <div class="mobile-divider"></div>
            <a href="/near-me/tms-near-me/" class="mobile-nav-item" onclick="closeMobileMenu()">Near Me</a>
            <a href="/stories/" class="mobile-nav-item" onclick="closeMobileMenu()">Patient Stories</a>
            <a href="/research/" class="mobile-nav-item" onclick="closeMobileMenu()">Research</a>
            <a href="/providers/" class="mobile-nav-item" onclick="closeMobileMenu()">For Providers</a>
        </div>

        <div class="mobile-drawer-footer">
            <a href="/quiz/am-i-a-candidate/" class="mobile-quiz-btn" onclick="closeMobileMenu()">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
