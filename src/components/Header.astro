---
import {
    TREATMENT_SLUGS,
    INSURANCE_SLUGS,
    TECHNOLOGY_SLUGS,
    PROTOCOL_SLUGS,
    DEMOGRAPHIC_SLUGS,
    COMPARE_SLUGS,
    COMMERCIAL_SLUGS,
} from "../utils/seo_slugs";

const conditions = TREATMENT_SLUGS;
const insurance = INSURANCE_SLUGS;
const technology = [
    ...TECHNOLOGY_SLUGS,
    { slug: "exomind", title: "Exomind Wellness" },
    { slug: "apollo-tms", title: "Apollo TMS" },
    { slug: "nexstim", title: "Nexstim TMS" },
    { slug: "mag-and-more", title: "MAG & More" },
    { slug: "deymed", title: "Deymed TMS" },
];
const protocols = PROTOCOL_SLUGS;
const comparisons = COMPARE_SLUGS;
---

<header
    class="bg-white/80 backdrop-blur-md border-b border-slate-200/60 sticky top-0 z-[100] transition-all duration-300"
    id="main-header"
>
    <div
        class="container mx-auto px-4 lg:px-8 h-16 flex items-center justify-between"
    >
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 z-50 group">
            <div class="relative flex items-center justify-center w-9 h-9 rounded-xl bg-violet-600 text-white shadow-md shadow-violet-600/20 group-hover:bg-violet-700 group-hover:shadow-violet-700/30 transition-all duration-200">
                <svg class="w-[22px] h-[22px]" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- Simplified head profile silhouette with brain spiral — reads at any size -->
                    <path d="M18 4C12.5 4 8 8.5 8 14c0 3 1.3 5.7 3.3 7.5L10 28h12l-1.3-6.5C22.7 19.7 24 17 24 14c0-5.5-4.5-10-6-10z" fill="rgba(255,255,255,0.15)" stroke="white" stroke-width="1.8" stroke-linejoin="round"/>
                    <!-- Brain spiral — the TMS coil motif -->
                    <path d="M16 9c-2.2 0-4 1.5-4 3.5s1.8 3.5 4 3.5 4-1.5 4-3.5" stroke="white" stroke-width="1.6" stroke-linecap="round" fill="none"/>
                    <path d="M16 11c-1 0-2 .7-2 1.5s1 1.5 2 1.5 2-.7 2-1.5" stroke="white" stroke-width="1.6" stroke-linecap="round" fill="none"/>
                    <!-- TMS pulse waves -->
                    <path d="M5 11l-2-.8M5 14H3M5 17l-2 .8" stroke="white" stroke-width="1.5" stroke-linecap="round" opacity="0.7"/>
                </svg>
            </div>
            <div class="flex flex-col leading-none">
                <span class="text-[22px] font-extrabold tracking-tight text-slate-900 font-display">
                    TMS<span class="text-violet-600 font-extrabold">List</span>
                </span>
                <span class="text-[8.5px] font-semibold tracking-[0.15em] text-slate-400/80 uppercase mt-0.5">Wellness Directory</span>
            </div>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-0.5 xl:gap-1" id="desktop-nav">
            <!-- Find Care Mega Menu -->
            <div class="relative px-2 py-4" data-mega="find-care">
                <button
                    class="mega-trigger flex items-center gap-1.5 text-sm font-semibold text-slate-700 hover:text-violet-600 transition-colors tracking-wide"
                    aria-expanded="false"
                    aria-controls="mega-find-care"
                >
                    Find Care
                    <svg class="w-3.5 h-3.5 text-slate-400 transition-transform duration-300 mega-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>
            </div>

            <!-- Conditions Mega Menu -->
            <div class="relative px-2 py-4" data-mega="conditions">
                <a href="/treatments/" class="mega-trigger flex items-center gap-1.5 text-sm font-semibold text-slate-700 hover:text-violet-600 transition-colors tracking-wide"
                    aria-expanded="false"
                    aria-controls="mega-conditions"
                >
                    Conditions
                    <svg class="w-3.5 h-3.5 text-slate-400 transition-transform duration-300 mega-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </a>
            </div>

            <!-- Insurance Mega Menu -->
            <div class="relative px-2 py-4" data-mega="insurance">
                <a href="/insurance/" class="mega-trigger flex items-center gap-1.5 text-sm font-semibold text-slate-700 hover:text-violet-600 transition-colors tracking-wide"
                    aria-expanded="false"
                    aria-controls="mega-insurance"
                >
                    Insurance
                    <svg class="w-3.5 h-3.5 text-slate-400 transition-transform duration-300 mega-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </a>
            </div>

            <!-- Technology Mega Menu -->
            <div class="relative px-2 py-4" data-mega="technology">
                <a href="/technology/" class="mega-trigger flex items-center gap-1.5 text-sm font-semibold text-slate-700 hover:text-violet-600 transition-colors tracking-wide"
                    aria-expanded="false"
                    aria-controls="mega-technology"
                >
                    Technology
                    <svg class="w-3.5 h-3.5 text-slate-400 transition-transform duration-300 mega-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </a>
            </div>

            <!-- Resources Mega Menu -->
            <div class="relative px-2 py-4" data-mega="resources">
                <button class="mega-trigger flex items-center gap-1.5 text-sm font-semibold text-slate-700 hover:text-violet-600 transition-colors tracking-wide"
                    aria-expanded="false"
                    aria-controls="mega-resources"
                >
                    Resources
                    <svg class="w-3.5 h-3.5 text-slate-400 transition-transform duration-300 mega-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>
            </div>

            <!-- Providers Link -->
            <a href="/providers/" class="px-2 py-2 text-sm font-semibold text-slate-500 hover:text-violet-600 transition-colors tracking-wide ml-1 border-l border-slate-200 pl-4">
                Providers
            </a>
        </nav>

        <!-- CTA + Country Selector + Mobile Toggle -->
        <div class="flex items-center gap-2">
            <!-- Country Selector -->
            <div class="relative group/country hidden lg:block">
                <button id="country-selector-btn" class="flex items-center gap-1 px-2.5 py-2 text-sm font-medium text-slate-600 hover:text-violet-600 rounded-lg hover:bg-slate-50 transition-colors" aria-label="Select country">
                    <span id="country-flag" class="text-lg leading-none">&#127482;&#127480;</span>
                    <svg class="w-3 h-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="absolute right-0 top-full pt-1 opacity-0 invisible group-hover/country:opacity-100 group-hover/country:visible transition-all duration-200 w-48 z-50">
                    <div class="bg-white rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.08)] ring-1 ring-slate-200/60 py-1.5 max-h-[70vh] overflow-y-auto">
                        <a href="/us/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="US">
                            <span class="text-base">&#127482;&#127480;</span> United States
                        </a>
                        <a href="/uk/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="GB">
                            <span class="text-base">&#127468;&#127463;</span> United Kingdom
                        </a>
                        <a href="/ca/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="CA">
                            <span class="text-base">&#127464;&#127462;</span> Canada
                        </a>
                        <a href="/au/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="AU">
                            <span class="text-base">&#127462;&#127482;</span> Australia
                        </a>
                        <a href="/de/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="DE">
                            <span class="text-base">&#127465;&#127466;</span> Germany
                        </a>
                        <a href="/in/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="IN">
                            <span class="text-base">&#127470;&#127475;</span> India
                        </a>
                        <div class="border-t border-slate-100 my-1"></div>
                        <p class="px-3.5 py-1 text-[10px] font-bold text-slate-400 uppercase tracking-wider">Europe</p>
                        <a href="/fr/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="FR">
                            <span class="text-base">&#127467;&#127479;</span> France
                        </a>
                        <a href="/es/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="ES">
                            <span class="text-base">&#127466;&#127480;</span> Spain
                        </a>
                        <a href="/it/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="IT">
                            <span class="text-base">&#127470;&#127481;</span> Italy
                        </a>
                        <a href="/nl/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="NL">
                            <span class="text-base">&#127475;&#127473;</span> Netherlands
                        </a>
                        <a href="/se/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="SE">
                            <span class="text-base">&#127480;&#127466;</span> Sweden
                        </a>
                        <a href="/ie/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="IE">
                            <span class="text-base">&#127470;&#127466;</span> Ireland
                        </a>
                        <div class="border-t border-slate-100 my-1"></div>
                        <p class="px-3.5 py-1 text-[10px] font-bold text-slate-400 uppercase tracking-wider">Asia & Middle East</p>
                        <a href="/jp/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="JP">
                            <span class="text-base">&#127471;&#127477;</span> Japan
                        </a>
                        <a href="/kr/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="KR">
                            <span class="text-base">&#127472;&#127479;</span> South Korea
                        </a>
                        <a href="/sg/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="SG">
                            <span class="text-base">&#127480;&#127468;</span> Singapore
                        </a>
                        <a href="/ae/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="AE">
                            <span class="text-base">&#127462;&#127466;</span> UAE
                        </a>
                        <a href="/il/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="IL">
                            <span class="text-base">&#127470;&#127473;</span> Israel
                        </a>
                        <div class="border-t border-slate-100 my-1"></div>
                        <p class="px-3.5 py-1 text-[10px] font-bold text-slate-400 uppercase tracking-wider">Americas & Oceania</p>
                        <a href="/br/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="BR">
                            <span class="text-base">&#127463;&#127479;</span> Brazil
                        </a>
                        <a href="/mx/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="MX">
                            <span class="text-base">&#127474;&#127485;</span> Mexico
                        </a>
                        <a href="/nz/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="NZ">
                            <span class="text-base">&#127475;&#127487;</span> New Zealand
                        </a>
                        <a href="/za/" class="country-option flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-700 hover:bg-violet-50 hover:text-violet-700 transition-colors" data-country="ZA">
                            <span class="text-base">&#127487;&#127462;</span> South Africa
                        </a>
                    </div>
                </div>
            </div>
            <a href="/add-listing/" class="hidden sm:inline-flex items-center justify-center px-5 py-2.5 bg-violet-600 hover:bg-violet-700 text-white text-sm font-semibold rounded-lg shadow-sm hover:shadow transition-all">
                List Your Clinic
            </a>
            <button class="lg:hidden p-2 text-slate-600 hover:text-violet-600 transition-colors" id="mobile-menu-btn" aria-label="Open menu">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </div>
</header>

<!-- ========== MEGA MENU PANELS (full-width, positioned below header) ========== -->
<div id="mega-overlay" class="fixed inset-0 z-[90] bg-black/20 backdrop-blur-[2px] opacity-0 invisible transition-opacity duration-300 hidden lg:block pointer-events-none"></div>

<div class="hidden lg:block">
    <!-- FIND CARE Panel -->
    <div id="mega-find-care" class="mega-panel fixed left-0 right-0 top-16 z-[95] opacity-0 invisible -translate-y-2 transition-all duration-300 ease-out" role="menu">
        <div class="bg-white border-b border-slate-200/80 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.12)]">
            <div class="container mx-auto px-4 lg:px-8 py-8">
                <div class="grid grid-cols-12 gap-8">
                    <!-- Main navigation cards -->
                    <div class="col-span-8">
                        <div class="grid grid-cols-3 gap-3">
                            <a href="/us/" class="group/card flex flex-col p-4 rounded-xl border border-slate-100 hover:border-violet-200 hover:bg-violet-50/50 transition-all duration-200">
                                <div class="w-10 h-10 rounded-lg bg-violet-100 flex items-center justify-center text-violet-600 mb-3 group-hover/card:bg-violet-600 group-hover/card:text-white transition-colors">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                </div>
                                <div class="text-sm font-semibold text-slate-800 group-hover/card:text-violet-700">Find a Clinic</div>
                                <div class="text-xs text-slate-500 mt-1 leading-relaxed">Search clinics by location across all 50 states</div>
                            </a>
                            <a href="/verified-clinics/" class="group/card flex flex-col p-4 rounded-xl border border-slate-100 hover:border-emerald-200 hover:bg-emerald-50/50 transition-all duration-200">
                                <div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center text-emerald-600 mb-3 group-hover/card:bg-emerald-600 group-hover/card:text-white transition-colors">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                                </div>
                                <div class="text-sm font-semibold text-slate-800 group-hover/card:text-emerald-700">Verified Clinics</div>
                                <div class="text-xs text-slate-500 mt-1 leading-relaxed">Quality-checked providers with patient reviews</div>
                            </a>
                            <a href="/specialists/" class="group/card flex flex-col p-4 rounded-xl border border-slate-100 hover:border-blue-200 hover:bg-blue-50/50 transition-all duration-200">
                                <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center text-blue-600 mb-3 group-hover/card:bg-blue-600 group-hover/card:text-white transition-colors">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                </div>
                                <div class="text-sm font-semibold text-slate-800 group-hover/card:text-blue-700">Find a Specialist</div>
                                <div class="text-xs text-slate-500 mt-1 leading-relaxed">Psychiatrists and neurologists near you</div>
                            </a>
                            <a href="/compare-clinics/" class="group/card flex flex-col p-4 rounded-xl border border-slate-100 hover:border-violet-200 hover:bg-violet-50/50 transition-all duration-200">
                                <div class="w-10 h-10 rounded-lg bg-violet-100 flex items-center justify-center text-violet-600 mb-3 group-hover/card:bg-violet-600 group-hover/card:text-white transition-colors">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                                </div>
                                <div class="text-sm font-semibold text-slate-800 group-hover/card:text-violet-700">Compare Clinics</div>
                                <div class="text-xs text-slate-500 mt-1 leading-relaxed">Side-by-side comparison tool</div>
                            </a>
                            <a href="/map/" class="group/card flex flex-col p-4 rounded-xl border border-slate-100 hover:border-amber-200 hover:bg-amber-50/50 transition-all duration-200">
                                <div class="w-10 h-10 rounded-lg bg-amber-100 flex items-center justify-center text-amber-600 mb-3 group-hover/card:bg-amber-600 group-hover/card:text-white transition-colors">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
                                </div>
                                <div class="text-sm font-semibold text-slate-800 group-hover/card:text-amber-700">Clinic Map</div>
                                <div class="text-xs text-slate-500 mt-1 leading-relaxed">Interactive map with all providers</div>
                            </a>
                            <a href="/best-tms-clinics/" class="group/card flex flex-col p-4 rounded-xl border border-slate-100 hover:border-rose-200 hover:bg-rose-50/50 transition-all duration-200">
                                <div class="w-10 h-10 rounded-lg bg-rose-100 flex items-center justify-center text-rose-600 mb-3 group-hover/card:bg-rose-600 group-hover/card:text-white transition-colors">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                                </div>
                                <div class="text-sm font-semibold text-slate-800 group-hover/card:text-rose-700">Best TMS Clinics</div>
                                <div class="text-xs text-slate-500 mt-1 leading-relaxed">Top-rated clinics nationwide</div>
                            </a>
                        </div>
                    </div>
                    <!-- Featured CTA sidebar -->
                    <div class="col-span-4">
                        <div class="bg-gradient-to-br from-violet-600 to-violet-700 rounded-2xl p-6 text-white h-full flex flex-col justify-between">
                            <div>
                                <div class="inline-flex items-center gap-1.5 bg-white/20 rounded-full px-3 py-1 text-xs font-semibold mb-4">
                                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                                    Free Assessment
                                </div>
                                <h3 class="text-lg font-bold leading-snug">Am I a Candidate for TMS?</h3>
                                <p class="text-violet-100 text-sm mt-2 leading-relaxed">Answer a few questions to find out if TMS therapy could work for you.</p>
                            </div>
