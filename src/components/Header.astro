---
import Logo from "./Logo.astro";
import UserMenu from "./react/UserMenu";
import {
    TREATMENT_SLUGS,
    INSURANCE_SLUGS,
    TECHNOLOGY_SLUGS,
    PROTOCOL_SLUGS,
    DEMOGRAPHIC_SLUGS,
    COMPARE_SLUGS,
    COMMERCIAL_SLUGS,
} from "../utils/seo_slugs";

const conditions = TREATMENT_SLUGS;
const insurance = INSURANCE_SLUGS;
const technology = [
    ...TECHNOLOGY_SLUGS,
    { slug: "exomind", title: "Exomind Wellness" },
    { slug: "apollo-tms", title: "Apollo TMS" },
    { slug: "nexstim", title: "Nexstim TMS" },
    { slug: "mag-and-more", title: "MAG & More" },
    { slug: "deymed", title: "Deymed TMS" },
];
const protocols = PROTOCOL_SLUGS;
const comparisons = COMPARE_SLUGS;
const deviceComparisons = comparisons.filter(
  s => s.slug.includes('neurostar') || s.slug.includes('brainsway') || s.slug.includes('magventure') || s.slug.includes('magstim') || s.slug.includes('cloudtms') || s.slug.includes('nexstim') || s.slug.includes('apollo') || s.slug.includes('deep-tms'),
);

// Top conditions and technology items for mega menus
const topConditions = conditions.slice(0, 8);
const topTechnology = technology.slice(0, 6);
---

<header
    class="sticky top-0 z-[100] w-full transition-all duration-300"
    style="background:rgba(17,20,24,0.85);backdrop-filter:blur(20px) saturate(180%);-webkit-backdrop-filter:blur(20px) saturate(180%);border-bottom:1px solid #1E242C;"
    id="main-header"
    data-scrolled="false"
>
    <div
        class="container mx-auto px-4 lg:px-8 h-[68px] flex items-center justify-between"
    >
        <!-- Logo -->
        <Logo />

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-0.5" id="desktop-nav">

            <!-- Find a Clinic -->
            <a href="/us/" class="nav-link px-4 py-2 text-sm font-semibold rounded-lg">Find a Clinic</a>

            <!-- Conditions — mega menu -->
            <div class="nav-mega-dropdown relative" id="nav-conditions">
                <button
                    class="nav-link px-4 py-2 text-sm font-semibold rounded-lg flex items-center gap-1"
                    aria-expanded="false"
                    aria-haspopup="true"
                    id="nav-conditions-trigger"
                >
                    Conditions
                    <svg class="w-3.5 h-3.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div class="nav-mega-panel" role="menu" aria-labelledby="nav-conditions-trigger">
                    <div class="col-span-2 grid grid-cols-2 gap-x-6">
                        <div>
                            <p class="nav-mega-section-title">Top Conditions</p>
                            {topConditions.map((item) => (
                                <a href={`/treatments/${item.slug}/`} class="nav-mega-item">
                                    <div class="nav-mega-item-icon">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <div class="nav-mega-item-title">{item.title.replace("TMS for ", "")}</div>
                                    </div>
                                </a>
                            ))}
                        </div>
                        <div>
                            <p class="nav-mega-section-title">All Conditions</p>
                            {conditions.slice(8, 12).map((item) => (
                                <a href={`/treatments/${item.slug}/`} class="nav-mega-item">
                                    <div class="nav-mega-item-icon">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <div class="nav-mega-item-title">{item.title.replace("TMS for ", "")}</div>
                                    </div>
                                </a>
                            ))}
                            <a href="/treatments/" class="nav-mega-item mt-2" style="background:var(--gradient-brand-subtle);color:var(--accent);font-weight:600;">
                                <div class="nav-mega-item-icon" style="background:rgba(27,75,90,0.15);">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                                    </svg>
                                </div>
                                <div>
                                    <div class="nav-mega-item-title">Browse All Conditions</div>
                                    <div class="nav-mega-item-desc">{conditions.length} TMS treatments</div>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Technology — mega menu -->
            <div class="nav-mega-dropdown relative" id="nav-technology">
                <button
                    class="nav-link px-4 py-2 text-sm font-semibold rounded-lg flex items-center gap-1"
                    aria-expanded="false"
                    aria-haspopup="true"
                    id="nav-technology-trigger"
                >
                    Technology
                    <svg class="w-3.5 h-3.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div class="nav-mega-panel" role="menu" aria-labelledby="nav-technology-trigger">
                    <div>
                        <p class="nav-mega-section-title">TMS Devices</p>
                        {topTechnology.map((item) => (
                            <a href={`/technology/${item.slug}/`} class="nav-mega-item">
                                <div class="nav-mega-item-icon">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                                    </svg>
                                </div>
                                <div>
                                    <div class="nav-mega-item-title">{item.title}</div>
                                </div>
                            </a>
                        ))}
                        <a href="/technology/" class="nav-mega-item mt-2" style="background:var(--gradient-brand-subtle);color:var(--accent);font-weight:600;">
                            <div class="nav-mega-item-icon" style="background:rgba(27,75,90,0.15);">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                                </svg>
                            </div>
                            <div>
                                <div class="nav-mega-item-title">Browse All Devices</div>
                                <div class="nav-mega-item-desc">{technology.length} TMS technologies</div>
                            </div>
                        </a>
                    </div>
                    <div>
                        <p class="nav-mega-section-title">Compare Devices</p>
                        {deviceComparisons.slice(0, 6).map((item) => (
                            <a href={`/compare/${item.slug}/`} class="nav-mega-item">
                                <div class="nav-mega-item-icon" style="background:rgba(201,101,74,0.1);color:var(--warm);">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                                    </svg>
                                </div>
                                <div>
                                    <div class="nav-mega-item-title">{item.title}</div>
                                    <div class="nav-mega-item-desc">Compare</div>
                                </div>
                            </a>
                        ))}
                        <a href="/compare/" class="nav-mega-item mt-2" style="background:rgba(201,101,74,0.08);color:var(--warm);font-weight:600;">
                            <div class="nav-mega-item-icon" style="background:rgba(201,101,74,0.15);color:var(--warm);">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                                </svg>
                            </div>
                            <div>
                                <div class="nav-mega-item-title">All Comparisons</div>
                                <div class="nav-mega-item-desc">{comparisons.length} comparisons</div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Resources -->
            <div class="nav-mega-dropdown relative" id="nav-resources">
                <button
                    class="nav-link px-4 py-2 text-sm font-semibold rounded-lg flex items-center gap-1"
                    aria-expanded="false"
                    aria-haspopup="true"
                    id="nav-resources-trigger"
                >
                    Resources
                    <svg class="w-3.5 h-3.5 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div class="nav-mega-panel" role="menu" aria-labelledby="nav-resources-trigger" style="min-width:320px;">
                    <div>
                        <p class="nav-mega-section-title">Learn & Decide</p>
                        <a href="/quiz/am-i-a-candidate/" class="nav-mega-item" style="background:rgba(27,75,90,0.08);">
                            <div class="nav-mega-item-icon">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                                </svg>
                            </div>
                            <div>
                                <div class="nav-mega-item-title">Am I a Candidate?</div>
                                <div class="nav-mega-item-desc">Take the 2-min quiz</div>
                            </div>
                        </a>
                        <a href="/quiz/depression-severity-test/" class="nav-mega-item">
                            <div class="nav-mega-item-icon">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                                </svg>
                            </div>
                            <div>
                                <div class="nav-mega-item-title">PHQ-9 Depression Test</div>
                                <div class="nav-mega-item-desc">Self-assessment quiz</div>
                            </div>
                        </a>
                        <a href="/tms-cost-guide/" class="nav-mega-item">
                            <div class="nav-mega-item-icon">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                            <div>
                                <div class="nav-mega-item-title">TMS Cost Guide 2026</div>
                                <div class="nav-mega-item-desc">Pricing & insurance breakdown</div>
                            </div>
                        </a>
                        <a href="/questions/" class="nav-mega-item">
                            <div class="nav-mega-item-icon">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                            <div>
                                <div class="nav-mega-item-title">FAQ</div>
                                <div class="nav-mega-item-desc">Common questions answered</div>
                            </div>
                        </a>
                        <a href="/resources/" class="nav-mega-item">
                            <div class="nav-mega-item-icon">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 10.474c.334-2.048.478-3.09.478-4.49 0-3.867-3.134-7-7-7s-7 3.133-7 7c0 1.4.144 2.442.478 4.49.217 1.322.672 2.486 1.303 3.51h11.438c.631-1.024 1.086-2.188 1.303-3.51z"/>
                                </svg>
                            </div>
                            <div>
                                <div class="nav-mega-item-title">Guides & Downloads</div>
                                <div class="nav-mega-item-desc">Checklists, PDFs & more</div>
                            </div>
                        </a>
                    </div>
                    <div>
                        <p class="nav-mega-section-title">Community</p>
                        <a href="/blog/" class="nav-mega-item">
                            <div class="nav-mega-item-icon">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
                                </svg>
                            </div>
                            <div>
                                <div class="nav-mega-item-title">Blog</div>
                                <div class="nav-mega-item-desc">Expert insights & updates</div>
                            </div>
                        </a>
                        <a href="/stories/" class="nav-mega-item">
                            <div class="nav-mega-item-icon">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                            </div>
                            <div>
                                <div class="nav-mega-item-title">Patient Stories</div>
                                <div class="nav-mega-item-desc">Real TMS experiences</div>
                            </div>
                        </a>
                        <a href="/research/" class="nav-mega-item">
                            <div class="nav-mega-item-icon">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
                                </svg>
                            </div>
                            <div>
                                <div class="nav-mega-item-title">Research & Trials</div>
                                <div class="nav-mega-item-desc">Clinical evidence</div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- For Providers -->
            <a href="/providers/" class="nav-link px-4 py-2 text-sm font-semibold rounded-lg">For Providers</a>

            <!-- Community -->
            <a href="/community/" class="nav-link px-4 py-2 text-sm font-semibold rounded-lg">Community</a>
        </nav>

        <!-- CTA + Country Selector + Mobile Toggle -->
        <div class="flex items-center gap-1.5">
            <!-- Country Selector -->
            <div class="relative group/country hidden lg:block">
                <button
                    id="country-selector-btn"
                    class="nav-link flex items-center gap-1 px-2.5 py-2 text-sm font-medium rounded-lg"
                    aria-label="Select country"
                >
                    <span id="country-flag" class="text-lg leading-none">&#127482;&#127480;</span>
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>
                <div class="absolute right-0 top-full pt-1 opacity-0 invisible group-hover/country:opacity-100 group-hover/country:visible transition-all duration-200 z-50">
                    <div class="country-panel">
                        <p class="px-3 py-1 text-[10px] font-bold uppercase tracking-wider" style="color:var(--muted);">Americas</p>
                        <a href="/us/" class="country-option" data-country="US">&#127482;&#127480; United States</a>
                        <a href="/ca/" class="country-option" data-country="CA">&#127464;&#127462; Canada</a>
                        <a href="/br/" class="country-option" data-country="BR">&#127463;&#127479; Brazil</a>
                        <a href="/mx/" class="country-option" data-country="MX">&#127474;&#127485; Mexico</a>
                        <div class="border-t my-1" style="border-color:var(--line);"></div>
                        <p class="px-3 py-1 text-[10px] font-bold uppercase tracking-wider" style="color:var(--muted);">Europe</p>
                        <a href="/uk/" class="country-option" data-country="GB">&#127468;&#127463; United Kingdom</a>
                        <a href="/de/" class="country-option" data-country="DE">&#127465;&#127466; Germany</a>
                        <a href="/fr/" class="country-option" data-country="FR">&#127467;&#127479; France</a>
                        <a href="/es/" class="country-option" data-country="ES">&#127466;&#127480; Spain</a>
                        <a href="/it/" class="country-option" data-country="IT">&#127470;&#127481; Italy</a>
                        <a href="/nl/" class="country-option" data-country="NL">&#127475;&#127473; Netherlands</a>
                        <a href="/se/" class="country-option" data-country="SE">&#127480;&#127466; Sweden</a>
                        <a href="/ie/" class="country-option" data-country="IE">&#127470;&#127466; Ireland</a>
                        <div class="border-t my-1" style="border-color:var(--line);"></div>
                        <p class="px-3 py-1 text-[10px] font-bold uppercase tracking-wider" style="color:var(--muted);">Asia & Middle East</p>
                        <a href="/jp/" class="country-option" data-country="JP">&#127471;&#127477; Japan</a>
                        <a href="/kr/" class="country-option" data-country="KR">&#127472;&#127479; South Korea</a>
                        <a href="/sg/" class="country-option" data-country="SG">&#127480;&#127468; Singapore</a>
                        <a href="/ae/" class="country-option" data-country="AE">&#127462;&#127466; UAE</a>
                        <a href="/in/" class="country-option" data-country="IN">&#127470;&#127475; India</a>
                        <a href="/il/" class="country-option" data-country="IL">&#127470;&#127473; Israel</a>
                        <div class="border-t my-1" style="border-color:var(--line);"></div>
                        <p class="px-3 py-1 text-[10px] font-bold uppercase tracking-wider" style="color:var(--muted);">Oceania</p>
                        <a href="/au/" class="country-option" data-country="AU">&#127462;&#127482; Australia</a>
                        <a href="/nz/" class="country-option" data-country="NZ">&#127475;&#127487; New Zealand</a>
                        <a href="/za/" class="country-option" data-country="ZA">&#127487;&#127462; South Africa</a>
                    </div>
                </div>
            </div>

            <!-- Search -->
            <a href="/search/" class="nav-link hidden lg:flex items-center gap-2 px-3 py-2 text-sm rounded-lg" aria-label="Search clinics">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <span class="hidden xl:inline">Search</span>
            </a>

            <!-- User Menu -->
            <div class="hidden lg:block">
              <UserMenu client:load />
            </div>

            <!-- CTA — List Your Clinic -->
            <a href="/add-listing/" class="nav-cta hidden lg:inline-flex items-center justify-center px-5 py-2.5 text-sm rounded-xl">
                List Your Clinic
            </a>

            <!-- Mobile Toggle -->
            <button class="nav-link p-2 rounded-lg lg:hidden" id="mobile-menu-btn" aria-label="Open menu">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                </svg>
            </button>
        </div>
    </div>
</header>

<!-- Mobile Menu -->
<div id="mobile-menu" class="fixed inset-0 z-[100] bg-black/50 opacity-0 invisible transition-opacity duration-300 lg:hidden">
    <div id="mobile-menu-panel" class="absolute right-0 top-0 h-full w-full sm:w-96 max-w-full transform translate-x-full transition-transform duration-300 overflow-y-auto overscroll-contain" style="background:#111418;border-left:1px solid #1E242C;">
        <div class="flex items-center justify-between p-4 sticky top-0 z-10" style="background:#111418;border-bottom:1px solid #1E242C;">
            <Logo />
            <button id="mobile-menu-close" class="nav-link p-2 rounded-lg" aria-label="Close menu">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <nav class="p-4 pb-24 space-y-1">
            <!-- Section: Navigation -->
            <p class="text-[10px] font-bold uppercase tracking-widest px-4 pt-2 pb-1" style="color:var(--muted);">Navigation</p>
            <a href="/us/" class="flex items-center gap-3 px-4 py-3 rounded-xl transition-colors" style="color:#8896AB;">
