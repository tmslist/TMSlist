---
// Geo-aware location banner — replaces the old blocking ZIP code popup
// Detects country via cookie (set by middleware) or timezone fallback
// Shows a slim, dismissible banner directing visitors to their local directory
import { COUNTRY_NAMES, COUNTRY_FLAGS, COUNTRY_URL_PREFIXES } from "../utils/dataHelpers";
---

<!-- Geo Location Banner (non-intrusive, top of page) -->
<div id="geo-banner" class="hidden fixed top-16 left-0 right-0 z-[90] transition-all duration-300 translate-y-[-100%] opacity-0">
    <div class="bg-gradient-to-r from-violet-600 to-blue-600 text-white shadow-lg">
        <div class="container mx-auto px-4 py-2.5 flex items-center justify-between gap-4">
            <div class="flex items-center gap-3 min-w-0">
                <span id="geo-flag" class="text-xl shrink-0"></span>
                <p class="text-sm font-medium truncate">
                    <span id="geo-message">Finding clinics in your area...</span>
                </p>
            </div>
            <div class="flex items-center gap-2 shrink-0">
                <a id="geo-cta" href="/us/" class="px-4 py-1.5 bg-white text-violet-700 text-sm font-semibold rounded-lg hover:bg-violet-50 transition-colors whitespace-nowrap">
                    Browse Clinics
                </a>
                <button id="geo-dismiss" class="p-1 text-white/70 hover:text-white transition-colors rounded" aria-label="Dismiss">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        </div>
    </div>
</div>

<script is:inline>
(function() {
    var CTA_LABELS = {
        US: 'Browse US Clinics', GB: 'Browse UK Clinics', CA: 'Browse Canadian Clinics',
        AU: 'Browse Australian Clinics', DE: 'Browse German Clinics', IN: 'Browse Indian Clinics'
    };

    function showBanner() {
        if (localStorage.getItem('tms-geo-banner-dismissed')) return;
        if (localStorage.getItem('tms-location-popup-seen')) return;
        var geo = window.TMS_GEO;
        if (!geo) return;

        var banner = document.getElementById('geo-banner');
        var flag = document.getElementById('geo-flag');
        var message = document.getElementById('geo-message');
        var cta = document.getElementById('geo-cta');
        if (!banner) return;

        flag.textContent = geo.flag;
        message.textContent = 'We found TMS clinics near you in ' + geo.name;
        cta.textContent = CTA_LABELS[geo.country] || 'Browse Clinics';
        cta.href = geo.url;

        banner.classList.remove('hidden');
        requestAnimationFrame(function() {
            requestAnimationFrame(function() {
                banner.classList.remove('translate-y-[-100%]', 'opacity-0');
                banner.classList.add('translate-y-0', 'opacity-100');
            });
        });
        setTimeout(dismissBanner, 8000);
    }

    function dismissBanner() {
        var banner = document.getElementById('geo-banner');
        if (!banner) return;
        banner.classList.add('translate-y-[-100%]', 'opacity-0');
        banner.classList.remove('translate-y-0', 'opacity-100');
        setTimeout(function() { banner.classList.add('hidden'); }, 300);
        localStorage.setItem('tms-geo-banner-dismissed', 'true');
    }

    document.addEventListener('DOMContentLoaded', function() {
        var dismissBtn = document.getElementById('geo-dismiss');
        if (dismissBtn) dismissBtn.addEventListener('click', dismissBanner);
        setTimeout(showBanner, 1500);
    });

    window.showLocationPopup = function() {
        localStorage.removeItem('tms-geo-banner-dismissed');
        showBanner();
    };
})();
</script>
