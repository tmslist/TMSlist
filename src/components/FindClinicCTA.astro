---
// Editorial-style bottom CTA used by ContentPage layout.

interface Props {
  title?: string;
  description?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  title = "Find a TMS clinic near you.",
  description = "Browse verified providers with real patient reviews, insurance details, and treatment information.",
  primaryHref = "/us/",
  primaryLabel = "Search Clinics",
  secondaryHref = "/quiz/am-i-a-candidate/",
  secondaryLabel = "Am I a Candidate?",
} = Astro.props;
---

<section class="find-clinic-cta">
  <div class="find-clinic-cta-inner">
    <h2 class="serif find-clinic-cta-title">{title}</h2>
    <p class="find-clinic-cta-desc">{description}</p>
    <div class="find-clinic-cta-actions">
      <a href={primaryHref} class="find-clinic-cta-btn find-clinic-cta-btn-primary">{primaryLabel}</a>
      <a href={secondaryHref} class="find-clinic-cta-btn find-clinic-cta-btn-outline">{secondaryLabel}</a>
    </div>
    <p class="find-clinic-cta-note">Also: <a href="/tms-cost-guide/">read the TMS Cost Guide</a></p>
  </div>
</section>

<style>
  .find-clinic-cta {
    background: var(--ink);
    padding: 5rem 0;
  }

  .find-clinic-cta-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  @media (min-width: 1024px) {
    .find-clinic-cta-inner { padding: 0 2rem; }
  }

  .find-clinic-cta-title {
    font-size: clamp(2rem, 4vw, 3rem);
    color: white;
    line-height: 1.05;
    margin: 0 0 1.25rem;
  }

  .find-clinic-cta-desc {
    font-size: 17px;
    color: rgba(255,255,255,0.5);
    max-width: 36rem;
    margin: 0 auto 2.5rem;
    line-height: 1.65;
  }

  .find-clinic-cta-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .find-clinic-cta-btn {
    display: inline-flex;
    align-items: center;
    padding: 1rem 1.75rem;
    font-size: 15px;
    font-weight: 600;
    border-radius: 9999px;
    text-decoration: none;
    transition: opacity 0.15s ease, background 0.15s ease;
  }

  .find-clinic-cta-btn-primary {
    background: var(--warm);
    color: white;
  }
  .find-clinic-cta-btn-primary:hover { opacity: 0.9; }

  .find-clinic-cta-btn-outline {
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.8);
    font-weight: 500;
  }
  .find-clinic-cta-btn-outline:hover { background: rgba(255,255,255,0.05); }

  .find-clinic-cta-note {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    margin: 1.5rem 0 0;
  }
  .find-clinic-cta-note a {
    color: rgba(255,255,255,0.7);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .find-clinic-cta-note a:hover { color: white; }
</style>
