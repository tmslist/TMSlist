---
// Editorial-warm content hero. Used by ContentPage layout — cascades
// across about-us, contact, careers, legal pages, and content articles.

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface StatItem {
  value: string;
  label: string;
}

interface Badge {
  text: string;
  color: 'emerald' | 'blue' | 'amber' | 'violet' | 'rose' | 'cyan' | 'slate';
}

interface Props {
  title: string;
  subtitle?: string;
  breadcrumbs?: BreadcrumbItem[];
  badges?: Badge[];
  accentFrom?: string;
  accentTo?: string;
  stats?: StatItem[];
}

const {
  title,
  subtitle,
  breadcrumbs,
  badges = [],
  stats = [],
} = Astro.props;

const dotColors: Record<string, string> = {
  emerald: '#22c55e',
  blue: 'var(--accent2, #1E2A3B)',
  amber: 'var(--warm)',
  violet: 'var(--accent)',
  rose: 'var(--warm)',
  cyan: 'var(--accent2, #1E2A3B)',
  slate: 'var(--muted)',
};

const eyebrowDot = badges[0] ? (dotColors[badges[0].color] || '#22c55e') : '#22c55e';
const eyebrow = badges[0]?.text;

// Detect italic accent — split title at " " mid-sentence?
// We keep it simple: if title is short, it shows as is. Caller can put the
// accent phrase at the end and we render the last 1-2 words as italic accent.
function splitTitle(t: string): { main: string; accent: string | null } {
  // If the title is "x: y" or has a colon, split at colon
  if (t.includes(':')) {
    const [main, accent] = t.split(':').map(s => s.trim());
    return { main, accent };
  }
  // Otherwise no auto-split — show whole title with no accent
  return { main: t, accent: null };
}

const { main: titleMain, accent: titleAccent } = splitTitle(title);
---

<section class="editorial-content-hero">
  <div class="editorial-hero-dotgrid" aria-hidden="true"></div>
  <div class="editorial-hero-blob" aria-hidden="true"></div>

  <div class="editorial-hero-inner">
    {breadcrumbs && breadcrumbs.length > 0 && (
      <nav class="editorial-hero-crumb" aria-label="Breadcrumb">
        {breadcrumbs.map((item, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1 ? (
              <a href={item.url} class="editorial-hero-crumb-link">{item.name}</a>
            ) : (
              <span class="editorial-hero-crumb-current">{item.name}</span>
            )}
          </>
        ))}
      </nav>
    )}

    <div class={stats.length > 0 ? "editorial-hero-grid editorial-hero-grid-stats" : "editorial-hero-grid"}>
      <div class="editorial-hero-content">
        {eyebrow && (
          <div class="editorial-hero-eyebrow">
            <span class="editorial-hero-eyebrow-dot" style={`background:${eyebrowDot}`}></span>
            <span>{eyebrow}</span>
          </div>
        )}

        <h1 class="serif editorial-hero-title">
          {titleMain}
          {titleAccent && (
            <>
              <br />
              <span class="italic editorial-hero-title-accent">{titleAccent}</span>
            </>
          )}
        </h1>

        {subtitle && <p class="editorial-hero-subtitle">{subtitle}</p>}

        <slot name="hero-content" />
      </div>

      {stats.length > 0 && (
        <div class="editorial-hero-stats">
          {stats.map((stat) => (
            <div class="editorial-hero-stat">
              <div class="serif editorial-hero-stat-value">{stat.value}</div>
              <div class="editorial-hero-stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .editorial-content-hero {
    position: relative;
    background: var(--paper);
    padding: 8rem 0 4rem;
    border-bottom: 1px solid var(--line);
    overflow: hidden;
  }

  .editorial-hero-dotgrid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(var(--line) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.5;
  }

  .editorial-hero-blob {
    position: absolute;
    top: 0;
    left: 10%;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    filter: blur(150px);
    background: rgba(201,101,74,0.08);
    pointer-events: none;
  }

  .editorial-hero-inner {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 1024px) {
    .editorial-hero-inner { padding: 0 2rem; }
  }

  .editorial-hero-crumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
    color: var(--muted);
  }

  .editorial-hero-crumb-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .editorial-hero-crumb-link:hover { color: var(--ink); }
  .editorial-hero-crumb-current { color: var(--ink); }

  .editorial-hero-grid {
    display: grid;
    gap: 3rem;
    align-items: end;
  }

  @media (min-width: 1024px) {
    .editorial-hero-grid-stats { grid-template-columns: 1fr 1fr; }
  }

  .editorial-hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.075em;
    color: var(--muted);
  }

  .editorial-hero-eyebrow-dot {
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 50%;
  }

  .editorial-hero-title {
    font-size: clamp(2.25rem, 5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 1.5rem;
  }

  .editorial-hero-title-accent {
    color: var(--warm);
  }

  .editorial-hero-subtitle {
    font-size: 17px;
    line-height: 1.65;
    max-width: 36rem;
    color: var(--muted);
    margin: 0;
  }

  .editorial-hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-start;
  }

  @media (min-width: 1024px) {
    .editorial-hero-stats { justify-content: flex-end; }
  }

  .editorial-hero-stat {
    background: var(--paper2);
    border: 1px solid var(--line);
    border-radius: 1rem;
    padding: 1rem 1.25rem;
    text-align: center;
    min-width: 7rem;
  }

  .editorial-hero-stat-value {
    font-size: 1.875rem;
    line-height: 1;
    color: var(--ink);
  }

  .editorial-hero-stat-label {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.075em;
    margin-top: 0.25rem;
    color: var(--muted);
  }
</style>
