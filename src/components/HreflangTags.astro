---
interface Props {
  path: string;
  countries?: string[];
}

const { path, countries } = Astro.props;
const siteUrl = import.meta.env.SITE_URL || 'https://tmslist.com';

const countryHreflangMap: Record<string, string> = {
  US: 'en-US',
  UK: 'en-GB',
  CA: 'en-CA',
  AU: 'en-AU',
  DE: 'de-DE',
  FR: 'fr-FR',
  ES: 'es-ES',
  IT: 'it-IT',
  NL: 'nl-NL',
  SE: 'sv-SE',
  JP: 'ja-JP',
  KR: 'ko-KR',
  IN: 'en-IN',
  MX: 'es-MX',
  NZ: 'en-NZ',
  SG: 'en-SG',
  AE: 'ar-AE',
  ZA: 'en-ZA',
  IE: 'en-IE',
  IL: 'he-IL',
};

const countryPrefixMap: Record<string, string> = {
  US: '/us',
  UK: '/uk',
  CA: '/ca',
  AU: '/au',
  DE: '/de',
  FR: '/fr',
  ES: '/es',
  IT: '/it',
  NL: '/nl',
  SE: '/se',
  JP: '/jp',
  KR: '/kr',
  IN: '/in',
  MX: '/mx',
  NZ: '/nz',
  SG: '/sg',
  AE: '/ae',
  ZA: '/za',
  IE: '/ie',
  IL: '/il',
};

// Only render for country-specific pages
const activeCountries = countries || Object.keys(countryHreflangMap);
const isCountryPage = activeCountries.length > 0;
---

{isCountryPage && (
  <>
    {activeCountries.map(code => {
      const hreflang = countryHreflangMap[code];
      const prefix = countryPrefixMap[code];
      return hreflang && prefix ? (
        <link rel="alternate" hreflang={hreflang} href={`${siteUrl}${prefix}${path}`} />
      ) : null;
    })}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/us${path}`} />
  </>
)}
