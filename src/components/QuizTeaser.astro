<!-- IS TMS RIGHT FOR ME? — Quiz Teaser -->
<section class="py-16 bg-white relative overflow-hidden">
    <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto bg-gradient-to-br from-violet-600 via-violet-700 to-purple-800 rounded-3xl p-10 md:p-14 relative overflow-hidden">
            <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-[0.05]"></div>
            <div class="absolute top-0 right-0 w-[300px] h-[300px] bg-white/5 rounded-full blur-[80px]"></div>
            <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
                <div class="dark-section">
                    <div class="inline-flex items-center gap-2 px-3 py-1 bg-white/10 rounded-full mb-6">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
                        <span class="text-xs font-semibold text-white/80 uppercase tracking-widest">2-Minute Assessment</span>
                    </div>
                    <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight text-white mb-4">Is TMS Right<br/>For You?</h2>
                    <p class="text-violet-200 leading-relaxed mb-8">Answer a few quick questions about your condition, treatment history, and goals. We'll tell you if you're likely a good candidate.</p>
                    <a href="/quiz/am-i-a-candidate/" class="inline-flex items-center gap-2 px-8 py-4 bg-white text-violet-700 font-bold rounded-xl hover:bg-violet-50 transition-colors shadow-lg">
                        Take the Free Quiz
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                </div>
                <div class="space-y-4">
                    <div class="bg-white/10 backdrop-blur-sm rounded-xl p-5 border border-white/10">
                        <div class="text-xs font-semibold text-white/60 uppercase tracking-wider mb-3">Question 1 of 5</div>
                        <div class="text-white font-semibold mb-4">Have you tried antidepressant medication?</div>
                        <div class="space-y-2">
                            <div class="flex items-center gap-3 px-4 py-3 rounded-lg bg-white/10 border border-white/10 cursor-default pointer-events-none select-none"><div class="w-4 h-4 rounded-full border-2 border-white/40"></div><span class="text-sm text-white/80">Yes, multiple medications</span></div>
                            <div class="flex items-center gap-3 px-4 py-3 rounded-lg bg-white/10 border border-white/10 cursor-default pointer-events-none select-none"><div class="w-4 h-4 rounded-full border-2 border-white/40"></div><span class="text-sm text-white/80">Yes, one or two</span></div>
                            <div class="flex items-center gap-3 px-4 py-3 rounded-lg bg-white/10 border border-white/10 cursor-default pointer-events-none select-none"><div class="w-4 h-4 rounded-full border-2 border-white/40"></div><span class="text-sm text-white/80">No, not yet</span></div>
                        </div>
                    </div>
                    <div class="flex items-center justify-center gap-2">
                        <div class="w-8 h-1.5 rounded-full bg-white/60"></div>
                        <div class="w-2 h-1.5 rounded-full bg-white/20"></div>
                        <div class="w-2 h-1.5 rounded-full bg-white/20"></div>
                        <div class="w-2 h-1.5 rounded-full bg-white/20"></div>
                        <div class="w-2 h-1.5 rounded-full bg-white/20"></div>
                        <div class="w-2 h-1.5 rounded-full bg-white/20"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>