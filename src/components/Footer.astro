---
import {
    TREATMENT_SLUGS,
    TECHNOLOGY_SLUGS,
    INSURANCE_SLUGS,
    COMPARE_SLUGS,
    PROTOCOL_SLUGS,
    DEMOGRAPHIC_SLUGS,
    COMMERCIAL_SLUGS,
    BLOG_SLUGS,
} from "../utils/seo_slugs";
import { STATE_NAMES, getStateSlug } from "../utils/clinicData";

const POPULAR_STATES = [
    "CA", "TX", "FL", "NY", "PA",
    "IL", "OH", "GA", "NC", "MI",
    "NJ", "VA", "WA", "AZ", "MA",
];
---

<footer class="bg-[#0f172a] text-slate-500 pt-16 pb-8 border-t border-slate-800 font-sans">
    <div class="container mx-auto px-6">

        <!-- Main Footer Grid -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-x-6 gap-y-10 mb-14">

            <!-- Col 1: Find Care -->
            <div>
                <h4 class="text-slate-900 text-[11px] font-semibold uppercase tracking-[0.15em] mb-5">Find Care</h4>
                <ul class="space-y-2.5">
                    <li><a href="/us/" class="text-[13px] hover:text-slate-900 transition-colors">Find a Clinic</a></li>
                    <li><a href="/verified-clinics/" class="text-[13px] hover:text-slate-900 transition-colors">Verified Clinics</a></li>
                    <li><a href="/specialists/" class="text-[13px] hover:text-slate-900 transition-colors">Find a Specialist</a></li>
                    <li><a href="/compare-clinics/" class="text-[13px] hover:text-slate-900 transition-colors">Compare Clinics</a></li>
                    <li><a href="/near-me/tms-near-me/" class="text-[13px] hover:text-slate-900 transition-colors">TMS Near Me</a></li>
                    <li><a href="/quiz/am-i-a-candidate/" class="text-[13px] text-indigo-400 hover:text-slate-900 transition-colors font-medium">Am I a Candidate?</a></li>
                </ul>

                <h4 class="text-slate-900 text-[11px] font-semibold uppercase tracking-[0.15em] mt-8 mb-5">Patients</h4>
                <ul class="space-y-2.5">
                    {DEMOGRAPHIC_SLUGS.slice(0, 5).map((item) => (
                        <li><a href={`/demographic/${item.slug}/`} class="text-[13px] hover:text-slate-900 transition-colors">{item.title.replace("TMS for ", "")}</a></li>
                    ))}
                    <li><a href="/demographic/" class="text-[13px] text-indigo-400 hover:text-slate-900 transition-colors">All Demographics</a></li>
                </ul>
            </div>

            <!-- Col 2: Conditions -->
            <div>
                <h4 class="text-slate-900 text-[11px] font-semibold uppercase tracking-[0.15em] mb-5">Conditions</h4>
                <ul class="space-y-2.5">
                    {TREATMENT_SLUGS.slice(0, 12).map((item) => (
                        <li><a href={`/treatments/${item.slug}/`} class="text-[13px] hover:text-slate-900 transition-colors">{item.title.replace("TMS for ", "")}</a></li>
                    ))}
                    <li><a href="/treatments/" class="text-[13px] text-indigo-400 hover:text-slate-900 transition-colors">All Conditions</a></li>
                </ul>
            </div>

            <!-- Col 3: Technology & Insurance -->
            <div>
                <h4 class="text-slate-900 text-[11px] font-semibold uppercase tracking-[0.15em] mb-5">Technology</h4>
                <ul class="space-y-2.5">
                    {TECHNOLOGY_SLUGS.slice(0, 6).map((item) => (
                        <li><a href={`/technology/${item.slug}/`} class="text-[13px] hover:text-slate-900 transition-colors">{item.title}</a></li>
                    ))}
                    <li><a href="/wellness/" class="text-[13px] hover:text-slate-900 transition-colors">Exomind Wellness</a></li>
                    <li><a href="/technology/" class="text-[13px] text-indigo-400 hover:text-slate-900 transition-colors">All Devices</a></li>
                </ul>

                <h4 class="text-slate-900 text-[11px] font-semibold uppercase tracking-[0.15em] mt-8 mb-5">Insurance</h4>
                <ul class="space-y-2.5">
                    {INSURANCE_SLUGS.slice(0, 6).map((item) => (
                        <li><a href={`/insurance/${item.slug}/`} class="text-[13px] hover:text-slate-900 transition-colors">{item.title.replace(" TMS Coverage", "").replace(" Coverage for TMS", "")}</a></li>
                    ))}
                    <li><a href="/insurance/" class="text-[13px] text-indigo-400 hover:text-slate-900 transition-colors">All Insurance Guides</a></li>
                </ul>
            </div>

            <!-- Col 4: Resources -->
            <div>
                <h4 class="text-slate-900 text-[11px] font-semibold uppercase tracking-[0.15em] mb-5">Resources</h4>
                <ul class="space-y-2.5">
                    <li><a href="/blog/" class="text-[13px] hover:text-slate-900 transition-colors">Blog</a></li>
                    <li><a href="/questions/" class="text-[13px] hover:text-slate-900 transition-colors">FAQs</a></li>
                    <li><a href="/resources/" class="text-[13px] hover:text-slate-900 transition-colors">eBooks and Guides</a></li>
                    <li><a href="/stories/" class="text-[13px] hover:text-slate-900 transition-colors">Patient Stories</a></li>
                    <li><a href="/research/" class="text-[13px] hover:text-slate-900 transition-colors">Research and Trials</a></li>
                    <li><a href="/compare/" class="text-[13px] hover:text-slate-900 transition-colors">Compare Treatments</a></li>
                    <li><a href="/alternative-treatments/" class="text-[13px] hover:text-slate-900 transition-colors">Alternative Treatments</a></li>
                </ul>

                <h4 class="text-slate-900 text-[11px] font-semibold uppercase tracking-[0.15em] mt-8 mb-5">Protocols</h4>
                <ul class="space-y-2.5">
                    {PROTOCOL_SLUGS.slice(0, 5).map((item) => (
                        <li><a href={`/protocols/${item.slug}/`} class="text-[13px] hover:text-slate-900 transition-colors">{item.title}</a></li>
                    ))}
                </ul>
            </div>

            <!-- Col 5: Locations -->
            <div>
                <h4 class="text-slate-900 text-[11px] font-semibold uppercase tracking-[0.15em] mb-5">Locations</h4>
                <ul class="space-y-2.5">
                    {POPULAR_STATES.map((stateCode) => (
                        <li><a href={`/us/${getStateSlug(stateCode)}/`} class="text-[13px] hover:text-slate-900 transition-colors">{STATE_NAMES[stateCode]}</a></li>
                    ))}
                    <li><a href="/us/" class="text-[13px] text-indigo-400 hover:text-slate-900 transition-colors">All Locations</a></li>
                </ul>
            </div>

            <!-- Col 6: For Providers -->
            <div>
                <h4 class="text-slate-900 text-[11px] font-semibold uppercase tracking-[0.15em] mb-5">For Providers</h4>
                <ul class="space-y-2.5">
                    <li><a href="/add-listing/" class="text-[13px] text-indigo-400 hover:text-slate-900 transition-colors font-medium">List Your Clinic</a></li>
                    <li><a href="/add-listing/?type=doctor" class="text-[13px] hover:text-slate-900 transition-colors">List as Doctor</a></li>
                    <li><a href="/providers/" class="text-[13px] hover:text-slate-900 transition-colors">Provider Directory</a></li>
                    {COMMERCIAL_SLUGS.slice(0, 6).map((item) => (
                        <li><a href={`/providers/services/${item.slug}/`} class="text-[13px] hover:text-slate-900 transition-colors">{item.title}</a></li>
                    ))}
                    <li><a href="/admin/login/" class="text-[13px] text-emerald-400 hover:text-slate-900 transition-colors font-medium mt-2 block">Provider Login</a></li>
                </ul>

                <h4 class="text-slate-900 text-[11px] font-semibold uppercase tracking-[0.15em] mt-8 mb-5">Company</h4>
                <ul class="space-y-2.5">
                    <li><a href="/about-us/" class="text-[13px] hover:text-slate-900 transition-colors">About Us</a></li>
                    <li><a href="/contact/" class="text-[13px] hover:text-slate-900 transition-colors">Contact</a></li>
                    <li><a href="/sitemap/" class="text-[13px] hover:text-slate-900 transition-colors">Sitemap</a></li>
                </ul>
            </div>
        </div>

        <!-- Brand Row -->
        <div class="border-t border-slate-800 pt-10 pb-6 flex flex-col lg:flex-row items-start lg:items-center gap-8">
            <a href="/" class="flex items-center gap-2 group block shrink-0">
                <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-indigo-600 text-white shadow-lg shadow-indigo-600/20 group-hover:bg-indigo-700 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <span class="text-xl font-semibold tracking-tight text-slate-900 tracking-tight">
                    TMS<span class="text-indigo-500">List</span>
                </span>
            </a>
            <p class="text-sm text-slate-500 leading-relaxed max-w-lg">
                Real TMS clinics. Real reviews. Real insurance info.
                We help you find the right provider -- and skip the runaround.
            </p>
            <div class="flex gap-3 lg:ml-auto">
                <a href="#" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-slate-500 hover:bg-white/10 hover:text-slate-900 transition-all" aria-label="Twitter">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
                </a>
                <a href="#" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-slate-500 hover:bg-white/10 hover:text-slate-900 transition-all" aria-label="LinkedIn">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
            </div>
        </div>

        <!-- Bottom Bar -->
        <div class="flex flex-col md:flex-row justify-between items-center gap-4 pt-6 border-t border-slate-800">
            <p class="text-[11px] text-slate-600 tracking-wide order-2 md:order-1">
                &copy; 2026 TMS List Inc. All rights reserved.
            </p>
            <div class="flex flex-wrap justify-center md:justify-end gap-5 order-1 md:order-2">
                <a href="/legal/privacy-policy/" class="text-[10px] text-slate-500 hover:text-slate-900 transition-colors uppercase tracking-widest">Privacy Policy</a>
                <a href="/legal/terms-of-service/" class="text-[10px] text-slate-500 hover:text-slate-900 transition-colors uppercase tracking-widest">Terms of Service</a>
                <a href="/legal/medical-disclaimer/" class="text-[10px] text-slate-500 hover:text-slate-900 transition-colors uppercase tracking-widest">Medical Disclaimer</a>
            </div>
        </div>
    </div>
</footer>
