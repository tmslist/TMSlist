        <!-- Visitor's country directory (only that country, not the full international list) -->
        {visitorCountryEntry && (
            <div class="footer-country-section border-t mb-10" data-country={visitorCountryEntry.code} id={`footer-${visitorCountryEntry.urlPrefix}-locations`} style="border-color: rgba(230,234,240,0.12); padding-top: 2rem;">
                <div class="flex items-center justify-between mb-5">
                    <h4 class="text-xs font-semibold uppercase tracking-widest" style="color: rgba(230,234,240,0.4);">
                        <Fragment set:html={visitorCountryEntry.flag} /> TMS Clinics in {visitorCountryEntry.name}
                    </h4>
                    <span class="text-[11px]" style="color: rgba(230,234,240,0.4);">{visitorCountryEntry.clinicCount} clinics</span>
                </div>
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-x-4 gap-y-1">
                    {visitorCountryEntry.regions.map((region) => (
                        <div class="footer-state-group">
                            <button type="button" class="footer-state-toggle w-full flex items-center justify-between py-2 text-left group" aria-expanded="false" aria-label={`Toggle ${region.name} regions`}>
                                <span class="footer-link font-medium group-hover:font-semibold transition-all">{region.name}</span>
                                <span class="flex items-center gap-1.5">
                                    <span class="text-[10px]" style="color: rgba(230,234,240,0.3);">{region.clinicCount}</span>
                                    <svg class="w-3 h-3 transition-all duration-200 footer-chevron" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color: rgba(230,234,240,0.3);">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </span>
                            </button>
                            <ul class="footer-city-list hidden pl-2 pb-2 space-y-1">
                                {region.cities.map((city) => (
                                    <li>
                                        <a href={`/${visitorCountryEntry.urlPrefix}/${region.slug}/${city.slug}/`} class="footer-link-city flex items-center justify-between">
                                            <span>{city.name}</span>
                                            <span class="text-[10px]" style="color: rgba(230,234,240,0.3);">{city.count}</span>
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))}
                </div>
            </div>
        )}

        <!-- Bottom Bar -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 pt-6" style="border-top: 1px solid rgba(230,234,240,0.12);">
            <p class="text-[11px] leading-relaxed order-2 md:order-1" style="color: rgba(230,234,240,0.35);">
                &copy; {new Date().getFullYear()} ATZ Medappz Pvt Ltd. All rights reserved.
            </p>
            <div class="flex flex-wrap justify-start md:justify-end gap-5 order-1 md:order-2">
                <a href="/legal/privacy-policy/" class="footer-bottom-link">Privacy Policy</a>
                <a href="/legal/terms-of-service/" class="footer-bottom-link">Terms of Service</a>
                <a href="/legal/medical-disclaimer/" class="footer-bottom-link">Medical Disclaimer</a>
                <a href="/legal/dmca/" class="footer-bottom-link">DMCA</a>
                <a href="/accessibility/" class="footer-bottom-link">Accessibility</a>
            </div>
        </div>
    </div>
</footer>

<style>
    @reference "../styles/global.css";

    .footer-col-title {
        font-size: 0.6875rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(230,234,240,0.12);
        color: rgba(230,234,240,0.4);
    }

    .footer-link {
        display: block;
        font-size: 0.8125rem;
        transition: color 0.15s ease;
        text-decoration: none;
        padding: 0.125rem 0;
        color: rgba(230,234,240,0.55);
    }
    .footer-link:hover {
        color: rgba(230,234,240,0.9);
    }

    .footer-link-accent {
        color: var(--warm);
        font-weight: 500;
    }
    .footer-link-accent:hover {
        color: var(--accent2);
    }

    .footer-link-city {
        display: block;
        font-size: 0.75rem;
        transition: color 0.15s ease;
        text-decoration: none;
        padding: 0.125rem 0;
        color: rgba(230,234,240,0.4);
    }
    .footer-link-city:hover {
        color: var(--warm);
    }

    .footer-state-toggle {
        cursor: pointer;
        transition: color 0.15s ease;
    }
    .footer-state-toggle .footer-link {
        transition: font-weight 0.15s ease, color 0.15s ease;
    }

    .footer-social-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 50%;
        transition: all 0.2s ease;
        text-decoration: none;
        border: 1px solid rgba(230,234,240,0.15);
        color: rgba(230,234,240,0.4);
    }
    .footer-social-btn:hover {
        background: rgba(230,234,240,0.08);
        color: rgba(230,234,240,0.9);
        border-color: rgba(230,234,240,0.3);
        transform: translateY(-2px);
    }

    .footer-bottom-link {
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: color 0.15s ease;
        text-decoration: none;
        padding: 0.125rem 0;
        color: rgba(230,234,240,0.35);
    }
    .footer-bottom-link:hover {
        color: rgba(230,234,240,0.6);
    }
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
    // Collapsible state/region toggle
    document.querySelectorAll('.footer-state-toggle').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var group = btn.closest('.footer-state-group');
            var list = group.querySelector('.footer-city-list');
            var chevron = btn.querySelector('.footer-chevron');
            var isOpen = btn.getAttribute('aria-expanded') === 'true';

            var section = btn.closest('[id^="footer-"]') || btn.closest('.footer-country-section');
            if (section) {
                section.querySelectorAll('.footer-state-toggle').forEach(function(other) {
                    if (other !== btn && other.getAttribute('aria-expanded') === 'true') {
                        other.setAttribute('aria-expanded', 'false');
                        var otherList = other.closest('.footer-state-group').querySelector('.footer-city-list');
                        if (otherList) otherList.classList.add('hidden');
                        var otherChevron = other.querySelector('.footer-chevron');
                        if (otherChevron) otherChevron.style.transform = '';
                    }
                });
            }

            btn.setAttribute('aria-expanded', String(!isOpen));
            list && list.classList.toggle('hidden');
            chevron && (chevron.style.transform = isOpen ? '' : 'rotate(180deg)');
        });
    });

    // Geo-aware locations
    var country = (window.TMS_GEO && window.TMS_GEO.country) || 'US';

    document.querySelectorAll('.footer-locations-list').forEach(function(el) {
        el.classList.toggle('hidden', el.getAttribute('data-country') !== country);
    });
    document.querySelectorAll('.footer-directory-section, .footer-country-section').forEach(function(el) {
        el.classList.toggle('hidden', el.getAttribute('data-country') !== country);
    });
});

document.querySelectorAll('.footer-newsletter-form').forEach(function(form) {
    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        var f = e.target;
        var emailInput = f.querySelector('[name="email"]');
        var email = emailInput ? emailInput.value : '';
        var source = f.dataset.source || 'footer';
        var msg = f.parentElement.querySelector('.footer-newsletter-msg');
        try {
            var res = await fetch('/api/newsletter/subscribe', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: email, source: source }),
            });
            if (res.ok) {
                f.classList.add('hidden');
                if (msg) {
                    msg.textContent = 'Subscribed! Check your inbox.';
                    msg.classList.remove('hidden');
                    msg.style.color = 'rgba(180,230,200,0.95)';
                }
            } else {
                var data = {};
                try { data = await res.json(); } catch (_) {}
                if (msg) {
                    msg.textContent = data.error || 'Something went wrong. Try again.';
                    msg.classList.remove('hidden');
                    msg.style.color = 'rgba(255,180,180,0.95)';
                }
            }
        } catch (_) {
            if (msg) {
                msg.textContent = 'Network error. Try again.';
                msg.classList.remove('hidden');
                msg.style.color = 'rgba(255,180,180,0.95)';
            }
        }
    });
});
</script>
