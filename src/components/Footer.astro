<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
    // Collapsible state/region toggle (works for both US and international)
    const toggles = document.querySelectorAll('.footer-state-toggle');
    toggles.forEach((btn) => {
        btn.addEventListener('click', () => {
            const group = btn.closest('.footer-state-group');
            const list = group.querySelector('.footer-city-list');
            const chevron = btn.querySelector('.footer-chevron');
            const isOpen = btn.getAttribute('aria-expanded') === 'true';

            // Close other open groups within the same section
            const section = btn.closest('[id^="footer-"]') || btn.closest('.footer-country-section');
            if (section) {
                section.querySelectorAll('.footer-state-toggle').forEach((other) => {
                    if (other !== btn && other.getAttribute('aria-expanded') === 'true') {
                        other.setAttribute('aria-expanded', 'false');
                        other.closest('.footer-state-group').querySelector('.footer-city-list').classList.add('hidden');
                        other.querySelector('.footer-chevron').style.transform = '';
                    }
                });
            }

            btn.setAttribute('aria-expanded', String(!isOpen));
            list.classList.toggle('hidden');
            chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
        });
    });

    // Use shared geo.js detection (loaded in Layout head)
    var country = (window.TMS_GEO && window.TMS_GEO.country) || 'US';

    // Col 5: Show only the matching country's location links
    document.querySelectorAll('.footer-locations-list').forEach(function(el) {
        if (el.getAttribute('data-country') === country) {
            el.classList.remove('hidden');
        } else {
            el.classList.add('hidden');
        }
    });

    // Directory sections: show matching country, hide others
    document.querySelectorAll('.footer-directory-section').forEach(function(el) {
        if (el.getAttribute('data-country') === country) {
            el.classList.remove('hidden');
        } else {
            el.classList.add('hidden');
        }
    });
    document.querySelectorAll('.footer-country-section').forEach(function(el) {
        if (el.getAttribute('data-country') === country) {
            el.classList.remove('hidden');
        } else {
            el.classList.add('hidden');
        }
    });
});
</script>
