---
import {
    TREATMENT_SLUGS,
    TECHNOLOGY_SLUGS,
    INSURANCE_SLUGS,
    COMPARE_SLUGS,
    PROTOCOL_SLUGS,
    DEMOGRAPHIC_SLUGS,
    COMMERCIAL_SLUGS,
    BLOG_SLUGS,
} from "../utils/seo_slugs";
import { STATE_NAMES, getStateSlug } from "../utils/clinicData";
import {
    getUniqueStates,
    getClinicsByState,
    buildInternationalDirectory,
} from "../utils/dataHelpers";
import { getVisitorCountry } from "../utils/visitorCountry";

const VISITOR_COUNTRY = getVisitorCountry(Astro.isPrerendered ? null : Astro.cookies, Astro.url);
const isUS = VISITOR_COUNTRY === 'US';

const POPULAR_STATES = [
    "CA", "TX", "FL", "NY", "PA",
    "IL", "OH", "GA", "NC", "MI",
    "NJ", "VA", "WA", "AZ", "MA",
];

// Only build the heavy US state/city map for US visitors — this is a 50-state
// loop that's pointless for international visitors and bloats the response.
const stateCityMap: Array<{
    code: string; name: string; slug: string; clinicCount: number;
    cities: Array<{ name: string; slug: string; count: number }>;
}> = [];
if (isUS) {
    const statesWithClinics = (await getUniqueStates())
        .filter((code) => STATE_NAMES[code])
        .sort((a, b) => (STATE_NAMES[a] || "").localeCompare(STATE_NAMES[b] || ""));

    for (const stateCode of statesWithClinics) {
        const clinics = await getClinicsByState(stateCode);
        const cities = [...new Set(clinics.map((c) => c.city).filter(Boolean))].sort();
        stateCityMap.push({
            code: stateCode,
            name: STATE_NAMES[stateCode]!,
            slug: getStateSlug(stateCode),
            clinicCount: clinics.length,
            cities: cities.map((city) => ({
                name: city,
                slug: city.toLowerCase().replace(/\s+/g, "-"),
                count: clinics.filter((c) => c.city === city).length,
            })),
        });
    }
}

// Pull only the visitor's country block from the international directory
// (skip entirely for US visitors — they get the US section above).
const fullIntlDirectory = isUS ? [] : await buildInternationalDirectory();
const visitorCountryEntry = isUS
    ? null
    : fullIntlDirectory.find((c) => c.code === VISITOR_COUNTRY) || null;
// If the visitor's country has no clinics indexed yet, fall back to showing the
// US section so the footer is never empty.
const showUSAsFallback = !isUS && !visitorCountryEntry;
let fallbackStateCityMap: typeof stateCityMap = [];
if (showUSAsFallback) {
    const statesWithClinics = (await getUniqueStates())
        .filter((code) => STATE_NAMES[code])
        .sort((a, b) => (STATE_NAMES[a] || "").localeCompare(STATE_NAMES[b] || ""));
    for (const stateCode of statesWithClinics) {
        const clinics = await getClinicsByState(stateCode);
        fallbackStateCityMap.push({
            code: stateCode,
            name: STATE_NAMES[stateCode]!,
            slug: getStateSlug(stateCode),
            clinicCount: clinics.length,
            cities: [],
        });
    }
}
const renderUS = isUS || showUSAsFallback;
const renderedStateCityMap = isUS ? stateCityMap : fallbackStateCityMap;
