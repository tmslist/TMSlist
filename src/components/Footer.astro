---
import {
    TREATMENT_SLUGS,
    TECHNOLOGY_SLUGS,
    INSURANCE_SLUGS,
    COMPARE_SLUGS,
    PROTOCOL_SLUGS,
    DEMOGRAPHIC_SLUGS,
    COMMERCIAL_SLUGS,
    BLOG_SLUGS,
} from "../utils/seo_slugs";
import { STATE_NAMES, getStateSlug } from "../utils/clinicData";
import {
    getUniqueStates,
    getClinicsByState,
    buildInternationalDirectory,
} from "../utils/dataHelpers";

const POPULAR_STATES = [
    "CA", "TX", "FL", "NY", "PA",
    "IL", "OH", "GA", "NC", "MI",
    "NJ", "VA", "WA", "AZ", "MA",
];

const statesWithClinics = (await getUniqueStates())
    .filter((code) => STATE_NAMES[code])
    .sort((a, b) => (STATE_NAMES[a] || "").localeCompare(STATE_NAMES[b] || ""));

const stateCityMap = [];
for (const stateCode of statesWithClinics) {
    const clinics = await getClinicsByState(stateCode);
    const cities = [...new Set(clinics.map((c) => c.city).filter(Boolean))].sort();
    stateCityMap.push({
        code: stateCode,
        name: STATE_NAMES[stateCode],
        slug: getStateSlug(stateCode),
        clinicCount: clinics.length,
        cities: cities.map((city) => ({
            name: city,
            slug: city.toLowerCase().replace(/\s+/g, "-"),
            count: clinics.filter((c) => c.city === city).length,
        })),
    });
}

const internationalDirectory = await buildInternationalDirectory();
---

