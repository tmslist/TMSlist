---
interface StatItem {
  value: string;
  label: string;
  color?: 'violet' | 'emerald' | 'blue' | 'amber' | 'cyan' | 'rose';
  icon?: 'check' | 'clock' | 'shield' | 'chart' | 'brain' | 'dollar';
}

interface Props {
  stats: StatItem[];
}

const { stats } = Astro.props;

const colorMap: Record<string, string> = {
  violet: 'bg-violet-50 text-violet-700 border-violet-100',
  emerald: 'bg-emerald-50 text-emerald-700 border-emerald-100',
  blue: 'bg-blue-50 text-blue-700 border-blue-100',
  amber: 'bg-amber-50 text-amber-700 border-amber-100',
  cyan: 'bg-cyan-50 text-cyan-700 border-cyan-100',
  rose: 'bg-rose-50 text-rose-700 border-rose-100',
};

const iconPaths: Record<string, string> = {
  check: 'M5 13l4 4L19 7',
  clock: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  chart: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  brain: 'M12 2C9.5 2 7.5 3.2 6.2 5 4.8 4.2 3.2 4.5 2.2 5.8 1 7.2 1.2 9.2 2.5 10.5 1.5 11.5 1 13 1 14.5 1 17 3 19 5.5 19.5 6 20.5 6.8 21.5 8 22c1.5.5 3.2.2 4-1M12 2c2.5 0 4.5 1.2 5.8 3 1.4-.8 3-.5 4 .8 1.2 1.4 1 3.4-.3 4.7 1 1 1.5 2.5 1.5 4 0 2.5-2 4.5-4.5 5-.5 1-1.3 2-2.5 2.5-1.5.5-3.2.2-4-1',
  dollar: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
};
---

<section class="container mx-auto px-4 -mt-6 relative z-20 mb-12">
  <div class={`grid grid-cols-2 ${stats.length >= 4 ? 'lg:grid-cols-4' : 'lg:grid-cols-3'} gap-4`}>
    {stats.map((stat) => {
      const color = stat.color || 'violet';
      const classes = colorMap[color];
      const iconPath = stat.icon ? iconPaths[stat.icon] : null;
      return (
        <div class={`${classes} border rounded-2xl p-5 text-center shadow-sm`}>
          {iconPath && (
            <svg class="w-5 h-5 mx-auto mb-2 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
            </svg>
          )}
          <div class="text-2xl font-bold font-display">{stat.value}</div>
          <div class="text-xs opacity-70 mt-1">{stat.label}</div>
        </div>
      );
    })}
  </div>
</section>
