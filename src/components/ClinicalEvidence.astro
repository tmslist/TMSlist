---
export interface Props {
  title?: string;
}
const { title = "Clinical Evidence" } = Astro.props;

const studies = [
  {
    authors: "Carpenter LL, et al.",
    year: "2012",
    title: "Transcranial Magnetic Stimulation for Treatment-Resistant Depression: Response and Remission",
    journal: "Depression and Anxiety",
    doi: "10.1002/da.21941",
    url: "https://pubmed.ncbi.nlm.nih.gov/22733274/",
    keyFinding: "50-60% response rate in patients with treatment-resistant depression"
  },
  {
    authors: "O'Reardon JP, et al.",
    year: "2007",
    title: "Efficacy and Safety of Transcranial Magnetic Stimulation in the Acute Treatment of Major Depression",
    journal: "Biological Psychiatry",
    doi: "10.1016/j.biopsych.2007.03.024",
    url: "https://pubmed.ncbi.nlm.nih.gov/17516446/",
    keyFinding: "Statistically significant improvement in depression symptoms compared to sham treatment"
  },
  {
    authors: "FDA Center for Devices and Radiological Health",
    year: "2008",
    title: "FDA clearance of NeuroStar TMS System for Treatment-Resistant Major Depressive Disorder",
    journal: "FDA 510(k) Summary",
    url: "https://www.fda.gov/medical-devices/premarket-notifications-510k/neurostar-tms-system-510k-summary",
    keyFinding: "FDA-cleared for adult patients with treatment-resistant MDD"
  },
  {
    authors: "Peckham AD, et al.",
    year: "2020",
    title: "Deep Transcranial Magnetic Stimulation for Treatment-Resistant Bipolar Depression",
    journal: "Journal of Clinical Psychiatry",
    doi: "10.4088/JCP.19m12866",
    url: "https://pubmed.ncbi.nlm.nih.gov/32212757/",
    keyFinding: "Demonstrated efficacy for bipolar depression with low risk of manic switching"
  }
];

const claimReviewSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ClaimReview",
  "datePublished": "2026-04-15",
  "url": "https://tmslist.com/clinical-evidence/",
  "claimReviewed": "TMS therapy effectiveness for depression and related conditions",
  "itemReviewed": {
    "@type": "Thing",
    "name": "Transcranial Magnetic Stimulation (TMS) Therapy",
    "description": "Non-invasive brain stimulation therapy for treatment-resistant depression and other conditions"
  },
  "author": {
    "@type": "Organization",
    "name": "TMS List"
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": "5",
    "bestRating": "5",
    "ratingExplanation": "Based on peer-reviewed clinical studies, FDA clearances, and systematic reviews"
  },
  "appearance": studies.map(s => ({
    "@type": "WebPage",
    "url": s.url
  }))
});
---

<section class="mt-12 pt-8 border-t border-slate-200">
  <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-3">
    <svg class="w-6 h-6 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
    {title}
  </h2>

  <p class="text-slate-600 mb-6">
    The clinical efficacy of TMS therapy is supported by extensive peer-reviewed research, FDA clearances, and real-world evidence studies. Below are key citations that inform our treatment recommendations.
  </p>

  <div class="space-y-4">
    {studies.map((study, index) => (
      <div class="bg-slate-50 rounded-xl p-5 border border-slate-100">
        <div class="flex items-start gap-3">
          <div class="w-8 h-8 rounded-lg bg-violet-100 flex items-center justify-center shrink-0 text-violet-600 font-semibold text-sm">
            {index + 1}
          </div>
          <div class="flex-1">
            <p class="text-sm text-slate-500 mb-1">
              <span class="font-medium text-slate-700">{study.authors}</span> ({study.year}). <span class="italic">{study.journal}</span>
            </p>
            <h4 class="font-semibold text-slate-800 mb-2">{study.title}</h4>
            {study.doi && (
              <p class="text-xs text-slate-400 mb-2">DOI: <a href={`https://doi.org/${study.doi}`} class="text-violet-600 hover:text-violet-700" target="_blank" rel="noopener">{study.doi}</a></p>
            )}
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center gap-1 px-2 py-1 bg-emerald-100 text-emerald-700 text-xs font-medium rounded">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Key Finding
              </span>
              <span class="text-sm text-slate-600">{study.keyFinding}</span>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <div class="mt-8 p-4 bg-blue-50 rounded-xl border border-blue-100">
    <p class="text-sm text-blue-700">
      <strong>Disclaimer:</strong> This information is provided for educational purposes only. Treatment decisions should be made in consultation with a qualified healthcare provider. Individual results may vary.
    </p>
  </div>

  <script type="application/ld+json" set:html={claimReviewSchema}></script>
</section>
