---
import type { Clinic } from '../types/clinic';

interface Props {
    clinicCount: number;
    countryCode?: string;
}

const { clinicCount, countryCode = 'US' } = Astro.props as Props;
---

<!-- PROVIDER TRUST SIGNALS -->
<section class="py-14 bg-white border-y border-slate-100" data-clinic-country={countryCode}>
    <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-10">
                <h2 class="text-2xl md:text-3xl font-display font-bold tracking-tight text-slate-900 mb-2">
                    {countryCode === 'US' ? 'Trusted by Patients Nationwide' : `Trusted in ${countryCode === 'IN' ? 'India' : countryCode}`}
                </h2>
                <p class="text-slate-500">Every clinic on TMSList is verified for quality, credentials, and patient satisfaction.</p>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                <!-- Verified Clinics -->
                <div class="text-center p-6 bg-slate-50 rounded-2xl">
                    <div class="w-14 h-14 mx-auto rounded-2xl bg-violet-100 flex items-center justify-center mb-4">
                        <svg class="w-7 h-7 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    </div>
                    <div class="text-3xl font-display font-bold text-slate-900 mb-1">{clinicCount}+</div>
                    <div class="text-sm font-semibold text-slate-500">Verified Clinics</div>
                    <div class="text-xs text-slate-400 mt-1">Credentials checked</div>
                </div>

                <!-- Patient Reviews -->
                <div class="text-center p-6 bg-slate-50 rounded-2xl">
                    <div class="w-14 h-14 mx-auto rounded-2xl bg-amber-100 flex items-center justify-center mb-4">
                        <svg class="w-7 h-7 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
                    </div>
                    <div class="text-3xl font-display font-bold text-slate-900 mb-1">12K+</div>
                    <div class="text-sm font-semibold text-slate-500">Patient Reviews</div>
                    <div class="text-xs text-slate-400 mt-1">4.6 avg rating</div>
                </div>

                <!-- TMS Specialists -->
                <div class="text-center p-6 bg-slate-50 rounded-2xl">
                    <div class="w-14 h-14 mx-auto rounded-2xl bg-cyan-100 flex items-center justify-center mb-4">
                        <svg class="w-7 h-7 text-cyan-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    </div>
                    <div class="text-3xl font-display font-bold text-slate-900 mb-1">720+</div>
                    <div class="text-sm font-semibold text-slate-500">TMS Specialists</div>
                    <div class="text-xs text-slate-400 mt-1">Board-certified</div>
                </div>

                <!-- States/Regions Covered -->
                <div class="text-center p-6 bg-slate-50 rounded-2xl stats-states-covered">
                    <div class="w-14 h-14 mx-auto rounded-2xl bg-emerald-100 flex items-center justify-center mb-4">
                        <svg class="w-7 h-7 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <div class="text-3xl font-display font-bold text-slate-900 mb-1">20+</div>
                    <div class="text-sm font-semibold text-slate-500">Countries</div>
                    <div class="text-xs text-slate-400 mt-1">50 US States</div>
                </div>
            </div>

            <!-- Trust badges row -->
            <div class="flex flex-wrap items-center justify-center gap-6 mt-10 pt-8 border-t border-slate-100">
                <div class="flex items-center gap-2 text-sm text-slate-500">
                    <svg class="w-5 h-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>FDA-Cleared Treatments Only</span>
                </div>
                <div class="flex items-center gap-2 text-sm text-slate-500">
                    <svg class="w-5 h-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>HIPAA Compliant</span>
                </div>
                <div class="flex items-center gap-2 text-sm text-slate-500">
                    <svg class="w-5 h-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>No Paid Rankings</span>
                </div>
                <div class="flex items-center gap-2 text-sm text-slate-500">
                    <svg class="w-5 h-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span>Updated Weekly</span>
                </div>
            </div>
        </div>
    </div>
</section>