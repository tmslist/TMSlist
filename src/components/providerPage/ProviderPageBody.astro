---
/**
 * Shared layout for all provider-type sub-city pages.
 * Works for: /us/[state]/[city]/psychiatrists/, /psychologists/, /therapists/
 */
import EditorialHero from '../editorial/EditorialHero.astro';
import { getDoctorPhoto } from '../../utils/dataHelpers';
import type { DoctorWithClinic } from '../../utils/providerFilter';
import { getProviderSEOContent } from '../../utils/providerFilter';
import { PROVIDER_TYPES } from '../../utils/cityData';

interface Props {
  providerType: 'psychiatrists' | 'psychologists' | 'therapists';
  cityName: string;
  stateName: string;
  stateSlug: string;
  citySlug: string;
  doctors: DoctorWithClinic[];
  clinics: Record<string, any>[];
}

const { providerType, cityName, stateName, stateSlug, citySlug, doctors, clinics } = Astro.props;
const provider = PROVIDER_TYPES.find(p => p.slug === providerType)!;
const seo = getProviderSEOContent(providerType, cityName, stateName);
const clinicCount = clinics.length;
const avgRating = clinics.length > 0
  ? (clinics.reduce((sum, c) => {
      const r = typeof c.rating === 'object' ? c.rating?.aggregate : c.rating;
      return sum + (Number(r) || 0);
    }, 0) / Math.max(clinics.length, 1)).toFixed(1)
  : '4.5';
---

<div style="background:var(--paper);">
  <EditorialHero
    eyebrow={doctors.length > 0 ? `${doctors.length} ${provider.label} Found` : `${provider.label} in ${cityName}`}
    eyebrowDot="#22c55e"
    title={`${provider.label} in`}
    titleAccent={`${cityName}.`}
    description={doctors.length > 0
      ? `${doctors.length} ${provider.plural} specializing in TMS therapy across ${clinicCount} clinics in ${cityName}, ${stateName}.`
      : `Find ${provider.plural.toLowerCase()} specializing in TMS therapy in ${cityName}, ${stateName}. Browse verified providers and book a consultation.`}
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: "United States", href: "/us/" },
      { label: stateName, href: `/us/${stateSlug}/` },
      { label: cityName, href: `/us/${stateSlug}/${citySlug}/` },
      { label: provider.label },
    ]}
    ctas={[
      { label: "View All Clinics", href: `/us/${stateSlug}/${citySlug}/clinics/` },
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/", variant: "outline" },
    ]}
    stats={[
      { value: doctors.length, label: provider.label, color: "ink" },
      { value: clinicCount, label: "Clinics", color: "accent" },
      { value: `${avgRating}★`, label: "Avg Rating", color: "warm" },
    ]}
  />

  <!-- Providers Grid or Empty State -->
  <section class="py-16">
    <div class="container mx-auto px-6">
      {doctors.length > 0 ? (
        <>
          <h2 class="text-3xl font-semibold text-[var(--ink)] mb-10">All {provider.label} in {cityName}</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {doctors.map((doctor: any, idx: number) => {
              const clinicImg = doctor.clinic?.hero_image_url;
              const avatarUrl = getDoctorPhoto(doctor);
              const clinicRating = typeof doctor.clinic?.rating === 'object'
                ? doctor.clinic.rating?.aggregate
                : doctor.clinic?.rating || 4.5;
              const reviewCount = typeof doctor.clinic?.rating === 'object'
                ? doctor.clinic.rating?.count
                : 50;
              return (
              <article class="bg-[var(--paper)] rounded-2xl shadow-sm border border-[var(--line)] overflow-hidden hover:shadow-lg transition-all group">
                {clinicImg && !clinicImg.includes('tms_chair') && (
                  <div class="h-32 overflow-hidden relative">
                    <img src={clinicImg} alt={`${doctor.clinic?.name} clinic`} class="w-full h-full object-cover" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent to-white/90"></div>
                  </div>
                )}
                <div class={`p-6 ${clinicImg && !clinicImg.includes('tms_chair') ? '-mt-10 relative z-10' : ''}`}>
                  <div class="flex items-start gap-4 mb-4">
                    <img
                      src={avatarUrl}
                      alt={`${doctor.name} - TMS ${provider.singular} in ${cityName}`}
                      class="w-20 h-20 rounded-full object-cover border-4 border-white shadow-md"
                      loading="lazy"
                      width="80"
                      height="80"
                    />
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-1 flex-wrap">
                        <span class="px-2 py-0.5 bg-emerald-100 text-emerald-700 text-[10px] font-bold uppercase tracking-wider rounded-full">Verified</span>
                        <span class="px-2 py-0.5 bg-[rgba(10,22,40,0.08)] text-[var(--accent)] text-[10px] font-bold uppercase tracking-wider rounded-full">
                          #{idx + 1} in {cityName}
                        </span>
                      </div>
                      <h3 class="text-xl font-bold text-[var(--ink)] group-hover:text-[var(--accent)] transition-colors truncate">
                        <a href={`/specialist/${doctor.slug}`}>{doctor.name}</a>
                      </h3>
                      <p class="text-[var(--accent)] font-medium text-sm">{doctor.title}</p>
                    </div>
                  </div>

                  <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-[var(--muted)] mb-3">
                    {doctor.school && (
                      <span class="flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /></svg>
                        {doctor.school}
                      </span>
                    )}
                    {doctor.years_experience > 0 && (
                      <span class="flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        {doctor.years_experience}+ years
                      </span>
                    )}
                    <span class="flex items-center gap-1">
                      <svg class="w-3.5 h-3.5 text-yellow-400 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                      {Number(clinicRating).toFixed(1)} ({reviewCount} reviews)
                    </span>
                  </div>

                  {doctor.bio && (
                    <p class="text-[var(--muted)] text-sm mb-3 line-clamp-2">{doctor.bio}</p>
                  )}

                  {(doctor.specialties || []).length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mb-4">
                      {(doctor.specialties as string[]).slice(0, 4).map((spec: string) => (
                        <span class="px-2.5 py-1 bg-[rgba(10,22,40,0.08)] text-[var(--accent)] rounded-full text-xs font-medium">{spec}</span>
                      ))}
                    </div>
                  )}

                  <div class="pt-4 border-t border-[var(--line)] flex items-center justify-between">
                    <a href={`/clinic/${doctor.clinic?.slug}`} class="text-sm text-[var(--muted)] hover:text-[var(--accent)] truncate max-w-[60%]">
                      at {doctor.clinic?.name}
                    </a>
                    {doctor.slug ? (
                      <a href={`/specialist/${doctor.slug}`} class="px-4 py-2 bg-[var(--ink)] text-white text-sm font-semibold rounded-lg hover:bg-[var(--ink2)] transition-colors">
                        View Profile
                      </a>
                    ) : (
                      <a href={`/clinic/${doctor.clinic?.slug}`} class="px-4 py-2 bg-[var(--ink)] text-white text-sm font-semibold rounded-lg hover:bg-[var(--ink2)] transition-colors">
                        View Clinic
                      </a>
                    )}
                  </div>
                </div>
              </article>
              );
            })}
          </div>
        </>
      ) : (
        <!-- Empty State -->
        <div class="text-center py-16 max-w-2xl mx-auto">
          <div class="w-20 h-20 mx-auto mb-6 bg-[rgba(10,22,40,0.08)] rounded-2xl flex items-center justify-center">
            <svg class="w-10 h-10 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-[var(--ink)] mb-3">No {provider.label} Listed Yet in {cityName}</h2>
          <p class="text-[var(--muted)] mb-6 text-lg">
            We're expanding our {provider.singular} network in {cityName}. In the meantime, explore nearby cities or browse our full clinic directory.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            <a href={`/us/${stateSlug}/${citySlug}/clinics/`} class="px-5 py-2.5 bg-[var(--ink)] text-white rounded-xl text-sm font-semibold hover:bg-[var(--ink2)] transition-colors">
              View {cityName} Clinics
            </a>
            <a href="/quiz/am-i-a-candidate/" class="px-5 py-2.5 bg-[var(--paper)] border border-[var(--line)] rounded-xl text-sm font-semibold hover:border-[rgba(10,22,40,0.2)] transition-colors">
              Take Eligibility Quiz
            </a>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Related Links -->
  <section class="py-8 bg-[var(--paper2)]">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
        <a href={`/us/${stateSlug}/${citySlug}/clinics/`} class="flex items-center gap-3 p-4 bg-[var(--paper)] rounded-xl border border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-[rgba(10,22,40,0.08)] rounded-lg flex items-center justify-center text-[var(--accent)]">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
          </div>
          <span class="text-sm font-semibold text-[var(--ink)]">All Clinics in {cityName}</span>
        </a>
        <a href={`/us/${stateSlug}/${citySlug}/psychiatrists/`} class="flex items-center gap-3 p-4 bg-[var(--paper)] rounded-xl border border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center text-emerald-600">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <span class="text-sm font-semibold text-[var(--ink)]">Psychiatrists</span>
        </a>
        <a href="/treatments/" class="flex items-center gap-3 p-4 bg-[var(--paper)] rounded-xl border border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center text-amber-600">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
          </div>
          <span class="text-sm font-semibold text-[var(--ink)]">Conditions Treated</span>
        </a>
        <a href="/quiz/am-i-a-candidate/" class="flex items-center gap-3 p-4 bg-[var(--paper)] rounded-xl border border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-[rgba(10,22,40,0.1)] rounded-lg flex items-center justify-center text-[var(--accent)]">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <span class="text-sm font-semibold text-[var(--ink)]">Am I a Candidate?</span>
        </a>
      </div>
    </div>
  </section>

  <!-- SEO Content -->
  <section class="py-16 bg-[var(--paper)]">
    <div class="container mx-auto px-6 max-w-4xl">
      <h2 class="text-3xl font-semibold text-[var(--ink)] mb-8">
        Finding the Right {provider.singular} in {cityName}
      </h2>
      <div class="prose prose-lg max-w-none text-[var(--muted)]">
        <p>
          When seeking a {provider.description} in {cityName}, {stateName}, consider their specific training in Transcranial Magnetic Stimulation (TMS) therapy.
          {doctors.length > 0
            ? `Our directory features ${doctors.length} verified ${provider.plural} across ${clinicCount} TMS clinics, each bringing unique expertise and treatment approaches.`
            : `TMS therapy is an FDA-cleared, non-invasive treatment for conditions like treatment-resistant depression, anxiety, OCD, and PTSD. Finding a qualified ${provider.singular} is the first step toward treatment.`}
        </p>
        <h3 class="text-xl font-semibold text-[var(--ink)] mt-8 mb-4">
          What to Look for in a TMS {provider.singular}
        </h3>
        <p>
          The ideal TMS {provider.singular} should have specific training in neuromodulation techniques, a strong background in treating your specific condition, and experience with the particular TMS device used at their clinic.
          Board certifications and ongoing education in TMS protocols are strong indicators of expertise.
        </p>
        <h3 class="text-xl font-semibold text-[var(--ink)] mt-8 mb-4">
          Treatment Approach and Protocols
        </h3>
        <p>
          Each {provider.singular} in our {cityName} directory takes a personalized approach to TMS therapy. The standard protocol involves 36 sessions over 6-9 weeks, though some clinics offer accelerated protocols.
          Your {provider.singular} will conduct a comprehensive evaluation, develop a personalized treatment plan, and monitor your progress throughout.
        </p>
        <h3 class="text-xl font-semibold text-[var(--ink)] mt-8 mb-4">
          Insurance and Cost
        </h3>
        <p>
          Most {provider.plural} in {cityName} accept major insurance plans including Medicare, BlueCross BlueShield, Aetna, and UnitedHealthcare for TMS therapy.
          Out-of-pocket costs typically range from $250-$500 per session. Many clinics offer financing options to make treatment more accessible.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Schema Section -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": seo.faqSchema.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  })} />
</div>
