---

---

<!-- Request Callback Modal -->
<div
    id="callback-modal"
    class="fixed inset-0 z-[100] hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="callback-modal-title"
>
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-gray-900/60 backdrop-blur-sm transition-opacity opacity-0" id="callback-backdrop"></div>

    <!-- Panel -->
    <div class="flex items-center justify-center min-h-screen p-4">
        <div class="relative bg-white rounded-2xl shadow-xl text-left overflow-hidden transform transition-all sm:max-w-md w-full scale-95 opacity-0" id="callback-panel">
            <!-- Header -->
            <div class="dark-section bg-violet-600 px-6 py-4 flex justify-between items-center">
                <div>
                    <h3 class="text-lg font-semibold text-white" id="callback-modal-title">Request a Callback</h3>
                    <p class="text-violet-200 text-xs mt-0.5" id="callback-clinic-name"></p>
                </div>
                <button type="button" class="text-violet-200 hover:text-white transition-colors" id="callback-close-btn">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>

            <!-- Form -->
            <div class="px-6 py-6">
                <p class="text-sm text-gray-500 mb-5">Share your details and a TMS specialist from this clinic will call you back within 24 hours.</p>

                <!-- Success state -->
                <div id="callback-success" class="hidden text-center py-6">
                    <div class="w-16 h-16 mx-auto rounded-full bg-emerald-100 flex items-center justify-center mb-4">
                        <svg class="w-8 h-8 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    </div>
                    <h4 class="font-display font-bold text-slate-900 text-lg mb-2">Callback Requested!</h4>
                    <p class="text-sm text-slate-500">A specialist will reach out to you within 24 hours. Check your phone for their call.</p>
                </div>

                <!-- Form state -->
                <form id="callback-form" class="space-y-4">
                    <input type="hidden" id="callback-clinic-id" name="clinicId" value="" />
                    <input type="hidden" id="callback-clinic-name-field" name="clinicName" value="" />

                    <div>
                        <label for="cb-name" class="block text-sm font-medium text-gray-700">Full Name <span class="text-red-400">*</span></label>
                        <input type="text" name="name" id="cb-name" required
                            class="mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-violet-500 focus:ring-violet-500 text-sm px-4 py-2.5 border"
                            placeholder="Your full name" />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="cb-phone" class="block text-sm font-medium text-gray-700">Phone <span class="text-red-400">*</span></label>
                            <input type="tel" name="phone" id="cb-phone" required
                                class="mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-violet-500 focus:ring-violet-500 text-sm px-4 py-2.5 border"
                                placeholder="(555) 123-4567" />
                        </div>
                        <div>
                            <label for="cb-email" class="block text-sm font-medium text-gray-700">Email</label>
                            <input type="email" name="email" id="cb-email"
                                class="mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-violet-500 focus:ring-violet-500 text-sm px-4 py-2.5 border"
                                placeholder="you@email.com" />
                        </div>
                    </div>

                    <div>
                        <label for="cb-time" class="block text-sm font-medium text-gray-700">Preferred Call Time</label>
                        <select id="cb-time" name="preferredTime"
                            class="mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-violet-500 focus:ring-violet-500 text-sm px-4 py-2.5 border">
                            <option value="anytime">Anytime</option>
                            <option value="morning">Morning (local time)</option>
                            <option value="afternoon">Afternoon (local time)</option>
                            <option value="evening">Evening (local time)</option>
                        </select>
                    </div>

                    <div>
                        <label for="cb-message" class="block text-sm font-medium text-gray-700">Brief note (optional)</label>
                        <textarea id="cb-message" name="message" rows="2"
                            class="mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-violet-500 focus:ring-violet-500 text-sm px-4 py-2.5 border"
                            placeholder="I'm interested in TMS for depression..."></textarea>
                    </div>

                    <div id="callback-error" class="hidden p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>

                    <button type="submit" id="callback-submit-btn"
                        class="w-full flex justify-center items-center gap-2 py-3 px-4 rounded-xl text-sm font-semibold text-white bg-violet-600 hover:bg-violet-700 transition-all disabled:opacity-50 disabled:cursor-not-allowed shadow-md">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        Request Callback
                    </button>
                    <p class="text-xs text-center text-gray-400 mt-2">Your information is secure and HIPAA compliant.</p>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- WhatsApp Gate Modal -->
<div
    id="whatsapp-modal"
    class="fixed inset-0 z-[100] hidden"
    role="dialog"
    aria-modal="true"
    aria-labelledby="whatsapp-modal-title"
>
    <div class="absolute inset-0 bg-gray-900/60 backdrop-blur-sm transition-opacity opacity-0" id="whatsapp-backdrop"></div>
    <div class="flex items-center justify-center min-h-screen p-4">
        <div class="relative bg-white rounded-2xl shadow-xl text-left overflow-hidden transform transition-all sm:max-w-md w-full scale-95 opacity-0" id="whatsapp-panel">
            <div class="dark-section bg-emerald-600 px-6 py-4 flex justify-between items-center">
                <div>
                    <h3 class="text-lg font-semibold text-white" id="whatsapp-modal-title">Message via WhatsApp</h3>
                    <p class="text-emerald-200 text-xs mt-0.5" id="whatsapp-clinic-name"></p>
                </div>
                <button type="button" class="text-emerald-200 hover:text-white transition-colors" id="whatsapp-close-btn">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <div class="px-6 py-6">
                <p class="text-sm text-gray-500 mb-5">Please share your details so the clinic knows who's reaching out. You'll be connected on WhatsApp after submitting.</p>
                <form id="whatsapp-form" class="space-y-4">
                    <input type="hidden" id="wa-clinic-id" name="clinicId" value="" />
                    <input type="hidden" id="wa-clinic-phone" name="clinicPhone" value="" />
                    <input type="hidden" id="wa-clinic-name-field" name="clinicName" value="" />
                    <div>
                        <label for="wa-name" class="block text-sm font-medium text-gray-700">Full Name <span class="text-red-400">*</span></label>
                        <input type="text" name="name" id="wa-name" required
                            class="mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm px-4 py-2.5 border"
                            placeholder="Your full name" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="wa-phone" class="block text-sm font-medium text-gray-700">Your Phone <span class="text-red-400">*</span></label>
                            <input type="tel" name="phone" id="wa-phone" required
                                class="mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm px-4 py-2.5 border"
                                placeholder="(555) 123-4567" />
                        </div>
                        <div>
                            <label for="wa-email" class="block text-sm font-medium text-gray-700">Email</label>
                            <input type="email" name="email" id="wa-email"
                                class="mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm px-4 py-2.5 border"
                                placeholder="you@email.com" />
                        </div>
                    </div>
                    <div>
                        <label for="wa-reason" class="block text-sm font-medium text-gray-700">Reason for inquiry</label>
                        <select id="wa-reason" name="reason"
                            class="mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm px-4 py-2.5 border">
                            <option value="tms-inquiry">TMS Treatment Inquiry</option>
                            <option value="insurance">Insurance Question</option>
                            <option value="appointment">Book Appointment</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div id="whatsapp-error" class="hidden p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700"></div>
                    <button type="submit" id="whatsapp-submit-btn"
                        class="w-full flex justify-center items-center gap-2 py-3 px-4 rounded-xl text-sm font-semibold text-white bg-emerald-600 hover:bg-emerald-700 transition-all disabled:opacity-50 disabled:cursor-not-allowed shadow-md">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.612.616l4.527-1.472A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.24 0-4.318-.728-6.002-1.962l-.42-.318-2.69.874.896-2.632-.348-.553A9.96 9.96 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/></svg>
                        Continue to WhatsApp
                    </button>
                    <p class="text-xs text-center text-gray-400 mt-2">Your details are saved securely before connecting.</p>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    // ===== CALLBACK MODAL =====
    const cbModal = document.getElementById('callback-modal');
    const cbBackdrop = document.getElementById('callback-backdrop');
    const cbPanel = document.getElementById('callback-panel');
    const cbCloseBtn = document.getElementById('callback-close-btn');
    const cbForm = document.getElementById('callback-form');
    const cbSuccess = document.getElementById('callback-success');
    const cbError = document.getElementById('callback-error');
    const cbSubmitBtn = document.getElementById('callback-submit-btn');

    function openCallbackModal(detail) {
        // Populate clinic info
        const clinicName = detail?.clinicName || '';
        const clinicId = detail?.clinicId || '';
        document.getElementById('callback-clinic-name').textContent = clinicName;
        document.getElementById('callback-clinic-id').value = clinicId;
        document.getElementById('callback-clinic-name-field').value = clinicName;

        // Reset form state
        cbForm?.classList.remove('hidden');
        cbSuccess?.classList.add('hidden');
        cbError?.classList.add('hidden');
        cbForm?.reset();

        // Show modal
        cbModal?.classList.remove('hidden');
        setTimeout(() => {
            cbBackdrop?.classList.remove('opacity-0');
            cbPanel?.classList.remove('opacity-0', 'scale-95');
            cbPanel?.classList.add('opacity-100', 'scale-100');
        }, 10);
        document.body.style.overflow = 'hidden';
    }

    function closeCallbackModal() {
        cbBackdrop?.classList.add('opacity-0');
        cbPanel?.classList.remove('opacity-100', 'scale-100');
        cbPanel?.classList.add('opacity-0', 'scale-95');
        setTimeout(() => {
            cbModal?.classList.add('hidden');
            document.body.style.overflow = '';
        }, 300);
    }

    cbCloseBtn?.addEventListener('click', closeCallbackModal);
    cbModal?.addEventListener('click', (e) => {
        if (e.target === cbModal || e.target === cbBackdrop) closeCallbackModal();
    });

    cbForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        cbSubmitBtn.disabled = true;
        cbSubmitBtn.textContent = 'Submitting...';
        cbError?.classList.add('hidden');

        const formData = new FormData(cbForm);
        try {
            const res = await fetch('/api/leads', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    type: 'callback_request',
                    name: formData.get('name'),
                    email: formData.get('email') || 'noemail@provided.com',
                    phone: formData.get('phone'),
                    message: `Callback requested. Preferred time: ${formData.get('preferredTime')}. ${formData.get('message') || ''}`,
                    clinicName: formData.get('clinicName'),
                    clinicId: formData.get('clinicId'),
                    sourceUrl: window.location.href,
                    metadata: {
                        preferred_time: formData.get('preferredTime'),
                    },
                }),
            });
            if (!res.ok) {
                const errData = await res.json().catch(() => ({}));
                throw new Error(errData.error || `Request failed (${res.status})`);
            }
            cbForm.classList.add('hidden');
            cbSuccess?.classList.remove('hidden');
        } catch {
            cbError.textContent = 'Something went wrong. Please try again.';
            cbError?.classList.remove('hidden');
        } finally {
            cbSubmitBtn.disabled = false;
            cbSubmitBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg> Request Callback';
        }
    });

    // Listen for custom event
    document.addEventListener('open-callback-modal', (e) => openCallbackModal(e.detail));

    // Auto-bind buttons with data-request-callback
    document.querySelectorAll('[data-request-callback]').forEach((el) => {
        el.addEventListener('click', (e) => {
            e.preventDefault();
            openCallbackModal({
                clinicName: el.dataset.clinicName || '',
                clinicId: el.dataset.clinicId || '',
            });
        });
    });

    // ===== WHATSAPP GATE MODAL =====
    const waModal = document.getElementById('whatsapp-modal');
    const waBackdrop = document.getElementById('whatsapp-backdrop');
    const waPanel = document.getElementById('whatsapp-panel');
    const waCloseBtn = document.getElementById('whatsapp-close-btn');
    const waForm = document.getElementById('whatsapp-form');
    const waError = document.getElementById('whatsapp-error');
    const waSubmitBtn = document.getElementById('whatsapp-submit-btn');

    function openWhatsAppModal(detail) {
        const clinicName = detail?.clinicName || '';
        const clinicId = detail?.clinicId || '';
        const clinicPhone = detail?.clinicPhone || '';
        document.getElementById('whatsapp-clinic-name').textContent = clinicName;
        document.getElementById('wa-clinic-id').value = clinicId;
        document.getElementById('wa-clinic-phone').value = clinicPhone;
        document.getElementById('wa-clinic-name-field').value = clinicName;

        waError?.classList.add('hidden');
        waForm?.reset();

        waModal?.classList.remove('hidden');
        setTimeout(() => {
            waBackdrop?.classList.remove('opacity-0');
            waPanel?.classList.remove('opacity-0', 'scale-95');
            waPanel?.classList.add('opacity-100', 'scale-100');
        }, 10);
        document.body.style.overflow = 'hidden';
    }

    function closeWhatsAppModal() {
        waBackdrop?.classList.add('opacity-0');
        waPanel?.classList.remove('opacity-100', 'scale-100');
        waPanel?.classList.add('opacity-0', 'scale-95');
        setTimeout(() => {
            waModal?.classList.add('hidden');
            document.body.style.overflow = '';
        }, 300);
    }

    waCloseBtn?.addEventListener('click', closeWhatsAppModal);
    waModal?.addEventListener('click', (e) => {
        if (e.target === waModal || e.target === waBackdrop) closeWhatsAppModal();
    });

    waForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        waSubmitBtn.disabled = true;
        waSubmitBtn.textContent = 'Connecting...';
        waError?.classList.add('hidden');

        const formData = new FormData(waForm);
        const clinicPhone = formData.get('clinicPhone');
        const userName = formData.get('name');
        const reason = formData.get('reason');

        try {
            // Save lead first
            const saveRes = await fetch('/api/leads', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    type: 'whatsapp_inquiry',
                    name: userName,
                    phone: formData.get('phone'),
                    email: formData.get('email') || 'noemail@provided.com',
                    message: `WhatsApp inquiry: ${reason}`,
                    clinicName: formData.get('clinicName'),
                    clinicId: formData.get('clinicId'),
                    sourceUrl: window.location.href,
                    metadata: { reason },
                }),
            });
            if (!saveRes.ok) {
                const errData = await saveRes.json().catch(() => ({}));
                throw new Error(errData.error || `Request failed (${saveRes.status})`);
            }

            // Open WhatsApp with pre-filled message
            const cleanPhone = clinicPhone.replace(/\D/g, '');
            const message = encodeURIComponent(`Hi, I'm ${userName}. I found your clinic on TMSList and I'd like to inquire about TMS therapy. (Reason: ${reason})`);
            window.open(`https://wa.me/${cleanPhone}?text=${message}`, '_blank');
            closeWhatsAppModal();
        } catch {
            waError.textContent = 'Something went wrong. Please try again.';
            waError?.classList.remove('hidden');
        } finally {
            waSubmitBtn.disabled = false;
            waSubmitBtn.innerHTML = '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg> Continue to WhatsApp';
        }
    });

    document.addEventListener('open-whatsapp-modal', (e) => openWhatsAppModal(e.detail));

    document.querySelectorAll('[data-whatsapp-gate]').forEach((el) => {
        el.addEventListener('click', (e) => {
            e.preventDefault();
            openWhatsAppModal({
                clinicName: el.dataset.clinicName || '',
                clinicId: el.dataset.clinicId || '',
                clinicPhone: el.dataset.clinicPhone || '',
            });
        });
    });

    // Escape key closes any open modal
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            if (!cbModal?.classList.contains('hidden')) closeCallbackModal();
            if (!waModal?.classList.contains('hidden')) closeWhatsAppModal();
        }
    });
})();
</script>
