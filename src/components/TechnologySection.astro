---
import { TECHNOLOGY_SLUGS } from '../utils/seo_slugs';
import BrandLogo from './BrandLogo.astro';

const featuredTech = TECHNOLOGY_SLUGS.slice(0, 4);
---

<!-- TECHNOLOGY - Compact -->
<section class="py-12 bg-[var(--paper)]">
    <div class="container mx-auto px-4">
        <div class="text-center mb-8">
            <span
                class="inline-block px-3 py-1 bg-[var(--paper2)] text-[var(--ink)] rounded-full text-xs font-semibold uppercase tracking-wider mb-2"
                >Compare Technology</span
            >
            <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-[var(--ink)]">
                Leading TMS Devices
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- BrainsWay -->
            <a
                href="/technology/brainsway-deep-tms/"
                class="group flex flex-col bg-[var(--paper)] rounded-3xl p-6 border border-[var(--line)] hover:border-[rgba(10,22,40,0.30)] hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[rgba(10,22,40,0.2)] transition-all duration-300 "
            >
                <div class="h-16 flex items-center justify-start gap-3 mb-6">
                    <BrandLogo slug="brainsway" name="BrainsWay" size={40} />
                    <span class="text-2xl font-bold text-[var(--ink)] tracking-tight">BrainsWay</span>
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[var(--accent)] uppercase tracking-wider mb-2 text-[var(--accent)]">Best For: OCD & Deep Structures</div>
                    <h3 class="text-lg font-semibold text-[var(--ink)] leading-tight mb-2">Deep TMS (H-Coil)</h3>
                    <p class="text-[var(--muted)] text-sm leading-relaxed">
                        "Reviews consistently highlight its efficacy for OCD. Patients appreciate the helmet design which ensures consistent coil positioning for deep brain penetration."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-[var(--line)] flex items-center justify-between">
                     <span class="text-[var(--muted)] text-xs font-medium">H-Coil Technology</span>
                     <span class="text-[var(--accent)] text-sm font-semibold group-hover:translate-x-1 transition-transform">View Clinics →</span>
                </div>
            </a>

            <!-- MagVenture -->
            <a
                href="/technology/magventure/"
                class="group flex flex-col bg-[var(--paper)] rounded-3xl p-6 border border-[var(--line)] hover:border-[rgba(10,22,40,0.30)] hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[rgba(10,22,40,0.2)] transition-all duration-300 "
            >
                <div class="h-16 flex items-center justify-start gap-3 mb-6">
                    <BrandLogo slug="magventure" name="MagVenture" size={40} />
                    <span class="text-2xl font-bold text-[var(--ink)] tracking-tight">MagVenture</span>
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[var(--accent)] uppercase tracking-wider mb-2 text-[var(--accent)]">Best For: Speed & Versatility</div>
                    <h3 class="text-lg font-semibold text-[var(--ink)] leading-tight mb-2">Research Favorite</h3>
                    <p class="text-[var(--muted)] text-sm leading-relaxed">
                        "Highly regarded for its Theta Burst capability, allowing for 3-minute sessions. Patients love the time efficiency without compromising clinical outcomes."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-[var(--line)] flex items-center justify-between">
                     <span class="text-[var(--muted)] text-xs font-medium">3-Min Sessions</span>
                     <span class="text-[var(--accent)] text-sm font-semibold group-hover:translate-x-1 transition-transform">View Clinics →</span>
                </div>
            </a>

            <!-- Magstim -->
            <a
                href="/technology/magstim/"
                class="group flex flex-col bg-[var(--paper)] rounded-3xl p-6 border border-[var(--line)] hover:border-[rgba(10,22,40,0.30)] hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[rgba(10,22,40,0.2)] transition-all duration-300 "
            >
                <div class="h-16 flex items-center justify-start gap-3 mb-6">
                     <BrandLogo slug="magstim" name="Magstim" size={40} />
                     <span class="text-2xl font-bold text-[var(--ink)] tracking-tight">Magstim</span>
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[var(--accent)] uppercase tracking-wider mb-2 text-[var(--accent)]">Best For: Clinical Precision</div>
                    <h3 class="text-lg font-semibold text-[var(--ink)] leading-tight mb-2">UK-Engineered Quality</h3>
                    <p class="text-[var(--muted)] text-sm leading-relaxed">
                        "Trusted by research institutions worldwide. The Magstim Horizon system offers precise pulse delivery with advanced neuronavigation for targeted treatment."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-[var(--line)] flex items-center justify-between">
                     <span class="text-[var(--muted)] text-xs font-medium">Horizon System</span>
                     <span class="text-[var(--accent)] text-sm font-semibold group-hover:translate-x-1 transition-transform">View Clinics →</span>
                </div>
            </a>

            <!-- Apollo TMS -->
            <a
                href="/technology/apollo-tms/"
                class="group flex flex-col bg-[var(--paper)] rounded-3xl p-6 border border-[var(--line)] hover:border-[rgba(10,22,40,0.30)] hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[rgba(10,22,40,0.2)] transition-all duration-300 "
            >
                <div class="h-16 flex items-center justify-start gap-3 mb-6">
                    <BrandLogo slug="apollo-tms" name="Apollo TMS" size={40} />
                    <span class="text-2xl font-bold text-[var(--ink)] tracking-tight">Apollo TMS</span>
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[var(--accent)] uppercase tracking-wider mb-2 text-[var(--accent)]">Best For: Patient Comfort</div>
                    <h3 class="text-lg font-semibold text-[var(--ink)] leading-tight mb-2">Ergonomic Design</h3>
                    <p class="text-[var(--muted)] text-sm leading-relaxed">
                        "Users often praise the Apollo system for its adjustable positioning and comfortable chair, making the 20-minute daily sessions more relaxing."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-[var(--line)] flex items-center justify-between">
                     <span class="text-[var(--muted)] text-xs font-medium">Patient Focused</span>
                     <span class="text-[var(--accent)] text-sm font-semibold group-hover:translate-x-1 transition-transform">View Clinics →</span>
                </div>
            </a>

            <!-- Nexstim -->
            <a
                href="/technology/nexstim/"
                class="group flex flex-col bg-[var(--paper)] rounded-3xl p-6 border border-[var(--line)] hover:border-[rgba(10,22,40,0.30)] hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[rgba(10,22,40,0.2)] transition-all duration-300 "
            >
                <div class="h-16 flex items-center justify-start gap-3 mb-6">
                     <BrandLogo slug="nexstim" name="Nexstim" size={40} />
                     <span class="text-2xl font-bold text-[var(--ink)] tracking-tight">Nexstim</span>
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[var(--accent)] uppercase tracking-wider mb-2 text-[var(--accent)]">Best For: Navigated Precision</div>
                    <h3 class="text-lg font-semibold text-[var(--ink)] leading-tight mb-2">MRI-Guided TMS</h3>
                    <p class="text-[var(--muted)] text-sm leading-relaxed">
                        "The NBT system uses real-time MRI-based navigation to target the exact brain region. Ideal for patients who want the most precise coil placement possible."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-[var(--line)] flex items-center justify-between">
                     <span class="text-[var(--muted)] text-xs font-medium">SmartFocus Tech</span>
                     <span class="text-[var(--accent)] text-sm font-semibold group-hover:translate-x-1 transition-transform">View Clinics →</span>
                </div>
            </a>

            <!-- CloudTMS -->
            <a
                href="/technology/cloudtms/"
                class="group flex flex-col bg-[var(--paper)] rounded-3xl p-6 border border-[var(--line)] hover:border-[rgba(10,22,40,0.30)] hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[rgba(10,22,40,0.2)] transition-all duration-300 "
            >
                <div class="h-16 flex items-center justify-start gap-3 mb-6">
                     <BrandLogo slug="cloudtms" name="CloudTMS" size={40} />
                     <span class="text-2xl font-bold text-[var(--ink)] tracking-tight">CloudTMS</span>
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[var(--accent)] uppercase tracking-wider mb-2 text-[var(--accent)]">Best For: Open Design</div>
                    <h3 class="text-lg font-semibold text-[var(--ink)] leading-tight mb-2">Modern &amp; Airy</h3>
                    <p class="text-[var(--muted)] text-sm leading-relaxed">
                        "The system's open-air coil design is a favorite among patients who might feel claustrophobic. It offers a sleek, modern treatment experience."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-[var(--line)] flex items-center justify-between">
                     <span class="text-[var(--muted)] text-xs font-medium">Scalable Tech</span>
                     <span class="text-[var(--accent)] text-sm font-semibold group-hover:translate-x-1 transition-transform">View Clinics →</span>
                </div>
            </a>

            <!-- Neurosoft -->
            <a
                href="/technology/neurosoft/"
                class="group flex flex-col bg-[var(--paper)] rounded-3xl p-6 border border-[var(--line)] hover:border-[rgba(10,22,40,0.30)] hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[rgba(10,22,40,0.2)] transition-all duration-300 "
            >
                <div class="h-16 flex items-center justify-start gap-3 mb-6">
                     <BrandLogo slug="neurosoft" name="Neurosoft" size={40} />
                     <span class="text-2xl font-bold text-[var(--ink)] tracking-tight">Neurosoft</span>
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[var(--accent)] uppercase tracking-wider mb-2 text-[var(--accent)]">Best For: Affordable Access</div>
                    <h3 class="text-lg font-semibold text-[var(--ink)] leading-tight mb-2">Cost-Effective TMS</h3>
                    <p class="text-[var(--muted)] text-sm leading-relaxed">
                        "Popular in international markets for its reliable performance at a lower price point. The NEURO-MS/D system delivers effective stimulation with proven protocols."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-[var(--line)] flex items-center justify-between">
                     <span class="text-[var(--muted)] text-xs font-medium">Global Reach</span>
                     <span class="text-[var(--accent)] text-sm font-semibold group-hover:translate-x-1 transition-transform">View Clinics →</span>
                </div>
            </a>

            <!-- NeuroStar (moved to end) -->
            <a
                href="/technology/neurostar/"
                class="group flex flex-col bg-[var(--paper)] rounded-3xl p-6 border border-[var(--line)] hover:border-[rgba(10,22,40,0.30)] hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[rgba(10,22,40,0.2)] transition-all duration-300 "
            >
                <div class="h-16 flex items-center justify-start gap-3 mb-6">
                    <BrandLogo slug="neurostar" name="NeuroStar" size={40} />
                    <span class="text-2xl font-bold text-[var(--ink)] tracking-tight">NeuroStar</span>
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[var(--accent)] uppercase tracking-wider mb-2 text-[var(--accent)]">Best For: Proven &amp; Widely Available</div>
                    <h3 class="text-lg font-semibold text-[var(--ink)] leading-tight mb-2">The Market Leader</h3>
                    <p class="text-[var(--muted)] text-sm leading-relaxed">
                        "The most widely recognized name in TMS. Patients frequently cite the confidence that comes with its long history of FDA clearance and widespread insurance coverage."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-[var(--line)] flex items-center justify-between">
                     <span class="text-[var(--muted)] text-xs font-medium">3,000+ Systems</span>
                     <span class="text-[var(--accent)] text-sm font-semibold group-hover:translate-x-1 transition-transform">View Clinics →</span>
                </div>
            </a>
        </div>

        <div class="text-center mt-6">
            <a
                href="/technology/"
                class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--ink)] font-semibold rounded-xl hover:bg-[var(--ink2)] transition-colors text-sm text-white shadow-md"
            >
                Compare All Technologies
            </a>
        </div>
    </div>
</section>