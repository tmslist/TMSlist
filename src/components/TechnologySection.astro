---
import { TECHNOLOGY_SLUGS } from '../utils/seo_slugs';

const featuredTech = TECHNOLOGY_SLUGS.slice(0, 4);
---

<!-- TECHNOLOGY - Compact -->
<section class="py-12 bg-white dark:bg-slate-950">
    <div class="container mx-auto px-4">
        <div class="text-center mb-8">
            <span
                class="inline-block px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-xs font-semibold uppercase tracking-wider mb-2 dark:bg-slate-800 dark:text-slate-300"
                >Compare Technology</span
            >
            <h2 class="text-2xl md:text-3xl font-semibold tracking-tight text-gray-900 dark:text-slate-100">
                Leading TMS Devices
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- BrainsWay -->
            <a
                href="/technology/brainsway-deep-tms/"
                class="group flex flex-col bg-white rounded-3xl p-6 border border-slate-100 hover:border-[#7C3AED]/30 hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[#7C3AED]/10 transition-all duration-300 dark:bg-slate-900 dark:border-slate-800 dark:hover:border-violet-500/30 dark:hover:shadow-violet-500/10"
            >
                <div class="h-16 flex items-center justify-start mb-6">
                    <img
                        src="https://www.brainsway.com/wp-content/uploads/2021/04/BrainsWay-2021-logo_full-color_black-name-1-e1619462194423.png"
                        alt="BrainsWay Deep TMS"
                        class="h-10 w-auto object-contain max-w-[180px] mix-blend-multiply dark:mix-blend-normal"
                    />
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[#7C3AED] uppercase tracking-wider mb-2 dark:text-violet-400">Best For: OCD & Deep Structures</div>
                    <h3 class="text-lg font-semibold text-slate-900 leading-tight mb-2 dark:text-slate-100">Deep TMS (H-Coil)</h3>
                    <p class="text-slate-500 text-sm leading-relaxed dark:text-slate-400">
                        "Reviews consistently highlight its efficacy for OCD. Patients appreciate the helmet design which ensures consistent coil positioning for deep brain penetration."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-slate-50 flex items-center justify-between dark:border-slate-800">
                     <span class="text-slate-500 text-xs font-medium dark:text-slate-400">H-Coil Technology</span>
                     <span class="text-[#7C3AED] text-sm font-semibold group-hover:translate-x-1 transition-transform dark:text-violet-400">View Clinics →</span>
                </div>
            </a>

            <!-- MagVenture -->
            <a
                href="/technology/magventure/"
                class="group flex flex-col bg-white rounded-3xl p-6 border border-slate-100 hover:border-[#7C3AED]/30 hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[#7C3AED]/10 transition-all duration-300 dark:bg-slate-900 dark:border-slate-800 dark:hover:border-violet-500/30 dark:hover:shadow-violet-500/10"
            >
                <div class="h-16 flex items-center justify-start mb-6">
                     <img
                        src="https://neuronewsinternational.com/wp-content/uploads/sites/3/2024/05/MagVenture-logo-featured.jpg"
                        alt="MagVenture TMS"
                        class="h-14 w-auto object-contain max-w-[180px] mix-blend-multiply dark:mix-blend-normal"
                    />
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[#7C3AED] uppercase tracking-wider mb-2">dark:text-violet-400">Best For: Speed & Versatility</div>
                    <h3 class="text-lg font-semibold text-slate-900 leading-tight mb-2 dark:text-slate-100">Research Favorite</h3>
                    <p class="text-slate-500 text-sm leading-relaxed dark:text-slate-400">
                        "Highly regarded for its Theta Burst capability, allowing for 3-minute sessions. Patients love the time efficiency without compromising clinical outcomes."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-slate-50 flex items-center justify-between dark:border-slate-800">
                     <span class="text-slate-500 text-xs font-medium dark:text-slate-400">3-Min Sessions</span>
                     <span class="text-[#7C3AED] text-sm font-semibold group-hover:translate-x-1 transition-transform dark:text-violet-400">View Clinics →</span>
                </div>
            </a>

            <!-- Magstim -->
            <a
                href="/technology/magstim/"
                class="group flex flex-col bg-white rounded-3xl p-6 border border-slate-100 hover:border-[#7C3AED]/30 hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[#7C3AED]/10 transition-all duration-300 dark:bg-slate-900 dark:border-slate-800 dark:hover:border-violet-500/30 dark:hover:shadow-violet-500/10"
            >
                <div class="h-16 flex items-center justify-start mb-6">
                     <span class="text-2xl font-bold text-slate-800 tracking-tight dark:text-slate-200">Magstim</span>
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[#7C3AED] uppercase tracking-wider mb-2 dark:text-violet-400">Best For: Clinical Precision</div>
                    <h3 class="text-lg font-semibold text-slate-900 leading-tight mb-2 dark:text-slate-100">UK-Engineered Quality</h3>
                    <p class="text-slate-500 text-sm leading-relaxed dark:text-slate-400">
                        "Trusted by research institutions worldwide. The Magstim Horizon system offers precise pulse delivery with advanced neuronavigation for targeted treatment."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-slate-50 flex items-center justify-between dark:border-slate-800">
                     <span class="text-slate-500 text-xs font-medium dark:text-slate-400">Horizon System</span>
                     <span class="text-[#7C3AED] text-sm font-semibold group-hover:translate-x-1 transition-transform dark:text-violet-400">View Clinics →</span>
                </div>
            </a>

            <!-- Apollo TMS -->
            <a
                href="/technology/apollo-tms/"
                class="group flex flex-col bg-white rounded-3xl p-6 border border-slate-100 hover:border-[#7C3AED]/30 hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[#7C3AED]/10 transition-all duration-300 dark:bg-slate-900 dark:border-slate-800 dark:hover:border-violet-500/30 dark:hover:shadow-violet-500/10"
            >
                <div class="h-16 flex items-center justify-start mb-6">
                     <img
                        src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcS95RvWVC2pIymNtuccsRAMKtSuZmU_pAHsfQ&s"
                        alt="Apollo TMS"
                        class="h-12 w-auto object-contain max-w-[180px] mix-blend-multiply dark:mix-blend-normal"
                    />
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[#7C3AED] uppercase tracking-wider mb-2 dark:text-violet-400">Best For: Patient Comfort</div>
                    <h3 class="text-lg font-semibold text-slate-900 leading-tight mb-2 dark:text-slate-100">Ergonomic Design</h3>
                    <p class="text-slate-500 text-sm leading-relaxed dark:text-slate-400">
                        "Users often praise the Apollo system for its adjustable positioning and comfortable chair, making the 20-minute daily sessions more relaxing."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-slate-50 flex items-center justify-between dark:border-slate-800">
                     <span class="text-slate-500 text-xs font-medium dark:text-slate-400">Patient Focused</span>
                     <span class="text-[#7C3AED] text-sm font-semibold group-hover:translate-x-1 transition-transform dark:text-violet-400">View Clinics →</span>
                </div>
            </a>

            <!-- Nexstim -->
            <a
                href="/technology/nexstim/"
                class="group flex flex-col bg-white rounded-3xl p-6 border border-slate-100 hover:border-[#7C3AED]/30 hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[#7C3AED]/10 transition-all duration-300 dark:bg-slate-900 dark:border-slate-800 dark:hover:border-violet-500/30 dark:hover:shadow-violet-500/10"
            >
                <div class="h-16 flex items-center justify-start mb-6">
                     <span class="text-2xl font-bold text-slate-800 tracking-tight dark:text-slate-200">Nexstim</span>
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[#7C3AED] uppercase tracking-wider mb-2 dark:text-violet-400">Best For: Navigated Precision</div>
                    <h3 class="text-lg font-semibold text-slate-900 leading-tight mb-2 dark:text-slate-100">MRI-Guided TMS</h3>
                    <p class="text-slate-500 text-sm leading-relaxed dark:text-slate-400">
                        "The NBT system uses real-time MRI-based navigation to target the exact brain region. Ideal for patients who want the most precise coil placement possible."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-slate-50 flex items-center justify-between dark:border-slate-800">
                     <span class="text-slate-500 text-xs font-medium dark:text-slate-400">SmartFocus Tech</span>
                     <span class="text-[#7C3AED] text-sm font-semibold group-hover:translate-x-1 transition-transform dark:text-violet-400">View Clinics →</span>
                </div>
            </a>

            <!-- CloudTMS -->
            <a
                href="/technology/cloudtms/"
                class="group flex flex-col bg-white rounded-3xl p-6 border border-slate-100 hover:border-[#7C3AED]/30 hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[#7C3AED]/10 transition-all duration-300 dark:bg-slate-900 dark:border-slate-800 dark:hover:border-violet-500/30 dark:hover:shadow-violet-500/10"
            >
                <div class="h-16 flex items-center justify-start mb-6">
                     <img
                        src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSCJmEAxcCP5r_c64O63lpys4QTJ5lm3Jvbdg&s"
                        alt="CloudTMS"
                        class="h-12 w-auto object-contain max-w-[180px] mix-blend-multiply dark:mix-blend-normal"
                    />
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[#7C3AED] uppercase tracking-wider mb-2 dark:text-violet-400">Best For: Open Design</div>
                    <h3 class="text-lg font-semibold text-slate-900 leading-tight mb-2 dark:text-slate-100">Modern &amp; Airy</h3>
                    <p class="text-slate-500 text-sm leading-relaxed dark:text-slate-400">
                        "The system's open-air coil design is a favorite among patients who might feel claustrophobic. It offers a sleek, modern treatment experience."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-slate-50 flex items-center justify-between dark:border-slate-800">
                     <span class="text-slate-500 text-xs font-medium dark:text-slate-400">Scalable Tech</span>
                     <span class="text-[#7C3AED] text-sm font-semibold group-hover:translate-x-1 transition-transform dark:text-violet-400">View Clinics →</span>
                </div>
            </a>

            <!-- Neurosoft -->
            <a
                href="/technology/neurosoft/"
                class="group flex flex-col bg-white rounded-3xl p-6 border border-slate-100 hover:border-[#7C3AED]/30 hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[#7C3AED]/10 transition-all duration-300 dark:bg-slate-900 dark:border-slate-800 dark:hover:border-violet-500/30 dark:hover:shadow-violet-500/10"
            >
                <div class="h-16 flex items-center justify-start mb-6">
                     <span class="text-2xl font-bold text-slate-800 tracking-tight dark:text-slate-200">Neurosoft</span>
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[#7C3AED] uppercase tracking-wider mb-2 dark:text-violet-400">Best For: Affordable Access</div>
                    <h3 class="text-lg font-semibold text-slate-900 leading-tight mb-2 dark:text-slate-100">Cost-Effective TMS</h3>
                    <p class="text-slate-500 text-sm leading-relaxed dark:text-slate-400">
                        "Popular in international markets for its reliable performance at a lower price point. The NEURO-MS/D system delivers effective stimulation with proven protocols."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-slate-50 flex items-center justify-between dark:border-slate-800">
                     <span class="text-slate-500 text-xs font-medium dark:text-slate-400">Global Reach</span>
                     <span class="text-[#7C3AED] text-sm font-semibold group-hover:translate-x-1 transition-transform dark:text-violet-400">View Clinics →</span>
                </div>
            </a>

            <!-- NeuroStar (moved to end) -->
            <a
                href="/technology/neurostar/"
                class="group flex flex-col bg-white rounded-3xl p-6 border border-slate-100 hover:border-[#7C3AED]/30 hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[#7C3AED]/10 transition-all duration-300 dark:bg-slate-900 dark:border-slate-800 dark:hover:border-violet-500/30 dark:hover:shadow-violet-500/10"
            >
                <div class="h-16 flex items-center justify-start mb-6">
                    <img
                        src="https://neurostar.com/wp-content/themes/neurostar/assets/images/NeuroStar_Logo.svg"
                        alt="NeuroStar Advanced Therapy"
                        class="h-full w-auto object-contain max-w-[180px] mix-blend-multiply dark:mix-blend-normal"
                    />
                </div>
                <div class="mb-4">
                    <div class="text-xs font-semibold text-[#7C3AED] uppercase tracking-wider mb-2 dark:text-violet-400">Best For: Proven &amp; Widely Available</div>
                    <h3 class="text-lg font-semibold text-slate-900 leading-tight mb-2 dark:text-slate-100">The Market Leader</h3>
                    <p class="text-slate-500 text-sm leading-relaxed dark:text-slate-400">
                        "The most widely recognized name in TMS. Patients frequently cite the confidence that comes with its long history of FDA clearance and widespread insurance coverage."
                    </p>
                </div>
                <div class="mt-auto pt-4 border-t border-slate-50 flex items-center justify-between dark:border-slate-800">
                     <span class="text-slate-500 text-xs font-medium dark:text-slate-400">3,000+ Systems</span>
                     <span class="text-[#7C3AED] text-sm font-semibold group-hover:translate-x-1 transition-transform dark:text-violet-400">View Clinics →</span>
                </div>
            </a>
        </div>

        <div class="text-center mt-6">
            <a
                href="/technology/"
                class="dark-section inline-flex items-center gap-2 px-6 py-3 bg-violet-600 font-semibold rounded-xl hover:bg-violet-800 transition-colors text-sm dark:bg-slate-800 dark:hover:bg-slate-700"
            >
                Compare All Technologies
            </a>
        </div>
    </div>
</section>