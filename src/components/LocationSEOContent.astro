---
export interface Props {
  type: 'state' | 'city' | 'country' | 'region';
  locationName: string;
  stateName?: string;
  clinicCount: number;
  topCities?: string[];
  countryCode?: string;
  faqPageSchema?: string;
}

const {
  type,
  locationName,
  stateName,
  clinicCount,
  topCities = [],
  countryCode = 'US',
  faqPageSchema,
} = Astro.props;

const isUS = countryCode === 'US';
const isUK = countryCode === 'GB';
const isCA = countryCode === 'CA';
const isAU = countryCode === 'AU';

const insurancePlans = isUS
  ? 'Medicare, BlueCross BlueShield, Aetna, Cigna, and UnitedHealthcare'
  : isUK
  ? 'BUPA, AXA PPP, Aviva, and other private health insurers'
  : isCA
  ? ' provincial health plans and extended health insurance'
  : isAU
  ? 'Medicare with Psychiatric Specialist items and private health insurance'
  : 'major insurance providers';

const treatmentMention = isUS
  ? 'FDA-cleared for major depressive disorder (MDD), obsessive-compulsive disorder (OCD), and smoking cessation, with coverage expanding for anxiety and PTSD'
  : isUK
  ? 'NICE-approved for treatment-resistant depression and OCD under NHS and private psychiatric care pathways'
  : isCA
  ? 'approved by Health Canada for major depressive disorder and increasingly covered by provincial health plans'
  : isAU
  ? 'TGA-approved for major depressive disorder, with Medicare rebates available under specific psychiatric item numbers'
  : 'clinically proven and approved by relevant regulatory bodies';

const sessionCost = isUS
  ? '$300–$500 per session without insurance; insurance-covered courses typically have a copay of $30–$75 per session'
  : isUK
  ? '£80–£250 per private session; NHS access varies by trust'
  : isCA
  ? 'CAD $150–$350 per session privately; OHIP and provincial coverage varies'
  : isAU
  ? 'AUD $150–$350 per session with Medicare rebates of approximately $120–$180 per session under MBS items'
  : 'varies by provider and region';

const faqs = [
  {
    q: `What is TMS therapy and how does it work?`,
    a: `Transcranial Magnetic Stimulation (TMS) uses focused magnetic pulses to stimulate underactive areas of the brain associated with depression and other mental health conditions. During a TMS session, a small coil is placed against your scalp — no surgery, no sedation, and no systemic side effects. Each session lasts 20–40 minutes, and most patients can drive home afterward. A full course typically involves 5 sessions per week over 6–8 weeks (20–40 sessions total).`,
  },
  {
    q: `Is TMS covered by insurance in ${locationName}?`,
    a: `${treatmentMention}. Most ${insurancePlans} cover TMS therapy when clinically appropriate, typically requiring a diagnosis of treatment-resistant depression and documented failure of at least two antidepressant medications. Pre-authorisation from your insurer is usually required before starting treatment. Many ${isUS ? 'U.S.' : isUK ? 'British' : isCA ? 'Canadian' : 'Australian'} clinics handle the prior authorisation process on your behalf.`,
  },
  {
    q: `What conditions does TMS treat?`,
    a: `TMS is primarily used to treat major depressive disorder (MDD) that has not responded adequately to medication. It is also FDA/NICE/Health Canada/TGA-cleared for OCD and smoking cessation, and clinical trials are ongoing for anxiety, PTSD, bipolar depression, and cognitive impairment. Your treating psychiatrist will determine whether TMS is appropriate for your specific diagnosis.`,
  },
  {
    q: `How much does TMS cost in ${locationName}?`,
    a: `Without insurance coverage, TMS costs approximately ${sessionCost}. With insurance or Medicare/NHS/provincial coverage, your out-of-pocket cost depends on your specific plan's copay, deductible, and coinsurance. Most patients with insurance coverage pay significantly less — often under $500 total for a full treatment course.`,
  },
  {
    q: `What TMS technologies are available?`,
    a: `The three main FDA/NICE/Health Canada/TGA-cleared TMS devices are NeuroStar (standard rTMS),BrainsWay Deep TMS (H-coil for broader brain coverage), and MagVenture (focal TMS with Theta Burst Protocol). Theta Burst Stimulation (TMS) is a newer protocol that reduces session time to 3–6 minutes per session while maintaining similar efficacy to standard protocols. Your psychiatrist will recommend the most appropriate technology based on your diagnosis and treatment history.`,
  },
  {
    q: `How do I know if I am a good candidate for TMS?`,
    a: `You may be a good candidate for TMS if you have been diagnosed with treatment-resistant depression (meaning you have tried two or more antidepressants without adequate relief), if you experience intolerable side effects from medication, or if you prefer a non-medication treatment approach. TMS is not recommended for patients with epilepsy, metal implants near the head, or active substance use disorders. Take our 2-minute eligibility quiz to see if you might qualify.`,
  },
];

const defaultFaqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq: {q: string, a: string}) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a },
  })),
});
---

<!-- SEO Content Section -->
<section class="mt-16 pt-12 border-t border-slate-100">
  <div class="max-w-4xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-violet-50 border border-violet-100 rounded-full mb-4">
        <svg class="w-3.5 h-3.5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span class="text-xs font-semibold text-violet-700 tracking-wide">Your Complete Guide</span>
      </div>
      <h2 class="text-3xl font-bold text-slate-900 mb-3">
        {type === 'city' ? 'TMS Therapy in ' : type === 'country' || type === 'region' ? 'TMS Therapy in ' : ''}{locationName}{type === 'state' ? ', United States' : ''} — Everything You Need to Know
      </h2>
      <p class="text-slate-500 max-w-2xl mx-auto">
        From how TMS works to insurance coverage, costs, and what to expect — here's a comprehensive guide to finding TMS therapy in {locationName}.
      </p>
    </div>

    <!-- What is TMS -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-8 mb-8">
      <h3 class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-violet-100 text-violet-600 flex items-center justify-center text-sm font-bold shrink-0">1</span>
        What Is TMS Therapy?
      </h3>
      <div class="text-slate-600 leading-relaxed space-y-4">
        <p>
          Transcranial Magnetic Stimulation (TMS) is a non-invasive, FDA/NICE/Health Canada/TGA-cleared treatment that uses focused magnetic pulses to stimulate underactive regions of the brain linked to depression and other mental health conditions. Unlike electroconvulsive therapy (ECT), TMS requires no anaesthesia, no surgery, and causes no memory impairment.
        </p>
        <p>
          In {locationName}{stateName ? `, ${stateName}` : ''}, there {clinicCount === 1 ? 'is' : 'are'} <strong>{clinicCount} verified TMS {clinicCount === 1 ? 'clinic' : 'clinics'}</strong> offering this treatment. A full course typically consists of 20–40 sessions, delivered 5 days a week over 6–8 weeks. Each session lasts approximately 20–40 minutes, and patients typically resume normal activities immediately afterward.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
          <div class="bg-violet-50 rounded-xl p-4 text-center">
            <div class="text-2xl font-bold text-violet-700">20–40 min</div>
            <div class="text-xs text-violet-600 mt-1 font-medium">Per Session</div>
          </div>
          <div class="bg-blue-50 rounded-xl p-4 text-center">
            <div class="text-2xl font-bold text-blue-700">50–60%</div>
            <div class="text-xs text-blue-600 mt-1 font-medium">Response Rate</div>
          </div>
          <div class="bg-emerald-50 rounded-xl p-4 text-center">
            <div class="text-2xl font-bold text-emerald-700">No Surgery</div>
            <div class="text-xs text-emerald-600 mt-1 font-medium">Non-invasive</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Conditions Treated -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-8 mb-8">
      <h3 class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-violet-100 text-violet-600 flex items-center justify-center text-sm font-bold shrink-0">2</span>
        Conditions Treated with TMS
      </h3>
      <p class="text-slate-600 mb-6">
        TMS is primarily used for treatment-resistant depression but has expanding clinical applications. In {locationName}{stateName ? `, ${stateName}` : ''}, clinics offer TMS for:
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {[
          { name: 'Major Depressive Disorder (MDD)', desc: 'Primary TMS indication; typically requires 2+ failed medication trials' },
          { name: 'Obsessive-Compulsive Disorder (OCD)', desc: 'FDA/NICE-cleared; often used when CBT alone is insufficient' },
          { name: 'Anxiety & Depression', desc: 'Increasingly prescribed off-label with strong clinical evidence' },
          { name: 'Post-Traumatic Stress Disorder (PTSD)', desc: 'Active research area; deep TMS showing promising results' },
          { name: 'Smoking Cessation', desc: 'FDA-cleared TMS target; reduces nicotine cravings' },
          { name: 'Migraines & Chronic Pain', desc: 'Emerging TMS applications with growing evidence base' },
        ].map((condition) => (
          <div class="flex items-start gap-3 p-4 bg-slate-50 rounded-xl">
            <div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <div>
              <div class="font-semibold text-slate-800 text-sm">{condition.name}</div>
              <div class="text-xs text-slate-500 mt-0.5">{condition.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Insurance & Cost -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-8 mb-8">
      <h3 class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-violet-100 text-violet-600 flex items-center justify-center text-sm font-bold shrink-0">3</span>
        Insurance Coverage & Cost in {locationName}
      </h3>
      <p class="text-slate-600 mb-6">
        {treatmentMention}. <strong>{insurancePlans}</strong> typically cover TMS when pre-authorised and when standard medication and psychotherapy have not provided adequate relief.
      </p>
      <div class="space-y-4">
        <div class="flex items-start gap-4 p-4 bg-emerald-50 rounded-xl">
          <div class="w-10 h-10 rounded-lg bg-emerald-100 text-emerald-600 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div>
            <div class="font-semibold text-slate-800">Covered by Insurance</div>
            <div class="text-sm text-slate-600 mt-1">Most {isUS ? 'U.S.' : isUK ? 'UK' : isCA ? 'Canadian' : 'Australian'} insurance plans cover TMS with prior authorisation. Most patients pay a $30–$75 copay per session.</div>
          </div>
        </div>
        <div class="flex items-start gap-4 p-4 bg-amber-50 rounded-xl">
          <div class="w-10 h-10 rounded-lg bg-amber-100 text-amber-600 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <div class="font-semibold text-slate-800">Self-Pay / No Insurance</div>
            <div class="text-sm text-slate-600 mt-1">Without insurance, TMS costs approximately {sessionCost}. Many clinics offer payment plans to make treatment more affordable.</div>
          </div>
        </div>
      </div>
      <div class="mt-6">
        <a href="/quiz/am-i-a-candidate/" class="inline-flex items-center gap-2 px-5 py-3 bg-violet-600 text-white text-sm font-semibold rounded-xl hover:bg-violet-700 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          Check Your Insurance Eligibility
        </a>
      </div>
    </div>

    <!-- TMS Technologies -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-8 mb-8">
      <h3 class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-3">
        <span class="w-8 h-8 rounded-lg bg-violet-100 text-violet-600 flex items-center justify-center text-sm font-bold shrink-0">4</span>
        TMS Technologies Available in {locationName}
      </h3>
      <p class="text-slate-600 mb-6">
        The three main TMS devices are FDA/NICE/Health Canada/TGA-cleared and available at clinics in {locationName}. Each uses a different coil design and stimulation protocol:
      </p>
      <div class="space-y-4">
        {[
          { name: 'NeuroStar', type: 'Standard rTMS (Repetitive Transcranial Magnetic Stimulation)', desc: 'The most widely used TMS system. Targets the left dorsolateral prefrontal cortex (DLPFC) for depression. Standard protocol: 37.5 min sessions, 5x/week for 6 weeks.' },
          { name: 'BrainsWay Deep TMS', type: 'H-Coil Deep TMS System', desc: 'Uses an H-shaped coil that penetrates deeper and broader brain regions. Cleared for depression and OCD. May be effective for patients who did not respond to standard rTMS.' },
          { name: 'MagVenture', type: 'Focal TMS with Theta Burst Stimulation (TBS)', desc: 'Offers both standard and accelerated Theta Burst protocols. TBS can reduce session time to 3–6 minutes with comparable efficacy to standard 37.5-minute sessions.' },
        ].map((tech) => (
          <div class="border border-slate-100 rounded-xl p-5">
            <div class="flex items-start justify-between gap-3 mb-2">
              <h4 class="font-bold text-slate-900">{tech.name}</h4>
              <span class="text-xs font-medium text-violet-600 bg-violet-50 px-2.5 py-1 rounded-lg shrink-0">{tech.type}</span>
            </div>
            <p class="text-sm text-slate-500 leading-relaxed">{tech.desc}</p>
          </div>
        ))}
      </div>
      <div class="mt-6 text-sm text-slate-500">
        <a href="/technology/" class="text-violet-600 hover:underline font-medium">Compare TMS devices in detail →</a>
      </div>
    </div>

    <!-- FAQPage JSON-LD for search engines and answer engines -->
    {faqPageSchema && <script type="application/ld+json" set:html={faqPageSchema} />}
    {!faqPageSchema && <script type="application/ld+json" set:html={defaultFaqSchema} />}

    <!-- FAQ Section -->
    <div class="bg-gradient-to-br from-slate-50 to-violet-50/30 rounded-2xl border border-slate-100 p-8 mb-8">
      <h3 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-3">
        <svg class="w-6 h-6 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Frequently Asked Questions About TMS in {locationName}
      </h3>
      <div class="space-y-4" id="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item group bg-white rounded-xl border border-slate-100 overflow-hidden" id={`faq-${i}`}>
            <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer list-none font-semibold text-slate-800 hover:text-violet-700 transition-colors">
              <span class="text-sm">{faq.q}</span>
              <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-5 pb-5 text-sm text-slate-600 leading-relaxed border-t border-slate-50 pt-4">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>

    <!-- Related Resources -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-8">
      <h3 class="text-xl font-bold text-slate-900 mb-6">Related Resources</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          { title: 'Conditions Treated with TMS', desc: 'Depression, anxiety, OCD, PTSD and more', href: '/treatments/', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
          { title: 'TMS Technology Guide', desc: 'Compare NeuroStar, BrainsWay, MagVenture, and Theta Burst', href: '/technology/', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
          { title: 'Insurance Coverage for TMS', desc: 'Medicare, BlueCross, Aetna, Cigna, and more', href: '/insurance/', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
          { title: 'Find a TMS Specialist', desc: 'Board-certified psychiatrists near you', href: '/specialists/', icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
          { title: 'TMS Cost Guide', desc: 'Session costs, insurance copays, and self-pay options', href: '/tms-cost-guide/', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
          { title: 'Am I a Candidate?', desc: 'Take our 2-minute quiz to find out', href: '/quiz/am-i-a-candidate/', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
        ].map((resource) => (
          <a href={resource.href} class="group flex items-start gap-4 p-4 rounded-xl border border-slate-100 hover:border-violet-200 hover:bg-violet-50/30 transition-all">
            <div class="w-10 h-10 rounded-lg bg-violet-50 group-hover:bg-violet-100 flex items-center justify-center shrink-0 transition-colors">
              <svg class="w-5 h-5 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={resource.icon}/></svg>
            </div>
            <div>
              <div class="font-semibold text-slate-800 text-sm group-hover:text-violet-700 transition-colors">{resource.title}</div>
              <div class="text-xs text-slate-500 mt-0.5">{resource.desc}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
