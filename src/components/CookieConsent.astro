<!-- GDPR/CCPA Cookie Consent Banner -->
<div
  id="cookie-consent-banner"
  class="fixed bottom-16 lg:bottom-0 left-0 right-0 z-[142] translate-y-full transition-transform duration-500 ease-out"
  role="dialog"
  aria-label="Cookie consent"
>
  <div class="mx-auto max-w-4xl px-4 pb-4 lg:pb-6">
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 sm:gap-4 rounded-2xl bg-[rgba(10,22,40,0.95)] backdrop-blur-lg border border-white/10 px-5 py-4 shadow-[0_-4px_30px_rgb(0,0,0,0.15)]">
      <p class="text-sm text-white/80 leading-relaxed flex-1">
        We use cookies for analytics to improve your experience. See our
        <a href="/legal/privacy-policy/" class="text-[var(--warm)] hover:text-[var(--warm)] underline underline-offset-2 transition-colors">privacy policy</a>.
      </p>
      <div class="flex gap-2 shrink-0">
        <button
          id="cookie-reject-btn"
          class="px-4 py-2 text-sm font-semibold text-white/80 hover:text-white bg-transparent border border-white/20 hover:border-white/40 rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-white/20"
        >
          Reject
        </button>
        <button
          id="cookie-accept-btn"
          class="px-5 py-2 text-sm font-semibold text-white bg-[var(--ink2)] hover:bg-[var(--ink)] rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:ring-offset-2 focus:ring-offset-[#0A1628]"
        >
          Accept
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var stored = localStorage.getItem('cookie_consent');
    if (stored === 'accepted' || stored === 'rejected') return;

    var banner = document.getElementById('cookie-consent-banner');
    if (!banner) return;

    setTimeout(function () {
      banner.style.transform = 'translateY(0)';
    }, 500);

    function dismiss(decision) {
      localStorage.setItem('cookie_consent', decision);
      window.dispatchEvent(new CustomEvent('cookie-consent', { detail: decision }));
      banner.style.transform = 'translateY(100%)';
      setTimeout(function () { banner.remove(); }, 500);
    }

    document.getElementById('cookie-accept-btn').addEventListener('click', function () {
      dismiss('accepted');
    });
    document.getElementById('cookie-reject-btn').addEventListener('click', function () {
      dismiss('rejected');
    });
  })();
</script>
