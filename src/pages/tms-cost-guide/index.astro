---
import Layout from '../../layouts/Layout.astro';

const title = "TMS Cost Guide 2026 | Pricing, Insurance & Financing | TMS List";
const description = "Comprehensive TMS therapy cost guide for 2026. National averages ($200-$400/session), insurance coverage, Medicare rates, financing options, and city-by-city price comparison.";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "TMS Cost Guide 2026",
    "description": description,
    "publisher": {
        "@type": "Organization",
        "name": "TMS List",
        "url": "https://tmslist.com"
    },
    "dateModified": "2026-04-01"
});

const cityData = [
    { city: "New York, NY", perSession: "$350-$500", fullCourse: "$10,500-$18,000", insurance: "Most plans cover" },
    { city: "Los Angeles, CA", perSession: "$300-$450", fullCourse: "$9,000-$16,200", insurance: "Most plans cover" },
    { city: "Chicago, IL", perSession: "$250-$400", fullCourse: "$7,500-$14,400", insurance: "Most plans cover" },
    { city: "Houston, TX", perSession: "$200-$350", fullCourse: "$6,000-$12,600", insurance: "Most plans cover" },
    { city: "Phoenix, AZ", perSession: "$200-$350", fullCourse: "$6,000-$12,600", insurance: "Most plans cover" },
    { city: "Philadelphia, PA", perSession: "$275-$425", fullCourse: "$8,250-$15,300", insurance: "Most plans cover" },
    { city: "San Antonio, TX", perSession: "$200-$325", fullCourse: "$6,000-$11,700", insurance: "Most plans cover" },
    { city: "San Diego, CA", perSession: "$300-$425", fullCourse: "$9,000-$15,300", insurance: "Most plans cover" },
    { city: "Dallas, TX", perSession: "$225-$375", fullCourse: "$6,750-$13,500", insurance: "Most plans cover" },
    { city: "Miami, FL", perSession: "$275-$425", fullCourse: "$8,250-$15,300", insurance: "Most plans cover" },
];
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "TMS Cost Guide", url: "/tms-cost-guide/" },
]}>
    <main>
        <!-- Hero -->
        <section class="relative bg-slate-950 overflow-hidden">
            <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
            <div class="absolute top-[-10%] right-[20%] w-[500px] h-[500px] bg-amber-600/12 rounded-full blur-[150px]"></div>
            <div class="absolute bottom-[5%] left-[10%] w-[350px] h-[350px] bg-emerald-500/8 rounded-full blur-[100px]"></div>

            <div class="container mx-auto px-4 pt-12 pb-20 lg:pt-16 lg:pb-28 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-500 mb-12" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
                    <span class="text-slate-700">/</span>
                    <span class="text-slate-300">TMS Cost Guide</span>
                </nav>

                <div class="grid lg:grid-cols-2 gap-12 items-end">
                    <div>
                        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-full mb-6">
                            <span class="flex h-2 w-2 rounded-full bg-amber-400"></span>
                            <span class="text-xs font-semibold text-slate-300 tracking-wide">Updated April 2026</span>
                        </div>
                        <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white leading-[0.95] mb-6">
                            TMS Cost<br/>
                            <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 via-orange-400 to-emerald-400">Guide 2026</span>
                        </h1>
                        <p class="text-lg text-slate-400 leading-relaxed max-w-xl">
                            Everything you need to know about TMS therapy costs: national averages, insurance coverage, financing options, and city-by-city pricing.
                        </p>
                    </div>

                    <div class="flex flex-wrap gap-4 lg:justify-end">
                        <div class="px-6 py-4 bg-white/5 backdrop-blur border border-white/10 rounded-2xl">
                            <div class="text-3xl font-bold text-white">$200-$400</div>
                            <div class="text-xs text-slate-400 font-medium mt-1">Per Session</div>
                        </div>
                        <div class="px-6 py-4 bg-white/5 backdrop-blur border border-white/10 rounded-2xl">
                            <div class="text-3xl font-bold text-emerald-400">$6K-$12K</div>
                            <div class="text-xs text-slate-400 font-medium mt-1">Full Course</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-16 bg-white" style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"></div>
        </section>

        <!-- National Averages -->
        <section class="py-16 lg:py-24 bg-white">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="text-center mb-16">
                    <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 tracking-tight mb-4">National Cost Averages</h2>
                    <p class="text-slate-500 max-w-2xl mx-auto">TMS therapy costs vary by location, insurance, and treatment protocol. Here are the 2026 national averages.</p>
                </div>

                <!-- Cost Comparison Table -->
                <div class="bg-white rounded-3xl border border-slate-100 overflow-hidden shadow-sm mb-16">
                    <div class="overflow-x-auto">
                        <table class="w-full min-w-[600px]">
                            <thead>
                                <tr class="border-b border-slate-100">
                                    <th class="text-left p-5 text-xs font-bold text-slate-400 uppercase tracking-wider">Cost Category</th>
                                    <th class="text-left p-5 text-xs font-bold text-slate-400 uppercase tracking-wider">With Insurance</th>
                                    <th class="text-left p-5 text-xs font-bold text-slate-400 uppercase tracking-wider">Without Insurance</th>
                                    <th class="text-left p-5 text-xs font-bold text-slate-400 uppercase tracking-wider">Medicare</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="border-b border-slate-50">
                                    <td class="p-5 font-semibold text-slate-900">Per Session</td>
                                    <td class="p-5 text-slate-600">$30-$75 copay</td>
                                    <td class="p-5 text-slate-600">$200-$400</td>
                                    <td class="p-5 text-slate-600">$40-$80 (20% coinsurance)</td>
                                </tr>
                                <tr class="border-b border-slate-50">
                                    <td class="p-5 font-semibold text-slate-900">Full Course (36 sessions)</td>
                                    <td class="p-5 text-slate-600">$1,080-$2,700</td>
                                    <td class="p-5 text-slate-600">$6,000-$12,000</td>
                                    <td class="p-5 text-slate-600">$1,440-$2,880</td>
                                </tr>
                                <tr class="border-b border-slate-50">
                                    <td class="p-5 font-semibold text-slate-900">Theta Burst (per session)</td>
                                    <td class="p-5 text-slate-600">$30-$75 copay</td>
                                    <td class="p-5 text-slate-600">$200-$350</td>
                                    <td class="p-5 text-slate-600">$40-$70</td>
                                </tr>
                                <tr>
                                    <td class="p-5 font-semibold text-slate-900">Initial Consultation</td>
                                    <td class="p-5 text-slate-600">$20-$50 copay</td>
                                    <td class="p-5 text-slate-600">$150-$350</td>
                                    <td class="p-5 text-slate-600">$30-$70</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Key Stats -->
                <div class="grid md:grid-cols-3 gap-6 mb-16">
                    <div class="bg-emerald-50/50 border border-emerald-100 rounded-2xl p-6 text-center">
                        <div class="text-3xl font-bold text-emerald-600 mb-2">~80%</div>
                        <p class="text-sm text-slate-600 font-medium">Medicare coverage rate for TMS therapy (patient pays 20% coinsurance)</p>
                    </div>
                    <div class="bg-blue-50/50 border border-blue-100 rounded-2xl p-6 text-center">
                        <div class="text-3xl font-bold text-blue-600 mb-2">85%+</div>
                        <p class="text-sm text-slate-600 font-medium">Commercial insurance plans now cover TMS for treatment-resistant depression</p>
                    </div>
                    <div class="bg-violet-50/50 border border-violet-100 rounded-2xl p-6 text-center">
                        <div class="text-3xl font-bold text-violet-600 mb-2">36</div>
                        <p class="text-sm text-slate-600 font-medium">Average number of sessions in a standard TMS treatment course</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Insurance Coverage -->
        <section class="py-16 lg:py-24 bg-slate-50">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="flex items-center gap-3 mb-10">
                    <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center">
                        <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    </div>
                    <h2 class="text-3xl font-bold text-slate-900 tracking-tight">Insurance Coverage</h2>
                </div>

                <div class="grid md:grid-cols-2 gap-6 mb-10">
                    <div class="bg-white rounded-2xl border border-slate-100 p-6">
                        <h3 class="font-bold text-slate-900 mb-3">What Insurance Typically Covers</h3>
                        <ul class="space-y-2 text-sm text-slate-600">
                            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Standard rTMS for treatment-resistant depression (most plans)</li>
                            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Theta burst stimulation (growing coverage)</li>
                            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Initial psychiatric evaluation</li>
                            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Motor threshold determination</li>
                        </ul>
                    </div>
                    <div class="bg-white rounded-2xl border border-slate-100 p-6">
                        <h3 class="font-bold text-slate-900 mb-3">Common Requirements for Coverage</h3>
                        <ul class="space-y-2 text-sm text-slate-600">
                            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg> Diagnosis of major depressive disorder (MDD)</li>
                            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg> Failure of 2-4 prior medication trials</li>
                            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg> Prior authorization from insurer</li>
                            <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg> Referral from treating psychiatrist</li>
                        </ul>
                    </div>
                </div>

                <div class="bg-blue-50/50 border border-blue-100 rounded-2xl p-6">
                    <div class="flex items-start gap-3">
                        <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center shrink-0">
                            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <div>
                            <h4 class="font-bold text-slate-900 mb-1">Medicare Coverage</h4>
                            <p class="text-sm text-slate-600 leading-relaxed">Medicare Part B covers TMS therapy for treatment-resistant depression under CPT codes 90867, 90868, and 90869. Patients typically pay 20% coinsurance after meeting their deductible. Medicare Advantage plans may have different requirements — check with your specific plan.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- City-by-City Comparison -->
        <section class="py-16 lg:py-24 bg-white">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-bold text-slate-900 tracking-tight mb-4">Cost by City</h2>
                    <p class="text-slate-500 max-w-2xl mx-auto">TMS pricing varies significantly by metro area. Here are self-pay rates for the top 10 US cities (2026 estimates).</p>
                </div>

                <div class="bg-white rounded-3xl border border-slate-100 overflow-hidden shadow-sm">
                    <div class="overflow-x-auto">
                        <table class="w-full min-w-[600px]">
                            <thead>
                                <tr class="border-b border-slate-100">
                                    <th class="text-left p-5 text-xs font-bold text-slate-400 uppercase tracking-wider">City</th>
                                    <th class="text-left p-5 text-xs font-bold text-slate-400 uppercase tracking-wider">Per Session (Self-Pay)</th>
                                    <th class="text-left p-5 text-xs font-bold text-slate-400 uppercase tracking-wider">Full Course (36 sessions)</th>
                                    <th class="text-left p-5 text-xs font-bold text-slate-400 uppercase tracking-wider">Insurance</th>
                                </tr>
                            </thead>
                            <tbody>
                                {cityData.map((row, i) => (
                                    <tr class={`border-b border-slate-50 ${i % 2 === 0 ? '' : 'bg-slate-50/50'}`}>
                                        <td class="p-5">
                                            <span class="font-semibold text-slate-900">{row.city}</span>
                                        </td>
                                        <td class="p-5 text-slate-600 font-medium">{row.perSession}</td>
                                        <td class="p-5 text-slate-600">{row.fullCourse}</td>
                                        <td class="p-5"><span class="px-2 py-0.5 bg-emerald-100 text-emerald-700 text-xs font-bold rounded">{row.insurance}</span></td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                </div>

                <p class="text-sm text-slate-400 mt-4 text-center">Prices are estimates based on aggregated provider data. Actual costs may vary by clinic and protocol.</p>
            </div>
        </section>

        <!-- Financing Options -->
        <section class="py-16 lg:py-24 bg-slate-50">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-bold text-slate-900 tracking-tight mb-4">Financing Options</h2>
                    <p class="text-slate-500 max-w-2xl mx-auto">If insurance does not cover your treatment or you have high out-of-pocket costs, several financing options can help.</p>
                </div>

                <div class="grid md:grid-cols-2 gap-6">
                    <div class="bg-white rounded-2xl border border-slate-100 p-8">
                        <div class="w-12 h-12 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center mb-5">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">CareCredit</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Healthcare-specific credit card offering promotional 0% interest periods (6-24 months). Widely accepted at TMS clinics. Apply online with instant approval decisions.</p>
                    </div>
                    <div class="bg-white rounded-2xl border border-slate-100 p-8">
                        <div class="w-12 h-12 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center mb-5">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">Clinic Payment Plans</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Many TMS clinics offer in-house payment plans that spread the cost over 6-12 months. Interest rates and terms vary by provider — always ask before starting treatment.</p>
                    </div>
                    <div class="bg-white rounded-2xl border border-slate-100 p-8">
                        <div class="w-12 h-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center mb-5">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">HSA / FSA Accounts</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">TMS therapy is an eligible expense for both Health Savings Accounts (HSA) and Flexible Spending Accounts (FSA). Use pre-tax dollars to reduce your effective cost by 20-35%.</p>
                    </div>
                    <div class="bg-white rounded-2xl border border-slate-100 p-8">
                        <div class="w-12 h-12 rounded-xl bg-violet-50 text-violet-600 flex items-center justify-center mb-5">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">Sliding Scale & Scholarships</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Some clinics offer reduced rates based on income or financial hardship. Device manufacturers like Neuronetics also offer patient assistance programs for qualifying individuals.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Cost-Saving Tips -->
        <section class="py-16 lg:py-24 bg-white">
            <div class="container mx-auto px-4 max-w-4xl">
                <h2 class="text-2xl font-bold text-slate-900 tracking-tight mb-8">Tips to Reduce Your TMS Costs</h2>
                <div class="space-y-4">
                    <div class="flex items-start gap-4 p-5 bg-slate-50 rounded-xl">
                        <span class="w-8 h-8 rounded-lg bg-violet-600 text-white flex items-center justify-center font-bold text-sm shrink-0">1</span>
                        <div>
                            <h4 class="font-bold text-slate-900 mb-1">Verify insurance benefits first</h4>
                            <p class="text-sm text-slate-500">Call your insurer with CPT codes 90867/90868/90869 before choosing a clinic. Ask about prior authorization requirements, covered session limits, and in-network providers.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4 p-5 bg-slate-50 rounded-xl">
                        <span class="w-8 h-8 rounded-lg bg-violet-600 text-white flex items-center justify-center font-bold text-sm shrink-0">2</span>
                        <div>
                            <h4 class="font-bold text-slate-900 mb-1">Choose an in-network provider</h4>
                            <p class="text-sm text-slate-500">In-network clinics have pre-negotiated rates with your insurer. Going out-of-network can significantly increase your out-of-pocket costs.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4 p-5 bg-slate-50 rounded-xl">
                        <span class="w-8 h-8 rounded-lg bg-violet-600 text-white flex items-center justify-center font-bold text-sm shrink-0">3</span>
                        <div>
                            <h4 class="font-bold text-slate-900 mb-1">Ask about theta burst stimulation</h4>
                            <p class="text-sm text-slate-500">TBS sessions are shorter (3 min vs 19-37 min), and some clinics charge less per session. Clinical evidence shows comparable efficacy to standard rTMS for depression.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4 p-5 bg-slate-50 rounded-xl">
                        <span class="w-8 h-8 rounded-lg bg-violet-600 text-white flex items-center justify-center font-bold text-sm shrink-0">4</span>
                        <div>
                            <h4 class="font-bold text-slate-900 mb-1">Time treatment to your deductible</h4>
                            <p class="text-sm text-slate-500">If your annual deductible has been met (or is close to being met), starting TMS later in the plan year can reduce your cost. Also consider if you are close to your out-of-pocket maximum.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4 p-5 bg-slate-50 rounded-xl">
                        <span class="w-8 h-8 rounded-lg bg-violet-600 text-white flex items-center justify-center font-bold text-sm shrink-0">5</span>
                        <div>
                            <h4 class="font-bold text-slate-900 mb-1">Negotiate self-pay rates</h4>
                            <p class="text-sm text-slate-500">If paying out of pocket, ask for a cash-pay discount or prepayment discount for the full course. Many clinics offer 10-20% off when you pay upfront.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA -->
