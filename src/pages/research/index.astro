---
import Layout from '../../layouts/Layout.astro';
import { RESEARCH_SLUGS } from '../../utils/seo_slugs';

const title = "TMS Research & Clinical Trials | Latest Scientific Data";
const description = "Explore the latest TMS therapy research, clinical trials, and FDA clearance history. Evidence-based information on transcranial magnetic stimulation.";
---

<Layout title={title} description={description}>
    <main class="bg-gray-50 min-h-screen">
        <section class="dark-section bg-gradient-to-br from-slate-900 via-indigo-900 to-blue-900 py-16 md:py-24">
            <div class="container mx-auto px-6">
                <nav class="flex text-sm text-blue-200 mb-8">
                    <a href="/" class="hover:text-white">Home</a>
                    <span class="mx-2">/</span>
                    <span>Research</span>
                </nav>
                <div class="max-w-3xl">
                    <h1 class="text-3xl md:text-5xl font-semibold tracking-tight mb-4">
                        Research and Clinical Trials
                    </h1>
                    <p class="text-lg text-blue-100 leading-relaxed">
                        TMS therapy is backed by decades of clinical research. Explore the latest studies, FDA clearance history, and ongoing clinical trials.
                    </p>
                </div>
            </div>
        </section>

        <section class="py-16">
            <div class="container mx-auto px-6 max-w-4xl">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    {RESEARCH_SLUGS.map(item => (
                        <a href={`/research/${item.slug}/`} class="group bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-lg hover:border-indigo-200 transition-all">
                            <div class="w-12 h-12 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center mb-5">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                            </div>
                            <h2 class="text-xl font-semibold text-gray-900 group-hover:text-blue-600 transition-colors mb-3">
                                {item.title}
                            </h2>
                            <p class="text-gray-500 text-sm mb-4">
                                Evidence-based information from peer-reviewed studies and FDA data.
                            </p>
                            <span class="text-blue-600 font-semibold text-sm">Read Research</span>
                        </a>
                    ))}
                </div>

                <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="bg-white rounded-xl p-6 border border-gray-100 text-center">
                        <div class="text-3xl font-semibold text-indigo-600 mb-2">2008</div>
                        <p class="text-sm text-gray-600">First FDA clearance for TMS (depression)</p>
                    </div>
                    <div class="bg-white rounded-xl p-6 border border-gray-100 text-center">
                        <div class="text-3xl font-semibold text-indigo-600 mb-2">1M+</div>
                        <p class="text-sm text-gray-600">TMS treatments performed in the US</p>
                    </div>
                    <div class="bg-white rounded-xl p-6 border border-gray-100 text-center">
                        <div class="text-3xl font-semibold text-indigo-600 mb-2">50-60%</div>
                        <p class="text-sm text-gray-600">Response rate for treatment-resistant depression</p>
                    </div>
                </div>

                <div class="mt-12 bg-blue-50 rounded-2xl p-8 border border-blue-100">
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">Medical Disclaimer</h3>
                    <p class="text-sm text-gray-600">
                        The research summaries on this page are for educational purposes only. They do not constitute medical advice. Always consult with a qualified healthcare provider before starting any treatment. For personalized guidance, find a
                        <a href="/specialists/" class="text-blue-600 hover:underline">TMS specialist near you</a>.
                    </p>
                </div>
            </div>
        </section>
    </main>
</Layout>
