---
import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import EditorialSection from '../../components/editorial/EditorialSection.astro';
import EditorialCard from '../../components/editorial/EditorialCard.astro';
import EditorialCTA from '../../components/editorial/EditorialCTA.astro';
import MedicalReviewBanner from '../../components/MedicalReviewBanner.astro';
import { RESEARCH_SLUGS } from '../../utils/seo_slugs';

const title = "TMS Research & Clinical Trials | Latest Scientific Data";
const description = "Explore peer-reviewed TMS therapy research and clinical trials. Evidence-based information on transcranial magnetic stimulation, FDA clearances, and neuromodulation science.";

const researchMeta: Record<string, { description: string; tone: 'success' | 'accent' | 'warm' | 'muted' }> = {
    'clinical-trials': { description: 'Active trials for anxiety, PTSD, autism, and more. How to find and enroll in TMS studies.', tone: 'accent' },
    'fda-clearance-history': { description: 'Complete timeline of FDA clearances from 2008 to present. Devices, indications, and trial data.', tone: 'success' },
    'tms-depression-meta-analysis': { description: 'Summary of 30+ RCTs. Response rates, remission data, and comparison to medications.', tone: 'accent' },
    'neuroplasticity-and-tms': { description: 'How TMS rewires the brain. fMRI evidence, LTP, and why effects build over sessions.', tone: 'warm' },
    'tms-vs-ect-evidence': { description: 'Head-to-head trial data. Efficacy, cognitive side effects, cost, and when each is appropriate.', tone: 'accent' },
    'accelerated-tms-protocols': { description: 'Stanford SNT, SAINT trial data, multi-session safety, and cost-effectiveness research.', tone: 'warm' },
};
const defaultMeta = { description: 'Evidence-based information from peer-reviewed studies.', tone: 'accent' as const };
---

<Layout title={title} description={description}>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow="Peer-Reviewed Evidence"
    eyebrowDot="#22c55e"
    title="The science"
    titleAccent="behind TMS."
    description="Decades of peer-reviewed evidence. Explore clinical trials, FDA milestones, and the science of transcranial magnetic stimulation."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Research" }]}
    ctas={[
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: "Find a TMS Clinic", href: "/us/", variant: "outline" },
    ]}
    stats={[
      { value: "2008", label: "First FDA Clearance", color: "ink" },
      { value: "1M+", label: "US Treatments", color: "accent" },
      { value: "58%", label: "Response Rate", color: "warm" },
    ]}
  />

  <div style="max-width:900px; margin:0 auto; padding:2rem 1.5rem 0;">
    <MedicalReviewBanner />
  </div>

  <EditorialSection
    title="Research Topics"
    intro="Curated summaries of the most important TMS evidence — written for clinicians and patients alike."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>'
    tone="accent"
    noBorder
  >
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {RESEARCH_SLUGS.map((item) => {
        const meta = researchMeta[item.slug] || defaultMeta;
        return (
          <EditorialCard
            href={`/research/${item.slug}/`}
            tag="Research"
            tagTone={meta.tone}
            title={item.title}
            description={meta.description}
            size="lg"
          />
        );
      })}
    </div>

    <div class="mt-12" style="background:var(--paper2); border:1px solid var(--line); border-radius:1.5rem; padding:1.5rem;">
      <div class="flex items-start gap-4">
        <div style="width:2.5rem; height:2.5rem; border-radius:0.75rem; background:rgba(10,22,40,0.1); color:var(--accent); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div>
          <h3 class="serif" style="font-size:1.125rem; color:var(--ink); margin:0 0 0.375rem;">Medical Disclaimer</h3>
          <p style="font-size:14px; color:var(--muted); margin:0; line-height:1.65;">Research summaries are for educational purposes only and do not constitute medical advice. Always consult a qualified healthcare provider. <a href="/specialists/" style="color:var(--accent); text-decoration:underline;">Find a TMS specialist near you</a>.</p>
        </div>
      </div>
    </div>
  </EditorialSection>

  <EditorialCTA
    title="See what the research means for you."
    description="Clinical evidence is compelling. Take the next step to see if TMS fits your situation."
    ctas={[
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: "Find a TMS Clinic", href: "/best-tms-clinics/", variant: "outline" },
      { label: "TMS for Depression", href: "/treatments/depression/", variant: "outline" },
    ]}
    stickyMobile
  />
</main>

</Layout>
