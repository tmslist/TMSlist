---
import Layout from '../../layouts/Layout.astro';
import { RESEARCH_SLUGS } from '../../utils/seo_slugs';

const title = "TMS Research & Clinical Trials | Latest Scientific Data";
const description = "Explore the latest TMS therapy research, clinical trials, and FDA clearance history. Evidence-based information on transcranial magnetic stimulation.";

const researchMeta: Record<string, { description: string; icon: string; color: string; bg: string }> = {
    'clinical-trials': { description: 'Active trials for anxiety, PTSD, autism, and more. How to find and enroll in TMS studies.', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', color: 'text-blue-600', bg: 'bg-blue-50' },
    'fda-clearance-history': { description: 'Complete timeline of FDA clearances from 2008 to present. Devices, indications, and trial data.', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', color: 'text-emerald-600', bg: 'bg-emerald-50' },
    'tms-depression-meta-analysis': { description: 'Summary of 30+ RCTs. Response rates, remission data, and comparison to medications.', icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', color: 'text-violet-600', bg: 'bg-violet-50' },
    'neuroplasticity-and-tms': { description: 'How TMS rewires the brain. fMRI evidence, LTP, and why effects build over sessions.', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', color: 'text-amber-600', bg: 'bg-amber-50' },
    'tms-vs-ect-evidence': { description: 'Head-to-head trial data. Efficacy, cognitive side effects, cost, and when each is appropriate.', icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3', color: 'text-blue-600', bg: 'bg-blue-50' },
    'accelerated-tms-protocols': { description: 'Stanford SNT, SAINT trial data, multi-session safety, and cost-effectiveness research.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', color: 'text-violet-600', bg: 'bg-violet-50' },
};
const defaultMeta = { description: 'Evidence-based information from peer-reviewed studies.', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', color: 'text-blue-600', bg: 'bg-blue-50' };
---

<Layout title={title} description={description}>
    <main class="min-h-screen">
        <!-- Hero -->
        <section class="relative bg-white border-b border-slate-100 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
            <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-slate-700 font-medium">Research</span>
                </nav>
                <div class="max-w-3xl">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-blue-50 border border-blue-100 rounded-full mb-6">
                        <span class="flex h-2 w-2 rounded-full bg-blue-500"></span>
                        <span class="text-xs font-semibold text-blue-700 tracking-wide">Peer-Reviewed Evidence</span>
                    </div>
                    <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 mb-4 leading-tight">
                        TMS <span class="text-violet-600">Research</span> & Clinical Trials
                    </h1>
                    <p class="text-lg text-slate-500 leading-relaxed">
                        Decades of peer-reviewed evidence. Explore clinical trials, FDA milestones, and the science behind transcranial magnetic stimulation.
                    </p>
                </div>
            </div>
        </section>

        <!-- Stats Bar -->
        <section class="bg-slate-50 border-b border-slate-100 py-8">
            <div class="container mx-auto px-4">
                <div class="flex flex-wrap justify-center gap-8 md:gap-16 text-center">
                    <div>
                        <div class="text-2xl font-bold text-violet-600">2008</div>
                        <div class="text-xs text-slate-500 font-medium mt-1">First FDA Clearance</div>
                    </div>
                    <div>
                        <div class="text-2xl font-bold text-blue-600">1M+</div>
                        <div class="text-xs text-slate-500 font-medium mt-1">US Treatments</div>
                    </div>
                    <div>
                        <div class="text-2xl font-bold text-emerald-600">50-60%</div>
                        <div class="text-xs text-slate-500 font-medium mt-1">Response Rate</div>
                    </div>
                    <div>
                        <div class="text-2xl font-bold text-amber-600">4</div>
                        <div class="text-xs text-slate-500 font-medium mt-1">FDA Indications</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Research Topics -->
        <section class="py-12 lg:py-16">
            <div class="container mx-auto px-4 max-w-6xl">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
                        <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    </div>
                    <h2 class="text-2xl font-bold text-slate-900">Research Topics</h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                    {RESEARCH_SLUGS.map((item) => {
                        const meta = researchMeta[item.slug] || defaultMeta;
                        return (
                            <a href={`/research/${item.slug}/`} class="group bg-white rounded-2xl border border-slate-100 shadow-sm p-6 hover:shadow-md hover:border-violet-200 hover:-translate-y-0.5 transition-all">
                                <div class={`w-12 h-12 rounded-xl ${meta.bg} ${meta.color} flex items-center justify-center mb-4`}>
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={meta.icon}/></svg>
                                </div>
                                <h3 class="text-lg font-bold text-slate-900 group-hover:text-violet-600 transition-colors mb-2">{item.title}</h3>
                                <p class="text-slate-500 text-sm leading-relaxed mb-4">{meta.description}</p>
                                <div class="flex items-center justify-between pt-3 border-t border-slate-50">
                                    <span class="text-blue-600 font-semibold text-sm">Read Research</span>
                                    <svg class="w-4 h-4 text-slate-400 group-hover:text-violet-500 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </div>
                            </a>
                        );
                    })}
                </div>

                <!-- Disclaimer -->
                <div class="mt-16 p-6 bg-blue-50/50 border border-blue-100 rounded-2xl">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center shrink-0">
                            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-slate-900 mb-1">Medical Disclaimer</h3>
                            <p class="text-sm text-slate-500">Research summaries are for educational purposes only and do not constitute medical advice. Always consult a qualified healthcare provider. <a href="/specialists/" class="text-blue-600 hover:underline">Find a TMS specialist near you</a>.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
