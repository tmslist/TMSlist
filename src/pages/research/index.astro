---
import Layout from '../../layouts/Layout.astro';
import { RESEARCH_SLUGS } from '../../utils/seo_slugs';

const title = "TMS Research & Clinical Trials | Latest Scientific Data";
const description = "Explore the latest TMS therapy research, clinical trials, and FDA clearance history. Evidence-based information on transcranial magnetic stimulation.";
---

<Layout title={title} description={description}>
    <main>
        <!-- Hero -->
        <section class="relative bg-slate-950 overflow-hidden">
            <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
            <div class="absolute top-[-10%] right-[15%] w-[500px] h-[500px] bg-blue-600/12 rounded-full blur-[150px]"></div>
            <div class="absolute bottom-[5%] left-[10%] w-[400px] h-[400px] bg-cyan-500/8 rounded-full blur-[120px]"></div>

            <div class="container mx-auto px-4 pt-12 pb-24 lg:pt-16 lg:pb-28 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-500 mb-12" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
                    <span class="text-slate-700">/</span>
                    <span class="text-slate-300">Research</span>
                </nav>
                <div class="max-w-2xl">
                    <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white leading-[0.95] mb-5">
                        TMS<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400">Research</span>
                    </h1>
                    <p class="text-lg text-slate-400 leading-relaxed">
                        Decades of peer-reviewed evidence. Explore clinical trials, FDA milestones, and the science behind transcranial magnetic stimulation.
                    </p>
                </div>

                <!-- Stats -->
                <div class="flex flex-wrap gap-4 mt-12">
                    <div class="px-6 py-4 bg-white/5 backdrop-blur border border-white/10 rounded-2xl">
                        <div class="text-3xl font-bold text-white">2008</div>
                        <div class="text-xs text-slate-400 font-medium mt-1">First FDA Clearance</div>
                    </div>
                    <div class="px-6 py-4 bg-white/5 backdrop-blur border border-white/10 rounded-2xl">
                        <div class="text-3xl font-bold text-blue-400">1M+</div>
                        <div class="text-xs text-slate-400 font-medium mt-1">US Treatments</div>
                    </div>
                    <div class="px-6 py-4 bg-white/5 backdrop-blur border border-white/10 rounded-2xl">
                        <div class="text-3xl font-bold text-emerald-400">50-60%</div>
                        <div class="text-xs text-slate-400 font-medium mt-1">Response Rate</div>
                    </div>
                    <div class="px-6 py-4 bg-white/5 backdrop-blur border border-white/10 rounded-2xl">
                        <div class="text-3xl font-bold text-violet-400">4</div>
                        <div class="text-xs text-slate-400 font-medium mt-1">FDA Indications</div>
                    </div>
                </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-16 bg-white" style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"></div>
        </section>

        <!-- Research Topics -->
        <section class="py-16 lg:py-24 bg-white">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="mb-12">
                    <h2 class="text-3xl font-bold text-slate-900 tracking-tight mb-2">Research Topics</h2>
                    <p class="text-slate-500">Evidence-based summaries from peer-reviewed clinical studies.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {RESEARCH_SLUGS.map((item, i) => {
                        const styles = [
                            { bg: 'from-blue-500/10 to-cyan-500/5', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', color: 'text-blue-600' },
                            { bg: 'from-violet-500/10 to-purple-500/5', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', color: 'text-violet-600' },
                        ];
                        const s = styles[i % 2];
                        return (
                        <a href={`/research/${item.slug}/`} class="group relative bg-gradient-to-br from-slate-50 to-white rounded-3xl border border-slate-100 p-8 lg:p-10 hover:border-blue-200 hover:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.08)] transition-all duration-300 overflow-hidden">
                            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-blue-50 to-transparent rounded-bl-[80px] opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <div class="relative z-10">
                                <div class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${s.bg} flex items-center justify-center mb-6`}>
                                    <svg class={`w-6 h-6 ${s.color}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={s.icon}/></svg>
                                </div>
                                <h2 class="text-xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors mb-3 tracking-tight">{item.title}</h2>
                                <p class="text-slate-500 text-sm leading-relaxed mb-6">Evidence-based summaries from peer-reviewed clinical studies and meta-analyses.</p>
                                <span class="text-blue-600 font-semibold text-sm inline-flex items-center gap-2 group-hover:gap-3 transition-all">
                                    Read Research <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                                </span>
                            </div>
                        </a>
                    )})}
                </div>

                <!-- Disclaimer -->
                <div class="mt-16 p-6 bg-blue-50/50 border border-blue-100 rounded-2xl">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center shrink-0">
                            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-slate-900 mb-1">Medical Disclaimer</h3>
                            <p class="text-sm text-slate-500">Research summaries are for educational purposes only and do not constitute medical advice. Always consult a qualified healthcare provider. <a href="/specialists/" class="text-blue-600 hover:underline">Find a TMS specialist near you</a>.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
