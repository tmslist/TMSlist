---
export const prerender = true;

import ContentPage from '../../layouts/ContentPage.astro';
import { getCollection, render } from 'astro:content';
import { RESEARCH_SLUGS } from '../../utils/seo_slugs';

export async function getStaticPaths() {
  let contentPaths: any[] = [];
  try {
    const entries = await getCollection('research');
    contentPaths = entries.map((entry) => ({
      params: { slug: entry.id },
      props: { title: entry.data.title, description: entry.data.description || '', hasContent: true, entry },
    }));
  } catch { /* collection may not exist yet */ }

  const contentSlugsSet = new Set(contentPaths.map(p => p.params.slug));
  const fallbackPaths = RESEARCH_SLUGS
    .filter(({ slug }) => !contentSlugsSet.has(slug))
    .map(({ slug, title }) => ({
      params: { slug },
      props: { title, description: title ? `TMS research: ${title}. Scientific evidence, clinical studies, and findings on transcranial magnetic stimulation.` : '', hasContent: false, entry: null },
    }));

  return [...contentPaths, ...fallbackPaths];
}

const { title, description, hasContent, entry } = Astro.props;
const slug = Astro.params.slug!;
let Content: any = null;
if (hasContent && entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const now = new Date().toISOString();
const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  "headline": title,
  "description": description || `TMS research: ${title}.`,
  "url": `${siteUrl}/research/${slug}/`,
  "datePublished": now,
  "dateModified": now,
  "author": { "@type": "Organization", "name": "TMS List Editorial Team", "url": siteUrl },
  "publisher": { "@type": "Organization", "name": "TMS List", "url": siteUrl, "logo": { "@type": "ImageObject", "url": `${siteUrl}/favicon.svg` } },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `${siteUrl}/research/${slug}/` },
  "reviewedBy": { "@type": "Person", "name": "Dr. Karan Narwal", "jobTitle": "Mental Health Specialist & Consultant" },
});
---

<ContentPage
  title={title}
  subtitle={description || "Latest scientific data and clinical trials on TMS therapy."}
  description={description}
  schema={articleSchema}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Research", url: "/research/" },
    { name: title, url: `/research/${slug}/` },
  ]}
>
  {Content ? <Content /> : null}
</ContentPage>
