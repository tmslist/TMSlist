---
import Layout from '../../layouts/Layout.astro';

const title = "Editorial Policy | Content Standards & Medical Review | TMS List";
const description = "Learn about TMS List's editorial standards, medical review process, fact-checking methodology, and corrections policy. All content reviewed by qualified medical professionals.";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Editorial Policy",
    "description": description,
    "publisher": {
        "@type": "Organization",
        "name": "TMS List",
        "url": "https://tmslist.com"
    }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Editorial Policy", url: "/editorial-policy/" },
]}>
    <main>
        <!-- Hero -->
        <section class="relative bg-[var(--paper)] border-b border-[var(--line)] overflow-hidden">
            <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
            <div class="absolute top-[-10%] right-[20%] w-[500px] h-[500px] bg-[var(--accent)]/12 rounded-full blur-[150px]"></div>
            <div class="absolute bottom-[5%] left-[10%] w-[350px] h-[350px] bg-[rgba(34,197,94,0.05)] rounded-full blur-[100px]"></div>

            <div class="container mx-auto px-4 pt-12 pb-20 lg:pt-16 lg:pb-28 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-[var(--muted)] mb-12" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-[var(--accent2)] transition-colors">Home</a>
                    <span class="text-[var(--ink2)]">/</span>
                    <span class="text-[var(--muted)]">Editorial Policy</span>
                </nav>

                <div class="max-w-3xl">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-[var(--paper2)] border border-[var(--line)] rounded-full mb-6">
                        <span class="flex h-2 w-2 rounded-full bg-[var(--accent2)]"></span>
                        <span class="text-xs font-semibold text-[var(--muted)] tracking-wide">Medical Standards</span>
                    </div>
                    <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-[var(--ink)] leading-[0.95] mb-6">
                        Editorial<br/>
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--accent2)] via-[var(--ink2)] to-emerald-400">Policy</span>
                    </h1>
                    <p class="text-lg text-[var(--muted)] leading-relaxed max-w-xl">
                        Accuracy matters when it comes to mental health. Every piece of content on TMS List is reviewed, fact-checked, and held to the highest editorial standards.
                    </p>
                </div>
            </div>
            
        </section>

        <!-- Medical Reviewer -->
        <section class="py-16 lg:py-24 bg-[var(--paper)]">
            <div class="container mx-auto px-4 max-w-4xl">
                <div class="bg-gradient-to-br from-[var(--paper2)] to-[rgba(10,22,40,0.30)] rounded-3xl border border-[var(--line)] p-8 lg:p-12 mb-16">
                    <div class="flex flex-col md:flex-row items-start gap-8">
                        <img src="https://img1.wsimg.com/isteam/ip/f791d9b9-2f6c-4539-b9b3-61b4c8a8a446/Screenshot%202024-11-16%20at%204.26.32%E2%80%AFPM.png/:/cr=t:0%25,l:6.95%25,w:86.1%25,h:100%25/rs=w:600,h:600,cg:true" alt="Dr. Karan Narwal" class="w-20 h-20 rounded-2xl object-cover shrink-0 border-2 border-[var(--line)]" width="80" height="80" loading="lazy" />
                        <div>
                            <div class="flex items-center gap-3 mb-2">
                                <h2 class="text-2xl font-bold text-[var(--ink)]">Dr. Karan Narwal</h2>
                                <span class="px-3 py-1 bg-[var(--accent2)] text-[var(--ink)] text-[10px] font-bold uppercase tracking-widest rounded-md">Medical Reviewer</span>
                            </div>
                            <p class="text-[var(--accent)] font-semibold text-sm mb-4">Mental Health Specialist & Consultant</p>
                            <p class="text-[var(--muted)] leading-relaxed mb-4">
                                Dr. Narwal oversees the medical accuracy of all clinical content on TMS List. With extensive experience in mental health treatment and neuromodulation therapies, he ensures that our information reflects current medical consensus, FDA guidelines, and peer-reviewed research.
                            </p>
                            <p class="text-[var(--muted)] leading-relaxed">
                                Every article, treatment guide, and clinical comparison is reviewed by Dr. Narwal before publication to verify medical accuracy, appropriate context, and balanced presentation of treatment options.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Content Review Process -->
                <div class="mb-16">
                    <div class="flex items-center gap-3 mb-8">
                        <div class="w-10 h-10 rounded-xl bg-[rgba(10,22,40,0.08)] flex items-center justify-center">
                            <svg class="w-5 h-5 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                        </div>
                        <h2 class="text-2xl font-bold text-[var(--ink)]">Content Review Process</h2>
                    </div>

                    <div class="space-y-6">
                        <div class="flex gap-6">
                            <div class="flex flex-col items-center">
                                <div class="w-10 h-10 rounded-full bg-[var(--ink)] text-white flex items-center justify-center font-bold text-sm shrink-0">1</div>
                                <div class="w-0.5 flex-1 bg-[var(--paper2)] mt-2"></div>
                            </div>
                            <div class="pb-8">
                                <h3 class="text-lg font-bold text-[var(--ink)] mb-2">Research & Drafting</h3>
                                <p class="text-[var(--muted)] leading-relaxed">Our health writers research topics using peer-reviewed journals, FDA databases, clinical trial registries (ClinicalTrials.gov), and established medical references. All claims are sourced and cited.</p>
                            </div>
                        </div>
                        <div class="flex gap-6">
                            <div class="flex flex-col items-center">
                                <div class="w-10 h-10 rounded-full bg-[var(--ink)] text-white flex items-center justify-center font-bold text-sm shrink-0">2</div>
                                <div class="w-0.5 flex-1 bg-[var(--paper2)] mt-2"></div>
                            </div>
                            <div class="pb-8">
                                <h3 class="text-lg font-bold text-[var(--ink)] mb-2">Medical Review</h3>
                                <p class="text-[var(--muted)] leading-relaxed">Dr. Karan Narwal reviews every piece of clinical content for medical accuracy, appropriate nuance, and alignment with current treatment guidelines and FDA indications.</p>
                            </div>
                        </div>
                        <div class="flex gap-6">
                            <div class="flex flex-col items-center">
                                <div class="w-10 h-10 rounded-full bg-[var(--ink)] text-white flex items-center justify-center font-bold text-sm shrink-0">3</div>
                                <div class="w-0.5 flex-1 bg-[var(--paper2)] mt-2"></div>
                            </div>
                            <div class="pb-8">
                                <h3 class="text-lg font-bold text-[var(--ink)] mb-2">Fact-Checking</h3>
                                <p class="text-[var(--muted)] leading-relaxed">Independent fact-checkers verify all statistics, study citations, FDA clearance dates, and clinical claims against primary sources. Any discrepancy triggers a revision cycle.</p>
                            </div>
                        </div>
                        <div class="flex gap-6">
                            <div class="flex flex-col items-center">
                                <div class="w-10 h-10 rounded-full bg-emerald-600 text-[var(--ink)] flex items-center justify-center font-bold text-sm shrink-0">4</div>
                            </div>
                            <div>
                                <h3 class="text-lg font-bold text-[var(--ink)] mb-2">Publication & Monitoring</h3>
                                <p class="text-[var(--muted)] leading-relaxed">Published content is monitored for new research, guideline updates, and reader feedback. Articles are updated when new evidence emerges or FDA indications change.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Source Standards -->
                <div class="mb-16">
                    <div class="flex items-center gap-3 mb-8">
                        <div class="w-10 h-10 rounded-xl bg-[var(--paper2)] flex items-center justify-center">
                            <svg class="w-5 h-5 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                        </div>
                        <h2 class="text-2xl font-bold text-[var(--ink)]">How We Source Content</h2>
                    </div>

                    <div class="grid md:grid-cols-2 gap-6">
                        <div class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] p-6">
                            <h3 class="font-bold text-[var(--ink)] mb-3">Peer-Reviewed Journals</h3>
                            <p class="text-[var(--muted)] text-sm leading-relaxed mb-3">Clinical claims are sourced from peer-reviewed publications including:</p>
                            <ul class="space-y-1.5 text-sm text-[var(--muted)]">
                                <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[var(--accent2)] shrink-0"></span> Brain Stimulation (Elsevier)</li>
                                <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[var(--accent2)] shrink-0"></span> Journal of Clinical Psychiatry</li>
                                <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[var(--accent2)] shrink-0"></span> JAMA Psychiatry</li>
                                <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[var(--accent2)] shrink-0"></span> The Lancet Psychiatry</li>
                                <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-[var(--accent2)] shrink-0"></span> Biological Psychiatry</li>
                            </ul>
                        </div>
                        <div class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] p-6">
                            <h3 class="font-bold text-[var(--ink)] mb-3">Regulatory & Government Data</h3>
                            <p class="text-[var(--muted)] text-sm leading-relaxed mb-3">Device clearances and treatment data from official sources:</p>
                            <ul class="space-y-1.5 text-sm text-[var(--muted)]">
                                <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></span> FDA 510(k) Database</li>
                                <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></span> ClinicalTrials.gov</li>
                                <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></span> NICE Guidelines (UK)</li>
                                <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></span> Medicare Coverage Database</li>
                                <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></span> APA Practice Guidelines</li>
                            </ul>
                        </div>
                        <div class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] p-6">
                            <h3 class="font-bold text-[var(--ink)] mb-3">Clinical Trials</h3>
                            <p class="text-[var(--muted)] text-sm leading-relaxed">We reference randomized controlled trials (RCTs), meta-analyses, and systematic reviews. We prioritize studies with large sample sizes, double-blind methodologies, and replication across independent research groups.</p>
                        </div>
                        <div class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] p-6">
                            <h3 class="font-bold text-[var(--ink)] mb-3">Expert Interviews</h3>
                            <p class="text-[var(--muted)] text-sm leading-relaxed">We supplement published research with insights from practicing TMS providers, psychiatrists, and neuroscientists. Expert opinions are clearly attributed and distinguished from evidence-based claims.</p>
                        </div>
                    </div>
                </div>

                <!-- Corrections Policy -->
                <div class="bg-amber-50/50 border border-amber-100 rounded-2xl p-8">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-amber-100 flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-[var(--ink)] mb-3">Corrections Policy</h3>
                            <p class="text-[var(--muted)] leading-relaxed mb-4">
                                We take errors seriously. If you identify inaccurate information on TMS List, we want to know about it. Our corrections process:
                            </p>
                            <ul class="space-y-2 text-[var(--muted)] mb-4">
                                <li class="flex items-start gap-2"><span class="font-bold text-amber-600 mt-0.5">1.</span> Submit a correction request via <a href="mailto:tmslistofficial@gmail.com?subject=Content Correction" class="inline-flex items-center gap-2 px-4 py-2 bg-[var(--ink)] hover:bg-[var(--ink2)] text-white text-sm font-semibold rounded-lg transition-colors">Email Us</a></li>
                                <li class="flex items-start gap-2"><span class="font-bold text-amber-600 mt-0.5">2.</span> Our editorial team investigates within 48 hours</li>
                                <li class="flex items-start gap-2"><span class="font-bold text-amber-600 mt-0.5">3.</span> Verified errors are corrected and the article is marked with a visible correction notice</li>
                                <li class="flex items-start gap-2"><span class="font-bold text-amber-600 mt-0.5">4.</span> Significant corrections include the date, original claim, and corrected information</li>
                            </ul>
                            <p class="text-sm text-[var(--muted)]">We maintain a public corrections log for transparency. Content with major corrections is re-reviewed by Dr. Narwal.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="relative py-20 bg-[var(--ink)] overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-[#0A1628]/10 via-transparent to-[rgba(10,22,40,0.10)]"></div>
            <div class="container mx-auto px-4 text-center relative z-10">
                <p class="text-sm font-semibold text-[var(--accent2)] tracking-wider uppercase mb-4">Evidence-Based Information</p>
                <h2 class="text-3xl lg:text-4xl font-bold text-[var(--ink)] mb-4 tracking-tight">Start your TMS research here</h2>
                <p class="text-[var(--muted)] max-w-lg mx-auto mb-10">Trusted content, verified clinics, and transparent methodology. Explore TMS therapy with confidence.</p>
                <div class="flex items-center justify-center gap-4 flex-wrap">
                    <a href="/quiz/am-i-a-candidate/" class="px-8 py-4 bg-[var(--ink)] hover:bg-[var(--ink2)] text-white font-semibold rounded-xl transition-colors shadow-lg shadow-[rgba(10,22,40,0.2)]">
                        Am I a Candidate?
                    </a>
                    <a href="/us/" class="px-8 py-4 bg-[var(--paper2)] border border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] text-[var(--ink)] font-semibold rounded-xl transition-all backdrop-blur">
                        Browse Clinics
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>
