---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found | TMS List" description="The page you're looking for doesn't exist or has been moved.">
  <main class="container mx-auto px-4 py-24 text-center min-h-[60vh] flex flex-col items-center justify-center">
    <div class="max-w-lg mx-auto">
      <p class="text-7xl font-semibold tracking-tight text-indigo-600 mb-4">404</p>
      <h1 class="text-3xl font-semibold text-gray-900 mb-4">Page not found</h1>
      <p class="text-lg text-gray-600 mb-8">
        The page you're looking for doesn't exist or has been moved.
        If you were looking for a TMS clinic, try searching below.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="px-6 py-3 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 transition-colors"
        >
          Go Home
        </a>
        <a
          href="/us/"
          class="px-6 py-3 bg-white text-gray-700 font-semibold border border-gray-300 rounded-xl hover:bg-gray-50 transition-colors"
        >
          Browse Clinics
        </a>
      </div>
    </div>
  </main>
</Layout>
