---
import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import { getClinicsByCountry, COUNTRY_NAMES } from '../../utils/dataHelpers';
import { t } from '../../utils/i18n';
import { COUNTRY_META } from '../../utils/countryData';
import LocationSEOContent from '../../components/LocationSEOContent.astro';

const meta = COUNTRY_META.CA;
const clinics = await getClinicsByCountry('CA');
const totalClinics = clinics.length;

// Group clinics by province
const provinceMap = new Map<string, number>();
clinics.forEach(c => {
    if (!c.state) return;
    provinceMap.set(c.state, (provinceMap.get(c.state) || 0) + 1);
});

const provinces = [...provinceMap.entries()]
    .map(([name, count]) => ({
        name,
        slug: name.toLowerCase().replace(/\s+/g, '-'),
        count,
    }))
    .sort((a, b) => a.name.localeCompare(b.name));

const title = `TMS Therapy Clinics in Canada | Find ${totalClinics}+ Providers | TMS List`;
const description = `Browse ${totalClinics}+ Health Canada approved TMS therapy clinics across ${provinces.length} provinces. Compare clinics by location, technology, and patient ratings.`;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "TMS Therapy Clinics in Canada",
  "description": description,
  "url": "https://tmslist.com/ca/",
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": provinces.length,
    "itemListElement": provinces.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": `TMS Clinics in ${p.name}`,
      "url": `https://tmslist.com/ca/${p.slug}/`
    }))
  }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "Canada", url: "/ca/" },
]}>
  <main>
    <EditorialHero
            eyebrow={`${totalClinics}+ Verified Clinics · ${provinces.length} Regions`}
            eyebrowDot="#22c55e"
            title="TMS therapy in"
            titleAccent="Canada."
            description={`Browse ${totalClinics}+ ${meta.tmsStatus} TMS providers across ${provinces.length} regions. Find top-rated clinics for depression, anxiety, OCD, and more.`}
            breadcrumbs={[
                { label: "Home", href: "/" },
                { label: "Canada" },
            ]}
            ctas={[
                { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
                { label: "Browse All Clinics", href: "/ca/", variant: "outline" },
            ]}
            stats={[
                { value: `${totalClinics}+`, label: "Clinics", color: "ink" },
                { value: provinces.length, label: "Regions", color: "accent" },
                { value: meta.tmsStatus.length > 12 ? "FDA-Like" : meta.tmsStatus, label: "Status", color: "warm" },
            ]}
        />
    <section class="py-12"><div class="container mx-auto px-4">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {provinces.map((province) => (
        <a href={`/ca/${province.slug}/`} class="block bg-[var(--paper)] rounded-2xl border border-[var(--line)] p-5 hover:border-[rgba(10,22,40,0.15)] hover:shadow-[0_4px_20px_rgb(0,0,0,0.04)] transition-all group">
          <span class="text-lg font-medium text-[var(--ink2)] group-hover:text-[var(--accent)]">{province.name}</span>
          <span class="block text-sm text-[var(--muted)] mt-1">{province.count} {province.count === 1 ? 'clinic' : 'clinics'}</span>
        </a>
      ))}
    </div>
    </div></section>

    <LocationSEOContent
      type="country"
      locationName="Canada"
      clinicCount={totalClinics}
      countryCode="CA"
    />
  </main>
</Layout>

<script>
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;

    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }

    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });
</script>
