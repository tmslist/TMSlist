---
import Layout from '../../../../layouts/Layout.astro';
import ClinicCard from '../../../../components/ClinicCard.astro';
import { getClinicsByCountry, COUNTRY_NAMES } from '../../../../utils/dataHelpers';
import { COUNTRY_META } from '../../../../utils/countryData';
import { calculateClinicScore } from '../../../../utils/ranking';
import LocationSEOContent from '../../../../components/LocationSEOContent.astro';

const { region, city } = Astro.params;
const regionSlug = region!;
const citySlug = city!;

const allClinics = await getClinicsByCountry('CA');

// Find province name from slug
const provinceMatch = allClinics.find(c => c.state && c.state.toLowerCase().replace(/\s+/g, '-') === regionSlug);
if (!provinceMatch) return Astro.redirect("/ca/");
const provinceName = provinceMatch.state;

// Find city name from slug
const cityMatch = allClinics.find(c => c.state === provinceName && c.city && c.city.toLowerCase().replace(/\s+/g, '-').replace(/\./g, '') === citySlug);
if (!cityMatch) return Astro.redirect(`/ca/${regionSlug}/`);
const cityName = cityMatch.city;

const cityClinics = allClinics.filter(c => c.state === provinceName && c.city === cityName);
const meta = COUNTRY_META.CA;

// Sort clinics by score
const sortedClinics = [...cityClinics].sort((a: any, b: any) => calculateClinicScore(b) - calculateClinicScore(a));

const title = `TMS Clinics in ${cityName}, ${provinceName} | Find Treatment Centres Near You`;
const description = `Compare ${cityClinics.length} TMS therapy ${cityClinics.length === 1 ? 'clinic' : 'clinics'} in ${cityName}, ${provinceName}. View ratings, technology, and treatment options for Health Canada approved providers.`;

const getRating = (clinic: any) => typeof clinic.rating === 'number' ? clinic.rating : clinic.rating?.aggregate || 4.5;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `TMS Clinics in ${cityName}, ${provinceName}`,
  "description": description,
  "url": `https://tmslist.com/ca/${regionSlug}/${citySlug}/`,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": cityClinics.length,
    "itemListElement": sortedClinics.slice(0, 10).map((c: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "MedicalClinic",
        "name": c.name,
        "url": `https://tmslist.com/clinic/${c.slug}`,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": c.address,
          "addressLocality": cityName,
          "addressRegion": provinceName,
          "addressCountry": "CA"
        },
        "telephone": c.contact?.phone || c.phone,
        ...(getRating(c) > 0 ? {
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": getRating(c),
            "reviewCount": typeof c.rating === 'object' ? c.rating?.count || 0 : 50
          }
        } : {})
      }
    }))
  }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "Canada", url: "/ca/" },
  { name: provinceName, url: `/ca/${regionSlug}/` },
  { name: cityName, url: `/ca/${regionSlug}/${citySlug}/` },
]}>
  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="relative bg-white border-b border-slate-100 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
      <div
        class="ai-hero-image absolute inset-0 opacity-20"
        data-subject={`${cityName}, ${provinceName}`}
        data-type="city"
        data-cache-key={`ai-img:city:${cityName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}-${provinceName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
        data-alt={`Watercolor illustration of ${cityName}, ${provinceName}`}
      >
        <div class="ai-img-placeholder absolute inset-0"></div>
        <img class="ai-img-result hidden w-full h-full object-cover" alt="TMS clinic illustration" />
        <div class="ai-img-fallback hidden"></div>
      </div>
      <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
        <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
          <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
          <span class="text-slate-300">/</span>
          <a href="/ca/" class="hover:text-violet-600 transition-colors">Canada</a>
          <span class="text-slate-300">/</span>
          <a href={`/ca/${regionSlug}/`} class="hover:text-violet-600 transition-colors">{provinceName}</a>
          <span class="text-slate-300">/</span>
          <span class="text-slate-700 font-medium">{cityName}</span>
        </nav>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-slate-900 mb-6">
          TMS <span class="text-violet-600">Clinics</span> in {cityName}
        </h1>
        <p class="text-xl text-slate-500 max-w-3xl mb-8">
          Compare {cityClinics.length} Health Canada approved TMS therapy {cityClinics.length === 1 ? 'clinic' : 'clinics'} in {cityName}, {provinceName}.
          View ratings, technology, and book consultations.
        </p>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="bg-white border-b border-gray-100 py-6">
      <div class="container mx-auto px-6">
        <div class="flex flex-wrap justify-center gap-8 md:gap-16">
          <div class="text-center">
            <div class="text-3xl font-semibold tracking-tight text-violet-600">{cityClinics.length}</div>
            <div class="text-sm text-gray-500 font-medium">TMS {cityClinics.length === 1 ? 'Clinic' : 'Clinics'}</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-semibold tracking-tight text-violet-600">{cityClinics.reduce((acc: number, c: any) => acc + (c.doctors_data?.length || 0), 0)}</div>
            <div class="text-sm text-gray-500 font-medium">Specialists</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-semibold tracking-tight text-violet-600">{cityClinics.filter((c: any) => c.verified).length}</div>
            <div class="text-sm text-gray-500 font-medium">Verified</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Clinics Grid -->
    <section class="py-16">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl font-semibold text-gray-900 mb-10">All TMS Clinics in {cityName}</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {sortedClinics.map((clinic: any) => <ClinicCard clinic={clinic} />)}
        </div>
      </div>
    </section>

    <LocationSEOContent
      type="city"
      locationName={cityName}
      stateName={provinceName}
      clinicCount={cityClinics.length}
      countryCode="CA"
    />
  </main>
</Layout>

<script>
  // AI city hero image with localStorage cache
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;

    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }

    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });
</script>
