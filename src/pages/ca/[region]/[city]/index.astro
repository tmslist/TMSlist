---
import Layout from '../../../../layouts/Layout.astro';
import ClinicCard from '../../../../components/ClinicCard.astro';
import { getClinicsByCountry, COUNTRY_NAMES } from '../../../../utils/dataHelpers';
import { COUNTRY_META } from '../../../../utils/countryData';
import { calculateClinicScore } from '../../../../utils/ranking';

export async function getStaticPaths() {
    const clinics = getClinicsByCountry('CA');

    // Group by province -> city
    const provinceCity = new Map<string, Map<string, typeof clinics>>();
    clinics.forEach(c => {
        if (!c.state || !c.city) return;
        if (!provinceCity.has(c.state)) provinceCity.set(c.state, new Map());
        const cityMap = provinceCity.get(c.state)!;
        if (!cityMap.has(c.city)) cityMap.set(c.city, []);
        cityMap.get(c.city)!.push(c);
    });

    const paths: any[] = [];
    provinceCity.forEach((cities, provinceName) => {
        const regionSlug = provinceName.toLowerCase().replace(/\s+/g, '-');
        cities.forEach((cityClinics, cityName) => {
            const citySlug = cityName.toLowerCase().replace(/\s+/g, '-').replace(/\./g, '');
            if (cityClinics.length > 0) {
                paths.push({
                    params: { region: regionSlug, city: citySlug },
                    props: {
                        provinceName,
                        cityName,
                        clinics: cityClinics,
                        regionSlug,
                        citySlug,
                    },
                });
            }
        });
    });

    return paths;
}

const { provinceName, cityName, clinics: cityClinics, regionSlug, citySlug } = Astro.props;
const meta = COUNTRY_META.CA;

// Sort clinics by score
const sortedClinics = [...cityClinics].sort((a: any, b: any) => calculateClinicScore(b) - calculateClinicScore(a));

const title = `TMS Clinics in ${cityName}, ${provinceName} | Find Treatment Centres Near You`;
const description = `Compare ${cityClinics.length} TMS therapy ${cityClinics.length === 1 ? 'clinic' : 'clinics'} in ${cityName}, ${provinceName}. View ratings, technology, and treatment options for Health Canada approved providers.`;

const getRating = (clinic: any) => typeof clinic.rating === 'number' ? clinic.rating : clinic.rating?.aggregate || 4.5;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `TMS Clinics in ${cityName}, ${provinceName}`,
  "description": description,
  "url": `https://tmslist.com/ca/${regionSlug}/${citySlug}/`,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": cityClinics.length,
    "itemListElement": sortedClinics.slice(0, 10).map((c: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "MedicalClinic",
        "name": c.name,
        "url": `https://tmslist.com/clinic/${c.slug}`,
        "address": {
          "@type": "PostalAddress",
          "streetAddress": c.address,
          "addressLocality": cityName,
          "addressRegion": provinceName,
          "addressCountry": "CA"
        },
        "telephone": c.contact?.phone || c.phone,
        ...(getRating(c) > 0 ? {
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": getRating(c),
            "reviewCount": typeof c.rating === 'object' ? c.rating?.count || 50 : 50
          }
        } : {})
      }
    }))
  }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "Canada", url: "/ca/" },
  { name: provinceName, url: `/ca/${regionSlug}/` },
  { name: cityName, url: `/ca/${regionSlug}/${citySlug}/` },
]}>
  <main class="bg-gray-50 min-h-screen">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-slate-900 via-indigo-900 to-blue-900 py-20">
      <div class="container mx-auto px-6">
        <nav class="flex text-sm text-blue-200 mb-8" aria-label="Breadcrumb">
          <ol class="inline-flex items-center space-x-2">
            <li><a href="/" class="hover:text-white">Home</a></li>
            <li><span class="mx-2">/</span></li>
            <li><a href="/ca/" class="hover:text-white">Canada</a></li>
            <li><span class="mx-2">/</span></li>
            <li><a href={`/ca/${regionSlug}/`} class="hover:text-white">{provinceName}</a></li>
            <li><span class="mx-2">/</span></li>
            <li class="text-white font-medium">{cityName}</li>
          </ol>
        </nav>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-white mb-6">
          TMS <span class="text-cyan-400">Clinics</span> in {cityName}
        </h1>
        <p class="text-xl text-blue-100 max-w-3xl mb-8">
          Compare {cityClinics.length} Health Canada approved TMS therapy {cityClinics.length === 1 ? 'clinic' : 'clinics'} in {cityName}, {provinceName}.
          View ratings, technology, and book consultations.
        </p>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="bg-white border-b border-gray-100 py-6">
      <div class="container mx-auto px-6">
        <div class="flex flex-wrap justify-center gap-8 md:gap-16">
          <div class="text-center">
            <div class="text-3xl font-semibold tracking-tight text-indigo-600">{cityClinics.length}</div>
            <div class="text-sm text-gray-500 font-medium">TMS {cityClinics.length === 1 ? 'Clinic' : 'Clinics'}</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-semibold tracking-tight text-indigo-600">{cityClinics.reduce((acc: number, c: any) => acc + (c.doctors_data?.length || 0), 0)}</div>
            <div class="text-sm text-gray-500 font-medium">Specialists</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-semibold tracking-tight text-indigo-600">{cityClinics.filter((c: any) => c.verified).length}</div>
            <div class="text-sm text-gray-500 font-medium">Verified</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Clinics Grid -->
    <section class="py-16">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl font-semibold text-gray-900 mb-10">All TMS Clinics in {cityName}</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {sortedClinics.map((clinic: any) => <ClinicCard clinic={clinic} />)}
        </div>
      </div>
    </section>

    <!-- SEO Content Section -->
    <section class="py-16 bg-white">
      <div class="container mx-auto px-6 max-w-4xl">
        <h2 class="text-3xl font-semibold text-gray-900 mb-8">TMS Therapy in {cityName}, {provinceName}</h2>

        <div class="prose prose-lg max-w-none text-gray-600">
          <p>
            {cityName}, {provinceName} is home to {cityClinics.length} Health Canada approved TMS (Transcranial Magnetic Stimulation) therapy {cityClinics.length === 1 ? 'clinic' : 'clinics'}, offering advanced treatment options for depression, anxiety, OCD, and other mental health conditions.
            Our comprehensive directory helps you compare facilities, read verified reviews, and find the right clinic for your needs.
          </p>

          <h3 class="text-xl font-semibold text-gray-900 mt-8 mb-4">Why Choose TMS Therapy?</h3>
          <p>
            TMS therapy offers a non-invasive, Health Canada approved treatment option for those who haven't found relief from medication alone.
            Unlike ECT (electroconvulsive therapy), TMS requires no anaesthesia, has minimal side effects, and allows patients to drive themselves to and from treatment.
            Clinical studies show remission rates of 50-60% for treatment-resistant depression.
          </p>

          <h3 class="text-xl font-semibold text-gray-900 mt-8 mb-4">Cost and Coverage in {provinceName}</h3>
          <p>
            TMS therapy sessions in Canada typically cost {meta.sessionCostRange} per session. {meta.insuranceNote}
          </p>

          <h3 class="text-xl font-semibold text-gray-900 mt-8 mb-4">What to Expect at a {cityName} TMS Clinic</h3>
          <p>
            Your TMS journey typically begins with a consultation where a psychiatrist evaluates your medical history and treatment goals.
            If you're a candidate, you'll undergo a brain mapping session to identify the optimal treatment location.
            Treatment involves 30-36 sessions over 6-9 weeks, with each session lasting 19-37 minutes depending on the protocol.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 bg-gradient-to-r from-indigo-600 to-blue-600">
      <div class="container mx-auto px-6 text-center">
        <h2 class="text-3xl font-semibold text-white mb-6">Find Your TMS Clinic in {cityName}</h2>
        <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
          Compare {cityClinics.length} verified {cityClinics.length === 1 ? 'clinic' : 'clinics'} and start your journey to mental wellness today.
        </p>
        <a href="/quiz/am-i-a-candidate/" class="inline-block px-8 py-4 bg-white text-indigo-600 font-semibold rounded-xl hover:bg-gray-100 transition-colors shadow-[0_4px_20px_rgb(0,0,0,0.03)]">
          Am I a Candidate?
        </a>
      </div>
    </section>
  </main>
</Layout>
