---
import Layout from '../../layouts/Layout.astro';
import { getClinicsByCountry, COUNTRY_NAMES } from '../../utils/dataHelpers';
import { COUNTRY_META } from '../../utils/countryData';
import { t } from '../../utils/i18n';
const locale = 'it' as const;

const countryCode = 'IT';
const meta = COUNTRY_META[countryCode];
const clinics = await getClinicsByCountry(countryCode);
const totalClinics = clinics.length;

const regionMap = new Map<string, number>();
clinics.forEach(c => {
    if (!c.state) return;
    regionMap.set(c.state, (regionMap.get(c.state) || 0) + 1);
});

const regions = [...regionMap.entries()]
    .map(([name, count]) => ({
        name,
        slug: name.toLowerCase().replace(/\s+/g, '-'),
        count,
    }))
    .sort((a, b) => a.name.localeCompare(b.name));

const title = `TMS Therapy Clinics in Italy | ${totalClinics} Verified Providers`;
const description = `Browse ${totalClinics} TMS therapy clinics across ${regions.length} regions in Italy. ${meta.seoDescription}`;

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "TMS Therapy Clinics in Italy",
    "description": description,
    "url": "https://tmslist.com/it/",
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": regions.length,
        "itemListElement": regions.map((r, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "name": `TMS Clinics in ${r.name}, Italy`,
            "url": `https://tmslist.com/it/${r.slug}/`
        }))
    }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Italy", url: "/it/" },
]}>
    <main>
        <!-- Hero Section -->
        <section class="relative bg-white border-b border-slate-100 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
            <div
                class="ai-hero-image absolute inset-0 opacity-20"
                data-subject="Italy"
                data-type="city"
                data-cache-key="ai-img:city:it"
                data-alt={`Illustration of Italy`}
            >
                <div class="ai-img-placeholder absolute inset-0"></div>
                <img class="ai-img-result hidden w-full h-full object-cover" alt="TMS clinic illustration" />
                <div class="ai-img-fallback hidden"></div>
            </div>
            <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8" aria-label="Breadcrumb">
            <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
            <span class="text-slate-300">/</span>
            <span class="text-slate-700 font-medium">Italy</span>
        </nav>
                <div class="max-w-3xl">
                    <h1 class="text-3xl font-semibold mb-2">TMS Therapy in <span class="text-violet-600">Italy</span></h1>
                    <p class="text-gray-600 mb-8 max-w-3xl">Browse {totalClinics} verified TMS providers across {regions.length} regions in Italy. TMS is {meta.tmsStatus}, with sessions costing {meta.sessionCostRange} per session.</p>
                </div>
            </div>
        </section>

        <!-- Content -->
        <div class="container mx-auto px-4 py-8">

        <!-- Key Facts -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-violet-600">{totalClinics}</div>
                <div class="text-sm text-gray-500 font-medium">Clinics</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-violet-600">{regions.length}</div>
                <div class="text-sm text-gray-500 font-medium">Regions</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-violet-600">{meta.publicHealthSystem}</div>
                <div class="text-sm text-gray-500 font-medium">Public Health</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-violet-600">{meta.sessionCostRange}</div>
                <div class="text-sm text-gray-500 font-medium">Per Session</div>
            </div>
        </div>

        <div class="flex items-center mb-8">
            <h2 class="text-2xl font-semibold text-gray-900">Sfoglia per regione</h2>
            <div class="ml-4 h-px flex-1 bg-gray-200"></div>
            <span class="ml-4 text-sm font-medium text-gray-400">{regions.length} regions</span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {regions.map((region) => (
                <a href={`/it/${region.slug}/`} class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-violet-500 hover:shadow-md transition-all group">
                    <span class="text-lg font-medium text-gray-800 group-hover:text-violet-600">{region.name}</span>
                    <span class="block text-sm text-gray-500 mt-1">{region.count} {region.count === 1 ? 'clinic' : 'clinics'}</span>
                </a>
            ))}
        </div>

        <!-- SEO Content -->
        <section class="mt-16 pt-12 border-t border-gray-100 prose prose-lg max-w-none text-gray-600">
            <h2>La terapia TMS in Italia</h2>
            <p>L'Italia ha una forte tradizione nella ricerca sulla TMS, con contributi di istituzioni come l'Università Vita-Salute San Raffaele di Milano e la Fondazione Santa Lucia di Roma. I neuroscienziati italiani sono stati all'avanguardia nella metodologia di ricerca sulla TMS. La TMS clinica è disponibile negli ospedali universitari nella maggior parte delle grandi città, con un numero crescente di cliniche private.</p>
            <p>La terapia TMS è offerta presso i principali ospedali universitari e cliniche private italiane. Milano, Roma, Bologna e Padova sono centri chiave per il trattamento rTMS della depressione e delle condizioni neurologiche.</p>
            <h3>Assicurazione e costi</h3>
            <p>Il SSN (Servizio Sanitario Nazionale) può coprire la TMS presso gli ospedali universitari attraverso percorsi clinici specifici. Il trattamento privato costa {meta.sessionCostRange} per sessione. Alcune assicurazioni private coprono parzialmente i costi con la prescrizione di uno psichiatra.</p>
            <p>Il costo tipico di una sessione TMS in Italia varia da {meta.sessionCostRange}. I cicli di trattamento comprendono generalmente 20-30 sessioni nell'arco di 4-6 settimane.</p>
            <h3>Come scegliere una clinica TMS in Italia</h3>
            <p>Nella scelta di un fornitore TMS in Italia, considerate l'accreditamento della clinica, l'esperienza dello psichiatra curante, la tecnologia TMS utilizzata e se la vostra assicurazione copre il trattamento. Il nostro elenco vi aiuta a confrontare le cliniche per regione e a trovare il fornitore giusto.</p>
            <h3>Risorse correlate</h3>
            <ul>
                <li><a href="/treatments/">Condizioni trattate con TMS</a> — depressione, ansia, DOC, PTSD e altro</li>
                <li><a href="/technology/">Guida tecnologica TMS</a> — confrontare NeuroStar, BrainsWay, MagVenture</li>
                <li><a href="/research/">Ricerca TMS</a> — ultimi studi clinici e risultati</li>
            </ul>
        </section>
        </div>
    </main>
</Layout>

<script>
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;
    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }
    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });
</script>
