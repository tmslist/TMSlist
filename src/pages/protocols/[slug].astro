---
export const prerender = true;

import ContentPage from '../../layouts/ContentPage.astro';
import { getCollection, render } from 'astro:content';
import { PROTOCOL_SLUGS } from '../../utils/seo_slugs';

export async function getStaticPaths() {
  let entries: any[] = [];
  try {
    entries = await getCollection('protocols');
  } catch { /* collection may not exist yet */ }

  const contentPaths = entries.map((entry) => ({
    params: { slug: entry.id },
    props: { title: entry.data.title, description: entry.data.description, hasContent: true, entry },
  }));

  const contentSlugsSet = new Set(contentPaths.map(p => p.params.slug));
  const fallbackPaths = PROTOCOL_SLUGS
    .filter(({ slug }) => !contentSlugsSet.has(slug))
    .map(({ slug, title }) => ({
      params: { slug },
      props: { title, description: title ? `TMS ${title} protocol guide. Learn about stimulation parameters, session structure, and clinical outcomes.` : '', hasContent: false, entry: null },
    }));

  return [...contentPaths, ...fallbackPaths];
}

const slug = Astro.params.slug!;
const props = Astro.props || {};
const title = props.title || PROTOCOL_SLUGS.find(p => p.slug === slug)?.title || slug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
const description = props.description || '';
const hasContent = props.hasContent || false;
const entry = props.entry || null;
let Content: any = null;
if (hasContent && entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const medicalSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": title,
  "description": description || `TMS protocol guide: ${title}.`,
  "url": `${siteUrl}/protocols/${slug}/`,
  "about": { "@type": "MedicalTherapy", "name": "Transcranial Magnetic Stimulation (TMS)", "medicalSpecialty": "Psychiatry" },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `${siteUrl}/protocols/${slug}/` },
  "reviewedBy": { "@type": "Person", "name": "Dr. Karan Narwal", "jobTitle": "Mental Health Specialist & Consultant" },
  "publisher": { "@type": "Organization", "name": "TMS List", "url": siteUrl },
});
---

<ContentPage
  title={title}
  subtitle={description || "Deep dive into specific TMS treatment protocols and methodologies."}
  description={description}
  schema={medicalSchema}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Protocols", url: "/protocols/" },
    { name: title, url: `/protocols/${slug}/` },
  ]}
>
  {Content ? <Content /> : null}
</ContentPage>
