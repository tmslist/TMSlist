---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import EditorialSection from '../../components/editorial/EditorialSection.astro';
import EditorialCard from '../../components/editorial/EditorialCard.astro';
import EditorialCTA from '../../components/editorial/EditorialCTA.astro';
import { PROTOCOL_SLUGS } from '../../utils/seo_slugs';

const title = "TMS Protocols & Techniques | SAINT, Theta Burst, Deep TMS & More";
const description = "Compare TMS therapy protocols — standard rTMS, theta burst stimulation, SAINT protocol, deep TMS, and more. Learn which approach fits your treatment needs.";

const PROTOCOL_META: Record<string, { description: string; duration: string; sessions: string; highlight?: string }> = {
  'saint-protocol': { description: 'Stanford Accelerated Intelligent Neuromodulation Therapy. Full treatment course in just 5 days using imaging-guided theta burst.', duration: '5 days', sessions: '50 (10/day)', highlight: '79% remission' },
  'theta-burst-stimulation': { description: 'Condensed stimulation pattern mimicking natural brain rhythms. Same efficacy as standard TMS in 3-9 minutes per session.', duration: '6-9 weeks', sessions: '30-36', highlight: '3-min sessions' },
  'deep-tms': { description: 'BrainsWay H-coil technology reaching deeper brain structures. Only device FDA-cleared for OCD and smoking cessation.', duration: '6 weeks', sessions: '29-36', highlight: 'Deep targets' },
  'accelerated-tms': { description: 'Multiple sessions per day to compress treatment timeline. Promising for patients who need rapid improvement.', duration: '1-2 weeks', sessions: '20-50', highlight: 'Faster results' },
  'neuronavigation': { description: 'MRI-guided precision targeting for optimal coil placement. May improve outcomes by ensuring accurate stimulation sites.', duration: '6-9 weeks', sessions: '30-36', highlight: 'Precision targeting' },
  'maintenance-tms': { description: 'Periodic sessions after initial treatment to sustain benefits. Prevents relapse in responders.', duration: 'Ongoing', sessions: '1-4/month', highlight: 'Sustain gains' },
  'fmri-guided-tms': { description: 'Functional MRI mapping identifies personalized brain targets based on individual connectivity patterns.', duration: '6-9 weeks', sessions: '30-36', highlight: 'Personalized targets' },
  'eeg-synchronized-tms': { description: 'Stimulation timed to individual brain wave patterns for enhanced neural engagement and plasticity.', duration: '4-6 weeks', sessions: '20-30', highlight: 'Brain-wave synced' },
  'off-label-tms': { description: 'TMS applications beyond FDA-cleared indications — anxiety, PTSD, chronic pain, addiction, and more.', duration: 'Varies', sessions: 'Varies', highlight: 'Expanding uses' },
};

const enrichedProtocols = PROTOCOL_SLUGS.map(item => ({
  ...item,
  ...(PROTOCOL_META[item.slug] || { description: 'Learn about this TMS protocol.', duration: 'Varies', sessions: 'Varies' }),
}));

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "TMS Treatment Protocols",
  "description": description,
  "url": "https://tmslist.com/protocols/",
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": PROTOCOL_SLUGS.length,
    "itemListElement": PROTOCOL_SLUGS.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": item.title,
      "url": `https://tmslist.com/protocols/${item.slug}/`
    }))
  }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "Protocols", url: "/protocols/" },
]}>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow={`${enrichedProtocols.length} Treatment Protocols`}
    eyebrowDot="#22c55e"
    title="Every way to"
    titleAccent="deliver TMS."
    description="From standard 37-minute sessions to 3-minute theta burst and 5-day accelerated courses. Compare protocols to find the right approach."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Protocols" }]}
    ctas={[
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: "Find a TMS Clinic", href: "/us/", variant: "outline" },
    ]}
    stats={[
      { value: enrichedProtocols.length, label: "Protocols", color: "ink" },
      { value: "3", label: "FDA-Cleared", color: "accent" },
      { value: "79%", label: "SAINT Remission", color: "warm" },
    ]}
  />

  <EditorialSection
    title="Treatment Protocols"
    intro="Compare every major TMS protocol used today — duration, session count, and what makes each distinctive."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>'
    tone="accent"
  >
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {enrichedProtocols.map((p) => (
        <EditorialCard
          href={`/protocols/${p.slug}/`}
          tag={p.highlight}
          tagTone="accent"
          title={p.title}
          description={p.description}
          size="lg"
          stats={[
            { label: "Duration", value: p.duration, color: "ink" },
            { label: "Sessions", value: p.sessions, color: "accent" },
          ]}
        />
      ))}
    </div>
  </EditorialSection>

  <EditorialCTA
    title="Which protocol is right for you?"
    description="Talk to a verified TMS clinic about which protocol fits your condition, timeline, and insurance."
    ctas={[
      { label: "Take the Assessment", href: "/quiz/am-i-a-candidate/" },
      { label: "Find a Clinic Near You", href: "/us/", variant: "outline" },
    ]}
    stickyMobile
  />
</main>

</Layout>
