              <div class="p-4 text-center border-l border-[var(--line)] text-sm text-[var(--muted)]">None</div>
              <div class="p-4 text-center border-l border-[var(--ink)] bg-[var(--ink)] text-sm font-bold text-emerald-400">None</div>
