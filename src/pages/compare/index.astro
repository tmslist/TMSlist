---
import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import { COMPARE_SLUGS } from '../../utils/seo_slugs';

const title = "Compare TMS Treatments & Devices | Side-by-Side Guides | TMS List";
const description = "Compare TMS therapy vs medications, ECT, ketamine and other treatments. Side-by-side analysis of NeuroStar, BrainsWay, MagVenture, Magstim, and other TMS devices.";

const siteUrl = import.meta.env.SITE_URL || 'https://tmslist.com';

const treatmentComparisons = COMPARE_SLUGS.filter(
  s => s.slug.includes('tms-vs-') && !s.slug.includes('neurostar') && !s.slug.includes('magventure') && !s.slug.includes('magstim') && !s.slug.includes('brainsway') && !s.slug.includes('cloudtms') && !s.slug.includes('nexstim') && !s.slug.includes('apollo') && !s.slug.includes('deep-tms'),
);

const deviceComparisons = COMPARE_SLUGS.filter(
  s => s.slug.includes('neurostar') || s.slug.includes('magventure') || s.slug.includes('brainsway') || s.slug.includes('magstim') || s.slug.includes('cloudtms') || s.slug.includes('nexstim') || s.slug.includes('apollo') || s.slug.includes('deep-tms'),
);

const compareSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'TMS Treatment & Device Comparisons',
  description,
  url: `${siteUrl}/compare/`,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: COMPARE_SLUGS.length,
    itemListElement: COMPARE_SLUGS.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.title,
      url: `${siteUrl}/compare/${item.slug}/`,
    })),
  },
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is TMS better than medication for depression?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'TMS and antidepressants work through different mechanisms. TMS directly stimulates the prefrontal cortex with magnetic pulses; antidepressants alter chemistry throughout the body. For treatment-resistant patients who have not responded to medications, TMS often produces better outcomes with fewer systemic side effects. For patients who have not tried medications, antidepressants remain a valid first-line option.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does TMS compare to ECT?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ECT requires general anesthesia and induces a controlled seizure. It is highly effective for severe, treatment-resistant depression and catatonia, but carries risks of anesthesia, memory side effects, and requires a companion for transport. TMS is non-invasive, requires no sedation, and causes no cognitive impairment. Most patients prefer TMS when both are viable options.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which TMS device is best?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'All FDA-cleared TMS devices (NeuroStar, BrainsWay, MagVenture, Magstim, CloudTMS, Nexstim) have strong clinical evidence. NeuroStar has the largest US market share. BrainsWay is the only one with OCD clearance via deep TMS. The best device for you depends on your condition, insurance coverage, and what your local clinic uses. Device choice should be made with your treating psychiatrist.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I switch from TMS to ketamine or vice versa?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, many patients explore both treatments. TMS and ketamine work through different mechanisms and can be complementary. Some clinics now offer both treatments. Your psychiatrist can help determine the right sequencing based on your treatment history, severity, and how quickly you need results.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which comparison should I read first?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Start with TMS vs. Medication if you are newly diagnosed. Read TMS vs. ECT if you have severe or treatment-resistant depression. For device comparisons, read NeuroStar vs. BrainsWay if you are choosing a clinic — these are the two most common devices in the US.',
      },
    },
  ],
});

const comparisonMeta: Record<string, { color: string; desc: string; icon: string; category: string }> = {
  'tms-vs-antidepressants': { color: 'emerald', desc: 'Effectiveness, side effects, time to response, long-term outcomes, and insurance coverage.', icon: 'M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3', category: 'Medication' },
  'tms-vs-ect': { color: 'rose', desc: 'Invasiveness, efficacy for severe depression, cognitive side effects, and treatment logistics.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', category: 'Procedures' },
  'tms-vs-ketamine': { color: 'violet', desc: 'Mechanism of action, speed of results, treatment protocols, cost, and availability.', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', category: 'Alternative' },
  'tms-vs-psychotherapy': { color: 'blue', desc: 'How TMS and CBT/therapy compare and when to use each alongside the other.', icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z', category: 'Therapy' },
  'tms-vs-esketamine': { color: 'pink', desc: 'Spravato nasal spray vs. TMS for treatment-resistant depression — mechanisms, access, cost.', icon: 'M9.5 9.5L12 12m0 0l2.5 2.5M12 12l2.5-2.5M12 12L9.5 9.5m0 0l2.5 2.5M12 12l-2.5-2.5', category: 'Alternative' },
  'tms-vs-psilocybin': { color: 'amber', desc: 'Psychedelic-assisted therapy vs. TMS for depression — evidence, legality, and patient experience.', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', category: 'Experimental' },
  'tms-vs-neurofeedback': { color: 'cyan', desc: 'EEG neurofeedback vs. TMS for depression and anxiety — protocols, outcomes, and accessibility.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', category: 'Biofeedback' },
  'tms-vs-vns': { color: 'slate', desc: 'Vagus nerve stimulation vs. TMS — invasive vs. non-invasive, FDA indications, and outcomes.', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', category: 'Device' },
  'tms-vs-dbs': { color: 'orange', desc: 'Deep brain stimulation vs. TMS — invasiveness, target populations, and evidence base.', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', category: 'Surgical' },
  'tms-vs-cbt': { color: 'teal', desc: 'TMS and Cognitive Behavioral Therapy for depression — different mechanisms, combined use.', icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z', category: 'Therapy' },
  'tms-vs-transcranial-dcs': { color: 'indigo', desc: 'Transcranial Direct Current Stimulation (tDCS) vs. TMS — intensity, evidence, home use.', icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6m4 0v4m0 0h4m-4 0h4m10 5v-4a2 2 0 012-2h2a2 2 0 012 2v4m-8-8h4m-4 0H7m10 5a2 2 0 104 0 2 2 0 00-4 0z', category: 'Device' },
  'tms-vs-lithium': { color: 'fuchsia', desc: 'TMS for bipolar depression vs. lithium — mood stabilization, rapid cycling, and combination therapy.', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', category: 'Medication' },
};

const colorMap: Record<string, { bg: string; border: string; text: string; badge: string }> = {
  emerald: { bg: 'bg-emerald-50', border: 'border-emerald-200 hover:border-emerald-400', text: 'text-emerald-600', badge: 'bg-emerald-100 text-emerald-700' },
  blue: { bg: 'bg-[var(--paper2)]', border: 'border-[var(--line)] hover:border-[rgba(10,22,40,0.2)]', text: 'text-[var(--accent)]', badge: 'bg-[rgba(10,22,40,0.1)] text-[var(--accent)]' },
  rose: { bg: 'bg-[rgba(201,101,74,0.06)]', border: 'border-[var(--line)] hover:border-[rgba(201,101,74,0.2)]', text: 'text-[var(--warm)]', badge: 'bg-[rgba(201,101,74,0.1)] text-[var(--warm)]' },
  violet: { bg: 'bg-[rgba(10,22,40,0.08)]', border: 'border-[rgba(10,22,40,0.15)] hover:border-[var(--ink2)]', text: 'text-[var(--accent)]', badge: 'bg-[rgba(10,22,40,0.08)] text-[var(--accent)]' },
  amber: { bg: 'bg-amber-50', border: 'border-amber-200 hover:border-amber-400', text: 'text-amber-600', badge: 'bg-amber-100 text-amber-700' },
  pink: { bg: 'bg-[rgba(201,101,74,0.06)]', border: 'border-[var(--line)] hover:border-[rgba(201,101,74,0.2)]', text: 'text-[var(--warm)]', badge: 'bg-[rgba(201,101,74,0.1)] text-[var(--warm)]' },
  cyan: { bg: 'bg-[var(--paper2)]', border: 'border-[var(--line)] hover:border-[rgba(10,22,40,0.2)]', text: 'text-[var(--accent)]', badge: 'bg-[rgba(10,22,40,0.1)] text-[var(--accent)]' },
  slate: { bg: 'bg-[var(--paper2)]', border: 'border-[var(--line)] hover:border-[var(--line)]', text: 'text-[var(--muted)]', badge: 'bg-[var(--paper2)] text-[var(--ink2)]' },
  orange: { bg: 'bg-orange-50', border: 'border-orange-200 hover:border-orange-400', text: 'text-orange-600', badge: 'bg-orange-100 text-orange-700' },
  teal: { bg: 'bg-teal-50', border: 'border-teal-200 hover:border-teal-400', text: 'text-teal-600', badge: 'bg-teal-100 text-teal-700' },
  indigo: { bg: 'bg-[rgba(201,101,74,0.06)]', border: 'border-[var(--line)] hover:border-[rgba(201,101,74,0.2)]', text: 'text-[var(--warm)]', badge: 'bg-[rgba(201,101,74,0.1)] text-[var(--warm)]' },
  fuchsia: { bg: 'bg-[rgba(201,101,74,0.06)]', border: 'border-[var(--line)] hover:border-[rgba(201,101,74,0.2)]', text: 'text-[var(--warm)]', badge: 'bg-[rgba(201,101,74,0.1)] text-[var(--warm)]' },
};

const deviceColorMap: Record<string, { bg: string; border: string; text: string; badge: string }> = {
  neurostar: { bg: 'bg-[var(--paper2)]', border: 'border-[var(--line)] hover:border-[rgba(10,22,40,0.2)]', text: 'text-[var(--accent)]', badge: 'bg-[rgba(10,22,40,0.1)] text-[var(--accent)]' },
  brainsway: { bg: 'bg-emerald-50', border: 'border-emerald-200 hover:border-emerald-400', text: 'text-emerald-600', badge: 'bg-emerald-100 text-emerald-700' },
  magventure: { bg: 'bg-[rgba(10,22,40,0.08)]', border: 'border-[rgba(10,22,40,0.15)] hover:border-[var(--ink2)]', text: 'text-[var(--accent)]', badge: 'bg-[rgba(10,22,40,0.08)] text-[var(--accent)]' },
  magstim: { bg: 'bg-[rgba(201,101,74,0.06)]', border: 'border-[var(--line)] hover:border-[rgba(201,101,74,0.2)]', text: 'text-[var(--warm)]', badge: 'bg-[rgba(201,101,74,0.1)] text-[var(--warm)]' },
};
---

<Layout title={title} description={description} schema={compareSchema}>
  <main style="background:var(--paper)">
    <EditorialHero
      eyebrow={`${COMPARE_SLUGS.length} Comparison Guides`}
      eyebrowDot="#22c55e"
      title="Side-by-side"
      titleAccent="comparisons."
      description="Understand treatment options, device differences, and which approach might be right for your situation."
      breadcrumbs={[{ label: "Home", href: "/" }, { label: "Compare" }]}
      ctas={[
        { label: "TMS vs Medication", href: "/compare/tms-vs-antidepressants/" },
        { label: "TMS vs ECT", href: "/compare/tms-vs-ect/", variant: "outline" },
      ]}
      stats={[
        { value: treatmentComparisons.length, label: "Treatment Comparisons", color: "ink" },
        { value: deviceComparisons.length, label: "Device Comparisons", color: "accent" },
        { value: COMPARE_SLUGS.length, label: "Total Guides", color: "warm" },
      ]}
    />

    <!-- YouTube Video Section -->
    <section class="py-12 bg-[var(--paper)] border-b border-[var(--line)]  ">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-8">
          <h2 class="text-2xl font-bold text-[var(--ink)] tracking-tight mb-2 ">Watch: TMS Explained in 5 Minutes</h2>
          <p class="text-[var(--muted)] ">Quick overview of how TMS works, how it compares to other treatments, and what to expect.</p>
        </div>
        <div class="relative rounded-2xl overflow-hidden shadow-xl border border-[var(--line)] max-w-3xl mx-auto aspect-video  ">
          <iframe
            class="w-full h-full"
            src="https://www.youtube.com/embed/gVAVAaobtJo"
            title="TMS Treatment Comparison Overview"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy">
          </iframe>
        </div>
        <div class="text-center mt-4">
          <p class="text-xs text-[var(--muted)] ">Full comparison videos are in production. Subscribe to get notified when they launch.</p>
        </div>
      </div>
    </section>

    <!-- Treatment Comparisons -->
    <section class="py-16">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex items-end justify-between mb-10">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <div class="w-5 h-5 rounded bg-[rgba(10,22,40,0.1)] text-[var(--accent)] flex items-center justify-center text-[10px] font-bold">1</div>
              <span class="text-xs font-semibold text-[var(--accent)] uppercase tracking-wider ">Treatment Comparisons</span>
            </div>
            <h2 class="text-2xl lg:text-3xl font-bold text-[var(--ink)] tracking-tight ">TMS vs. Other Treatments</h2>
            <p class="text-[var(--muted)] mt-1 ">How does TMS stack up against medications, ECT, ketamine, therapy, and experimental options?</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {treatmentComparisons.map(comp => {
            const meta = comparisonMeta[comp.slug] || { color: 'slate', desc: 'Side-by-side comparison of effectiveness, side effects, and treatment protocols.', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', category: 'Comparison' };
            const c = colorMap[meta.color] || colorMap.slate;
            return (
              <a href={`/compare/${comp.slug}/`}
                 class={`group bg-[var(--paper)] rounded-2xl border ${c.border} p-6 hover:shadow-[0_16px_48px_-12px_rgba(0,0,0,0.10)] transition-all duration-300  `}>
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center gap-2">
                    <span class={`px-2.5 py-1 ${c.badge} text-[10px] font-bold uppercase tracking-wider rounded-md`}>{meta.category}</span>
                  </div>
                  <svg class="w-4 h-4 text-[var(--muted)] group-hover:text-[var(--accent2)] group-hover:translate-x-1 transition-all " fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </div>
                <h3 class="text-base font-bold text-[var(--ink)] group-hover:text-[var(--accent)] transition-colors mb-2 leading-snug tracking-tight">{comp.title}</h3>
                <p class="text-sm text-[var(--muted)] leading-relaxed ">{meta.desc}</p>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Device Comparisons -->
    <section class="py-16 bg-[var(--paper2)] border-t border-[var(--line)]  ">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex items-end justify-between mb-10">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <div class="w-5 h-5 rounded bg-[rgba(10,22,40,0.1)] text-[var(--accent)] flex items-center justify-center text-[10px] font-bold">2</div>
              <span class="text-xs font-semibold text-[var(--accent)] uppercase tracking-wider">Device Comparisons</span>
            </div>
            <h2 class="text-2xl lg:text-3xl font-bold text-[var(--ink)] tracking-tight ">TMS Device Showdown</h2>
            <p class="text-[var(--muted)] mt-1 ">Compare FDA-cleared TMS machines: coil types, protocols, clinical evidence, and US availability.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {deviceComparisons.map(comp => {
            const deviceSlug = comp.slug.replace(/-(?:vs|versus)-.*$/, '').replace(/-vs-.*$/, '');
            const c = deviceColorMap[deviceSlug] || { bg: 'bg-[var(--paper2)] ', border: 'border-[var(--line)] hover:border-[var(--line)]  ', text: 'text-[var(--muted)] ', badge: 'bg-[var(--paper2)] text-[var(--ink2)] ' };
            return (
              <a href={`/compare/${comp.slug}/`}
                 class={`group bg-[var(--paper)] rounded-2xl border ${c.border} p-6 hover:shadow-[0_16px_48px_-12px_rgba(0,0,0,0.10)] transition-all duration-300  `}>
                <div class="flex items-center justify-between mb-4">
                  <div class="w-8 h-8 rounded-lg bg-[rgba(10,22,40,0.08)] flex items-center justify-center">
                    <svg class="w-4 h-4 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
                  </div>
                  <svg class="w-4 h-4 text-[var(--muted)] group-hover:text-[var(--accent2)] group-hover:translate-x-1 transition-all " fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </div>
                <h3 class="text-base font-bold text-[var(--ink)] group-hover:text-[var(--accent)] transition-colors mb-2 leading-snug tracking-tight">{comp.title}</h3>
                <p class="text-sm text-[var(--muted)] leading-relaxed ">Compare coil types, FDA clearances, clinical protocols, and US clinic availability.</p>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- How to Decide -->
    <section class="py-16 bg-[var(--paper)] border-t border-[var(--line)]  ">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-10">
          <h2 class="text-2xl lg:text-3xl font-bold text-[var(--ink)] tracking-tight mb-3 ">How to Choose the Right Treatment</h2>
          <p class="text-[var(--muted)] max-w-xl mx-auto ">Every patient situation is different. Here's how to think through your options systematically.</p>
        </div>

        <!-- Decision Matrix -->
        <div class="overflow-x-auto rounded-2xl border border-[var(--line)] shadow-sm mb-10  ">
          <table class="w-full text-sm">
            <thead class="bg-[var(--paper2)] ">
              <tr>
                <th class="text-left px-6 py-4 font-bold text-[var(--ink2)] ">Factor</th>
                <th class="text-left px-6 py-4 font-bold text-[var(--ink2)] ">TMS</th>
                <th class="text-left px-6 py-4 font-bold text-[var(--ink2)] ">Antidepressants</th>
                <th class="text-left px-6 py-4 font-bold text-[var(--ink2)] ">ECT</th>
                <th class="text-left px-6 py-4 font-bold text-[var(--ink2)] ">Ketamine</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[var(--line)] divide-[var(--line)]">
              <tr>
                <td class="px-6 py-3.5 font-medium text-[var(--ink2)] ">Invasiveness</td>
                <td class="px-6 py-3.5 text-[var(--muted)] "><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Non-invasive</span></td>
                <td class="px-6 py-3.5 text-[var(--muted)] "><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Oral medication</span></td>
                <td class="px-6 py-3.5 text-[var(--muted)] "><span class="px-2 py-1 bg-[rgba(201,101,74,0.06)] text-[var(--warm)] text-xs rounded-full font-medium">Sedation required</span></td>
                <td class="px-6 py-3.5 text-[var(--muted)] "><span class="px-2 py-1 bg-amber-50 text-amber-600 text-xs rounded-full font-medium">IV infusion</span></td>
              </tr>
              <tr class="bg-[var(--paper2)] ">
                <td class="px-6 py-3.5 font-medium text-[var(--ink2)] ">Response rate (TRD)</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">50–60%</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">30–40%</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">60–80%</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">50–70%</td>
              </tr>
              <tr>
                <td class="px-6 py-3.5 font-medium text-[var(--ink2)] ">Time to effect</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">2–6 weeks</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">4–8 weeks</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">2–4 weeks</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">Hours to days</td>
              </tr>
              <tr class="bg-[var(--paper2)] ">
                <td class="px-6 py-3.5 font-medium text-[var(--ink2)] ">Cognitive side effects</td>
                <td class="px-6 py-3.5 text-[var(--muted)] "><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">None</span></td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">Possible (blunting)</td>
                <td class="px-6 py-3.5 text-[var(--muted)] "><span class="px-2 py-1 bg-[rgba(201,101,74,0.06)] text-[var(--warm)] text-xs rounded-full font-medium">Memory risk</span></td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">Minimal</td>
              </tr>
              <tr>
                <td class="px-6 py-3.5 font-medium text-[var(--ink2)] ">Insurance coverage</td>
                <td class="px-6 py-3.5 text-[var(--muted)] "><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Widely covered</span></td>
                <td class="px-6 py-3.5 text-[var(--muted)] "><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Universal</span></td>
                <td class="px-6 py-3.5 text-[var(--muted)] "><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Widely covered</span></td>
                <td class="px-6 py-3.5 text-[var(--muted)] "><span class="px-2 py-1 bg-amber-50 text-amber-600 text-xs rounded-full font-medium">Limited</span></td>
              </tr>
              <tr class="bg-[var(--paper2)] ">
                <td class="px-6 py-3.5 font-medium text-[var(--ink2)] ">Daily commitment</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">5 days/week × 6 wks</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">Daily pill</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">2–3×/week × 4 wks</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">6 infusions, then maintenance</td>
              </tr>
              <tr>
                <td class="px-6 py-3.5 font-medium text-[var(--ink2)] ">FDA-cleared for</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">MDD, OCD, smoking</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">Multiple indications</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">MDD, bipolar, catatonia</td>
                <td class="px-6 py-3.5 text-[var(--muted)] ">TRD, bipolar (Spravato)</td>
              </tr>
            </tbody>
          </table>
          <div class="p-4 bg-[var(--paper2)] text-xs text-[var(--muted)] text-center border-t border-[var(--line)]   ">
            TRD = treatment-resistant depression. Data reflects clinical trial ranges and may not reflect individual outcomes.
          </div>
        </div>

        <!-- Decision guide cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          <div class="bg-[var(--paper)] rounded-2xl p-7 border border-[var(--line)] shadow-sm   ">
            <div class="w-10 h-10 rounded-xl bg-[var(--paper2)] text-[var(--accent)] flex items-center justify-center mb-4 ">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="font-bold text-[var(--ink)] mb-2 ">Start Here: New Diagnosis</h3>
            <p class="text-sm text-[var(--muted)] leading-relaxed mb-3 ">If you've never been treated for depression, begin with antidepressants or psychotherapy under a psychiatrist's care. TMS is typically considered after medication failures.</p>
            <a href="/compare/tms-vs-antidepressants/" class="text-sm font-semibold text-[var(--accent)] hover:underline ">Read TMS vs. Medication →</a>
          </div>
          <div class="bg-[var(--paper)] rounded-2xl p-7 border border-[var(--line)] shadow-sm   ">
            <div class="w-10 h-10 rounded-xl bg-[rgba(201,101,74,0.06)] text-[var(--warm)] flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
            </div>
            <h3 class="font-bold text-[var(--ink)] mb-2 ">Severe / High Risk Cases</h3>
            <p class="text-sm text-[var(--muted)] leading-relaxed mb-3 ">If depression is severe, treatment-resistant, or includes psychotic features or catatonia, ECT may be the most effective option. TMS may be considered afterward for maintenance.</p>
            <a href="/compare/tms-vs-ect/" class="text-sm font-semibold text-[var(--warm)] hover:underline">Read TMS vs. ECT →</a>
          </div>
          <div class="bg-[var(--paper)] rounded-2xl p-7 border border-[var(--line)] shadow-sm   ">
            <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center mb-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
            </div>
            <h3 class="font-bold text-[var(--ink)] mb-2 ">Need Fast Results</h3>
            <p class="text-sm text-[var(--muted)] leading-relaxed mb-3 ">If you need rapid response due to severe symptoms or suicidality, ketamine/esketamine works in hours. TMS and medications take weeks. No single option works for everyone — speed vs. durability is a trade-off.</p>
            <a href="/compare/tms-vs-ketamine/" class="text-sm font-semibold text-emerald-600 hover:underline">Read TMS vs. Ketamine →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Find a Clinic CTA -->
    <section class="py-16 bg-[var(--ink)] border-t border-[var(--line)]">
      <div class="container mx-auto px-4 max-w-3xl text-center">
        <div class="w-14 h-14 rounded-2xl bg-[var(--accent)]/30 text-[var(--accent2)] flex items-center justify-center mx-auto mb-6">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
        </div>
        <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4 tracking-tight">Compare Specific Clinics</h2>
        <p class="text-[var(--muted)] mb-8 max-w-lg mx-auto ">Use our compare tool to evaluate two or more TMS clinics side-by-side — location, machines, ratings, insurance, and pricing.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/us/" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-[var(--accent)] hover:bg-[var(--accent2)] text-white font-semibold rounded-xl transition-colors shadow-lg shadow-[rgba(10,22,40,0.1)]">
            Find a Clinic
          </a>
          <a href="/compare/" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-[var(--paper)] hover:bg-[var(--paper2)] text-[var(--ink)] font-semibold rounded-xl transition-colors border border-[var(--line)]">
            Browse All Comparisons
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ Schema -->
    <script type="application/ld+json" set:html={faqSchema}></script>
  </main>
</Layout>
