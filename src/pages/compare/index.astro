---
import Layout from '../../layouts/Layout.astro';
import { COMPARE_SLUGS } from '../../utils/seo_slugs';

const title = "Compare TMS Treatments & Devices | Side-by-Side Guides | TMS List";
const description = "Compare TMS therapy vs medications, ECT, ketamine and other treatments. Side-by-side analysis of NeuroStar, BrainsWay, MagVenture, Magstim, and other TMS devices.";

const siteUrl = import.meta.env.SITE_URL || 'https://tmslist.com';

const treatmentComparisons = COMPARE_SLUGS.filter(
  s => s.slug.includes('tms-vs-') && !s.slug.includes('neurostar') && !s.slug.includes('magventure') && !s.slug.includes('magstim') && !s.slug.includes('brainsway') && !s.slug.includes('cloudtms') && !s.slug.includes('nexstim') && !s.slug.includes('apollo') && !s.slug.includes('deep-tms'),
);

const deviceComparisons = COMPARE_SLUGS.filter(
  s => s.slug.includes('neurostar') || s.slug.includes('magventure') || s.slug.includes('brainsway') || s.slug.includes('magstim') || s.slug.includes('cloudtms') || s.slug.includes('nexstim') || s.slug.includes('apollo') || s.slug.includes('deep-tms'),
);

const compareSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'TMS Treatment & Device Comparisons',
  description,
  url: `${siteUrl}/compare/`,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: COMPARE_SLUGS.length,
    itemListElement: COMPARE_SLUGS.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.title,
      url: `${siteUrl}/compare/${item.slug}/`,
    })),
  },
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is TMS better than medication for depression?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'TMS and antidepressants work through different mechanisms. TMS directly stimulates the prefrontal cortex with magnetic pulses; antidepressants alter chemistry throughout the body. For treatment-resistant patients who have not responded to medications, TMS often produces better outcomes with fewer systemic side effects. For patients who have not tried medications, antidepressants remain a valid first-line option.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does TMS compare to ECT?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ECT requires general anesthesia and induces a controlled seizure. It is highly effective for severe, treatment-resistant depression and catatonia, but carries risks of anesthesia, memory side effects, and requires a companion for transport. TMS is non-invasive, requires no sedation, and causes no cognitive impairment. Most patients prefer TMS when both are viable options.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which TMS device is best?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'All FDA-cleared TMS devices (NeuroStar, BrainsWay, MagVenture, Magstim, CloudTMS, Nexstim) have strong clinical evidence. NeuroStar has the largest US market share. BrainsWay is the only one with OCD clearance via deep TMS. The best device for you depends on your condition, insurance coverage, and what your local clinic uses. Device choice should be made with your treating psychiatrist.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I switch from TMS to ketamine or vice versa?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, many patients explore both treatments. TMS and ketamine work through different mechanisms and can be complementary. Some clinics now offer both treatments. Your psychiatrist can help determine the right sequencing based on your treatment history, severity, and how quickly you need results.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which comparison should I read first?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Start with TMS vs. Medication if you are newly diagnosed. Read TMS vs. ECT if you have severe or treatment-resistant depression. For device comparisons, read NeuroStar vs. BrainsWay if you are choosing a clinic — these are the two most common devices in the US.',
      },
    },
  ],
});

const comparisonMeta: Record<string, { color: string; desc: string; icon: string; category: string }> = {
  'tms-vs-antidepressants': { color: 'emerald', desc: 'Effectiveness, side effects, time to response, long-term outcomes, and insurance coverage.', icon: 'M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3', category: 'Medication' },
  'tms-vs-ect': { color: 'rose', desc: 'Invasiveness, efficacy for severe depression, cognitive side effects, and treatment logistics.', icon: 'M13 10V3L4 14h7v7l9-11h-7z', category: 'Procedures' },
  'tms-vs-ketamine': { color: 'violet', desc: 'Mechanism of action, speed of results, treatment protocols, cost, and availability.', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', category: 'Alternative' },
  'tms-vs-psychotherapy': { color: 'blue', desc: 'How TMS and CBT/therapy compare and when to use each alongside the other.', icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z', category: 'Therapy' },
  'tms-vs-esketamine': { color: 'pink', desc: 'Spravato nasal spray vs. TMS for treatment-resistant depression — mechanisms, access, cost.', icon: 'M9.5 9.5L12 12m0 0l2.5 2.5M12 12l2.5-2.5M12 12L9.5 9.5m0 0l2.5 2.5M12 12l-2.5-2.5', category: 'Alternative' },
  'tms-vs-psilocybin': { color: 'amber', desc: 'Psychedelic-assisted therapy vs. TMS for depression — evidence, legality, and patient experience.', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z', category: 'Experimental' },
  'tms-vs-neurofeedback': { color: 'cyan', desc: 'EEG neurofeedback vs. TMS for depression and anxiety — protocols, outcomes, and accessibility.', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', category: 'Biofeedback' },
  'tms-vs-vns': { color: 'slate', desc: 'Vagus nerve stimulation vs. TMS — invasive vs. non-invasive, FDA indications, and outcomes.', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', category: 'Device' },
  'tms-vs-dbs': { color: 'orange', desc: 'Deep brain stimulation vs. TMS — invasiveness, target populations, and evidence base.', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', category: 'Surgical' },
  'tms-vs-cbt': { color: 'teal', desc: 'TMS and Cognitive Behavioral Therapy for depression — different mechanisms, combined use.', icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z', category: 'Therapy' },
  'tms-vs-transcranial-dcs': { color: 'indigo', desc: 'Transcranial Direct Current Stimulation (tDCS) vs. TMS — intensity, evidence, home use.', icon: 'M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6m4 0v4m0 0h4m-4 0h4m10 5v-4a2 2 0 012-2h2a2 2 0 012 2v4m-8-8h4m-4 0H7m10 5a2 2 0 104 0 2 2 0 00-4 0z', category: 'Device' },
  'tms-vs-lithium': { color: 'fuchsia', desc: 'TMS for bipolar depression vs. lithium — mood stabilization, rapid cycling, and combination therapy.', icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z', category: 'Medication' },
};

const colorMap: Record<string, { bg: string; border: string; text: string; badge: string }> = {
  emerald: { bg: 'bg-emerald-50 dark:bg-emerald-950', border: 'border-emerald-200 hover:border-emerald-400 dark:border-emerald-900 dark:hover:border-emerald-700', text: 'text-emerald-600 dark:text-emerald-400', badge: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900 dark:text-emerald-300' },
  blue: { bg: 'bg-blue-50 dark:bg-blue-950', border: 'border-blue-200 hover:border-blue-400 dark:border-blue-900 dark:hover:border-blue-700', text: 'text-blue-600 dark:text-blue-400', badge: 'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' },
  rose: { bg: 'bg-rose-50 dark:bg-rose-950', border: 'border-rose-200 hover:border-rose-400 dark:border-rose-900 dark:hover:border-rose-700', text: 'text-rose-600 dark:text-rose-400', badge: 'bg-rose-100 text-rose-700 dark:bg-rose-900 dark:text-rose-300' },
  violet: { bg: 'bg-violet-50 dark:bg-violet-950', border: 'border-violet-200 hover:border-violet-400 dark:border-violet-900 dark:hover:border-violet-700', text: 'text-violet-600 dark:text-violet-400', badge: 'bg-violet-100 text-violet-700 dark:bg-violet-900 dark:text-violet-300' },
  amber: { bg: 'bg-amber-50 dark:bg-amber-950', border: 'border-amber-200 hover:border-amber-400 dark:border-amber-900 dark:hover:border-amber-700', text: 'text-amber-600 dark:text-amber-400', badge: 'bg-amber-100 text-amber-700 dark:bg-amber-900 dark:text-amber-300' },
  pink: { bg: 'bg-pink-50 dark:bg-pink-950', border: 'border-pink-200 hover:border-pink-400 dark:border-pink-900 dark:hover:border-pink-700', text: 'text-pink-600 dark:text-pink-400', badge: 'bg-pink-100 text-pink-700 dark:bg-pink-900 dark:text-pink-300' },
  cyan: { bg: 'bg-cyan-50 dark:bg-cyan-950', border: 'border-cyan-200 hover:border-cyan-400 dark:border-cyan-900 dark:hover:border-cyan-700', text: 'text-cyan-600 dark:text-cyan-400', badge: 'bg-cyan-100 text-cyan-700 dark:bg-cyan-900 dark:text-cyan-300' },
  slate: { bg: 'bg-slate-100 dark:bg-slate-800', border: 'border-slate-300 hover:border-slate-400 dark:border-slate-700 dark:hover:border-slate-600', text: 'text-slate-600 dark:text-slate-300', badge: 'bg-slate-200 text-slate-700 dark:bg-slate-700 dark:text-slate-300' },
  orange: { bg: 'bg-orange-50 dark:bg-orange-950', border: 'border-orange-200 hover:border-orange-400 dark:border-orange-900 dark:hover:border-orange-700', text: 'text-orange-600 dark:text-orange-400', badge: 'bg-orange-100 text-orange-700 dark:bg-orange-900 dark:text-orange-300' },
  teal: { bg: 'bg-teal-50 dark:bg-teal-950', border: 'border-teal-200 hover:border-teal-400 dark:border-teal-900 dark:hover:border-teal-700', text: 'text-teal-600 dark:text-teal-400', badge: 'bg-teal-100 text-teal-700 dark:bg-teal-900 dark:text-teal-300' },
  indigo: { bg: 'bg-indigo-50 dark:bg-indigo-950', border: 'border-violet-200 hover:border-violet-400 dark:border-indigo-900 dark:hover:border-indigo-700', text: 'text-violet-600 dark:text-indigo-400', badge: 'bg-indigo-100 text-indigo-700 dark:bg-indigo-900 dark:text-indigo-300' },
  fuchsia: { bg: 'bg-fuchsia-50 dark:bg-fuchsia-950', border: 'border-fuchsia-200 hover:border-fuchsia-400 dark:border-fuchsia-900 dark:hover:border-fuchsia-700', text: 'text-fuchsia-600 dark:text-fuchsia-400', badge: 'bg-fuchsia-100 text-fuchsia-700 dark:bg-fuchsia-900 dark:text-fuchsia-300' },
};

const deviceColorMap: Record<string, { bg: string; border: string; text: string; badge: string }> = {
  neurostar: { bg: 'bg-blue-50 dark:bg-blue-950', border: 'border-blue-200 hover:border-blue-400 dark:border-blue-900 dark:hover:border-blue-700', text: 'text-blue-600 dark:text-blue-400', badge: 'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' },
  brainsway: { bg: 'bg-emerald-50 dark:bg-emerald-950', border: 'border-emerald-200 hover:border-emerald-400 dark:border-emerald-900 dark:hover:border-emerald-700', text: 'text-emerald-600 dark:text-emerald-400', badge: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900 dark:text-emerald-300' },
  magventure: { bg: 'bg-violet-50 dark:bg-violet-950', border: 'border-violet-200 hover:border-violet-400 dark:border-violet-900 dark:hover:border-violet-700', text: 'text-violet-600 dark:text-violet-400', badge: 'bg-violet-100 text-violet-700 dark:bg-violet-900 dark:text-violet-300' },
  magstim: { bg: 'bg-rose-50 dark:bg-rose-950', border: 'border-rose-200 hover:border-rose-400 dark:border-rose-900 dark:hover:border-rose-700', text: 'text-rose-600 dark:text-rose-400', badge: 'bg-rose-100 text-rose-700 dark:bg-rose-900 dark:text-rose-300' },
};
---

<Layout title={title} description={description} schema={compareSchema}>
  <main>
    <!-- Hero -->
    <section class="relative bg-slate-950 overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.4) 1px, transparent 0); background-size: 28px 28px;"></div>
      <div class="absolute top-[-20%] right-[10%] w-[600px] h-[600px] bg-blue-500/10 rounded-full blur-[180px]"></div>
      <div class="absolute bottom-[-10%] left-[15%] w-[400px] h-[400px] bg-violet-500/10 rounded-full blur-[140px]"></div>

      <div class="container mx-auto px-4 pt-12 pb-20 lg:pt-16 lg:pb-28 relative z-10">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-12" aria-label="Breadcrumb">
          <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
          <span class="text-slate-700">/</span>
          <span class="text-slate-300">Compare</span>
        </nav>
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-full mb-6">
            <div class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></div>
            <span class="text-xs font-semibold text-slate-300 tracking-wider uppercase">{COMPARE_SLUGS.length} Comparison Guides</span>
          </div>
          <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white leading-[0.95] mb-5">
            Compare<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-violet-400">TMS Options</span>
          </h1>
          <p class="text-lg text-slate-400 leading-relaxed mb-8 max-w-xl">
            Side-by-side comparisons to help you understand treatment options, device differences, and which approach might be right for your situation.
          </p>
          <!-- Quick links -->
          <div class="flex flex-wrap gap-2">
            <a href="/compare/tms-vs-antidepressants/" class="px-3 py-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-xs text-slate-300 transition-colors">TMS vs. Medication</a>
            <a href="/compare/tms-vs-ect/" class="px-3 py-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-xs text-slate-300 transition-colors">TMS vs. ECT</a>
            <a href="/compare/tms-vs-ketamine/" class="px-3 py-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-xs text-slate-300 transition-colors">TMS vs. Ketamine</a>
            <a href="/compare/neurostar-vs-brainsway/" class="px-3 py-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-xs text-slate-300 transition-colors">NeuroStar vs. BrainsWay</a>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-16 bg-white dark:bg-slate-950" style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"></div>
    </section>

    <!-- YouTube Video Section -->
    <section class="py-12 bg-white border-b border-slate-100 dark:bg-slate-950 dark:border-slate-800">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-8">
          <h2 class="text-2xl font-bold text-slate-900 tracking-tight mb-2 dark:text-slate-100">Watch: TMS Explained in 5 Minutes</h2>
          <p class="text-slate-500 dark:text-slate-400">Quick overview of how TMS works, how it compares to other treatments, and what to expect.</p>
        </div>
        <div class="relative rounded-2xl overflow-hidden shadow-xl border border-slate-100 max-w-3xl mx-auto aspect-video dark:border-slate-800 dark:shadow-slate-950">
          <iframe
            class="w-full h-full"
            src="https://www.youtube.com/embed/gVAVAaobtJo"
            title="TMS Treatment Comparison Overview"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy">
          </iframe>
        </div>
        <div class="text-center mt-4">
          <p class="text-xs text-slate-400 dark:text-slate-500">Full comparison videos are in production. Subscribe to get notified when they launch.</p>
        </div>
      </div>
    </section>

    <!-- Treatment Comparisons -->
    <section class="py-16">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex items-end justify-between mb-10">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <div class="w-5 h-5 rounded bg-blue-100 text-blue-600 flex items-center justify-center text-[10px] font-bold dark:bg-blue-900 dark:text-blue-300">1</div>
              <span class="text-xs font-semibold text-blue-600 uppercase tracking-wider dark:text-blue-400">Treatment Comparisons</span>
            </div>
            <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 tracking-tight dark:text-slate-100">TMS vs. Other Treatments</h2>
            <p class="text-slate-500 mt-1 dark:text-slate-400">How does TMS stack up against medications, ECT, ketamine, therapy, and experimental options?</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {treatmentComparisons.map(comp => {
            const meta = comparisonMeta[comp.slug] || { color: 'slate', desc: 'Side-by-side comparison of effectiveness, side effects, and treatment protocols.', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', category: 'Comparison' };
            const c = colorMap[meta.color] || colorMap.slate;
            return (
              <a href={`/compare/${comp.slug}/`}
                 class={`group bg-white rounded-2xl border ${c.border} p-6 hover:shadow-[0_16px_48px_-12px_rgba(0,0,0,0.10)] transition-all duration-300 dark:bg-slate-900 dark:shadow-slate-950`}>
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center gap-2">
                    <span class={`px-2.5 py-1 ${c.badge} text-[10px] font-bold uppercase tracking-wider rounded-md`}>{meta.category}</span>
                  </div>
                  <svg class="w-4 h-4 text-slate-300 group-hover:text-blue-500 group-hover:translate-x-1 transition-all dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </div>
                <h3 class="text-base font-bold text-slate-900 group-hover:text-blue-600 transition-colors mb-2 leading-snug tracking-tight dark:text-slate-100 dark:group-hover:text-blue-400">{comp.title}</h3>
                <p class="text-sm text-slate-500 leading-relaxed dark:text-slate-400">{meta.desc}</p>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Device Comparisons -->
    <section class="py-16 bg-slate-50 border-t border-slate-100 dark:bg-slate-950 dark:border-slate-800">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex items-end justify-between mb-10">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <div class="w-5 h-5 rounded bg-violet-100 text-violet-600 flex items-center justify-center text-[10px] font-bold dark:bg-violet-900 dark:text-violet-300">2</div>
              <span class="text-xs font-semibold text-violet-600 uppercase tracking-wider dark:text-violet-400">Device Comparisons</span>
            </div>
            <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 tracking-tight dark:text-slate-100">TMS Device Showdown</h2>
            <p class="text-slate-500 mt-1 dark:text-slate-400">Compare FDA-cleared TMS machines: coil types, protocols, clinical evidence, and US availability.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {deviceComparisons.map(comp => {
            const deviceSlug = comp.slug.replace(/-(?:vs|versus)-.*$/, '').replace(/-vs-.*$/, '');
            const c = deviceColorMap[deviceSlug] || { bg: 'bg-slate-50 dark:bg-slate-900', border: 'border-slate-200 hover:border-slate-400 dark:border-slate-700 dark:hover:border-slate-600', text: 'text-slate-600 dark:text-slate-300', badge: 'bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-300' };
            return (
              <a href={`/compare/${comp.slug}/`}
                 class={`group bg-white rounded-2xl border ${c.border} p-6 hover:shadow-[0_16px_48px_-12px_rgba(0,0,0,0.10)] transition-all duration-300 dark:bg-slate-900 dark:shadow-slate-950`}>
                <div class="flex items-center justify-between mb-4">
                  <div class="w-8 h-8 rounded-lg bg-violet-50 flex items-center justify-center dark:bg-violet-950">
                    <svg class="w-4 h-4 text-violet-600 dark:text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
                  </div>
                  <svg class="w-4 h-4 text-slate-300 group-hover:text-violet-500 group-hover:translate-x-1 transition-all dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </div>
                <h3 class="text-base font-bold text-slate-900 group-hover:text-violet-600 transition-colors mb-2 leading-snug tracking-tight dark:text-slate-100 dark:group-hover:text-violet-400">{comp.title}</h3>
                <p class="text-sm text-slate-500 leading-relaxed dark:text-slate-400">Compare coil types, FDA clearances, clinical protocols, and US clinic availability.</p>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- How to Decide -->
    <section class="py-16 bg-white border-t border-slate-100 dark:bg-slate-950 dark:border-slate-800">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-10">
          <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 tracking-tight mb-3 dark:text-slate-100">How to Choose the Right Treatment</h2>
          <p class="text-slate-500 max-w-xl mx-auto dark:text-slate-400">Every patient situation is different. Here's how to think through your options systematically.</p>
        </div>

        <!-- Decision Matrix -->
        <div class="overflow-x-auto rounded-2xl border border-slate-100 shadow-sm mb-10 dark:border-slate-800 dark:shadow-slate-950">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 dark:bg-slate-900">
              <tr>
                <th class="text-left px-6 py-4 font-bold text-slate-700 dark:text-slate-300">Factor</th>
                <th class="text-left px-6 py-4 font-bold text-slate-700 dark:text-slate-300">TMS</th>
                <th class="text-left px-6 py-4 font-bold text-slate-700 dark:text-slate-300">Antidepressants</th>
                <th class="text-left px-6 py-4 font-bold text-slate-700 dark:text-slate-300">ECT</th>
                <th class="text-left px-6 py-4 font-bold text-slate-700 dark:text-slate-300">Ketamine</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50 dark:divide-slate-800">
              <tr>
                <td class="px-6 py-3.5 font-medium text-slate-700 dark:text-slate-300">Invasiveness</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium dark:bg-emerald-950 dark:text-emerald-400">Non-invasive</span></td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium dark:bg-emerald-950 dark:text-emerald-400">Oral medication</span></td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400"><span class="px-2 py-1 bg-rose-50 text-rose-600 text-xs rounded-full font-medium dark:bg-rose-950 dark:text-rose-400">Sedation required</span></td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400"><span class="px-2 py-1 bg-amber-50 text-amber-600 text-xs rounded-full font-medium dark:bg-amber-950 dark:text-amber-400">IV infusion</span></td>
              </tr>
              <tr class="bg-slate-30/40 dark:bg-slate-900">
                <td class="px-6 py-3.5 font-medium text-slate-700 dark:text-slate-300">Response rate (TRD)</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">50–60%</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">30–40%</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">60–80%</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">50–70%</td>
              </tr>
              <tr>
                <td class="px-6 py-3.5 font-medium text-slate-700 dark:text-slate-300">Time to effect</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">2–6 weeks</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">4–8 weeks</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">2–4 weeks</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">Hours to days</td>
              </tr>
              <tr class="bg-slate-30/40 dark:bg-slate-900">
                <td class="px-6 py-3.5 font-medium text-slate-700 dark:text-slate-300">Cognitive side effects</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium dark:bg-emerald-950 dark:text-emerald-400">None</span></td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">Possible (blunting)</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400"><span class="px-2 py-1 bg-rose-50 text-rose-600 text-xs rounded-full font-medium dark:bg-rose-950 dark:text-rose-400">Memory risk</span></td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">Minimal</td>
              </tr>
              <tr>
                <td class="px-6 py-3.5 font-medium text-slate-700 dark:text-slate-300">Insurance coverage</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium dark:bg-emerald-950 dark:text-emerald-400">Widely covered</span></td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium dark:bg-emerald-950 dark:text-emerald-400">Universal</span></td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium dark:bg-emerald-950 dark:text-emerald-400">Widely covered</span></td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400"><span class="px-2 py-1 bg-amber-50 text-amber-600 text-xs rounded-full font-medium dark:bg-amber-950 dark:text-amber-400">Limited</span></td>
              </tr>
              <tr class="bg-slate-30/40 dark:bg-slate-900">
                <td class="px-6 py-3.5 font-medium text-slate-700 dark:text-slate-300">Daily commitment</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">5 days/week × 6 wks</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">Daily pill</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">2–3×/week × 4 wks</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">6 infusions, then maintenance</td>
              </tr>
              <tr>
                <td class="px-6 py-3.5 font-medium text-slate-700 dark:text-slate-300">FDA-cleared for</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">MDD, OCD, smoking</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">Multiple indications</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">MDD, bipolar, catatonia</td>
                <td class="px-6 py-3.5 text-slate-600 dark:text-slate-400">TRD, bipolar (Spravato)</td>
              </tr>
            </tbody>
          </table>
          <div class="p-4 bg-slate-50 text-xs text-slate-400 text-center border-t border-slate-100 dark:bg-slate-900 dark:border-slate-800 dark:text-slate-500">
            TRD = treatment-resistant depression. Data reflects clinical trial ranges and may not reflect individual outcomes.
          </div>
        </div>

        <!-- Decision guide cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          <div class="bg-white rounded-2xl p-7 border border-slate-100 shadow-sm dark:bg-slate-900 dark:border-slate-800 dark:shadow-slate-950">
            <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center mb-4 dark:bg-blue-950 dark:text-blue-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="font-bold text-slate-900 mb-2 dark:text-slate-100">Start Here: New Diagnosis</h3>
            <p class="text-sm text-slate-500 leading-relaxed mb-3 dark:text-slate-400">If you've never been treated for depression, begin with antidepressants or psychotherapy under a psychiatrist's care. TMS is typically considered after medication failures.</p>
            <a href="/compare/tms-vs-antidepressants/" class="text-sm font-semibold text-blue-600 hover:underline dark:text-blue-400">Read TMS vs. Medication →</a>
          </div>
          <div class="bg-white rounded-2xl p-7 border border-slate-100 shadow-sm dark:bg-slate-900 dark:border-slate-800 dark:shadow-slate-950">
            <div class="w-10 h-10 rounded-xl bg-rose-50 text-rose-600 flex items-center justify-center mb-4 dark:bg-rose-950 dark:text-rose-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
            </div>
            <h3 class="font-bold text-slate-900 mb-2 dark:text-slate-100">Severe / High Risk Cases</h3>
            <p class="text-sm text-slate-500 leading-relaxed mb-3 dark:text-slate-400">If depression is severe, treatment-resistant, or includes psychotic features or catatonia, ECT may be the most effective option. TMS may be considered afterward for maintenance.</p>
            <a href="/compare/tms-vs-ect/" class="text-sm font-semibold text-rose-600 hover:underline dark:text-rose-400">Read TMS vs. ECT →</a>
          </div>
          <div class="bg-white rounded-2xl p-7 border border-slate-100 shadow-sm dark:bg-slate-900 dark:border-slate-800 dark:shadow-slate-950">
            <div class="w-10 h-10 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center mb-4 dark:bg-emerald-950 dark:text-emerald-400">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
            </div>
            <h3 class="font-bold text-slate-900 mb-2 dark:text-slate-100">Need Fast Results</h3>
            <p class="text-sm text-slate-500 leading-relaxed mb-3 dark:text-slate-400">If you need rapid response due to severe symptoms or suicidality, ketamine/esketamine works in hours. TMS and medications take weeks. No single option works for everyone — speed vs. durability is a trade-off.</p>
            <a href="/compare/tms-vs-ketamine/" class="text-sm font-semibold text-emerald-600 hover:underline dark:text-emerald-400">Read TMS vs. Ketamine →</a>
          </div>
        </div>
      </div>
    </section>

