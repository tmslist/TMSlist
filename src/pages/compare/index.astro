---
import Layout from '../../layouts/Layout.astro';
import { COMPARE_SLUGS } from '../../utils/seo_slugs';

const title = "Compare TMS Treatments & Devices | Side-by-Side Guides | TMS List";
const description = "Compare TMS therapy vs medications, ECT, ketamine and other treatments. Side-by-side analysis of NeuroStar, BrainsWay, MagVenture, Magstim, and other TMS devices.";

const siteUrl = import.meta.env.SITE_URL || 'https://tmslist.com';

const treatmentComparisons = COMPARE_SLUGS.filter(
  s => s.slug.includes('tms-vs-') && !s.slug.includes('neurostar') && !s.slug.includes('magventure') && !s.slug.includes('magstim') && !s.slug.includes('brainsway') && !s.slug.includes('cloudtms') && !s.slug.includes('nexstim') && !s.slug.includes('apollo') && !s.slug.includes('deep-tms'),
);

const deviceComparisons = COMPARE_SLUGS.filter(
  s => s.slug.includes('neurostar') || s.slug.includes('magventure') || s.slug.includes('brainsway') || s.slug.includes('magstim') || s.slug.includes('cloudtms') || s.slug.includes('nexstim') || s.slug.includes('apollo') || s.slug.includes('deep-tms'),
);

const compareSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'TMS Treatment & Device Comparisons',
  description,
  url: `${siteUrl}/compare/`,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: COMPARE_SLUGS.length,
    itemListElement: COMPARE_SLUGS.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.title,
      url: `${siteUrl}/compare/${item.slug}/`,
    })),
  },
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is TMS better than medication for depression?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'TMS and antidepressants work through different mechanisms. TMS directly stimulates the prefrontal cortex with magnetic pulses; antidepressants alter chemistry throughout the body. For treatment-resistant patients who have not responded to medications, TMS often produces better outcomes with fewer systemic side effects. For patients who have not tried medications, antidepressants remain a valid first-line option.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does TMS compare to ECT?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ECT requires general anesthesia and induces a controlled seizure. It is highly effective for severe, treatment-resistant depression and catatonia, but carries risks of anesthesia, memory side effects, and requires a companion for transport. TMS is non-invasive, requires no sedation, and causes no cognitive impairment. Most patients prefer TMS when both are viable options.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which TMS device is best?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'All FDA-cleared TMS devices (NeuroStar, BrainsWay, MagVenture, Magstim, CloudTMS, Nexstim) have strong clinical evidence. NeuroStar has the largest US market share. BrainsWay is the only one with OCD clearance via deep TMS. The best device for you depends on your condition, insurance coverage, and what your local clinic uses. Device choice should be made with your treating psychiatrist.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I switch from TMS to ketamine or vice versa?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes, many patients explore both treatments. TMS and ketamine work through different mechanisms and can be complementary. Some clinics now offer both treatments. Your psychiatrist can help determine the right sequencing based on your treatment history, severity, and how quickly you need results.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which comparison should I read first?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Start with TMS vs. Medication if you are newly diagnosed. Read TMS vs. ECT if you have severe or treatment-resistant depression. For device comparisons, read NeuroStar vs. BrainsWay if you are choosing a clinic — these are the two most common devices in the US.',
      },
    },
  ],
});

const comparisonMeta: Record<string, { color: string; desc: string; icon: string; category: string }> = {
  'tms-vs-antidepressants': { color: 'emerald', desc: 'Effectiveness, side effects, time to response, long-term outcomes, and insurance coverage.', icon: '💊', category: 'Medication' },
  'tms-vs-ect': { color: 'rose', desc: 'Invasiveness, efficacy for severe depression, cognitive side effects, and treatment logistics.', icon: '⚡', category: 'Procedures' },
  'tms-vs-ketamine': { color: 'violet', desc: 'Mechanism of action, speed of results, treatment protocols, cost, and availability.', icon: '🧪', category: 'Alternative' },
  'tms-vs-psychotherapy': { color: 'blue', desc: 'How TMS and CBT/therapy compare and when to use each alongside the other.', icon: '🗣️', category: 'Therapy' },
  'tms-vs-esketamine': { color: 'pink', desc: 'Spravato nasal spray vs. TMS for treatment-resistant depression — mechanisms, access, cost.', icon: '💨', category: 'Alternative' },
  'tms-vs-psilocybin': { color: 'amber', desc: 'Psychedelic-assisted therapy vs. TMS for depression — evidence, legality, and patient experience.', icon: '🍄', category: 'Experimental' },
  'tms-vs-neurofeedback': { color: 'cyan', desc: 'EEG neurofeedback vs. TMS for depression and anxiety — protocols, outcomes, and accessibility.', icon: '📊', category: 'Biofeedback' },
  'tms-vs-vns': { color: 'slate', desc: 'Vagus nerve stimulation vs. TMS — invasive vs. non-invasive, FDA indications, and outcomes.', icon: '💓', category: 'Device' },
  'tms-vs-dbs': { color: 'orange', desc: 'Deep brain stimulation vs. TMS — invasiveness, target populations, and evidence base.', icon: '🧠', category: 'Surgical' },
  'tms-vs-cbt': { color: 'teal', desc: 'TMS and Cognitive Behavioral Therapy for depression — different mechanisms, combined use.', icon: '🗣️', category: 'Therapy' },
  'tms-vs-transcranial-dcs': { color: 'indigo', desc: 'Transcranial Direct Current Stimulation (tDCS) vs. TMS — intensity, evidence, home use.', icon: '🔋', category: 'Device' },
  'tms-vs-lithium': { color: 'fuchsia', desc: 'TMS for bipolar depression vs. lithium — mood stabilization, rapid cycling, and combination therapy.', icon: '⚗️', category: 'Medication' },
};

const colorMap: Record<string, { bg: string; border: string; text: string; badge: string }> = {
  emerald: { bg: 'bg-emerald-50', border: 'border-emerald-200 hover:border-emerald-400', text: 'text-emerald-600', badge: 'bg-emerald-100 text-emerald-700' },
  blue: { bg: 'bg-blue-50', border: 'border-blue-200 hover:border-blue-400', text: 'text-blue-600', badge: 'bg-blue-100 text-blue-700' },
  rose: { bg: 'bg-rose-50', border: 'border-rose-200 hover:border-rose-400', text: 'text-rose-600', badge: 'bg-rose-100 text-rose-700' },
  violet: { bg: 'bg-violet-50', border: 'border-violet-200 hover:border-violet-400', text: 'text-violet-600', badge: 'bg-violet-100 text-violet-700' },
  amber: { bg: 'bg-amber-50', border: 'border-amber-200 hover:border-amber-400', text: 'text-amber-600', badge: 'bg-amber-100 text-amber-700' },
  pink: { bg: 'bg-pink-50', border: 'border-pink-200 hover:border-pink-400', text: 'text-pink-600', badge: 'bg-pink-100 text-pink-700' },
  cyan: { bg: 'bg-cyan-50', border: 'border-cyan-200 hover:border-cyan-400', text: 'text-cyan-600', badge: 'bg-cyan-100 text-cyan-700' },
  slate: { bg: 'bg-slate-100', border: 'border-slate-300 hover:border-slate-400', text: 'text-slate-600', badge: 'bg-slate-200 text-slate-700' },
  orange: { bg: 'bg-orange-50', border: 'border-orange-200 hover:border-orange-400', text: 'text-orange-600', badge: 'bg-orange-100 text-orange-700' },
  teal: { bg: 'bg-teal-50', border: 'border-teal-200 hover:border-teal-400', text: 'text-teal-600', badge: 'bg-teal-100 text-teal-700' },
  indigo: { bg: 'bg-indigo-50', border: 'border-indigo-200 hover:border-indigo-400', text: 'text-indigo-600', badge: 'bg-indigo-100 text-indigo-700' },
  fuchsia: { bg: 'bg-fuchsia-50', border: 'border-fuchsia-200 hover:border-fuchsia-400', text: 'text-fuchsia-600', badge: 'bg-fuchsia-100 text-fuchsia-700' },
};

const deviceColorMap: Record<string, { bg: string; border: string; text: string; badge: string }> = {
  neurostar: { bg: 'bg-blue-50', border: 'border-blue-200 hover:border-blue-400', text: 'text-blue-600', badge: 'bg-blue-100 text-blue-700' },
  brainsway: { bg: 'bg-emerald-50', border: 'border-emerald-200 hover:border-emerald-400', text: 'text-emerald-600', badge: 'bg-emerald-100 text-emerald-700' },
  magventure: { bg: 'bg-violet-50', border: 'border-violet-200 hover:border-violet-400', text: 'text-violet-600', badge: 'bg-violet-100 text-violet-700' },
  magstim: { bg: 'bg-rose-50', border: 'border-rose-200 hover:border-rose-400', text: 'text-rose-600', badge: 'bg-rose-100 text-rose-700' },
};
---

<Layout title={title} description={description} schema={compareSchema}>
  <main>
    <!-- Hero -->
    <section class="relative bg-slate-950 overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.4) 1px, transparent 0); background-size: 28px 28px;"></div>
      <div class="absolute top-[-20%] right-[10%] w-[600px] h-[600px] bg-blue-500/10 rounded-full blur-[180px]"></div>
      <div class="absolute bottom-[-10%] left-[15%] w-[400px] h-[400px] bg-violet-500/10 rounded-full blur-[140px]"></div>

      <div class="container mx-auto px-4 pt-12 pb-20 lg:pt-16 lg:pb-28 relative z-10">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-12" aria-label="Breadcrumb">
          <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
          <span class="text-slate-700">/</span>
          <span class="text-slate-300">Compare</span>
        </nav>
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-full mb-6">
            <div class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></div>
            <span class="text-xs font-semibold text-slate-300 tracking-wider uppercase">{COMPARE_SLUGS.length} Comparison Guides</span>
          </div>
          <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white leading-[0.95] mb-5">
            Compare<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-violet-400">TMS Options</span>
          </h1>
          <p class="text-lg text-slate-400 leading-relaxed mb-8 max-w-xl">
            Side-by-side comparisons to help you understand treatment options, device differences, and which approach might be right for your situation.
          </p>
          <!-- Quick links -->
          <div class="flex flex-wrap gap-2">
            <a href="/compare/tms-vs-antidepressants/" class="px-3 py-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-xs text-slate-300 transition-colors">TMS vs. Medication</a>
            <a href="/compare/tms-vs-ect/" class="px-3 py-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-xs text-slate-300 transition-colors">TMS vs. ECT</a>
            <a href="/compare/tms-vs-ketamine/" class="px-3 py-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-xs text-slate-300 transition-colors">TMS vs. Ketamine</a>
            <a href="/compare/neurostar-vs-brainsway/" class="px-3 py-1.5 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-xs text-slate-300 transition-colors">NeuroStar vs. BrainsWay</a>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-16 bg-white" style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"></div>
    </section>

    <!-- YouTube Video Section -->
    <section class="py-12 bg-white border-b border-slate-100">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-8">
          <h2 class="text-2xl font-bold text-slate-900 tracking-tight mb-2">Watch: TMS Explained in 5 Minutes</h2>
          <p class="text-slate-500">Quick overview of how TMS works, how it compares to other treatments, and what to expect.</p>
        </div>
        <div class="relative rounded-2xl overflow-hidden shadow-xl border border-slate-100 max-w-3xl mx-auto aspect-video">
          <iframe
            class="w-full h-full"
            src="https://www.youtube.com/embed/gVAVAaobtJo"
            title="TMS Treatment Comparison Overview"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy">
          </iframe>
        </div>
        <div class="text-center mt-4">
          <p class="text-xs text-slate-400">Full comparison videos are in production. Subscribe to get notified when they launch.</p>
        </div>
      </div>
    </section>

    <!-- Treatment Comparisons -->
    <section class="py-16">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex items-end justify-between mb-10">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <div class="w-5 h-5 rounded bg-blue-100 text-blue-600 flex items-center justify-center text-[10px] font-bold">1</div>
              <span class="text-xs font-semibold text-blue-600 uppercase tracking-wider">Treatment Comparisons</span>
            </div>
            <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 tracking-tight">TMS vs. Other Treatments</h2>
            <p class="text-slate-500 mt-1">How does TMS stack up against medications, ECT, ketamine, therapy, and experimental options?</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {treatmentComparisons.map(comp => {
            const meta = comparisonMeta[comp.slug] || { color: 'slate', desc: 'Side-by-side comparison of effectiveness, side effects, and treatment protocols.', icon: '⚖️', category: 'Comparison' };
            const c = colorMap[meta.color] || colorMap.slate;
            return (
              <a href={`/compare/${comp.slug}/`}
                 class={`group bg-white rounded-2xl border ${c.border} p-6 hover:shadow-[0_16px_48px_-12px_rgba(0,0,0,0.10)] transition-all duration-300`}>
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center gap-2">
                    <span class={`px-2.5 py-1 ${c.badge} text-[10px] font-bold uppercase tracking-wider rounded-md`}>{meta.category}</span>
                  </div>
                  <svg class="w-4 h-4 text-slate-300 group-hover:text-blue-500 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </div>
                <h3 class="text-base font-bold text-slate-900 group-hover:text-blue-600 transition-colors mb-2 leading-snug tracking-tight">{comp.title}</h3>
                <p class="text-sm text-slate-500 leading-relaxed">{meta.desc}</p>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Device Comparisons -->
    <section class="py-16 bg-slate-50 border-t border-slate-100">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex items-end justify-between mb-10">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <div class="w-5 h-5 rounded bg-violet-100 text-violet-600 flex items-center justify-center text-[10px] font-bold">2</div>
              <span class="text-xs font-semibold text-violet-600 uppercase tracking-wider">Device Comparisons</span>
            </div>
            <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 tracking-tight">TMS Device Showdown</h2>
            <p class="text-slate-500 mt-1">Compare FDA-cleared TMS machines: coil types, protocols, clinical evidence, and US availability.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {deviceComparisons.map(comp => {
            const deviceSlug = comp.slug.replace(/-(?:vs|versus)-.*$/, '').replace(/-vs-.*$/, '');
            const c = deviceColorMap[deviceSlug] || { bg: 'bg-slate-50', border: 'border-slate-200 hover:border-slate-400', text: 'text-slate-600', badge: 'bg-slate-100 text-slate-700' };
            return (
              <a href={`/compare/${comp.slug}/`}
                 class={`group bg-white rounded-2xl border ${c.border} p-6 hover:shadow-[0_16px_48px_-12px_rgba(0,0,0,0.10)] transition-all duration-300`}>
                <div class="flex items-center justify-between mb-4">
                  <div class="w-8 h-8 rounded-lg bg-violet-50 flex items-center justify-center">
                    <svg class="w-4 h-4 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
                  </div>
                  <svg class="w-4 h-4 text-slate-300 group-hover:text-violet-500 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </div>
                <h3 class="text-base font-bold text-slate-900 group-hover:text-violet-600 transition-colors mb-2 leading-snug tracking-tight">{comp.title}</h3>
                <p class="text-sm text-slate-500 leading-relaxed">Compare coil types, FDA clearances, clinical protocols, and US clinic availability.</p>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- How to Decide -->
    <section class="py-16 bg-white border-t border-slate-100">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-10">
          <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 tracking-tight mb-3">How to Choose the Right Treatment</h2>
          <p class="text-slate-500 max-w-xl mx-auto">Every patient situation is different. Here's how to think through your options systematically.</p>
        </div>

        <!-- Decision Matrix -->
        <div class="overflow-x-auto rounded-2xl border border-slate-100 shadow-sm mb-10">
          <table class="w-full text-sm">
            <thead class="bg-slate-50">
              <tr>
                <th class="text-left px-6 py-4 font-bold text-slate-700">Factor</th>
                <th class="text-left px-6 py-4 font-bold text-slate-700">TMS</th>
                <th class="text-left px-6 py-4 font-bold text-slate-700">Antidepressants</th>
                <th class="text-left px-6 py-4 font-bold text-slate-700">ECT</th>
                <th class="text-left px-6 py-4 font-bold text-slate-700">Ketamine</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              <tr>
                <td class="px-6 py-3.5 font-medium text-slate-700">Invasiveness</td>
                <td class="px-6 py-3.5 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Non-invasive</span></td>
                <td class="px-6 py-3.5 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Oral medication</span></td>
                <td class="px-6 py-3.5 text-slate-600"><span class="px-2 py-1 bg-rose-50 text-rose-600 text-xs rounded-full font-medium">Sedation required</span></td>
                <td class="px-6 py-3.5 text-slate-600"><span class="px-2 py-1 bg-amber-50 text-amber-600 text-xs rounded-full font-medium">IV infusion</span></td>
              </tr>
              <tr class="bg-slate-30/40">
                <td class="px-6 py-3.5 font-medium text-slate-700">Response rate (TRD)</td>
                <td class="px-6 py-3.5 text-slate-600">50–60%</td>
                <td class="px-6 py-3.5 text-slate-600">30–40%</td>
                <td class="px-6 py-3.5 text-slate-600">60–80%</td>
                <td class="px-6 py-3.5 text-slate-600">50–70%</td>
              </tr>
              <tr>
                <td class="px-6 py-3.5 font-medium text-slate-700">Time to effect</td>
                <td class="px-6 py-3.5 text-slate-600">2–6 weeks</td>
                <td class="px-6 py-3.5 text-slate-600">4–8 weeks</td>
                <td class="px-6 py-3.5 text-slate-600">2–4 weeks</td>
                <td class="px-6 py-3.5 text-slate-600">Hours to days</td>
              </tr>
              <tr class="bg-slate-30/40">
                <td class="px-6 py-3.5 font-medium text-slate-700">Cognitive side effects</td>
                <td class="px-6 py-3.5 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">None</span></td>
                <td class="px-6 py-3.5 text-slate-600">Possible (blunting)</td>
                <td class="px-6 py-3.5 text-slate-600"><span class="px-2 py-1 bg-rose-50 text-rose-600 text-xs rounded-full font-medium">Memory risk</span></td>
                <td class="px-6 py-3.5 text-slate-600">Minimal</td>
              </tr>
              <tr>
                <td class="px-6 py-3.5 font-medium text-slate-700">Insurance coverage</td>
                <td class="px-6 py-3.5 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Widely covered</span></td>
                <td class="px-6 py-3.5 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Universal</span></td>
                <td class="px-6 py-3.5 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Widely covered</span></td>
                <td class="px-6 py-3.5 text-slate-600"><span class="px-2 py-1 bg-amber-50 text-amber-600 text-xs rounded-full font-medium">Limited</span></td>
              </tr>
              <tr class="bg-slate-30/40">
                <td class="px-6 py-3.5 font-medium text-slate-700">Daily commitment</td>
                <td class="px-6 py-3.5 text-slate-600">5 days/week × 6 wks</td>
                <td class="px-6 py-3.5 text-slate-600">Daily pill</td>
                <td class="px-6 py-3.5 text-slate-600">2–3×/week × 4 wks</td>
                <td class="px-6 py-3.5 text-slate-600">6 infusions, then maintenance</td>
              </tr>
              <tr>
                <td class="px-6 py-3.5 font-medium text-slate-700">FDA-cleared for</td>
                <td class="px-6 py-3.5 text-slate-600">MDD, OCD, smoking</td>
                <td class="px-6 py-3.5 text-slate-600">Multiple indications</td>
                <td class="px-6 py-3.5 text-slate-600">MDD, bipolar, catatonia</td>
                <td class="px-6 py-3.5 text-slate-600">TRD, bipolar (Spravato)</td>
              </tr>
            </tbody>
          </table>
          <div class="p-4 bg-slate-50 text-xs text-slate-400 text-center border-t border-slate-100">
            TRD = treatment-resistant depression. Data reflects clinical trial ranges and may not reflect individual outcomes.
          </div>
        </div>

        <!-- Decision guide cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          <div class="bg-white rounded-2xl p-7 border border-slate-100 shadow-sm">
