---
import Layout from "../../layouts/Layout.astro";
import { COMPARE_SLUGS } from "../../utils/seo_slugs";

const title = "Compare TMS Treatments & Technologies | TMS List";
const description =
    "Compare TMS therapy with other treatments and compare different TMS devices. Make informed decisions about your mental health treatment.";

const treatmentComparisons = COMPARE_SLUGS.filter(
    (s) =>
        s.slug.includes("tms-vs-") &&
        !s.slug.includes("neurostar") &&
        !s.slug.includes("magventure"),
);

const deviceComparisons = COMPARE_SLUGS.filter(
    (s) =>
        s.slug.includes("neurostar") ||
        s.slug.includes("magventure") ||
        s.slug.includes("brainsway"),
);
---

<Layout title={title} description={description}>
    <main
        class="min-h-screen bg-slate-50"
    >
        <!-- Hero -->
        <section class="relative bg-white border-b border-slate-100 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
            <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-400 mb-6 justify-center">
                    <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-slate-600 font-medium">Compare</span>
                </nav>
                <div class="text-center">
                    <span
                        class="inline-block px-4 py-1.5 bg-violet-50 text-violet-700 rounded-full text-sm font-semibold uppercase tracking-wider mb-4"
                    >
                        Comparison Guides
                    </span>
                    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-slate-900 mb-4">
                        Compare <span class="text-violet-600">TMS Treatments</span>
                    </h1>
                    <p class="text-xl text-slate-500 max-w-2xl mx-auto">
                        Make informed decisions with our detailed side-by-side
                        comparisons of TMS therapy vs other treatments and different
                        TMS technologies.
                    </p>
                </div>
            </div>
        </section>

        <div class="container mx-auto px-6 max-w-6xl py-16">

            <!-- Treatment Comparisons -->
            <section class="mb-16">
                <h2
                    class="text-2xl font-semibold text-slate-900 mb-8 flex items-center gap-3"
                >
                    <span
                        class="w-10 h-10 rounded-full bg-violet-50 text-violet-600 flex items-center justify-center"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                    </span>
                    TMS vs Other Treatments
                </h2>
                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
                >
                    {
                        treatmentComparisons.map((comparison) => (
                            <a
                                href={`/compare/${comparison.slug}/`}
                                class="group bg-white border border-slate-100 shadow-sm rounded-2xl p-6 hover:shadow-md hover:border-violet-500/50 transition-all hover:-translate-y-1"
                            >
                                <div class="flex items-center justify-between mb-4">
                                    <span class="w-8 h-8 rounded-lg bg-violet-50 flex items-center justify-center"><svg class="w-4 h-4 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></span>
                                    <svg
                                        class="w-5 h-5 text-slate-500 group-hover:text-violet-600 transition-colors"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 5l7 7-7 7"
                                        />
                                    </svg>
                                </div>
                                <h3 class="text-lg font-semibold text-slate-900 mb-2">
                                    {comparison.title}
                                </h3>
                                <p class="text-sm text-slate-500">
                                    Compare effectiveness, side effects, cost,
                                    and treatment duration
                                </p>
                            </a>
                        ))
                    }
                </div>
            </section>

            <!-- Device Comparisons -->
            <section class="mb-16">
                <h2
                    class="text-2xl font-semibold text-slate-900 mb-8 flex items-center gap-3"
                >
                    <span
                        class="w-10 h-10 rounded-full bg-violet-50 text-blue-600 flex items-center justify-center"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"
                            ></path>
                        </svg>
                    </span>
                    TMS Device Comparisons
                </h2>
                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
                >
                    {
                        deviceComparisons.map((comparison) => (
                            <a
                                href={`/compare/${comparison.slug}/`}
                                class="group bg-white border border-slate-100 shadow-sm rounded-2xl p-6 hover:shadow-md hover:border-blue-500/50 transition-all hover:-translate-y-1"
                            >
                                <div class="flex items-center justify-between mb-4">
                                    <span class="w-8 h-8 rounded-lg bg-violet-50 flex items-center justify-center"><svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg></span>
                                    <svg
                                        class="w-5 h-5 text-slate-500 group-hover:text-blue-600 transition-colors"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 5l7 7-7 7"
                                        />
                                    </svg>
                                </div>
                                <h3 class="text-lg font-semibold text-slate-900 mb-2">
                                    {comparison.title}
                                </h3>
                                <p class="text-sm text-slate-500">
                                    Compare technology, FDA approvals, treatment
                                    protocols, and availability
                                </p>
                            </a>
                        ))
                    }
                </div>
            </section>

            <!-- How to Decide -->
            <section class="mb-16 bg-white rounded-2xl border border-slate-100 shadow-sm p-8 lg:p-10">
                <h2 class="text-xl font-bold text-slate-900 mb-6">How to Choose the Right Treatment</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="flex items-start gap-3">
                        <div class="w-8 h-8 rounded-lg bg-violet-50 flex items-center justify-center text-violet-600 shrink-0 mt-0.5">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="font-semibold text-slate-900 mb-1">Check FDA Status</h3>
                            <p class="text-sm text-slate-500 leading-relaxed">TMS is FDA-cleared for depression and OCD. Other treatments may have different approval levels.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600 shrink-0 mt-0.5">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="font-semibold text-slate-900 mb-1">Compare Costs</h3>
                            <p class="text-sm text-slate-500 leading-relaxed">Insurance coverage, out-of-pocket costs, and total treatment duration vary significantly between options.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center text-emerald-600 shrink-0 mt-0.5">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                        </div>
                        <div>
                            <h3 class="font-semibold text-slate-900 mb-1">Side Effects</h3>
                            <p class="text-sm text-slate-500 leading-relaxed">TMS has minimal side effects compared to medications and ECT. Each option has a different risk profile.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Compare Clinics CTA -->
            <section
                class="bg-gradient-to-br from-violet-50 to-blue-50 border border-violet-100 rounded-2xl p-8 md:p-12 text-center"
            >
                <h2 class="text-3xl font-semibold text-slate-900 mb-4">
                    Compare Specific Clinics
                </h2>
                <p class="text-lg text-slate-600 mb-8 max-w-2xl mx-auto">
                    Want to compare two or more TMS clinics in your area? Browse
                    our verified clinics and use the compare feature to see them
                    side-by-side.
                </p>
                <a
                    href="/verified-clinics/"
                    class="inline-flex items-center gap-2 px-8 py-4 bg-violet-600 text-white font-semibold rounded-xl hover:bg-violet-700 transition-colors shadow-lg shadow-violet-500/30"
                >
                    <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                        ></path>
                    </svg>
                    Browse Verified Clinics
                </a>
            </section>
        </div>
    </main>
</Layout>
