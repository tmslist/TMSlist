---
import Layout from '../../layouts/Layout.astro';

const title = "Accessibility Statement | WCAG 2.1 AA Compliance | TMS List";
const description = "TMS List is committed to WCAG 2.1 AA accessibility. Learn about our semantic HTML, ARIA labels, keyboard navigation, color contrast, and screen reader support.";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Accessibility Statement",
    "description": description,
    "publisher": {
        "@type": "Organization",
        "name": "TMS List",
        "url": "https://tmslist.com"
    }
});

const measures = [
    { title: "Semantic HTML", desc: "All pages use proper heading hierarchy (h1-h6), landmark regions (nav, main, footer), and meaningful document structure for assistive technology.", icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4", color: "violet" },
    { title: "ARIA Labels", desc: "Interactive elements, navigation menus, modals, and dynamic content include appropriate ARIA attributes (aria-label, aria-describedby, aria-live).", icon: "M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z", color: "blue" },
    { title: "Keyboard Navigation", desc: "Every interactive element is fully operable via keyboard. Focus indicators are visible, and tab order follows logical reading sequence. Skip-to-content links are provided.", icon: "M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z", color: "amber" },
    { title: "Color Contrast", desc: "Text and interactive elements meet WCAG 2.1 AA minimum contrast ratios: 4.5:1 for normal text and 3:1 for large text. Information is never conveyed by color alone.", icon: "M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01", color: "emerald" },
    { title: "Screen Reader Support", desc: "Content is tested with VoiceOver (macOS/iOS), NVDA (Windows), and TalkBack (Android). Images include descriptive alt text. Decorative images are hidden from assistive technology.", icon: "M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z", color: "cyan" },
    { title: "Responsive & Zoom", desc: "The site is fully responsive from 320px to 2560px and supports browser zoom up to 200% without loss of content or functionality. Text can be resized without breaking layout.", icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7", color: "rose" },
];

const colorMap: Record<string, { bg: string; text: string }> = {
    violet: { bg: 'bg-[rgba(10,22,40,0.08)]', text: 'text-[var(--accent)]' },
    blue: { bg: 'bg-[var(--paper2)]', text: 'text-[var(--accent)]' },
    amber: { bg: 'bg-amber-50', text: 'text-amber-600' },
    emerald: { bg: 'bg-emerald-50', text: 'text-emerald-600' },
    cyan: { bg: 'bg-[var(--paper2)]', text: 'text-[var(--accent)]' },
    rose: { bg: 'bg-[rgba(201,101,74,0.06)]', text: 'text-[var(--warm)]' },
};
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Accessibility", url: "/accessibility/" },
]}>
    <main>
        <!-- Hero -->
        <section class="relative bg-[var(--paper)] border-b border-[var(--line)] overflow-hidden">
            <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
            <div class="absolute top-[-10%] right-[20%] w-[500px] h-[500px] bg-[rgba(34,197,94,0.05)] rounded-full blur-[150px]"></div>
            <div class="absolute bottom-[5%] left-[10%] w-[350px] h-[350px] bg-[var(--accent2)]/8 rounded-full blur-[100px]"></div>

            <div class="container mx-auto px-4 pt-12 pb-20 lg:pt-16 lg:pb-28 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-[var(--muted)] mb-12" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-[var(--accent2)] transition-colors">Home</a>
                    <span class="text-[var(--ink2)]">/</span>
                    <span class="text-[var(--muted)]">Accessibility</span>
                </nav>

                <div class="max-w-3xl">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-[var(--paper2)] border border-[var(--line)] rounded-full mb-6">
                        <span class="flex h-2 w-2 rounded-full bg-emerald-400"></span>
                        <span class="text-xs font-semibold text-[var(--muted)] tracking-wide">WCAG 2.1 AA</span>
                    </div>
                    <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-[var(--ink)] leading-[0.95] mb-6">
                        Accessibility<br/>
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-[var(--ink2)]">Statement</span>
                    </h1>
                    <p class="text-lg text-[var(--muted)] leading-relaxed max-w-xl">
                        Mental health resources should be accessible to everyone. TMS List is committed to ensuring our platform is usable by people of all abilities.
                    </p>
                </div>
            </div>
            
        </section>

        <!-- Commitment -->
        <section class="py-16 lg:py-24 bg-[var(--paper)]">
            <div class="container mx-auto px-4 max-w-4xl">
                <div class="bg-[rgba(34,197,94,0.05)] border border-emerald-100 rounded-3xl p-8 lg:p-12 mb-16">
                    <div class="flex items-start gap-5">
                        <div class="w-14 h-14 rounded-2xl bg-emerald-100 flex items-center justify-center shrink-0">
                            <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                        </div>
                        <div>
                            <h2 class="text-2xl font-bold text-[var(--ink)] mb-3">Our Commitment</h2>
                            <p class="text-[var(--muted)] leading-relaxed mb-4">
                                TMS List is committed to conforming with the <strong>Web Content Accessibility Guidelines (WCAG) 2.1 Level AA</strong> standards. We believe that access to mental health information and provider directories is a fundamental need, and we strive to make our platform inclusive for all users, including those with visual, auditory, motor, or cognitive disabilities.
                            </p>
                            <p class="text-[var(--muted)] leading-relaxed">
                                This commitment extends to our website, mobile experience, and all interactive tools including our clinic search, comparison features, and candidacy quiz.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- What We've Done -->
                <div class="mb-16">
                    <h2 class="text-3xl font-bold text-[var(--ink)] tracking-tight mb-10 text-center">What We Have Implemented</h2>
                    <div class="grid md:grid-cols-2 gap-6">
                        {measures.map((m) => (
                            <div class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] p-6 hover:shadow-md hover:border-[var(--line)] transition-all">
                                <div class={`w-12 h-12 rounded-xl ${colorMap[m.color].bg} ${colorMap[m.color].text} flex items-center justify-center mb-4`}>
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={m.icon}/></svg>
                                </div>
                                <h3 class="text-lg font-bold text-[var(--ink)] mb-2">{m.title}</h3>
                                <p class="text-[var(--muted)] text-sm leading-relaxed">{m.desc}</p>
                            </div>
                        ))}
                    </div>
                </div>

                <!-- Ongoing Efforts -->
                <div class="mb-16">
                    <h2 class="text-2xl font-bold text-[var(--ink)] tracking-tight mb-6">Ongoing Efforts</h2>
                    <div class="space-y-4">
                        <div class="flex items-start gap-4 p-5 bg-[var(--paper2)] rounded-xl">
                            <div class="w-6 h-6 rounded-full bg-[var(--accent2)] text-[var(--ink)] flex items-center justify-center shrink-0 mt-0.5">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                            </div>
                            <p class="text-[var(--muted)] leading-relaxed">Regular automated and manual accessibility audits using axe, Lighthouse, and WAVE tools</p>
                        </div>
                        <div class="flex items-start gap-4 p-5 bg-[var(--paper2)] rounded-xl">
                            <div class="w-6 h-6 rounded-full bg-[var(--accent2)] text-[var(--ink)] flex items-center justify-center shrink-0 mt-0.5">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                            </div>
                            <p class="text-[var(--muted)] leading-relaxed">User testing with individuals who use assistive technologies, including screen readers and switch devices</p>
                        </div>
                        <div class="flex items-start gap-4 p-5 bg-[var(--paper2)] rounded-xl">
                            <div class="w-6 h-6 rounded-full bg-[var(--accent2)] text-[var(--ink)] flex items-center justify-center shrink-0 mt-0.5">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                            </div>
                            <p class="text-[var(--muted)] leading-relaxed">Staff training on accessible content authoring, including proper alt text, link descriptions, and heading structure</p>
                        </div>
                        <div class="flex items-start gap-4 p-5 bg-[var(--paper2)] rounded-xl">
                            <div class="w-6 h-6 rounded-full bg-[var(--accent2)] text-[var(--ink)] flex items-center justify-center shrink-0 mt-0.5">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                            </div>
                            <p class="text-[var(--muted)] leading-relaxed">Continuous improvement of form labels, error messages, and validation feedback for clinic search and contact forms</p>
                        </div>
                    </div>
                </div>

                <!-- Contact -->
                <div class="bg-[var(--paper2)]/50 border border-[var(--line)] rounded-2xl p-8">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-[rgba(10,22,40,0.1)] flex items-center justify-center shrink-0">
                            <svg class="w-6 h-6 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-xl font-bold text-[var(--ink)] mb-3">Report an Accessibility Issue</h3>
                            <p class="text-[var(--muted)] leading-relaxed mb-4">
                                If you encounter any accessibility barriers on TMS List, we want to hear from you. Please contact us with a description of the issue, the page URL, and the assistive technology you were using (if applicable).
                            </p>
                            <div class="space-y-2 text-sm">
                                <p class="text-[var(--muted)]"><strong>Email:</strong> <a href="mailto:tmslistofficial@gmail.com?subject=Accessibility Concern" class="inline-flex items-center gap-2 px-4 py-2 bg-[var(--ink)] hover:bg-[var(--ink2)] text-white text-sm font-semibold rounded-lg transition-colors">Contact Us</a></p>
                                <p class="text-[var(--muted)]"><strong>Response time:</strong> We aim to respond within 2 business days and resolve issues within 10 business days.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <p class="text-sm text-[var(--muted)] mt-8 text-center">This accessibility statement was last updated on April 10, 2026.</p>
            </div>
        </section>

        <!-- CTA -->
        <section class="relative py-20 bg-[var(--ink)] overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-[#0A1628]/10 via-transparent to-[rgba(10,22,40,0.10)]"></div>
            <div class="container mx-auto px-4 text-center relative z-10">
                <p class="text-sm font-semibold text-[var(--accent2)] tracking-wider uppercase mb-4">Accessible Care for Everyone</p>
                <h2 class="text-3xl lg:text-4xl font-bold text-[var(--ink)] mb-4 tracking-tight">Find a TMS provider near you</h2>
                <p class="text-[var(--muted)] max-w-lg mx-auto mb-10">Our directory is designed to be usable by everyone. Start your search for a verified TMS clinic today.</p>
                <div class="flex items-center justify-center gap-4 flex-wrap">
                    <a href="/quiz/am-i-a-candidate/" class="px-8 py-4 bg-[var(--ink)] hover:bg-[var(--ink2)] text-white font-semibold rounded-xl transition-colors shadow-lg shadow-[rgba(10,22,40,0.2)]">
                        Am I a Candidate?
                    </a>
                    <a href="/us/" class="px-8 py-4 bg-[var(--paper2)] border border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] text-[var(--ink)] font-semibold rounded-xl transition-all backdrop-blur">
                        Browse Clinics
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>
