---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import PortalLeads from "../../components/react/PortalLeads";
import PortalSidebar from "../../components/react/PortalSidebar";
import { getSessionFromRequest, hasRole } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!session) {
  return Astro.redirect("/portal/login");
}
if (!hasRole(session, 'admin', 'editor', 'clinic_owner')) {
  return Astro.redirect("/portal/login");
}
---

<Layout title="Enquiries | Doctor Portal | TMS List" description="View enquiries for your clinic." noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <PortalSidebar client:load currentPage="leads" userEmail={session.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-5xl">
        <PortalLeads client:load />
      </div>
    </main>
  </div>
</Layout>
