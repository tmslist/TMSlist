---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import PortalClaimClinic from "../../components/react/PortalClaimClinic";
import PortalSidebar from "../../components/react/PortalSidebar";
import { getSessionFromRequest } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!session) {
  return Astro.redirect("/portal/login/");
}
---

<Layout title="Claim Your Clinic | Doctor Portal | TMS List" description="Claim your clinic listing on TMS List." noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <PortalSidebar client:load currentPage="claim" userEmail={session.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-5xl">
        <PortalClaimClinic client:load userId={session.userId} userEmail={session.email} />
      </div>
    </main>
  </div>
</Layout>
