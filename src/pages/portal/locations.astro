---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import PortalLocations from '../../components/react/PortalLocations';
import PortalSidebar from '../../components/react/PortalSidebar';
import { getSessionFromRequest, hasRole } from '../../utils/auth';

const session = getSessionFromRequest(Astro.request);
if (!session || !hasRole(session, 'admin', 'editor', 'clinic_owner', 'viewer')) {
  return Astro.redirect('/portal/login/');
}
---

<Layout title="Locations | Doctor Portal | TMS List" description="Manage your clinic locations" noindex={true}>
  <div class="flex min-h-screen bg-[var(--paper2)]">
    <PortalSidebar client:load currentPage="locations" userEmail={session.email} userId={session.userId} />
    <main class="flex-1 md:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-3xl">
        <div class="mb-8">
          <h1 class="text-2xl font-bold text-[var(--ink)]">Locations</h1>
          <p class="text-[var(--muted)] mt-1">Manage your clinic's physical locations</p>
        </div>
        <PortalLocations client:load />
      </div>
    </main>
  </div>
</Layout>