---
import Layout from '../../layouts/Layout.astro';
import { getSessionFromRequest, hasRole } from '../../utils/auth';
import { getClinicPlan, getClinicSubscription, PLANS } from '../../db/subscriptions';
import { db } from '../../db';
import { users } from '../../db/schema';
import { eq } from 'drizzle-orm';

const session = getSessionFromRequest(Astro.request);
if (!session || !hasRole(session, 'clinic_owner', 'admin')) {
  return Astro.redirect('/portal/login');
}

// Get clinicId from user record
const [user] = await db.select().from(users).where(eq(users.id, session.userId)).limit(1);
const clinicId = user?.clinicId || (session as any).clinicId || null;
const success = Astro.url.searchParams.get('subscribed') === 'pro' || Astro.url.searchParams.get('subscribed') === 'premium' || Astro.url.searchParams.get('subscribed') === 'enterprise' || Astro.url.searchParams.get('success') === 'true';
const canceled = Astro.url.searchParams.get('canceled') === 'true';

let subscription = null;
let plan: 'free' | 'pro' | 'premium' | 'enterprise' = 'free';
let features = PLANS.free.features;

if (clinicId) {
  subscription = await getClinicSubscription(clinicId);
  plan = await getClinicPlan(clinicId);
  features = PLANS[plan].features;
}

const featuresList = [
  { key: 'listing', label: 'Listing Visibility', free: 'Basic', pro: 'Full', premium: 'Featured', enterprise: 'Priority' },
  { key: 'photos', label: 'Clinic Photos', free: '1 photo', pro: '5 photos', premium: '20 photos', enterprise: 'Unlimited' },
  { key: 'devices', label: 'TMS Devices & Protocols', free: false, pro: true, premium: true, enterprise: true },
  { key: 'insurance', label: 'Insurance Carriers', free: false, pro: true, premium: true, enterprise: true },
  { key: 'doctors', label: 'Doctor Profiles', free: false, pro: true, premium: true, enterprise: true },
  { key: 'leadCapture', label: 'Lead Capture', free: 'Form only', pro: 'Instant', premium: 'AI routing', enterprise: 'AI + phone' },
  { key: 'leadDashboard', label: 'Lead Dashboard', free: false, pro: false, premium: true, enterprise: true },
  { key: 'analytics', label: 'Analytics', free: false, pro: false, premium: true, enterprise: true },
  { key: 'chatbot', label: 'AI Chatbot', free: false, pro: false, premium: false, enterprise: true },
  { key: 'multiLocation', label: 'Multi-Location', free: false, pro: false, premium: false, enterprise: true },
  { key: 'apiAccess', label: 'API Access', free: false, pro: false, premium: false, enterprise: true },
  { key: 'support', label: 'Support', free: false, pro: 'Email', premium: 'Priority', enterprise: 'Dedicated' },
];
---

<Layout title="Billing & Plan" session={session}>
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Billing & Plan</h1>
    <p class="text-gray-500 mt-1">Manage your subscription and billing settings</p>
  </div>

  {success && (
    <div class="mb-6 bg-green-50 border border-green-200 rounded-xl p-4 flex items-center gap-3">
      <svg class="w-5 h-5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      <div>
        <p class="text-green-800 font-semibold text-sm">Subscription activated!</p>
        <p class="text-green-700 text-xs">Your plan has been upgraded. New features are now live on your listing. Payments processed by Stripe Inc.</p>
      </div>
    </div>
  )}

  {canceled && (
    <div class="mb-6 bg-amber-50 border border-amber-200 rounded-xl p-4 flex items-center gap-3">
      <svg class="w-5 h-5 text-amber-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      <div>
        <p class="text-amber-800 font-semibold text-sm">Checkout canceled</p>
        <p class="text-amber-700 text-xs">No charges were made. You can try again anytime.</p>
      </div>
    </div>
  )}

  <!-- Current Plan -->
  <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Current Plan</h2>
      <span class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-bold ${
        plan === 'enterprise' ? 'bg-slate-900 text-white' :
        plan === 'premium' ? 'bg-violet-100 text-violet-700' :
        plan === 'pro' ? 'bg-blue-100 text-blue-700' :
        'bg-gray-100 text-gray-600'
      }`}>
        {PLANS[plan].name}
        {subscription?.status === 'past_due' ? ' — Past Due' : ''}
        {subscription?.status === 'canceled' ? ' — Canceled' : ''}
      </span>
    </div>

    {subscription?.currentPeriodEnd && (
      <p class="text-sm text-gray-500">
        {subscription.status === 'canceled' ? 'Access until' : 'Next billing'}:
        {new Date(subscription.currentPeriodEnd).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}
      </p>
    )}

    {plan === 'free' && (
      <p class="text-sm text-gray-500">Free forever — no card required.</p>
    )}
  </div>

  <!-- Feature Comparison -->
  <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Plan Comparison</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100">
            <th class="text-left py-3 pr-4 font-medium text-gray-500">Feature</th>
            <th class="text-center py-3 px-3 font-medium text-gray-700">Free<br><span class="text-xs font-normal text-gray-400">$0</span></th>
            <th class="text-center py-3 px-3 font-medium text-blue-700">Pro<br><span class="text-xs font-normal text-gray-400">$18/mo</span></th>
            <th class="text-center py-3 px-3 font-medium text-violet-700">Premium<br><span class="text-xs font-normal text-gray-400">$30/mo</span></th>
            <th class="text-center py-3 px-3 font-medium text-slate-700">Enterprise<br><span class="text-xs font-normal text-gray-400">$60/mo</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          {featuresList.map(row => (
            <tr>
              <td class="py-3 pr-4 text-gray-700">{row.label}</td>
              <td class="py-3 px-3 text-center text-gray-500">{typeof row.free === 'boolean' ? (row.free ? '✓' : '—') : row.free}</td>
              <td class={`py-3 px-3 text-center font-medium ${plan === 'pro' ? 'text-blue-600' : 'text-gray-700'}`}>{typeof row.pro === 'boolean' ? (row.pro ? '✓' : '—') : row.pro}</td>
              <td class={`py-3 px-3 text-center font-medium ${plan === 'premium' ? 'text-violet-600' : 'text-gray-700'}`}>{typeof row.premium === 'boolean' ? (row.premium ? '✓' : '—') : row.premium}</td>
              <td class={`py-3 px-3 text-center font-medium ${plan === 'enterprise' ? 'text-violet-600' : 'text-gray-700'}`}>{typeof row.enterprise === 'boolean' ? (row.enterprise ? '✓' : '—') : row.enterprise}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Upgrade Section -->
  {plan !== 'enterprise' && (
    <div class="bg-gradient-to-br from-slate-900 to-slate-800 rounded-xl p-6 mb-6">
      <div class="flex items-start justify-between gap-6">
        <div>
          <h2 class="text-white font-semibold text-lg mb-1">
            {plan === 'free' ? 'Upgrade to Pro' : plan === 'pro' ? 'Upgrade to Premium' : 'Upgrade to Enterprise'}
          </h2>
          <p class="text-slate-400 text-sm">
            {plan === 'free' ? 'Show devices, insurance carriers, and doctor profiles to attract more patients.'
              : plan === 'pro' ? 'Get featured placement, AI lead routing, and advanced analytics.'
              : 'Unlock multi-location management, API access, and dedicated support.'}
          </p>
        </div>
        <div class="text-right shrink-0">
          <div class="text-white font-bold text-2xl">
            {plan === 'free' ? '$18' : plan === 'pro' ? '$30' : '$60'}<span class="text-slate-400 text-sm font-normal">/mo</span>
          </div>
          <button
            id="upgrade-btn"
            data-plan={plan === 'free' ? 'pro' : plan === 'pro' ? 'premium' : 'enterprise'}
            class="mt-3 inline-block w-full text-center bg-violet-600 hover:bg-violet-500 text-white font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm cursor-pointer"
          >
            {plan === 'free' ? 'Upgrade to Pro' : plan === 'pro' ? 'Upgrade to Premium' : 'Upgrade to Enterprise'} →
          </button>
        </div>
      </div>
    </div>
  )}

  <!-- Cancel -->
  {plan !== 'free' && (
    <div class="text-center">
      <button
        id="cancel-btn"
        class="text-gray-400 hover:text-red-600 text-sm font-medium transition-colors"
      >
        Cancel subscription
      </button>
    </div>
  )}

  <!-- Cancel confirmation modal -->
  <div id="cancel-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
    <div class="bg-white rounded-xl p-6 max-w-sm w-full mx-4 shadow-2xl">
      <h3 class="text-lg font-bold text-gray-900 mb-2">Cancel subscription?</h3>
      <p class="text-gray-500 text-sm mb-5">Your listing will revert to the free tier. You can upgrade again anytime.</p>
      <div class="flex gap-3">
        <button id="cancel-confirm" class="flex-1 py-2.5 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg transition-colors text-sm">
          Yes, cancel
        </button>
        <button id="cancel-close" class="flex-1 py-2.5 border border-gray-200 text-gray-600 font-medium rounded-lg hover:bg-gray-50 transition-colors text-sm">
          Keep subscription
        </button>
      </div>
    </div>
  </div>

  <!-- Company & Payment Info -->
  <div class="mt-8 pt-6 border-t border-gray-100 flex flex-col sm:flex-row items-start sm:items-center gap-4">
    <div class="text-xs text-gray-400 space-y-0.5">
      <p>Payments processed by <strong class="text-gray-500">Stripe Inc.</strong></p>
      <p>&copy; 2026 ATZ Medappz Pvt Ltd &middot; <a href="/legal/privacy-policy/" class="hover:text-gray-600 underline">Privacy Policy</a> &middot; <a href="/legal/terms-of-service/" class="hover:text-gray-600 underline">Terms of Service</a></p>
    </div>
    <a href="https://stripe.com" target="_blank" rel="noopener noreferrer" class="ml-auto flex items-center gap-1.5 text-xs text-gray-400 hover:text-gray-600 transition-colors shrink-0">
      <svg class="h-4 w-auto" viewBox="0 0 60 25" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M5.45 10.2c0-.86.7-1.18 1.87-1.18 1.66 0 3.78.5 5.46 1.4V5.88C10.93 5.24 9.07 4.98 7.32 4.98 3.3 4.98 0 7.1 0 10.43c0 5.2 7.1 4.37 7.1 6.62 0 .99-.87 1.34-2.1 1.34-1.83 0-4.14-.76-5.96-1.7v4.66c1.97.8 3.95 1.13 5.96 1.13 4.08 0 7.4-1.68 7.4-5.12-.02-5.76-7.02-4.65-7.02-6.83v-.03h.07z" fill="#635BFF"/>
        <path d="M20.03 4.8h4.8l-4.8 4.8h4.8l-4.8 4.8h4.8l-4.8 4.8h8.64v-1.92H23.67l4.8-4.8h-3.84l4.8-4.8h-3.84l4.8-4.8H20.03v1.92z" fill="#635BFF"/>
      </svg>
    </a>
  </div>
</Layout>

<script>
  const upgradeBtn = document.getElementById('upgrade-btn');
  const cancelBtn = document.getElementById('cancel-btn');
  const cancelModal = document.getElementById('cancel-modal');
  const cancelConfirm = document.getElementById('cancel-confirm');
  const cancelClose = document.getElementById('cancel-close');

  if (upgradeBtn) {
    upgradeBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      const plan = upgradeBtn.getAttribute('data-plan')!;
      upgradeBtn.textContent = 'Redirecting to Stripe...';
      upgradeBtn.classList.add('opacity-50', 'pointer-events-none');

      try {
        const res = await fetch('/api/payments/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ plan }),
        });
        const data = await res.json();
        if (data.checkoutUrl) {
          window.location.href = data.checkoutUrl;
        } else {
          alert('Could not create checkout. Please try again.');
          upgradeBtn.textContent = plan === 'pro' ? 'Upgrade to Pro →' : plan === 'premium' ? 'Upgrade to Premium →' : 'Upgrade to Enterprise →';
          upgradeBtn.classList.remove('opacity-50', 'pointer-events-none');
        }
      } catch {
        alert('Network error. Please try again.');
        upgradeBtn.textContent = plan === 'pro' ? 'Upgrade to Pro →' : plan === 'premium' ? 'Upgrade to Premium →' : 'Upgrade to Enterprise →';
        upgradeBtn.classList.remove('opacity-50', 'pointer-events-none');
      }
    });
  }

  if (cancelBtn && cancelModal) {
    cancelBtn.addEventListener('click', () => cancelModal.classList.remove('hidden'));
    cancelClose?.addEventListener('click', () => cancelModal.classList.add('hidden'));
    cancelConfirm?.addEventListener('click', async () => {
      cancelModal.classList.add('hidden');
      const res = await fetch('/api/payments/portal', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'cancel' }),
      });
      if (res.ok) {
        window.location.reload();
      } else {
        alert('Could not cancel subscription. Please contact support.');
      }
    });
  }
</script>