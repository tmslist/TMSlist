---
import Layout from '../../layouts/Layout.astro';
import { getSessionFromRequest, hasRole } from '../../utils/auth';
import { getClinicPlan, getClinicSubscription, PLANS } from '../../db/subscriptions';

const session = getSessionFromRequest(Astro.request);
if (!session || !hasRole(session, 'clinic_owner', 'admin')) {
  return Astro.redirect('/portal/login');
}

const clinicId = (session as any).clinicId as string;
const success = Astro.url.searchParams.get('success') === 'true';
const canceled = Astro.url.searchParams.get('canceled') === 'true';

let subscription = null;
let plan: 'free' | 'pro' | 'enterprise' = 'free';
let features = PLANS.free.features;

if (clinicId) {
  subscription = await getClinicSubscription(clinicId);
  plan = await getClinicPlan(clinicId);
  features = PLANS[plan].features;
}

const featuresList = [
  { key: 'listing', label: 'Full Listing Visibility', free: 'Basic', pro: 'Full', enterprise: 'Priority Placement' },
  { key: 'photos', label: 'Clinic Photos', free: '1 photo', pro: '5 photos', enterprise: 'Unlimited' },
  { key: 'devices', label: 'TMS Devices & Protocols', free: false, pro: true, enterprise: true },
  { key: 'insurance', label: 'Accepted Insurance Carriers', free: false, pro: true, enterprise: true },
  { key: 'doctors', label: 'Doctor Profiles', free: false, pro: true, enterprise: true },
  { key: 'leadCapture', label: 'Lead Capture', free: 'Contact form only', pro: 'Instant email + phone', enterprise: 'Instant + phone' },
  { key: 'leadDashboard', label: 'Lead Management Dashboard', free: false, pro: false, enterprise: true },
  { key: 'analytics', label: 'Analytics & Insights', free: false, pro: false, enterprise: true },
  { key: 'chatbot', label: 'AI Chatbot Widget', free: false, pro: false, enterprise: true },
];
---

<Layout title="Billing & Plan" session={session}>
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Billing & Plan</h1>
    <p class="text-gray-500 mt-1">Manage your subscription and billing settings</p>
  </div>

  {success && (
    <div class="mb-6 bg-green-50 border border-green-200 rounded-xl p-4 flex items-center gap-3">
      <svg class="w-5 h-5 text-green-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      <div>
        <p class="text-green-800 font-semibold text-sm">Subscription activated!</p>
        <p class="text-green-700 text-xs">Your plan has been upgraded. New features are now live on your listing.</p>
      </div>
    </div>
  )}

  {canceled && (
    <div class="mb-6 bg-amber-50 border border-amber-200 rounded-xl p-4 flex items-center gap-3">
      <svg class="w-5 h-5 text-amber-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      <div>
        <p class="text-amber-800 font-semibold text-sm">Checkout canceled</p>
        <p class="text-amber-700 text-xs">No charges were made. You can try again anytime.</p>
      </div>
    </div>
  )}

  <!-- Current Plan -->
  <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Current Plan</h2>
      <span class={`inline-flex items-center px-3 py-1 rounded-full text-sm font-bold ${
        plan === 'enterprise' ? 'bg-violet-100 text-violet-700' :
        plan === 'pro' ? 'bg-emerald-100 text-emerald-700' :
        'bg-gray-100 text-gray-600'
      }`}>
        {PLANS[plan].name}
        {subscription?.status === 'past_due' ? ' — Past Due' : ''}
        {subscription?.status === 'canceled' ? ' — Canceled' : ''}
      </span>
    </div>

    {subscription?.currentPeriodEnd && (
      <p class="text-sm text-gray-500">
        {subscription.status === 'canceled' ? 'Access until' : 'Next billing'}:
        {new Date(subscription.currentPeriodEnd).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}
      </p>
    )}

    {plan === 'free' && (
      <p class="text-sm text-gray-500">Free forever — no card required.</p>
    )}
  </div>

  <!-- Feature Comparison -->
  <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Plan Comparison</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-100">
            <th class="text-left py-3 pr-4 font-medium text-gray-500">Feature</th>
            <th class="text-center py-3 px-3 font-medium text-gray-700">Free</th>
            <th class="text-center py-3 px-3 font-medium text-emerald-700">Pro<br><span class="text-xs font-normal text-gray-400">₹1,499/mo</span></th>
            <th class="text-center py-3 px-3 font-medium text-violet-700">Enterprise<br><span class="text-xs font-normal text-gray-400">₹4,999/mo</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          {featuresList.map(row => (
            <tr>
              <td class="py-3 pr-4 text-gray-700">{row.label}</td>
              <td class="py-3 px-3 text-center text-gray-500">{typeof row.free === 'boolean' ? (row.free ? '✓' : '—') : row.free}</td>
              <td class={`py-3 px-3 text-center font-medium ${plan === 'pro' ? 'text-emerald-600' : 'text-gray-700'}`}>{typeof row.pro === 'boolean' ? (row.pro ? '✓' : '—') : row.pro}</td>
              <td class={`py-3 px-3 text-center font-medium ${plan === 'enterprise' ? 'text-violet-600' : 'text-gray-700'}`}>{typeof row.enterprise === 'boolean' ? (row.enterprise ? '✓' : '—') : row.enterprise}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Upgrade Section -->
  {plan !== 'enterprise' && (
    <div class="bg-gradient-to-br from-slate-900 to-slate-800 rounded-xl p-6 mb-6">
      <div class="flex items-start justify-between gap-6">
        <div>
          <h2 class="text-white font-semibold text-lg mb-1">
            {plan === 'free' ? 'Upgrade to Pro' : 'Upgrade to Enterprise'}
          </h2>
          <p class="text-slate-400 text-sm">
            {plan === 'free'
              ? 'Show your devices, insurance carriers, and doctor profiles to attract more patients.'
              : 'Unlock the lead dashboard, analytics, and AI chatbot to grow your practice.'}
          </p>
        </div>
        <div class="text-right shrink-0">
          <div class="text-white font-bold text-2xl">
            {plan === 'free' ? '₹1,499' : '₹4,999'}<span class="text-slate-400 text-sm font-normal">/mo</span>
          </div>
          <a
            href="#"
            id="upgrade-btn"
            data-plan={plan === 'free' ? 'pro' : 'enterprise'}
            data-currency="inr"
            class="mt-3 inline-block w-full text-center bg-violet-600 hover:bg-violet-500 text-white font-semibold px-5 py-2.5 rounded-lg transition-colors text-sm"
          >
            {plan === 'free' ? 'Upgrade to Pro' : 'Upgrade to Enterprise'} →
          </a>
        </div>
      </div>
    </div>
  )}

  <!-- Cancel -->
  {plan !== 'free' && (
    <div class="text-center">
      <button
        id="cancel-btn"
        class="text-gray-400 hover:text-red-600 text-sm font-medium transition-colors"
      >
        Cancel subscription
      </button>
    </div>
  )}

  <!-- Cancel confirmation modal -->
  <div id="cancel-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
    <div class="bg-white rounded-xl p-6 max-w-sm w-full mx-4 shadow-2xl">
      <h3 class="text-lg font-bold text-gray-900 mb-2">Cancel subscription?</h3>
      <p class="text-gray-500 text-sm mb-5">Your listing will revert to the free tier. You can upgrade again anytime.</p>
      <div class="flex gap-3">
        <button id="cancel-confirm" class="flex-1 py-2.5 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg transition-colors text-sm">
          Yes, cancel
        </button>
        <button id="cancel-close" class="flex-1 py-2.5 border border-gray-200 text-gray-600 font-medium rounded-lg hover:bg-gray-50 transition-colors text-sm">
          Keep subscription
        </button>
      </div>
    </div>
  </div>
</PortalLayout>

<script>
  const upgradeBtn = document.getElementById('upgrade-btn');
  const cancelBtn = document.getElementById('cancel-btn');
  const cancelModal = document.getElementById('cancel-modal');
  const cancelConfirm = document.getElementById('cancel-confirm');
  const cancelClose = document.getElementById('cancel-close');

  if (upgradeBtn) {
    upgradeBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      const plan = upgradeBtn.getAttribute('data-plan')!;
      const currency = upgradeBtn.getAttribute('data-currency')!;
      upgradeBtn.textContent = 'Redirecting to Razorpay...';
      upgradeBtn.classList.add('opacity-50', 'pointer-events-none');

      try {
        const res = await fetch('/api/payments/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ plan, currency }),
        });
        const data = await res.json();
        if (data.checkoutUrl) {
          window.location.href = data.checkoutUrl;
        } else {
          alert('Could not create checkout. Please try again.');
          upgradeBtn.textContent = plan === 'pro' ? 'Upgrade to Pro →' : 'Upgrade to Enterprise →';
          upgradeBtn.classList.remove('opacity-50', 'pointer-events-none');
        }
      } catch {
        alert('Network error. Please try again.');
        upgradeBtn.textContent = plan === 'pro' ? 'Upgrade to Pro →' : 'Upgrade to Enterprise →';
        upgradeBtn.classList.remove('opacity-50', 'pointer-events-none');
      }
    });
  }

  if (cancelBtn && cancelModal) {
    cancelBtn.addEventListener('click', () => cancelModal.classList.remove('hidden'));
    cancelClose?.addEventListener('click', () => cancelModal.classList.add('hidden'));
    cancelConfirm?.addEventListener('click', async () => {
      cancelModal.classList.add('hidden');
      const res = await fetch('/api/payments/portal', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'cancel' }),
      });
      if (res.ok) {
        window.location.reload();
      } else {
        alert('Could not cancel subscription. Please contact support.');
      }
    });
  }
</script>