---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import PortalClinicEditor from "../../components/react/PortalClinicEditor";
import PortalSidebar from "../../components/react/PortalSidebar";
import { getSessionFromRequest, hasRole } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!session) {
  return Astro.redirect("/portal/login/");
}
if (!hasRole(session, 'admin', 'editor', 'clinic_owner')) {
  return Astro.redirect("/portal/login/");
}
---

<Layout title="Edit Clinic | Doctor Portal | TMS List" description="Edit your clinic listing on TMS List." noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <PortalSidebar client:load currentPage="clinic" userEmail={session.email} userId={session.userId} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-5xl">
        <PortalClinicEditor client:load userId={session.userId} />
      </div>
    </main>
  </div>
</Layout>
