---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import PortalInvoiceHistory from '../../components/react/PortalInvoiceHistory';
import PortalSidebar from '../../components/react/PortalSidebar';
import { getSessionFromRequest, hasRole } from '../../utils/auth';

const session = getSessionFromRequest(Astro.request);
if (!session || !hasRole(session, 'clinic_owner', 'admin', 'editor')) {
  return Astro.redirect('/portal/login/');
}
---

<Layout title="Invoices | Doctor Portal | TMS List" description="View your billing history and invoices" noindex={true}>
  <div class="flex min-h-screen bg-[var(--paper2)]">
    <PortalSidebar client:load currentPage="invoices" userEmail={session.email} userId={session.userId} />
    <main class="flex-1 md:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="mb-8">
          <h1 class="text-2xl font-bold text-[var(--ink)]">Invoices</h1>
          <p class="text-[var(--muted)] mt-1">Billing history and payment records</p>
        </div>
        <PortalInvoiceHistory client:load />
      </div>
    </main>
  </div>
</Layout>