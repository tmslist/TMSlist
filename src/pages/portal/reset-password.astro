---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Reset Password | TMS List" description="Set a new password for your TMS List Doctor Portal." noindex={true}>
  <main class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/portal/login" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-emerald-600 mb-4 transition-colors">&larr; Back to login</a>
        <h1 class="text-2xl font-bold text-gray-900">Set New Password</h1>
        <p class="text-sm text-gray-500 mt-2">Enter a new password for your Doctor Portal account.</p>
      </div>

      <div class="bg-white rounded-2xl shadow-lg p-8">
        <div id="token-error" class="hidden mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-800 text-sm"></div>

        <form id="reset-form" class="space-y-4">
          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minLength={8}
              autocomplete="new-password"
              placeholder="Min. 8 characters"
              class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm focus:border-emerald-500 focus:ring-emerald-500"
            />
            <!-- Strength meter -->
            <div id="strength-meter" class="mt-2 hidden">
              <div class="flex gap-1 mb-1">
                <div id="str-bar-1" class="h-1 flex-1 rounded-full bg-gray-200 transition-colors"></div>
                <div id="str-bar-2" class="h-1 flex-1 rounded-full bg-gray-200 transition-colors"></div>
                <div id="str-bar-3" class="h-1 flex-1 rounded-full bg-gray-200 transition-colors"></div>
                <div id="str-bar-4" class="h-1 flex-1 rounded-full bg-gray-200 transition-colors"></div>
              </div>
              <p id="strength-label" class="text-xs text-gray-400"></p>
            </div>
          </div>
          <div>
            <label for="confirm" class="block text-sm font-medium text-gray-700 mb-1">Confirm Password</label>
            <input
              type="password"
              id="confirm"
              name="confirmPassword"
              required
              minLength={8}
              autocomplete="new-password"
              placeholder="Confirm your password"
              class="w-full px-4 py-3 rounded-lg border border-gray-300 text-sm focus:border-emerald-500 focus:ring-emerald-500"
            />
          </div>
          <button
            type="submit"
            id="submit-btn"
            class="w-full py-3 px-4 rounded-xl text-sm font-semibold text-white bg-emerald-600 hover:bg-emerald-700 transition-all disabled:opacity-50"
          >
            Reset Password
          </button>
        </form>

        <div id="success-message" class="hidden text-center py-4">
          <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">Password Reset!</h2>
          <p class="text-gray-500 mb-6">Your password has been updated. You can now sign in.</p>
          <a href="/portal/login" class="inline-flex items-center px-6 py-3 rounded-xl text-sm font-semibold text-white bg-emerald-600 hover:bg-emerald-700 transition-all">
            Sign In
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const STRENGTH_COLORS = ['bg-red-500', 'bg-orange-500', 'bg-yellow-500', 'bg-green-500'];
  const STRENGTH_LABELS = ['', 'Weak', 'Fair', 'Good', 'Strong'];
  const COMMON = ['password', 'password123', '12345678', 'qwerty', 'abc123'];

  function getStrength(password: string): number {
    if (!password) return 0;
    if (COMMON.some(p => password.toLowerCase().includes(p))) return 1;
    let score = 0;
    if (password.length >= 8) score++;
    if (/[A-Z]/.test(password)) score++;
    if (/[a-z]/.test(password)) score++;
    if (/[0-9]/.test(password)) score++;
    if (/[^A-Za-z0-9]/.test(password)) score++;
    return Math.min(score, 4);
  }

  function updateMeter(score: number, label: string) {
    const meter = document.getElementById('strength-meter');
    const bar1 = document.getElementById('str-bar-1')!;
    const bar2 = document.getElementById('str-bar-2')!;
    const bar3 = document.getElementById('str-bar-3')!;
    const bar4 = document.getElementById('str-bar-4')!;
    const strengthLabel = document.getElementById('strength-label')!;

    if (!label) { meter?.classList.add('hidden'); return; }
    meter?.classList.remove('hidden');
    [bar1, bar2, bar3, bar4].forEach((bar, i) => {
      bar.className = `h-1 flex-1 rounded-full transition-colors ${i < score ? STRENGTH_COLORS[score - 1] : 'bg-gray-200'}`;
    });
    strengthLabel.textContent = `${label} password`;
  }

  const params = new URLSearchParams(window.location.search);
  const token = params.get('token');
  const tokenError = document.getElementById('token-error')!;
  const form = document.getElementById('reset-form') as HTMLFormElement | null;
  const successMsg = document.getElementById('success-message')!;

  if (!token) {
    tokenError.textContent = 'Missing reset token. Please use the link from your email.';
    tokenError.classList.remove('hidden');
    form?.classList.add('hidden');
  }

  const pwInput = document.getElementById('password') as HTMLInputElement | null;
  pwInput?.addEventListener('input', () => {
    const score = getStrength(pwInput.value);
    updateMeter(score, STRENGTH_LABELS[score]);
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const password = (document.getElementById('password') as HTMLInputElement)?.value;
    const confirm = (document.getElementById('confirm') as HTMLInputElement)?.value;

    if (password !== confirm) {
      alert('Passwords do not match');
      return;
    }

    if (!token) return;
    btn.disabled = true;
    btn.textContent = 'Resetting...';

    try {
      const res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token, password }),
      });
      const data = await res.json();
      if (res.ok) {
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
      } else {
        btn.disabled = false;
        btn.textContent = 'Reset Password';
        alert(data.error || 'Failed to reset password');
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Reset Password';
      alert('Network error. Please try again.');
    }
  });
</script>
