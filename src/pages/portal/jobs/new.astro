---
export const prerender = false;
import Layout from "../../../layouts/Layout.astro";
import PortalJobsDashboard from "../../../components/react/PortalJobsDashboard";
import PortalSidebar from "../../../components/react/PortalSidebar";
import { getSessionFromRequest, hasRole } from "../../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!session) {
  return Astro.redirect("/portal/login/");
}
if (!hasRole(session, 'admin', 'editor', 'clinic_owner')) {
  return Astro.redirect("/portal/login/");
}
---

<Layout title="Post a Job | TMS List Portal" description="Post a new job at your TMS clinic." noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <PortalSidebar client:load currentPage="jobs" userEmail={session.email} userId={session.userId} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-3xl">
        <PortalJobsDashboard client:load />
      </div>
    </main>
  </div>
</Layout>
