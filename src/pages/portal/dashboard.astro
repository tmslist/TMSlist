---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import PortalDashboard from "../../components/react/PortalDashboard";
import PortalSidebar from "../../components/react/PortalSidebar";
import { getSessionFromRequest, hasRole } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!session) {
  return Astro.redirect("/portal/login");
}
if (!hasRole(session, 'admin', 'editor', 'clinic_owner')) {
  return Astro.redirect("/portal/login");
}
---

<Layout title="Doctor Dashboard | TMS List" description="Manage your clinic listing on TMS List." noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <PortalSidebar client:load currentPage="dashboard" userEmail={session.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-5xl">
        <PortalDashboard client:load userEmail={session.email} userId={session.userId} />
      </div>
    </main>
  </div>
</Layout>
