---
import Layout from "../../layouts/Layout.astro";
import EditorialHero from "../../components/editorial/EditorialHero.astro";

import {
    getOperationalClinics,
    getClinicPhoto,
    getClinicRating,
    getClinicReviewCount,
    STATE_NAMES,
    COUNTRY_NAMES,
    COUNTRY_FLAGS,
    COUNTRY_URL_PREFIXES,
} from "../../utils/dataHelpers";
import { getVisitorCountry } from "../../utils/visitorCountry";
import type { Clinic } from "../../types/clinic";

export const prerender = false;

const VISITOR_COUNTRY = getVisitorCountry(Astro.cookies, Astro.url);
import {
    TMS_DEVICE_CATEGORIES,
    INSURANCE_CATEGORIES,
    CONDITION_CATEGORIES,
    ACCESSIBILITY_FILTERS,
    AVAILABILITY_FILTERS,
    PRICE_RANGE_OPTIONS,
    PRICING_FILTERS,
} from "../../utils/filterOptions";

const allClinics = await getOperationalClinics();

// Scope to the visitor's country (US fallback if their country has no clinics)
const scopedToVisitor = VISITOR_COUNTRY === 'US'
    ? allClinics.filter((c: any) => !c.country || c.country === 'US')
    : allClinics.filter((c: any) => c.country === VISITOR_COUNTRY);
const clinics = scopedToVisitor.length > 0
    ? scopedToVisitor
    : allClinics.filter((c: any) => !c.country || c.country === 'US');

// US visitors keep the by-state grouping; non-US visitors get a single country grouping
const usClinics = VISITOR_COUNTRY === 'US' ? clinics : [];
const intlClinics = VISITOR_COUNTRY === 'US' ? [] : clinics;

// Group US by state
const stateGroups = usClinics.reduce(
    (acc, clinic) => {
        const stateCode = clinic.state;
        if (!acc[stateCode]) acc[stateCode] = [];
        acc[stateCode].push(clinic);
        return acc;
    },
    {} as Record<string, Clinic[]>,
);

// Sort states by clinic count
const sortedStates = Object.entries(stateGroups).sort(
    (a, b) => b[1].length - a[1].length,
);

// Group international by country
const countryGroups = intlClinics.reduce(
    (acc, clinic: any) => {
        const code = clinic.country;
        if (!acc[code]) acc[code] = [];
        acc[code].push(clinic);
        return acc;
    },
    {} as Record<string, Clinic[]>,
);
const sortedCountries = Object.entries(countryGroups).sort(
    (a, b) => b[1].length - a[1].length,
);

const stateNames = STATE_NAMES;
const totalLocations = Object.keys(stateGroups).length + Object.keys(countryGroups).length;

const visitorCountryName = COUNTRY_NAMES[VISITOR_COUNTRY] || 'United States';
const title = VISITOR_COUNTRY === 'US'
    ? `Verified TMS Clinics | Real Data from ${clinics.length} Providers`
    : `Verified TMS Clinics in ${visitorCountryName} | ${clinics.length} Providers`;
const description = VISITOR_COUNTRY === 'US'
    ? `Browse ${clinics.length} verified TMS therapy clinics across ${totalLocations} US states. Real ratings, reviews, and contact info.`
    : `Browse ${clinics.length} verified TMS therapy clinics in ${visitorCountryName}. Real ratings, reviews, and contact info.`;

// Calculate total reviews
const totalReviews = clinics.reduce(
    (sum, c) => sum + getClinicReviewCount(c),
    0,
);
const ratedClinics = clinics.filter((c) => getClinicRating(c) > 0);
const avgRating =
    ratedClinics.reduce((sum, c) => sum + getClinicRating(c), 0) /
    (ratedClinics.length || 1);
---

<Layout title={title} description={description}>
    <main style="background:var(--paper)">
        <EditorialHero
            eyebrow="Real Data · No Fake Reviews"
            eyebrowDot="#22c55e"
            title="Verified TMS"
            titleAccent="clinics."
            description={`${clinics.length} real TMS therapy providers across ${totalLocations} locations in ${Object.keys(countryGroups).length + 1} countries. All data verified with real ratings and reviews.`}
            breadcrumbs={[{ label: "Home", href: "/" }, { label: "Verified Clinics" }]}
            ctas={[
                { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
                { label: "Compare Clinics", href: "/compare-clinics/", variant: "outline" },
            ]}
            stats={[
                { value: clinics.length, label: "Clinics", color: "ink" },
                { value: `${avgRating.toFixed(1)}★`, label: "Avg Rating", color: "warm" },
                { value: totalReviews, label: "Reviews", color: "accent" },
            ]}
        />

        <!-- Filter Bar for Mobile -->
        <div class="lg:hidden bg-[var(--paper)] border-b sticky top-0 z-30 py-3 px-4">
            <button
                id="mobileFilterBtn"
                class="w-full flex items-center justify-center gap-2 py-3 px-6 bg-[var(--ink)] text-white font-semibold rounded-xl"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"
                    ></path></svg
                >
                Filters
            </button>
        </div>

        <!-- Main Content with Sidebar -->
        <section class="py-8 md:py-12">
            <div class="container mx-auto px-4 md:px-6">
                <div class="flex flex-col lg:flex-row gap-8">
                    <!-- Filter Sidebar -->
                    <aside
                        id="filterSidebar"
                        class="hidden lg:block lg:w-80 shrink-0"
                    >
                        <div
                            class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] shadow-sm sticky top-24 max-h-[calc(100vh-120px)] overflow-y-auto"
                        >
                            <div class="p-6 border-b border-[var(--line)]">
                                <div class="flex items-center justify-between">
                                    <h3 class="text-lg font-semibold text-[var(--ink)]">
                                        Filters
                                    </h3>
                                    <button
                                        id="clearFilters"
                                        class="text-sm text-[var(--accent)] hover:text-[var(--accent)] font-medium"
                                        >Clear All</button
                                    >
                                </div>
                                <p class="text-sm text-[var(--muted)] mt-1">
                                    Showing <span id="filteredCount"
                                        >{clinics.length}</span
                                    > clinics
                                </p>
                            </div>

                            <!-- Insurance Section -->
                            <div class="border-b border-[var(--line)]">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="insurance"
                                >
                                    <span class="font-semibold text-[var(--ink)]"
                                        >Insurance</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-[var(--muted)] transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                                <div
                                    id="section-insurance"
                                    class="hidden px-4 pb-4 space-y-4"
                                >
                                    {
                                        Object.entries(
                                            INSURANCE_CATEGORIES,
                                        ).map(([key, category]) => (
                                            <div>
                                                <p class="text-xs font-semibold text-[var(--muted)] uppercase tracking-wider mb-2">
                                                    {category.label}
                                                </p>
                                                <div class="space-y-1.5">
                                                    {category.options
                                                        .slice(0, 5)
                                                        .map((opt) => (
                                                            <label class="flex items-center gap-2 cursor-pointer hover:bg-[var(--paper2)] p-1.5 rounded-lg">
                                                                <input
                                                                    type="checkbox"
                                                                    class="filter-checkbox rounded border-[var(--line)] text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]"
                                                                    data-filter="insurance"
                                                                    data-value={
                                                                        opt.value
                                                                    }
                                                                />
                                                                <span class="text-sm text-[var(--ink2)]">
                                                                    {opt.label}
                                                                </span>
                                                            </label>
                                                        ))}
                                                </div>
                                            </div>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- TMS Devices Section -->
                            <div class="border-b border-[var(--line)]">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="devices"
                                >
                                    <span class="font-semibold text-[var(--ink)]"
                                        >TMS Devices</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-[var(--muted)] transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                                <div
                                    id="section-devices"
                                    class="hidden px-4 pb-4 space-y-4"
                                >
                                    {
                                        Object.entries(
                                            TMS_DEVICE_CATEGORIES,
                                        ).map(([key, category]) => (
                                            <div>
                                                <p class="text-xs font-semibold text-[var(--muted)] uppercase tracking-wider mb-2">
                                                    {category.label}
                                                </p>
                                                <div class="space-y-1.5">
                                                    {category.options.map(
                                                        (opt) => (
                                                            <label class="flex items-center gap-2 cursor-pointer hover:bg-[var(--paper2)] p-1.5 rounded-lg">
                                                                <input
                                                                    type="checkbox"
                                                                    class="filter-checkbox rounded border-[var(--line)] text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]"
                                                                    data-filter="device"
                                                                    data-value={
                                                                        opt.value
                                                                    }
                                                                />
                                                                <span class="text-sm text-[var(--ink2)]">
                                                                    {opt.label}
                                                                </span>
                                                            </label>
                                                        ),
                                                    )}
                                                </div>
                                            </div>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- Conditions Section -->
                            <div class="border-b border-[var(--line)]">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="conditions"
                                >
                                    <span class="font-semibold text-[var(--ink)]"
                                        >Conditions Treated</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-[var(--muted)] transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                                <div
                                    id="section-conditions"
                                    class="hidden px-4 pb-4 space-y-4"
                                >
                                    {
                                        Object.entries(
                                            CONDITION_CATEGORIES,
                                        ).map(([key, category]) => (
                                            <div>
                                                <p class="text-xs font-semibold text-[var(--muted)] uppercase tracking-wider mb-2">
                                                    {category.label}
                                                </p>
                                                <div class="space-y-1.5">
                                                    {category.options.map(
                                                        (opt) => (
                                                            <label class="flex items-center gap-2 cursor-pointer hover:bg-[var(--paper2)] p-1.5 rounded-lg">
                                                                <input
                                                                    type="checkbox"
                                                                    class="filter-checkbox rounded border-[var(--line)] text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]"
                                                                    data-filter="condition"
                                                                    data-value={
                                                                        opt.value
                                                                    }
                                                                />
                                                                <span class="text-sm text-[var(--ink2)]">
                                                                    {opt.label}
                                                                </span>
                                                            </label>
                                                        ),
                                                    )}
                                                </div>
                                            </div>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- Accessibility & Inclusivity Section -->
                            <div class="border-b border-[var(--line)]">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="accessibility"
                                >
                                    <span class="font-semibold text-[var(--ink)]"
                                        >Accessibility & Inclusivity</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-[var(--muted)] transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                                <div
                                    id="section-accessibility"
                                    class="hidden px-4 pb-4 space-y-1.5"
                                >
                                    {
                                        ACCESSIBILITY_FILTERS.map((filter) => (
                                            <label class="flex items-center gap-2 cursor-pointer hover:bg-[var(--paper2)] p-1.5 rounded-lg">
                                                <input
                                                    type="checkbox"
                                                    class="filter-checkbox rounded border-[var(--line)] text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]"
                                                    data-filter="accessibility"
                                                    data-value={filter.key}
                                                />
                                                <span class="text-lg">
                                                    {filter.icon}
                                                </span>
                                                <span class="text-sm text-[var(--ink2)]">
                                                    {filter.label}
                                                </span>
                                            </label>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- Availability Section -->
                            <div class="border-b border-[var(--line)]">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="availability"
                                >
                                    <span class="font-semibold text-[var(--ink)]"
                                        >Availability</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-[var(--muted)] transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                                <div
                                    id="section-availability"
                                    class="hidden px-4 pb-4 space-y-1.5"
                                >
                                    {
                                        AVAILABILITY_FILTERS.map((filter) => (
                                            <label class="flex items-center gap-2 cursor-pointer hover:bg-[var(--paper2)] p-1.5 rounded-lg">
                                                <input
                                                    type="checkbox"
                                                    class="filter-checkbox rounded border-[var(--line)] text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]"
                                                    data-filter="availability"
                                                    data-value={filter.key}
                                                />
                                                <span class="text-lg">
                                                    {filter.icon}
                                                </span>
                                                <span class="text-sm text-[var(--ink2)]">
                                                    {filter.label}
                                                </span>
                                            </label>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- Price Range Section -->
                            <div class="border-b border-[var(--line)]">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="pricing"
                                >
                                    <span class="font-semibold text-[var(--ink)]"
                                        >Pricing</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-[var(--muted)] transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                                <div
                                    id="section-pricing"
                                    class="hidden px-4 pb-4 space-y-3"
                                >
                                    <p
                                        class="text-xs font-semibold text-[var(--muted)] uppercase tracking-wider mb-2"
                                    >
                                        Price Range
                                    </p>
                                    {
                                        PRICE_RANGE_OPTIONS.map((opt) => (
                                            <label class="flex items-center gap-3 cursor-pointer hover:bg-[var(--paper2)] p-2 rounded-lg border border-[var(--line)]">
                                                <input
                                                    type="radio"
                                                    name="priceRange"
                                                    class="text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]"
                                                    data-filter="price"
                                                    data-value={opt.value}
                                                />
                                                <div>
                                                    <span class="text-sm font-medium text-[var(--ink)]">
                                                        {opt.label}
                                                    </span>
                                                    <p class="text-xs text-[var(--muted)]">
                                                        {opt.description}
                                                    </p>
                                                </div>
                                            </label>
                                        ))
                                    }
                                    <p
                                        class="text-xs font-semibold text-[var(--muted)] uppercase tracking-wider mt-4 mb-2"
                                    >
                                        Payment Options
                                    </p>
                                    {
                                        PRICING_FILTERS.map((filter) => (
                                            <label class="flex items-center gap-2 cursor-pointer hover:bg-[var(--paper2)] p-1.5 rounded-lg">
                                                <input
                                                    type="checkbox"
                                                    class="filter-checkbox rounded border-[var(--line)] text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]"
                                                    data-filter="pricing"
                                                    data-value={filter.key}
                                                />
                                                <span class="text-lg">
                                                    {filter.icon}
                                                </span>
                                                <span class="text-sm text-[var(--ink2)]">
                                                    {filter.label}
                                                </span>
                                            </label>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- State Filter -->
                            <div class="p-4">
                                <label
                                    class="block text-sm font-semibold text-[var(--ink)] mb-2"
                                    >Filter by State</label
                                >
                                <select
                                    id="stateFilter"
                                    class="w-full rounded-xl border-[var(--line)] text-sm focus:ring-[rgba(10,22,40,0.15)] focus:border-[var(--ink2)]"
                                >
                                    <option value="">All Locations</option>
                                    <optgroup label="United States">
                                    {
                                        sortedStates.map(([code, list]) => (
                                            <option value={code}>
                                                {stateNames[code] || code} (
                                                {list.length})
                                            </option>
                                        ))
                                    }
                                    </optgroup>
                                    {sortedCountries.length > 0 && (
                                        <optgroup label="International">
                                        {
                                            sortedCountries.map(([code, list]) => (
                                                <option value={code} set:html={`${COUNTRY_FLAGS[code] || ''} ${COUNTRY_NAMES[code] || code} (${list.length})`}></option>
                                            ))
                                        }
                                        </optgroup>
                                    )}
                                </select>
                            </div>
                        </div>
                    </aside>

                    <!-- Clinics Grid -->
                    <div class="flex-1" id="clinicsContainer">
                        {
                            sortedStates.map(([stateCode, stateClinics]) => (
                                <div
                                    class="mb-16 state-section"
                                    data-state={stateCode}
                                >
                                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-6 flex items-center gap-3">
                                        <span class="w-10 h-10 rounded-lg bg-[rgba(10,22,40,0.08)] text-[var(--accent)] flex items-center justify-center font-semibold text-sm">
                                            {stateCode}
                                        </span>
                                        {stateNames[stateCode] || stateCode}
                                        <span class="text-sm font-normal text-[var(--muted)] ml-2">
                                            ({stateClinics.length}{" "}
                                            {stateClinics.length === 1
                                                ? "clinic"
                                                : "clinics"}
                                            )
                                        </span>
                                    </h2>

                                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                                        {stateClinics.map((clinic) => {
                                            const availability = clinic.availability || {};
                                            const isAcceptingNew = availability.accepting_new_patients !== false;
                                            const isAvailable = availability.same_week_available || availability.accepting_new_patients;
                                            return (
                                            <article
                                                class="clinic-card bg-[var(--paper)] rounded-2xl overflow-hidden border border-[var(--line)] shadow-sm hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all flex flex-col"
                                                data-machines={JSON.stringify(
                                                    clinic.machines || [],
                                                )}
                                                data-insurances={JSON.stringify(
                                                    clinic.insurances || [],
                                                )}
                                                data-specialties={JSON.stringify(
                                                    clinic.specialties || [],
                                                )}
                                                data-state={clinic.state}
                                            >
                                                <div class="h-40 overflow-hidden">
                                                    <img
                                                        src={getClinicPhoto(
                                                            clinic,
                                                        )}
                                                        alt={clinic.name}
                                                        class="w-full h-full object-cover"
                                                        loading="lazy"
                                                    />
                                                </div>
                                                <div class="p-6 flex-1 flex flex-col">
                                                    <div class="flex items-center gap-2 mb-3 flex-wrap">
                                                        <svg class="w-3 h-3 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                                                        <span class="text-xs font-semibold text-emerald-700">Verified</span>
                                                        {isAcceptingNew && (
                                                            <span class="px-2 py-0.5 bg-emerald-50 text-emerald-700 text-[10px] font-semibold rounded-full border border-emerald-100">Accepting New</span>
                                                        )}
                                                        {isAvailable && (
                                                            <span class="px-2 py-0.5 bg-[var(--warm)]/10 text-[var(--warm)] text-[10px] font-semibold rounded-full border border-[var(--warm)]/20">Available This Week</span>
                                                        )}
                                                        {getClinicRating(
                                                            clinic,
                                                        ) > 0 && (
                                                            <span class="flex items-center gap-1 text-sm">
                                                                <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                                                <span class="font-semibold text-[var(--ink)]">
                                                                    {getClinicRating(
                                                                        clinic,
                                                                    )}
                                                                </span>
                                                                <span class="text-[var(--muted)]">
                                                                    (
                                                                    {getClinicReviewCount(
                                                                        clinic,
                                                                    )}
                                                                    )
                                                                </span>
                                                            </span>
                                                        )}
                                                    </div>

                                                    <h3 class="text-lg font-semibold text-[var(--ink)] mb-1 line-clamp-2">
                                                        {clinic.name}
                                                    </h3>
                                                    <p class="text-[var(--muted)] text-sm mb-3">
                                                        {clinic.city},{" "}
                                                        {clinic.state}
                                                    </p>

                                                    {/* Phone as click-to-call */}
                                                    {clinic.phone && (
                                                        <a
                                                            href={`tel:${clinic.phone.replace(/\D/g,'')}`}
                                                            class="inline-flex items-center gap-1.5 text-sm text-[var(--accent)] font-medium mb-3 hover:underline"
                                                        >
                                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                                            {clinic.phone}
                                                        </a>
                                                    )}

                                                    {/* Insurance chips */}
                                                    {clinic.insurances && clinic.insurances.length > 0 && (
                                                        <div class="flex flex-wrap gap-1 mb-3">
                                                            {clinic.insurances.slice(0, 3).map((ins: string) => (
                                                                <span class="px-2 py-0.5 bg-[var(--paper2)] border border-[var(--line)] text-[11px] font-medium text-[var(--ink2)] rounded">
                                                                    {ins}
                                                                </span>
                                                            ))}
                                                            {clinic.insurances.length > 3 && (
                                                                <span class="text-[11px] text-[var(--muted)]">+{clinic.insurances.length - 3}</span>
                                                            )}
                                                        </div>
                                                    )}

                                                    <div class="mt-auto pt-4 border-t border-[var(--line)] flex items-center justify-between gap-2">
                                                        {clinic.website && (
                                                            <a
                                                                href={
                                                                    clinic.website
                                                                }
                                                                target="_blank"
                                                                rel="noopener noreferrer"
                                                                class="text-sm text-[var(--muted)] hover:text-[var(--accent)]"
                                                            >
                                                                Website ↗
                                                            </a>
                                                        )}
                                                        <a
                                                            href={`/clinic/${clinic.slug}/`}
                                                            class="text-[var(--warm)] font-semibold text-sm hover:underline"
                                                        >
                                                            View Profile →
                                                        </a>
                                                    </div>
                                                </div>
                                            </article>
                                        )})}
                                    </div>
                                </div>
                            ))
                        }
                        {
                            sortedCountries.map(([countryCode, countryClinics]) => (
                                <div
                                    class="mb-16 state-section"
                                    data-state={countryCode}
                                >
                                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-6 flex items-center gap-3">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                        {COUNTRY_NAMES[countryCode] || countryCode}
                                        <span class="text-sm font-normal text-[var(--muted)] ml-2">
                                            ({countryClinics.length}{" "}
                                            {countryClinics.length === 1
                                                ? "clinic"
                                                : "clinics"}
                                            )
                                        </span>
                                    </h2>

                                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                                        {countryClinics.map((clinic) => {
                                            const availability = clinic.availability || {};
                                            const isAcceptingNew = availability.accepting_new_patients !== false;
                                            const isAvailable = availability.same_week_available || availability.accepting_new_patients;
                                            return (
                                            <article
                                                class="clinic-card bg-[var(--paper)] rounded-2xl overflow-hidden border border-[var(--line)] shadow-sm hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all flex flex-col"
                                                data-state={countryCode}
                                            >
                                                <div class="h-40 overflow-hidden">
                                                    <img
                                                        src={getClinicPhoto(clinic)}
                                                        alt={clinic.name}
                                                        class="w-full h-full object-cover"
                                                        loading="lazy"
                                                    />
                                                </div>
                                                <div class="p-6 flex-1 flex flex-col">
                                                    <div class="flex items-center gap-2 mb-3 flex-wrap">
                                                        <svg class="w-3 h-3 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                                                        <span class="text-xs font-semibold text-emerald-700">Verified</span>
                                                        {isAcceptingNew && (
                                                            <span class="px-2 py-0.5 bg-emerald-50 text-emerald-700 text-[10px] font-semibold rounded-full border border-emerald-100">Accepting New</span>
                                                        )}
                                                        {isAvailable && (
                                                            <span class="px-2 py-0.5 bg-[var(--warm)]/10 text-[var(--warm)] text-[10px] font-semibold rounded-full border border-[var(--warm)]/20">Available This Week</span>
                                                        )}
                                                        {getClinicRating(clinic) > 0 && (
                                                            <span class="flex items-center gap-1 text-sm">
                                                                <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                                                <span class="font-semibold text-[var(--ink)]">{getClinicRating(clinic)}</span>
                                                                <span class="text-[var(--muted)]">({getClinicReviewCount(clinic)})</span>
                                                            </span>
                                                        )}
                                                    </div>
                                                    <h3 class="text-lg font-semibold text-[var(--ink)] mb-1 line-clamp-2">{clinic.name}</h3>
                                                    <p class="text-[var(--muted)] text-sm mb-3">{clinic.city}, {clinic.state}</p>
                                                    {clinic.phone && (
                                                        <a
                                                            href={`tel:${clinic.phone.replace(/\D/g,'')}`}
                                                            class="inline-flex items-center gap-1.5 text-sm text-[var(--accent)] font-medium mb-3 hover:underline"
                                                        >
                                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                                            {clinic.phone}
                                                        </a>
                                                    )}
                                                    <div class="mt-auto pt-4 border-t border-[var(--line)] flex items-center justify-between gap-2">
                                                        <a
                                                            href={`/clinic/${clinic.slug}/`}
                                                            class="text-[var(--warm)] font-semibold text-sm hover:underline"
                                                        >
                                                            View Profile →
                                                        </a>
                                                    </div>
                                                </div>
                                            </article>
                                        )})}
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </section>

        <!-- Data Source Note -->
        <section class="py-12 bg-[var(--paper)] border-t border-[var(--line)]">
            <div class="container mx-auto px-4 md:px-6 text-center max-w-4xl">
                <p class="text-[var(--muted)] text-sm max-w-2xl mx-auto mb-6">
                    All clinic data is sourced from Google Places and verified
                    for accuracy. Ratings and review counts are real and not
                    fabricated. If you're a clinic owner and want to update your
                    listing, please <a
                        href="/add-listing/"
                        class="text-[var(--accent)] font-medium"
                        >add or update your listing</a
                    >.
                </p>
                <!-- Contextual links -->
                <div class="flex flex-wrap justify-center gap-4 mt-6">
                    <a href="/quiz/am-i-a-candidate/" class="px-4 py-2 text-sm font-medium bg-[var(--ink)] text-white rounded-lg hover:bg-[var(--ink2)] transition-colors">
                        Take the Eligibility Quiz
                    </a>
                    <a href="/blog/tms-cost-insurance-guide-2026/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">
                        TMS Cost &amp; Insurance Guide
                    </a>
                    <a href="/blog/questions-to-ask-tms-clinic/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">
                        Questions to Ask Your Clinic
                    </a>
                    <a href="/blog/preparing-for-first-tms-session/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">
                        Preparing for Your First Session
                    </a>
                    <a href="/blog/maintenance-tms-guide/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">
                        Maintenance TMS
                    </a>
                    <a href="/blog/how-to-find-tms-clinic-guide/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">
                        How to Find a TMS Clinic
                    </a>
                    <a href="/specialists/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">
                        Find a TMS Specialist
                    </a>
                    <a href="/blog/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">
                        TMS Research Blog
                    </a>
                </div>
            </div>
        </section>
    </main>

    <!-- Filter JavaScript -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // Toggle filter sections
            document.querySelectorAll(".filter-toggle").forEach((btn) => {
                btn.addEventListener("click", () => {
                    const section = btn.getAttribute("data-section");
                    const content = document.getElementById(
                        `section-${section}`,
                    );
                    const arrow = btn.querySelector("svg");
                    if (content) {
                        content.classList.toggle("hidden");
                        arrow?.classList.toggle("rotate-180");
                    }
                });
            });

            // Mobile filter toggle
            const mobileBtn = document.getElementById("mobileFilterBtn");
            const sidebar = document.getElementById("filterSidebar");
            if (mobileBtn && sidebar) {
                mobileBtn.addEventListener("click", () => {
                    sidebar.classList.toggle("hidden");
                    sidebar.classList.toggle("fixed");
                    sidebar.classList.toggle("inset-0");
                    sidebar.classList.toggle("z-50");
                    sidebar.classList.toggle("bg-[var(--paper)]");
                    sidebar.classList.toggle("overflow-y-auto");
                    sidebar.classList.toggle("p-4");
                });
            }

            // State filter
            const stateFilter = document.getElementById(
                "stateFilter",
            ) as HTMLSelectElement;
            if (stateFilter) {
                stateFilter.addEventListener("change", () => {
                    const value = stateFilter.value;
                    document
                        .querySelectorAll(".state-section")
                        .forEach((section) => {
                            const sectionEl = section as HTMLElement;
                            if (
                                !value ||
                                sectionEl.getAttribute("data-state") === value
                            ) {
                                sectionEl.style.display = "";
                            } else {
                                sectionEl.style.display = "none";
                            }
                        });
                    updateCount();
                });
            }

            // Clear filters
            const clearBtn = document.getElementById("clearFilters");
            if (clearBtn) {
                clearBtn.addEventListener("click", () => {
                    document
                        .querySelectorAll(".filter-checkbox")
                        .forEach((cb) => {
                            (cb as HTMLInputElement).checked = false;
                        });
                    document
                        .querySelectorAll('input[name="priceRange"]')
                        .forEach((r) => {
                            (r as HTMLInputElement).checked = false;
                        });
                    if (stateFilter) stateFilter.value = "";
                    document
                        .querySelectorAll(".clinic-card")
                        .forEach((card) => {
                            (card as HTMLElement).style.display = "";
                        });
                    document
                        .querySelectorAll(".state-section")
                        .forEach((section) => {
                            (section as HTMLElement).style.display = "";
                        });
                    updateCount();
                });
            }

            function updateCount() {
                const visible = document.querySelectorAll(
                    '.clinic-card:not([style*="display: none"])',
                ).length;
                const countEl = document.getElementById("filteredCount");
                if (countEl) countEl.textContent = String(visible);
            }
        });
    </script>
</Layout>
