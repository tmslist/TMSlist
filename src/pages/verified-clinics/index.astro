---
import Layout from "../../layouts/Layout.astro";

import {
    getOperationalClinics,
    getClinicPhoto,
    getClinicRating,
    getClinicReviewCount,
    STATE_NAMES,
    COUNTRY_NAMES,
    COUNTRY_FLAGS,
    COUNTRY_URL_PREFIXES,
} from "../../utils/dataHelpers";
import type { Clinic } from "../../types/clinic";
import {
    TMS_DEVICE_CATEGORIES,
    INSURANCE_CATEGORIES,
    CONDITION_CATEGORIES,
    ACCESSIBILITY_FILTERS,
    AVAILABILITY_FILTERS,
    PRICE_RANGE_OPTIONS,
    PRICING_FILTERS,
} from "../../utils/filterOptions";

const clinics = await getOperationalClinics();

// Separate US and international
const usClinics = clinics.filter((c: any) => !c.country || c.country === 'US');
const intlClinics = clinics.filter((c: any) => c.country && c.country !== 'US');

// Group US by state
const stateGroups = usClinics.reduce(
    (acc, clinic) => {
        const stateCode = clinic.state;
        if (!acc[stateCode]) acc[stateCode] = [];
        acc[stateCode].push(clinic);
        return acc;
    },
    {} as Record<string, Clinic[]>,
);

// Sort states by clinic count
const sortedStates = Object.entries(stateGroups).sort(
    (a, b) => b[1].length - a[1].length,
);

// Group international by country
const countryGroups = intlClinics.reduce(
    (acc, clinic: any) => {
        const code = clinic.country;
        if (!acc[code]) acc[code] = [];
        acc[code].push(clinic);
        return acc;
    },
    {} as Record<string, Clinic[]>,
);
const sortedCountries = Object.entries(countryGroups).sort(
    (a, b) => b[1].length - a[1].length,
);

const stateNames = STATE_NAMES;
const totalLocations = Object.keys(stateGroups).length + Object.keys(countryGroups).length;

const title =
    "Verified TMS Clinics | Real Data from " + clinics.length + " Providers";
const description = `Browse ${clinics.length} verified TMS therapy clinics across ${totalLocations} locations worldwide. Real ratings, reviews, and contact info.`;

// Calculate total reviews
const totalReviews = clinics.reduce(
    (sum, c) => sum + getClinicReviewCount(c),
    0,
);
const ratedClinics = clinics.filter((c) => getClinicRating(c) > 0);
const avgRating =
    ratedClinics.reduce((sum, c) => sum + getClinicRating(c), 0) /
    (ratedClinics.length || 1);
---

<Layout title={title} description={description}>
    <main class="min-h-screen">
        <!-- Hero -->
        <section class="relative bg-white border-b border-slate-100 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
            <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                    <span class="text-slate-300">/</span>
                    <span class="text-slate-700 font-medium">Verified Clinics</span>
                </nav>

                <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8">
                    <div class="max-w-2xl">
                        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-50 border border-emerald-100 rounded-full mb-6">
                            <span class="relative flex h-2 w-2"><span class="animate-ping absolute h-full w-full rounded-full bg-emerald-400 opacity-75"></span><span class="relative rounded-full h-2 w-2 bg-emerald-500"></span></span>
                            <span class="text-xs font-semibold text-emerald-700 tracking-wide">Real Data · No Fake Reviews</span>
                        </div>
                        <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 mb-4 leading-tight">
                            Verified TMS <span class="text-violet-600">Clinics</span>
                        </h1>
                        <p class="text-lg text-slate-500 leading-relaxed">
                            {clinics.length} real TMS therapy providers across {totalLocations} locations in {Object.keys(countryGroups).length + 1} countries. All data verified with real ratings and reviews.
                        </p>
                    </div>

                    <div class="flex gap-3 flex-wrap">
                        <div class="bg-white px-5 py-3 rounded-xl border border-slate-100 shadow-sm text-center">
                            <div class="text-2xl font-bold text-slate-900">{clinics.length}</div>
                            <div class="text-xs text-slate-400 font-medium">Clinics</div>
                        </div>
                        <div class="bg-white px-5 py-3 rounded-xl border border-slate-100 shadow-sm text-center">
                            <div class="text-2xl font-bold text-slate-900">{totalLocations}</div>
                            <div class="text-xs text-slate-400 font-medium">Locations</div>
                        </div>
                        <div class="bg-white px-5 py-3 rounded-xl border border-slate-100 shadow-sm text-center">
                            <div class="text-2xl font-bold text-amber-600">{avgRating.toFixed(1)}★</div>
                            <div class="text-xs text-slate-400 font-medium">Avg Rating</div>
                        </div>
                        <div class="bg-white px-5 py-3 rounded-xl border border-slate-100 shadow-sm text-center">
                            <div class="text-2xl font-bold text-slate-900">{totalReviews}</div>
                            <div class="text-xs text-slate-400 font-medium">Reviews</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Filter Bar for Mobile -->
        <div class="lg:hidden bg-white border-b sticky top-0 z-30 py-3 px-4">
            <button
                id="mobileFilterBtn"
                class="w-full flex items-center justify-center gap-2 py-3 px-6 bg-violet-600 text-white font-semibold rounded-xl"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"
                    ></path></svg
                >
                Filters
            </button>
        </div>

        <!-- Main Content with Sidebar -->
        <section class="py-8 md:py-12">
            <div class="container mx-auto px-4 md:px-6">
                <div class="flex flex-col lg:flex-row gap-8">
                    <!-- Filter Sidebar -->
                    <aside
                        id="filterSidebar"
                        class="hidden lg:block lg:w-80 shrink-0"
                    >
                        <div
                            class="bg-white rounded-2xl border border-gray-200 shadow-sm sticky top-24 max-h-[calc(100vh-120px)] overflow-y-auto"
                        >
                            <div class="p-6 border-b border-gray-100">
                                <div class="flex items-center justify-between">
                                    <h3 class="text-lg font-semibold text-gray-900">
                                        Filters
                                    </h3>
                                    <button
                                        id="clearFilters"
                                        class="text-sm text-violet-600 hover:text-violet-700 font-medium"
                                        >Clear All</button
                                    >
                                </div>
                                <p class="text-sm text-gray-500 mt-1">
                                    Showing <span id="filteredCount"
                                        >{clinics.length}</span
                                    > clinics
                                </p>
                            </div>

                            <!-- Insurance Section -->
                            <div class="border-b border-gray-100">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="insurance"
                                >
                                    <span class="font-semibold text-gray-900"
                                        >Insurance</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-gray-400 transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                                <div
                                    id="section-insurance"
                                    class="hidden px-4 pb-4 space-y-4"
                                >
                                    {
                                        Object.entries(
                                            INSURANCE_CATEGORIES,
                                        ).map(([key, category]) => (
                                            <div>
                                                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
                                                    {category.label}
                                                </p>
                                                <div class="space-y-1.5">
                                                    {category.options
                                                        .slice(0, 5)
                                                        .map((opt) => (
                                                            <label class="flex items-center gap-2 cursor-pointer hover:bg-gray-50 p-1.5 rounded-lg">
                                                                <input
                                                                    type="checkbox"
                                                                    class="filter-checkbox rounded border-gray-300 text-violet-600 focus:ring-violet-500"
                                                                    data-filter="insurance"
                                                                    data-value={
                                                                        opt.value
                                                                    }
                                                                />
                                                                <span class="text-sm text-gray-700">
                                                                    {opt.label}
                                                                </span>
                                                            </label>
                                                        ))}
                                                </div>
                                            </div>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- TMS Devices Section -->
                            <div class="border-b border-gray-100">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="devices"
                                >
                                    <span class="font-semibold text-gray-900"
                                        >TMS Devices</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-gray-400 transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                                <div
                                    id="section-devices"
                                    class="hidden px-4 pb-4 space-y-4"
                                >
                                    {
                                        Object.entries(
                                            TMS_DEVICE_CATEGORIES,
                                        ).map(([key, category]) => (
                                            <div>
                                                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
                                                    {category.label}
                                                </p>
                                                <div class="space-y-1.5">
                                                    {category.options.map(
                                                        (opt) => (
                                                            <label class="flex items-center gap-2 cursor-pointer hover:bg-gray-50 p-1.5 rounded-lg">
                                                                <input
                                                                    type="checkbox"
                                                                    class="filter-checkbox rounded border-gray-300 text-violet-600 focus:ring-violet-500"
                                                                    data-filter="device"
                                                                    data-value={
                                                                        opt.value
                                                                    }
                                                                />
                                                                <span class="text-sm text-gray-700">
                                                                    {opt.label}
                                                                </span>
                                                            </label>
                                                        ),
                                                    )}
                                                </div>
                                            </div>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- Conditions Section -->
                            <div class="border-b border-gray-100">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="conditions"
                                >
                                    <span class="font-semibold text-gray-900"
                                        >Conditions Treated</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-gray-400 transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                                <div
                                    id="section-conditions"
                                    class="hidden px-4 pb-4 space-y-4"
                                >
                                    {
                                        Object.entries(
                                            CONDITION_CATEGORIES,
                                        ).map(([key, category]) => (
                                            <div>
                                                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
                                                    {category.label}
                                                </p>
                                                <div class="space-y-1.5">
                                                    {category.options.map(
                                                        (opt) => (
                                                            <label class="flex items-center gap-2 cursor-pointer hover:bg-gray-50 p-1.5 rounded-lg">
                                                                <input
                                                                    type="checkbox"
                                                                    class="filter-checkbox rounded border-gray-300 text-violet-600 focus:ring-violet-500"
                                                                    data-filter="condition"
                                                                    data-value={
                                                                        opt.value
                                                                    }
                                                                />
                                                                <span class="text-sm text-gray-700">
                                                                    {opt.label}
                                                                </span>
                                                            </label>
                                                        ),
                                                    )}
                                                </div>
                                            </div>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- Accessibility & Inclusivity Section -->
                            <div class="border-b border-gray-100">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="accessibility"
                                >
                                    <span class="font-semibold text-gray-900"
                                        >Accessibility & Inclusivity</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-gray-400 transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                                <div
                                    id="section-accessibility"
                                    class="hidden px-4 pb-4 space-y-1.5"
                                >
                                    {
                                        ACCESSIBILITY_FILTERS.map((filter) => (
                                            <label class="flex items-center gap-2 cursor-pointer hover:bg-gray-50 p-1.5 rounded-lg">
                                                <input
                                                    type="checkbox"
                                                    class="filter-checkbox rounded border-gray-300 text-violet-600 focus:ring-violet-500"
                                                    data-filter="accessibility"
                                                    data-value={filter.key}
                                                />
                                                <span class="text-lg">
                                                    {filter.icon}
                                                </span>
                                                <span class="text-sm text-gray-700">
                                                    {filter.label}
                                                </span>
                                            </label>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- Availability Section -->
                            <div class="border-b border-gray-100">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="availability"
                                >
                                    <span class="font-semibold text-gray-900"
                                        >Availability</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-gray-400 transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                                <div
                                    id="section-availability"
                                    class="hidden px-4 pb-4 space-y-1.5"
                                >
                                    {
                                        AVAILABILITY_FILTERS.map((filter) => (
                                            <label class="flex items-center gap-2 cursor-pointer hover:bg-gray-50 p-1.5 rounded-lg">
                                                <input
                                                    type="checkbox"
                                                    class="filter-checkbox rounded border-gray-300 text-violet-600 focus:ring-violet-500"
                                                    data-filter="availability"
                                                    data-value={filter.key}
                                                />
                                                <span class="text-lg">
                                                    {filter.icon}
                                                </span>
                                                <span class="text-sm text-gray-700">
                                                    {filter.label}
                                                </span>
                                            </label>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- Price Range Section -->
                            <div class="border-b border-gray-100">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="pricing"
                                >
                                    <span class="font-semibold text-gray-900"
                                        >Pricing</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-gray-400 transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path></svg
                                    >
                                </button>
                                <div
                                    id="section-pricing"
                                    class="hidden px-4 pb-4 space-y-3"
                                >
                                    <p
                                        class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2"
                                    >
                                        Price Range
                                    </p>
                                    {
                                        PRICE_RANGE_OPTIONS.map((opt) => (
                                            <label class="flex items-center gap-3 cursor-pointer hover:bg-gray-50 p-2 rounded-lg border border-gray-100">
                                                <input
                                                    type="radio"
                                                    name="priceRange"
                                                    class="text-violet-600 focus:ring-violet-500"
                                                    data-filter="price"
                                                    data-value={opt.value}
                                                />
                                                <div>
                                                    <span class="text-sm font-medium text-gray-900">
                                                        {opt.label}
                                                    </span>
                                                    <p class="text-xs text-gray-500">
                                                        {opt.description}
                                                    </p>
                                                </div>
                                            </label>
                                        ))
                                    }
                                    <p
                                        class="text-xs font-semibold text-gray-400 uppercase tracking-wider mt-4 mb-2"
                                    >
                                        Payment Options
                                    </p>
                                    {
                                        PRICING_FILTERS.map((filter) => (
                                            <label class="flex items-center gap-2 cursor-pointer hover:bg-gray-50 p-1.5 rounded-lg">
                                                <input
                                                    type="checkbox"
                                                    class="filter-checkbox rounded border-gray-300 text-violet-600 focus:ring-violet-500"
                                                    data-filter="pricing"
                                                    data-value={filter.key}
                                                />
                                                <span class="text-lg">
                                                    {filter.icon}
                                                </span>
                                                <span class="text-sm text-gray-700">
                                                    {filter.label}
                                                </span>
                                            </label>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- State Filter -->
                            <div class="p-4">
                                <label
                                    class="block text-sm font-semibold text-gray-900 mb-2"
                                    >Filter by State</label
                                >
                                <select
                                    id="stateFilter"
                                    class="w-full rounded-xl border-gray-200 text-sm focus:ring-violet-500 focus:border-violet-500"
                                >
                                    <option value="">All Locations</option>
                                    <optgroup label="United States">
                                    {
                                        sortedStates.map(([code, list]) => (
                                            <option value={code}>
                                                {stateNames[code] || code} (
                                                {list.length})
                                            </option>
                                        ))
                                    }
                                    </optgroup>
                                    {sortedCountries.length > 0 && (
                                        <optgroup label="International">
                                        {
                                            sortedCountries.map(([code, list]) => (
                                                <option value={code} set:html={`${COUNTRY_FLAGS[code] || ''} ${COUNTRY_NAMES[code] || code} (${list.length})`}></option>
                                            ))
                                        }
                                        </optgroup>
                                    )}
                                </select>
                            </div>
                        </div>
                    </aside>

                    <!-- Clinics Grid -->
                    <div class="flex-1" id="clinicsContainer">
                        {
                            sortedStates.map(([stateCode, stateClinics]) => (
                                <div
                                    class="mb-16 state-section"
                                    data-state={stateCode}
                                >
                                    <h2 class="text-2xl font-semibold text-gray-900 mb-6 flex items-center gap-3">
                                        <span class="w-10 h-10 rounded-lg bg-violet-100 text-violet-600 flex items-center justify-center font-semibold text-sm">
                                            {stateCode}
                                        </span>
                                        {stateNames[stateCode] || stateCode}
                                        <span class="text-sm font-normal text-gray-400 ml-2">
                                            ({stateClinics.length}{" "}
                                            {stateClinics.length === 1
                                                ? "clinic"
                                                : "clinics"}
                                            )
                                        </span>
                                    </h2>

                                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                                        {stateClinics.map((clinic) => (
                                            <article
                                                class="clinic-card bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all"
                                                data-machines={JSON.stringify(
                                                    clinic.machines || [],
                                                )}
                                                data-insurances={JSON.stringify(
                                                    clinic.insurances || [],
                                                )}
                                                data-specialties={JSON.stringify(
                                                    clinic.specialties || [],
                                                )}
                                                data-state={clinic.state}
                                            >
                                                <div class="h-40 overflow-hidden">
                                                    <img
                                                        src={getClinicPhoto(
                                                            clinic,
                                                        )}
                                                        alt={clinic.name}
                                                        class="w-full h-full object-cover"
                                                        loading="lazy"
                                                    />
                                                </div>
                                                <div class="p-6">
                                                    <div class="flex items-center gap-2 mb-3">
                                                        <span class="px-3 py-1 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full">
                                                            ✓ Verified
                                                        </span>
                                                        {getClinicRating(
                                                            clinic,
                                                        ) > 0 && (
                                                            <span class="flex items-center gap-1 text-sm">
                                                                <span class="text-yellow-500">
                                                                    ★
                                                                </span>
                                                                <span class="font-semibold text-gray-900">
                                                                    {getClinicRating(
                                                                        clinic,
                                                                    )}
                                                                </span>
                                                                <span class="text-gray-400">
                                                                    (
                                                                    {getClinicReviewCount(
                                                                        clinic,
                                                                    )}
                                                                    )
                                                                </span>
                                                            </span>
                                                        )}
                                                    </div>

                                                    <h3 class="text-lg font-semibold text-gray-900 mb-1 line-clamp-2">
                                                        {clinic.name}
                                                    </h3>
                                                    <p class="text-gray-500 text-sm mb-3">
                                                        {clinic.city},{" "}
                                                        {clinic.state}
                                                    </p>

                                                    {clinic.phone && (
                                                        <p class="text-sm text-gray-600 mb-2">
                                                            <span class="text-gray-400">
                                                                </span>{" "}
                                                            {clinic.phone}
                                                        </p>
                                                    )}

                                                    <div class="flex flex-wrap gap-1.5 mb-4">
                                                        {clinic.machines &&
                                                            clinic.machines
                                                                .slice(0, 2)
                                                                .map(
                                                                    (
                                                                        machine,
                                                                    ) => (
                                                                        <span class="px-2 py-1 bg-violet-50 text-violet-700 text-xs font-medium rounded">
                                                                            {
                                                                                machine
                                                                            }
                                                                        </span>
                                                                    ),
                                                                )}
                                                    </div>

                                                    <div class="pt-4 border-t border-gray-100 flex items-center justify-between">
                                                        {clinic.website && (
                                                            <a
                                                                href={
                                                                    clinic.website
                                                                }
                                                                target="_blank"
                                                                rel="noopener noreferrer"
                                                                class="text-sm text-gray-400 hover:text-violet-600"
                                                            >
                                                                Website ↗
                                                            </a>
                                                        )}
                                                        <a
                                                            href={`/clinic/${clinic.slug}/`}
                                                            class="text-violet-600 font-semibold text-sm hover:text-violet-700"
                                                        >
                                                            View Details →
                                                        </a>
                                                    </div>
                                                </div>
                                            </article>
                                        ))}
                                    </div>
                                </div>
                            ))
                        }
                        {
                            sortedCountries.map(([countryCode, countryClinics]) => (
                                <div
                                    class="mb-16 state-section"
                                    data-state={countryCode}
                                >
                                    <h2 class="text-2xl font-semibold text-gray-900 mb-6 flex items-center gap-3">
                                        <span class="w-10 h-10 rounded-lg bg-blue-100 text-blue-600 flex items-center justify-center font-semibold text-lg" set:html={COUNTRY_FLAGS[countryCode] || '🌍'}>
                                        {COUNTRY_NAMES[countryCode] || countryCode}
                                        <span class="text-sm font-normal text-gray-400 ml-2">
                                            ({countryClinics.length}{" "}
                                            {countryClinics.length === 1
                                                ? "clinic"
                                                : "clinics"}
                                            )
                                        </span>
                                    </h2>

                                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                                        {countryClinics.map((clinic) => (
                                            <article
                                                class="clinic-card bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all"
                                                data-state={countryCode}
                                            >
                                                <div class="h-40 overflow-hidden">
                                                    <img
                                                        src={getClinicPhoto(clinic)}
                                                        alt={clinic.name}
                                                        class="w-full h-full object-cover"
                                                        loading="lazy"
                                                    />
                                                </div>
                                                <div class="p-6">
                                                    <div class="flex items-center gap-2 mb-3">
                                                        <span class="px-3 py-1 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full">
                                                            ✓ Verified
                                                        </span>
                                                        {getClinicRating(clinic) > 0 && (
                                                            <span class="flex items-center gap-1 text-sm">
                                                                <span class="text-yellow-500">★</span>
                                                                <span class="font-semibold text-gray-900">{getClinicRating(clinic)}</span>
                                                                <span class="text-gray-400">({getClinicReviewCount(clinic)})</span>
                                                            </span>
                                                        )}
                                                    </div>
                                                    <h3 class="text-lg font-semibold text-gray-900 mb-1 line-clamp-2">{clinic.name}</h3>
                                                    <p class="text-gray-500 text-sm mb-3">{clinic.city}, {clinic.state}</p>
                                                    <div class="pt-4 border-t border-gray-100 flex items-center justify-between">
                                                        <a
                                                            href={`/clinic/${clinic.slug}/`}
                                                            class="text-violet-600 font-semibold text-sm hover:text-violet-700"
                                                        >
                                                            View Details →
                                                        </a>
                                                    </div>
                                                </div>
                                            </article>
                                        ))}
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </section>

        <!-- Data Source Note -->
        <section class="py-12 bg-white border-t border-gray-100">
            <div class="container mx-auto px-4 md:px-6 text-center">
                <p class="text-gray-500 text-sm max-w-2xl mx-auto">
                    All clinic data is sourced from Google Places and verified
                    for accuracy. Ratings and review counts are real and not
                    fabricated. If you're a clinic owner and want to update your
                    listing, please <a
                        href="/add-listing/"
                        class="text-violet-600 font-medium"
                        >add or update your listing</a
                    >.
                </p>
            </div>
        </section>
    </main>

    <!-- Filter JavaScript -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // Toggle filter sections
            document.querySelectorAll(".filter-toggle").forEach((btn) => {
                btn.addEventListener("click", () => {
                    const section = btn.getAttribute("data-section");
                    const content = document.getElementById(
                        `section-${section}`,
                    );
                    const arrow = btn.querySelector("svg");
                    if (content) {
                        content.classList.toggle("hidden");
                        arrow?.classList.toggle("rotate-180");
                    }
                });
            });

            // Mobile filter toggle
            const mobileBtn = document.getElementById("mobileFilterBtn");
            const sidebar = document.getElementById("filterSidebar");
            if (mobileBtn && sidebar) {
                mobileBtn.addEventListener("click", () => {
                    sidebar.classList.toggle("hidden");
                    sidebar.classList.toggle("fixed");
                    sidebar.classList.toggle("inset-0");
                    sidebar.classList.toggle("z-50");
                    sidebar.classList.toggle("bg-white");
                    sidebar.classList.toggle("overflow-y-auto");
                    sidebar.classList.toggle("p-4");
                });
            }

            // State filter
            const stateFilter = document.getElementById(
                "stateFilter",
            ) as HTMLSelectElement;
            if (stateFilter) {
                stateFilter.addEventListener("change", () => {
                    const value = stateFilter.value;
                    document
                        .querySelectorAll(".state-section")
                        .forEach((section) => {
                            const sectionEl = section as HTMLElement;
                            if (
                                !value ||
                                sectionEl.getAttribute("data-state") === value
                            ) {
                                sectionEl.style.display = "";
                            } else {
                                sectionEl.style.display = "none";
                            }
                        });
                    updateCount();
                });
            }

            // Clear filters
            const clearBtn = document.getElementById("clearFilters");
            if (clearBtn) {
                clearBtn.addEventListener("click", () => {
                    document
                        .querySelectorAll(".filter-checkbox")
                        .forEach((cb) => {
                            (cb as HTMLInputElement).checked = false;
                        });
                    document
                        .querySelectorAll('input[name="priceRange"]')
                        .forEach((r) => {
                            (r as HTMLInputElement).checked = false;
                        });
                    if (stateFilter) stateFilter.value = "";
                    document
                        .querySelectorAll(".clinic-card")
                        .forEach((card) => {
                            (card as HTMLElement).style.display = "";
                        });
                    document
                        .querySelectorAll(".state-section")
                        .forEach((section) => {
                            (section as HTMLElement).style.display = "";
                        });
                    updateCount();
                });
            }

            function updateCount() {
                const visible = document.querySelectorAll(
                    '.clinic-card:not([style*="display: none"])',
                ).length;
                const countEl = document.getElementById("filteredCount");
                if (countEl) countEl.textContent = String(visible);
            }
        });
    </script>
</Layout>
