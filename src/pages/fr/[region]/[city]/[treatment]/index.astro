---
export const prerender = false;

import Layout from "../../../../../layouts/Layout.astro";
import EditorialHero from "../../../../../components/editorial/EditorialHero.astro";
import ClinicCard from "../../../../../components/ClinicCard.astro";
import { getClinicsByCountryRegionCity } from "../../../../../utils/dataHelpers";
import { COUNTRY_META } from "../../../../../utils/countryData";
import { TREATMENT_SLUGS } from "../../../../../utils/seo_slugs";
import { calculateClinicScore } from "../../../../../utils/ranking";

const { region, city, treatment } = Astro.params;
const meta = COUNTRY_META['FR'];
const regionName = (region || '').replace(/-/g, ' ').replace(/\b\w/g, (ch: string) => ch.toUpperCase());
const cityName = (city || '').replace(/-/g, ' ').replace(/\b\w/g, (ch: string) => ch.toUpperCase());
const treatmentEntry = TREATMENT_SLUGS.find(t => t.slug === treatment);
const conditionName = treatmentEntry ? treatmentEntry.title.replace('TMS for ', '') : (treatment || '').replace(/-/g, ' ').replace(/\b\w/g, (ch: string) => ch.toUpperCase());

const clinics = await getClinicsByCountryRegionCity('FR', regionName, cityName);
const sorted = [...clinics].sort((a, b) => calculateClinicScore(b) - calculateClinicScore(a));

const title = `${conditionName} Treatment with TMS in ${cityName}, France | TMS List`;
const description = `Find TMS providers for ${conditionName.toLowerCase()} in ${cityName}, ${regionName}, France. Compare ${sorted.length} verified clinics, check costs (${meta?.sessionCostRange || 'varies'}), and book consultations.`;
---

<Layout title={title} description={description} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "France", url: "/fr/" },
    { name: regionName, url: `/fr/${region}/` },
    { name: cityName, url: `/fr/${region}/${city}/` },
    { name: conditionName, url: `/fr/${region}/${city}/${treatment}/` },
]}>
    <main>
        <EditorialHero
            eyebrow={`${sorted.length} Verified Clinics`}
            eyebrowDot="#22c55e"
            title=`${conditionName} treatment in`
            titleAccent={`${cityName}.`}
            description={sorted.length > 0
                ? `Compare ${sorted.length} verified TMS providers treating ${conditionName.toLowerCase()} in ${cityName}, France. Session costs: ${meta?.sessionCostRange || 'varies by clinic'}.`
                : `Find TMS providers for ${conditionName.toLowerCase()} near ${cityName}, France.`}
            breadcrumbs={[
                { label: "Home", href: "/" },
                { label: "France", href: "/fr/" },
                { label: regionName, href: `/fr/${region}/` },
                { label: cityName, href: `/fr/${region}/${city}/` },
                { label: conditionName },
            ]}
            ctas={[
                { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
                { label: `Learn about ${conditionName} TMS`, href: `/treatments/${treatment}/`, variant: "outline" },
            ]}
            stats={[
                { value: sorted.length, label: "Clinics", color: "ink" },
                { value: meta?.sessionCostRange || "Varies", label: "Per Session", color: "accent" },
                { value: "FDA", label: "Cleared TMS", color: "warm" },
            ]}
        />

        <section class="py-12 lg:py-16 bg-[var(--paper)]">
            <div class="container mx-auto px-4">
                {sorted.length > 0 ? (
                    <>
                        <h2 class="text-2xl font-bold text-[var(--ink)] tracking-tight mb-8">{conditionName} TMS Providers in {cityName}</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            {sorted.map(clinic => <ClinicCard clinic={clinic} />)}
                        </div>
                    </>
                ) : (
                    <div class="text-center py-16">
                        <h2 class="text-xl font-bold text-[var(--ink)] mb-3">No clinics found for this treatment in {cityName}</h2>
                        <p class="text-[var(--muted)] mb-6">Browse all clinics in the region instead.</p>
                        <a href={`/fr/${region}/`} class="px-6 py-3 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-colors">All {regionName} Clinics</a>
                    </div>
                )}
            </div>
        </section>

        <section class="py-16 bg-[var(--paper2)]">
            <div class="container mx-auto px-4 max-w-4xl prose prose-lg prose-slate">
                <h2>About {conditionName} Treatment with TMS in {cityName}, France</h2>
                <p>
                    Transcranial Magnetic Stimulation (TMS) is a non-invasive brain stimulation therapy used to treat {conditionName.toLowerCase()} by targeting specific brain regions with focused magnetic pulses. In {cityName}, {sorted.length > 0 ? `${sorted.length} verified clinics` : 'providers'} offer this treatment.
                </p>
                <p>
                    TMS is {meta?.tmsStatus || 'available'} in France. Sessions typically cost {meta?.sessionCostRange || 'varies'}, with treatment courses involving 20-36 sessions over 4-6 weeks. {meta?.insuranceNote || ''}
                </p>
                <h3>Choosing a TMS Provider in {cityName}</h3>
                <p>When selecting a clinic in {cityName} for {conditionName.toLowerCase()} treatment, consider the treating psychiatrist's experience, TMS device used, insurance acceptance, and patient reviews. All clinics listed on TMS List are verified.</p>
                <p><a href={`/treatments/${treatment}/`}>Read our complete guide to TMS for {conditionName.toLowerCase()}</a></p>
            </div>
        </section>

        <section class="py-12 bg-[var(--paper)] border-t border-[var(--line)]">
            <div class="container mx-auto px-4 max-w-5xl">
                <h2 class="text-xl font-bold text-[var(--ink)] mb-6">Other TMS Treatments in {cityName}</h2>
                <div class="flex flex-wrap gap-2">
                    {TREATMENT_SLUGS.filter(t => t.slug !== treatment).slice(0, 10).map(t => (
                        <a href={`/fr/${region}/${city}/${t.slug}/`}
                           class="px-4 py-2 bg-[var(--paper2)] border border-[var(--line)] text-sm font-medium text-[var(--ink2)] rounded-xl hover:border-[rgba(10,22,40,0.2)] hover:text-[var(--accent)] transition-all">
                            {t.title.replace('TMS for ', '')}
                        </a>
                    ))}
                </div>
            </div>
        </section>

        <section class="relative py-16 bg-[var(--ink)] overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-[#0A1628]/10 via-transparent to-[rgba(10,22,40,0.10)]"></div>
            <div class="container mx-auto px-4 text-center relative z-10">
                <h2 class="text-2xl font-bold text-white mb-4">Find the right TMS provider for {conditionName.toLowerCase()}</h2>
                <p class="text-[var(--muted)] mb-8">Take our assessment or browse clinics in {cityName}.</p>
                <div class="flex gap-4 justify-center flex-wrap">
                    <a href="/quiz/am-i-a-candidate/" class="px-8 py-3.5 bg-[var(--ink)] hover:bg-[var(--ink2)] text-white font-semibold rounded-xl transition-colors shadow-lg shadow-[rgba(10,22,40,0.2)]">Am I a Candidate?</a>
                    <a href={`/fr/${region}/${city}/`} class="px-8 py-3.5 bg-[var(--paper)]/5 border border-white/10 hover:border-white/25 text-white font-semibold rounded-xl transition-all">All {cityName} Clinics</a>
                </div>
            </div>
        </section>
    </main>
</Layout>
