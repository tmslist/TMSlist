---
import Layout from "../layouts/Layout.astro";
import {
    TREATMENT_SLUGS,
    INSURANCE_SLUGS,
    COMPARE_SLUGS,
    TECHNOLOGY_SLUGS,
} from "../utils/seo_slugs";
import {
    getUniqueStates,
    getClinicsByState,
    STATE_NAMES,
    getStateSlug,
    buildInternationalDirectory,
    COUNTRY_NAMES,
    COUNTRY_FLAGS,
    COUNTRY_URL_PREFIXES,
} from "../utils/dataHelpers";

// Get all states with content
const uniqueStates = (await getUniqueStates()).sort();

// Prepare state data with city counts
const stateData = [];
for (const stateCode of uniqueStates) {
    const clinics = await getClinicsByState(stateCode);
    const cities = [
        ...new Set(clinics.map((c) => c.city).filter(Boolean)),
    ].sort();
    stateData.push({
        code: stateCode,
        name: STATE_NAMES[stateCode] || stateCode,
        slug: getStateSlug(stateCode),
        cityCount: cities.length,
        clinicCount: clinics.length,
    });
}

const internationalDirectory = await buildInternationalDirectory();

const title = "Sitemap | TMS List";
const description =
    "Complete site overview of TMS List. Browse all treatments, insurance providers, clinic locations, and comparison guides.";
---

<Layout title={title} description={description}>
    <main class="min-h-screen">
        <!-- Hero -->
        <section class="relative bg-slate-950 overflow-hidden">
            <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.3) 1px, transparent 0); background-size: 32px 32px;"></div>
            <div class="absolute top-[-10%] left-[20%] w-[500px] h-[500px] bg-violet-600/12 rounded-full blur-[150px]"></div>
            <div class="absolute bottom-[10%] right-[10%] w-[400px] h-[400px] bg-cyan-500/8 rounded-full blur-[120px]"></div>

            <div class="container mx-auto px-4 pt-12 pb-24 lg:pt-16 lg:pb-32 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-500 mb-12" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
                    <span class="text-slate-700">/</span>
                    <span class="text-slate-300">Sitemap</span>
                </nav>
                <div class="max-w-2xl">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-full mb-6">
                        <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></div>
                        <span class="text-xs font-semibold text-slate-300 tracking-wider uppercase">Complete Directory</span>
                    </div>
                    <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white leading-[0.95] mb-5">
                        Site<span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400">map</span>
                    </h1>
                    <p class="text-lg text-slate-400 leading-relaxed">
                        Browse our complete directory of TMS resources, locations, and guides.
                    </p>
                </div>
            </div>
        </section>

        <section class="py-16 bg-white">
        <div class="container mx-auto px-4 max-w-6xl">

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
            <!-- COLUMN 1: General & Treatments -->
            <div class="space-y-12">
                <section>
                    <h2
                        class="text-xl font-semibold tracking-tight text-slate-900 mb-4 border-b border-slate-200 pb-2"
                    >
                        General
                    </h2>
                    <ul class="space-y-2">
                        <li>
                            <a
                                href="/"
                                class="text-slate-600 hover:text-violet-600 hover:underline transition-colors"
                                >Home</a
                            >
                        </li>
                        <li>
                            <a
                                href="/verified-clinics/"
                                class="text-slate-600 hover:text-violet-600 hover:underline transition-colors"
                                >Verified Clinics</a
                            >
                        </li>
                        <li>
                            <a
                                href="/specialists/"
                                class="text-slate-600 hover:text-violet-600 hover:underline transition-colors"
                                >Find a Specialist</a
                            >
                        </li>
                        <li>
                            <a
                                href="/about-us/"
                                class="text-slate-600 hover:text-violet-600 hover:underline transition-colors"
                                >About Us</a
                            >
                        </li>
                        <li>
                            <a
                                href="/blog/"
                                class="text-slate-600 hover:text-violet-600 hover:underline transition-colors"
                                >Blog & Guides</a
                            >
                        </li>
                        <li>
                            <a
                                href="/contact/"
                                class="text-slate-600 hover:text-violet-600 hover:underline transition-colors"
                                >Contact</a
                            >
                        </li>
                        <li>
                            <a
                                href="/add-listing/"
                                class="text-slate-600 hover:text-violet-600 hover:underline transition-colors"
                                >List Your Clinic (Free)</a
                            >
                        </li>
                    </ul>
                </section>

                <section>
                    <h2
                        class="text-xl font-semibold tracking-tight text-slate-900 mb-4 border-b border-slate-200 pb-2"
                    >
                        Treatments
                    </h2>
                    <ul class="space-y-2">
                        {
                            TREATMENT_SLUGS.map((item) => (
                                <li>
                                    <a
                                        href={`/treatments/${item.slug}/`}
                                        class="text-gray-600 hover:text-violet-600 hover:underline block py-0.5"
                                    >
                                        {item.title}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </section>
            </div>

            <!-- COLUMN 2: Comparisons & Technology -->
            <div class="space-y-12">
                <section>
                    <h2
                        class="text-xl font-semibold tracking-tight text-slate-900 mb-4 border-b border-slate-200 pb-2"
                    >
                        Comparisons
                    </h2>
                    <ul class="space-y-2">
                        {
                            COMPARE_SLUGS.map((item) => (
                                <li>
                                    <a
                                        href={`/compare/${item.slug}/`}
                                        class="text-gray-600 hover:text-violet-600 hover:underline block py-0.5"
                                    >
                                        {item.title}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </section>

                <section>
                    <h2
                        class="text-xl font-semibold tracking-tight text-slate-900 mb-4 border-b border-slate-200 pb-2"
                    >
                        Technology
                    </h2>
                    <ul class="space-y-2">
                        {
                            TECHNOLOGY_SLUGS.map((item) => (
                                <li>
                                    <a
                                        href={`/technology/${item.slug}/`}
                                        class="text-gray-600 hover:text-violet-600 hover:underline block py-0.5"
                                    >
                                        {item.title}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </section>
            </div>

            <!-- COLUMN 3: Insurance -->
            <div class="space-y-12">
                <section>
                    <h2
                        class="text-xl font-semibold tracking-tight text-slate-900 mb-4 border-b border-slate-200 pb-2"
                    >
                        Insurance Coverage
                    </h2>
                    <ul class="space-y-2 text-sm">
                        {
                            INSURANCE_SLUGS.map((item) => (
                                <li>
                                    <a
                                        href={`/insurance/${item.slug}/`}
                                        class="text-gray-600 hover:text-violet-600 hover:underline block py-0.5"
                                    >
                                        {item.title}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </section>
            </div>

            <!-- COLUMN 4: Locations (States) -->
            <div class="space-y-12">
                <section>
                    <h2
                        class="text-xl font-semibold tracking-tight text-slate-900 mb-4 border-b border-slate-200 pb-2"
                    >
                        Locations
                    </h2>
                    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mt-2 mb-2">United States</h3>
                    <div class="grid grid-cols-1 gap-2 text-sm">
                        {
                            stateData.map((state) => (
                                <a
                                    href={`/us/${state.slug}/`}
                                    class="group flex items-center justify-between text-gray-600 hover:text-violet-600 hover:underline py-0.5"
                                >
                                    <span>{state.name}</span>
                                    <span class="text-xs text-gray-400 bg-gray-100 px-1.5 rounded group-hover:bg-violet-50 group-hover:text-violet-600">
                                        {state.cityCount} Cities
                                    </span>
                                </a>
                            ))
                        }
                    </div>

                    {internationalDirectory.map((country) => (
                        <div class="mt-6">
                            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-2">
                                {country.flag} {country.name}
                            </h3>
                            <div class="grid grid-cols-1 gap-2 text-sm">
                                <a
                                    href={`/${country.urlPrefix}/`}
                                    class="group flex items-center justify-between text-gray-600 hover:text-violet-600 hover:underline py-0.5 font-medium"
                                >
                                    <span>All {country.name} Clinics</span>
                                    <span class="text-xs text-gray-400 bg-gray-100 px-1.5 rounded group-hover:bg-violet-50 group-hover:text-violet-600">
                                        {country.clinicCount}
                                    </span>
                                </a>
                                {country.regions.map((region) => (
                                    <a
                                        href={`/${country.urlPrefix}/${region.slug}/`}
                                        class="group flex items-center justify-between text-gray-600 hover:text-violet-600 hover:underline py-0.5"
                                    >
                                        <span>{region.name}</span>
                                        <span class="text-xs text-gray-400 bg-gray-100 px-1.5 rounded group-hover:bg-violet-50 group-hover:text-violet-600">
                                            {region.clinicCount}
                                        </span>
                                    </a>
                                ))}
                            </div>
                        </div>
                    ))}
                </section>
            </div>
        </div>
        </div>
        </section>
    </main>
</Layout>
