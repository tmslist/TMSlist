---
import Layout from '../../layouts/Layout.astro';
import { TREATMENT_SLUGS } from '../../utils/seo_slugs';

const title = "TMS Treatment Conditions | Depression, OCD, Anxiety & More";
const description = "Explore FDA-cleared TMS therapy conditions including depression, OCD, migraine, and smoking cessation. Learn about treatment protocols, success rates, and TMS effectiveness.";

const TREATMENT_META: Record<string, {
    description: string;
    fdaCleared: boolean;
    successRate: string;
    sessions: string;
    brainArea: string;
    year?: string;
    responseRate?: string;
}> = {
    'depression': { description: 'The most studied TMS application. Targets the left dorsolateral prefrontal cortex to regulate mood circuits disrupted in major depressive disorder.', fdaCleared: true, successRate: '37%', responseRate: '58%', sessions: '30-36', brainArea: 'Left DLPFC', year: '2008' },
    'anxiety': { description: 'Emerging evidence supports TMS for generalized anxiety and social anxiety disorders, often treated alongside comorbid depression.', fdaCleared: false, successRate: '35-45%', sessions: '20-30', brainArea: 'Right DLPFC' },
    'ocd': { description: 'FDA-cleared using BrainsWay Deep TMS with the H7 coil. Targets the anterior cingulate cortex and medial prefrontal cortex.', fdaCleared: true, successRate: '40%', responseRate: '45%', sessions: '29-30', brainArea: 'mPFC / ACC', year: '2018' },
    'ptsd': { description: 'Growing clinical evidence with multiple ongoing trials. Targets right DLPFC to modulate threat-processing and emotional regulation networks.', fdaCleared: false, successRate: '35-45%', sessions: '20-30', brainArea: 'Right DLPFC' },
    'migraine': { description: 'Single-pulse TMS (sTMS) devices are FDA-cleared for acute migraine treatment via cortical spreading depression inhibition.', fdaCleared: true, successRate: '35%', sessions: 'As needed', brainArea: 'Occipital Cortex', year: '2013' },
    'tinnitus': { description: 'Low-frequency rTMS to the temporoparietal cortex shows promise in reducing phantom sound perception in chronic tinnitus.', fdaCleared: false, successRate: '30-40%', sessions: '10-20', brainArea: 'Temporoparietal' },
    'bipolar-depression': { description: 'TMS shows promise for bipolar depressive episodes. Careful low-frequency protocols help minimize manic switching risk.', fdaCleared: false, successRate: '30-40%', sessions: '20-30', brainArea: 'Right DLPFC' },
    'adhd': { description: 'Preliminary research explores targeting the prefrontal cortex to enhance executive function and attentional control in ADHD.', fdaCleared: false, successRate: '25-35%', sessions: '15-20', brainArea: 'Right DLPFC' },
    'smoking-cessation': { description: 'FDA-cleared using BrainsWay Deep TMS. Targets the bilateral insula and prefrontal cortex to reduce cravings.', fdaCleared: true, successRate: '35%', sessions: '18', brainArea: 'Bilateral Insula', year: '2020' },
    'chronic-pain': { description: 'High-frequency rTMS to the primary motor cortex shows analgesic effects in fibromyalgia, neuropathic pain, and complex regional pain syndrome.', fdaCleared: false, successRate: '30-50%', sessions: '10-20', brainArea: 'Motor Cortex' },
    'stroke-rehabilitation': { description: 'Inhibitory rTMS to the contralesional hemisphere helps rebalance interhemispheric competition and promote motor recovery after stroke.', fdaCleared: false, successRate: '25-40%', sessions: '10-20', brainArea: 'Motor Cortex' },
    'substance-abuse': { description: 'Research explores TMS for reducing cravings in alcohol, cocaine, and opioid use disorders by modulating reward circuitry.', fdaCleared: false, successRate: '25-40%', sessions: '15-20', brainArea: 'DLPFC / Insula' },
};

const enrichedTreatments = TREATMENT_SLUGS.map(item => {
    const slug = item.slug.replace('tms-for-', '').replace('tms-', '');
    const meta = TREATMENT_META[slug] || {
        description: `Learn about TMS therapy for ${item.title.replace('TMS for ', '').toLowerCase()}.`,
        fdaCleared: false, successRate: 'Varies', sessions: 'Varies', brainArea: 'DLPFC'
    };
    return { ...item, ...meta, cleanTitle: item.title.replace('TMS for ', '') };
});

const fdaCleared = enrichedTreatments.filter(t => t.fdaCleared);
const research = enrichedTreatments.filter(t => !t.fdaCleared);

const treatmentSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Conditions Treated with TMS Therapy",
    "description": description,
    "url": "https://tmslist.com/treatments/",
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": TREATMENT_SLUGS.length,
        "itemListElement": TREATMENT_SLUGS.map((item, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "item": {
                "@type": "MedicalCondition",
                "name": item.title.replace('TMS for ', ''),
                "url": `https://tmslist.com/treatments/${item.slug}/`,
                "possibleTreatment": { "@type": "MedicalTherapy", "name": "Transcranial Magnetic Stimulation (TMS)" }
            }
        }))
    }
});
---

<Layout title={title} description={description} schema={treatmentSchema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Conditions Treated", url: "/treatments/" },
]}>

<style>
  :root{--ink:#0A1628;--ink2:#1E2A3B;--muted:#5A6B82;--warm:#C9654A;--line:#E6EAF0;--paper:#FBFAF7;--paper2:#F4F1EA;--accent:#0A1628;}
  .serif{font-family:'Instrument Serif',Georgia,serif;font-weight:400;letter-spacing:-0.02em}
  .linky{position:relative;display:inline-block}
  .linky::after{content:'';position:absolute;bottom:-1px;left:0;right:0;height:1px;background:currentColor;transform:scaleX(0);transform-origin:left;transition:transform .35s cubic-bezier(.2,.8,.2,1)}
  .linky:hover::after{transform:scaleX(1)}
  .card-tag{font-size:10px;font-weight:600;padding:.25rem .625rem;border-radius:.375rem;text-transform:uppercase;letter-spacing:.1em}
  .cond-card{transition:box-shadow .2s,transform .2s;border-radius:1.5rem;overflow:hidden}
  .cond-card:hover{box-shadow:0 20px 60px -15px rgba(10,22,40,.15);transform:translateY(-2px)}
  .cond-card:hover .card-arrow{transform:translateX(4px)}
</style>

<main style="background:var(--paper)">

  <!-- HERO -->
  <section style="background:var(--paper); padding-top:8rem; padding-bottom:4rem; border-bottom:1px solid var(--line); position:relative; overflow:hidden;">
    <!-- Dot grid bg -->
    <div class="absolute inset-0 pointer-events-none" style="background-image:radial-gradient(var(--line) 1px,transparent 1px);background-size:40px 40px;opacity:.5"></div>
    <!-- Warm accent -->
    <div class="absolute top-0 left-[10%] w-[500px] h-[500px] rounded-full blur-[150px] pointer-events-none" style="background:rgba(201,101,74,0.08)"></div>

    <div class="max-w-[1400px] mx-auto px-6 lg:px-8 relative">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-[11px] uppercase tracking-[0.15em] mb-8" style="color:var(--muted)" aria-label="Breadcrumb">
        <a href="/" class="linky hover:text-[color:var(--ink)]" style="color:inherit">Home</a>
        <span>/</span>
        <span style="color:var(--ink)">Conditions</span>
      </nav>

      <div class="grid lg:grid-cols-2 gap-12 items-end">
        <div>
          <div class="flex items-center gap-2 mb-8">
            <span class="w-1.5 h-1.5 rounded-full" style="background:#22c55e"></span>
            <span class="text-[11px] font-semibold uppercase tracking-wider" style="color:var(--muted)">{fdaCleared.length} FDA-Cleared Indications</span>
          </div>

          <h1 class="serif mb-6" style="font-size:clamp(2.5rem,6vw,5.5rem); line-height:.93; color:var(--ink)">
            What TMS<br/>
            <span class="italic" style="color:var(--warm)">can treat.</span>
          </h1>

          <p class="text-[17px] leading-[1.65] max-w-xl" style="color:var(--muted)">
            From FDA-cleared protocols for depression and OCD to emerging research in PTSD and chronic pain. Evidence-based guides for every condition.
          </p>

          <div class="flex flex-wrap gap-3 mt-8">
            <a href="/quiz/am-i-a-candidate/" class="px-5 py-3 rounded-full text-[14px] font-medium text-white transition-opacity hover:opacity-90" style="background:var(--ink)">
              Take the Eligibility Quiz
            </a>
            <a href="/us/" class="px-5 py-3 rounded-full text-[14px] font-medium transition-colors" style="border:1px solid var(--line); color:var(--ink)">
              Find a TMS Clinic
            </a>
          </div>
        </div>

        <!-- Quick stats ribbon -->
        <div class="flex flex-wrap gap-3 lg:justify-end items-start">
          <div class="rounded-2xl px-5 py-4 text-center" style="background:var(--paper2); border:1px solid var(--line)">
            <div class="serif" style="font-size:2.25rem; color:var(--ink)">{enrichedTreatments.length}</div>
            <div class="text-[10px] font-medium uppercase tracking-wider mt-0.5" style="color:var(--muted)">Conditions</div>
          </div>
          <div class="rounded-2xl px-5 py-4 text-center" style="background:var(--paper2); border:1px solid var(--line)">
            <div class="serif" style="font-size:2.25rem; color:var(--accent)">{fdaCleared.length}</div>
            <div class="text-[10px] font-medium uppercase tracking-wider mt-0.5" style="color:var(--muted)">FDA-Cleared</div>
          </div>
          <div class="rounded-2xl px-5 py-4 text-center" style="background:var(--paper2); border:1px solid var(--line)">
            <div class="serif" style="font-size:2.25rem; color:var(--warm)">58%</div>
            <div class="text-[10px] font-medium uppercase tracking-wider mt-0.5" style="color:var(--muted)">Response Rate</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FDA-CLEARED CONDITIONS GRID -->
  <section style="background:var(--paper); padding:4rem 0; border-bottom:1px solid var(--line)">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-8">
      <div class="flex items-baseline justify-between mb-10 flex-wrap gap-4">
        <div>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:rgba(34,197,94,0.1); color:#22c55e">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <h2 class="serif" style="font-size:clamp(1.75rem,3vw,2.25rem); color:var(--ink)">FDA-Cleared</h2>
          </div>
          <p class="text-[15px]" style="color:var(--muted)">Conditions with regulatory approval for TMS. Typically covered by insurance.</p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {fdaCleared.map((item) => (
          <a href={`/treatments/${item.slug}/`} class="cond-card block" style="background:var(--paper2); border:1px solid var(--line)">
            <div class="p-7">
              <div class="flex items-center justify-between mb-5">
                <span class="card-tag" style="background:rgba(34,197,94,0.12); color:#16a34a; border:1px solid rgba(34,197,94,0.2)">
                  FDA Cleared {item.year ? `· ${item.year}` : ''}
                </span>
                <svg class="card-arrow w-5 h-5 transition-transform" style="color:var(--muted)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>

              <h3 class="serif mb-3 leading-tight" style="font-size:1.5rem; color:var(--ink)">{item.cleanTitle}</h3>
              <p class="text-[14px] leading-[1.65] mb-5" style="color:var(--muted)">{item.description}</p>

              <div class="pt-5" style="border-top:1px solid var(--line)">
                <div class="grid grid-cols-3 gap-3">
                  <div>
                    <div class="text-[10px] font-medium uppercase tracking-wider mb-0.5" style="color:var(--muted)">Response</div>
                    <div class="text-[15px] font-bold" style="color:var(--accent)">{item.responseRate || item.successRate}</div>
                  </div>
                  <div>
                    <div class="text-[10px] font-medium uppercase tracking-wider mb-0.5" style="color:var(--muted)">Sessions</div>
                    <div class="text-[15px] font-bold" style="color:var(--ink)">{item.sessions}</div>
                  </div>
                  <div>
                    <div class="text-[10px] font-medium uppercase tracking-wider mb-0.5" style="color:var(--muted)">Target</div>
                    <div class="text-[12px] font-medium truncate" style="color:var(--accent)">{item.brainArea}</div>
                  </div>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- RESEARCH & EMERGING CONDITIONS -->
  <section style="background:var(--paper); padding:4rem 0;">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-8">
      <div class="flex items-baseline justify-between mb-10 flex-wrap gap-4">
        <div>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:rgba(10,22,40,0.1); color:var(--accent)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
            </div>
            <h2 class="serif" style="font-size:clamp(1.75rem,3vw,2.25rem); color:var(--ink)">Research &amp; Emerging</h2>
          </div>
          <p class="text-[15px]" style="color:var(--muted)">Active trials and off-label applications with growing evidence. Not yet FDA-cleared for TMS.</p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {research.map((item) => (
          <a href={`/treatments/${item.slug}/`} class="cond-card block" style="background:var(--paper2); border:1px solid var(--line)">
            <div class="p-6">
              <div class="flex items-start justify-between mb-4">
                <span class="card-tag" style="background:rgba(10,22,40,0.1); color:var(--accent); border:1px solid rgba(10,22,40,0.2)">Research</span>
                <svg class="card-arrow w-4 h-4 transition-transform" style="color:var(--muted)" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>

              <h3 class="serif mb-2 leading-tight" style="font-size:1.25rem; color:var(--ink)">{item.cleanTitle}</h3>
              <p class="text-[13px] leading-[1.6] mb-4 line-clamp-2" style="color:var(--muted)">{item.description}</p>

              <div class="pt-4 flex items-center gap-4 text-[11px]" style="border-top:1px solid var(--line)">
                <div>
                  <span style="color:var(--muted)">Success </span>
                  <span class="font-medium" style="color:var(--ink)">{item.successRate}</span>
                </div>
                <div>
                  <span style="color:var(--muted)">Target </span>
                  <span style="color:var(--accent)">{item.brainArea}</span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section style="background:var(--ink); padding:5rem 0;">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-8 text-center">
      <h2 class="serif mb-5" style="font-size:clamp(2rem,4vw,3rem); color:white; line-height:1.05">
        Not sure where to start?
      </h2>
      <p class="text-[17px] mb-10 max-w-xl mx-auto" style="color:rgba(255,255,255,0.5)">
        Our quick assessment evaluates your symptoms and treatment history to determine if you may be a TMS candidate.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/quiz/am-i-a-candidate/" class="px-7 py-4 rounded-full font-semibold text-[15px] text-white transition-opacity hover:opacity-90" style="background:var(--warm)">
          Take the Assessment
        </a>
        <a href="/us/" class="px-7 py-4 rounded-full font-medium text-[15px] transition-colors" style="border:1px solid rgba(255,255,255,0.2); color:rgba(255,255,255,0.8)">
          Find a Clinic Near You
        </a>
      </div>
    </div>
  </section>

  <!-- STICKY MOBILE CTA BAR -->
  <div class="lg:hidden fixed bottom-0 left-0 right-0 z-50 shadow-[0_-4px_20px_rgba(0,0,0,0.15)]" style="background:var(--paper); border-top:1px solid var(--line)">
    <div class="flex items-center gap-2 px-4 py-3">
      <a href="/quiz/am-i-a-candidate/" class="flex-1 text-center text-white font-semibold text-sm py-3 px-4 rounded-xl" style="background:var(--ink)">
        Take the Quiz
      </a>
      <a href="/us/" class="flex-1 text-center font-semibold text-sm py-3 px-4 rounded-xl transition-colors" style="border:1px solid var(--line); color:var(--ink)">
        Find a Clinic
      </a>
    </div>
  </div>

</main>

</Layout>
