---
export const prerender = true;

import TreatmentPage from '../../layouts/TreatmentPage.astro';
import { getCollection, render } from 'astro:content';
import { TREATMENT_SLUGS } from '../../utils/seo_slugs';

export async function getStaticPaths() {
  const entries = await getCollection('treatments');

  const contentPaths = entries.map((entry) => ({
    params: { slug: entry.id },
    props: {
      title: entry.data.title,
      description: entry.data.description,
      condition: entry.data.condition,
      fdaApproved: entry.data.fdaApproved,
      successRate: entry.data.successRate,
      sessionCount: entry.data.sessionCount,
      duration: entry.data.duration,
      brainArea: entry.data.brainArea,
      image: entry.data.image,
      faqs: entry.data.faqs || [],
      hasContent: true,
      entry,
    },
  }));

  const contentSlugsSet = new Set(contentPaths.map(p => p.params.slug));
  const fallbackPaths = TREATMENT_SLUGS
    .filter(({ slug }) => !contentSlugsSet.has(slug))
    .map(({ slug, title }) => ({
      params: { slug },
      props: { title, description: `Learn how TMS therapy is used to treat ${title}. Explore FDA-cleared protocols, success rates, and find nearby providers.`, hasContent: false, entry: null },
    }));

  return [...contentPaths, ...fallbackPaths];
}

const { title, description, condition, fdaApproved, successRate, sessionCount, duration, brainArea, faqs, hasContent, entry } = Astro.props;
const slug = Astro.params.slug!;
let Content: any = null;
if (hasContent && entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const medicalSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": title,
  "description": description || `How TMS therapy is used to treat ${title}.`,
  "url": `${siteUrl}/treatments/${slug}/`,
  "about": {
    "@type": "MedicalTherapy",
    "name": "Transcranial Magnetic Stimulation (TMS)",
    "medicalSpecialty": "Psychiatry",
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `${siteUrl}/treatments/${slug}/` },
  "reviewedBy": {
    "@type": "Person",
    "name": "Dr. Karan Narwal",
    "jobTitle": "Mental Health Specialist & Consultant",
    "image": "https://img1.wsimg.com/isteam/ip/f791d9b9-2f6c-4539-b9b3-61b4c8a8a446/Screenshot%202024-11-16%20at%204.26.32%E2%80%AFPM.png/:/cr=t:0%25,l:6.95%25,w:86.1%25,h:100%25/rs=w:600,h:600,cg:true",
  },
  "lastReviewed": "2026-04-01",
  "publisher": {
    "@type": "Organization",
    "name": "TMS List",
    "url": siteUrl,
  },
});

const faqSchema = faqs && faqs.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq: { question: string; answer: string }) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
  })),
}) : null;
---

<TreatmentPage
  title={title}
  condition={condition}
  description={description}
  fdaApproved={fdaApproved}
  successRate={successRate}
  sessionCount={sessionCount}
  duration={duration}
  brainArea={brainArea}
  schema={medicalSchema}
  slug={slug}
  faqs={faqs || []}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Treatments", url: "/treatments/" },
    { name: title, url: `/treatments/${slug}/` },
  ]}
>
  {Content ? <Content /> : null}
</TreatmentPage>

{faqSchema && (
  <script type="application/ld+json" set:html={faqSchema} />
)}
