---
import ContentPage from "../layouts/ContentPage.astro";
---

<ContentPage
    title="Contact Us | TMS List Support & Partnerships"
    subtitle="Got a question? Found something wrong? We want to hear about it."
    description="Reach the TMS List team for support, to report a listing issue, or to discuss clinic partnerships."
>
    <p>
        We read every email. If something's wrong with a listing, if your clinic should be on here, or if you just have a question about TMS — reach out.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 not-prose mt-6">
        <div class="bg-gray-50 p-6 rounded-xl border border-gray-200">
            <h2 class="text-xl font-semibold mb-3">Patients & General</h2>
            <p class="text-gray-600 mb-4">
                Questions about TMS, help finding a clinic, or something that looks off on a listing.
            </p>
            <a
                href="mailto:tmslistofficial@gmail.com"
                class="inline-flex items-center gap-2 px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold rounded-lg transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                Email Us
            </a>
        </div>
        <div class="bg-gray-50 p-6 rounded-xl border border-gray-200">
            <h2 class="text-xl font-semibold mb-3">Clinic Owners</h2>
            <p class="text-gray-600 mb-4">
                Claim your profile, update your info, or ask about featured listings.
            </p>
            <a
                href="mailto:tmslistofficial@gmail.com"
                class="inline-flex items-center gap-2 px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold rounded-lg transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                Email Us
            </a>
        </div>
        <div class="bg-amber-50 p-6 rounded-xl border border-amber-200">
            <h2 class="text-xl font-semibold mb-3">Sales Enquiry</h2>
            <p class="text-gray-600 mb-4">
                Advertise your clinic, partnerships, or bulk listings.
            </p>
            <div class="flex flex-col gap-2">
                <a
                    href="mailto:tmslistofficial@gmail.com?subject=Sales Enquiry"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-amber-600 hover:bg-amber-500 text-white text-sm font-semibold rounded-lg transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    Email Us
                </a>
                <a
                    href="https://wa.me/919789565515?text=Hi%2C%20I%20have%20a%20sales%20enquiry%20about%20TMS%20List"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-semibold rounded-lg transition-colors">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    WhatsApp Us
                </a>
            </div>
        </div>
    </div>

    <!-- Contact Form -->
    <div class="not-prose mt-12 bg-gray-50 rounded-2xl border border-gray-200 p-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Send us a message</h2>
        <p class="text-gray-500 mb-6 text-sm">We'll get back to you within one business day.</p>

        <form id="contact-form" class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label for="contact-name" class="block text-sm font-medium text-gray-700 mb-1">Name <span class="text-red-400">*</span></label>
                    <input type="text" id="contact-name" name="name" required
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-sm focus:border-violet-500 focus:ring-2 focus:ring-violet-200" />
                </div>
                <div>
                    <label for="contact-email" class="block text-sm font-medium text-gray-700 mb-1">Email <span class="text-red-400">*</span></label>
                    <input type="email" id="contact-email" name="email" required
                        class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-sm focus:border-violet-500 focus:ring-2 focus:ring-violet-200" />
                </div>
            </div>

            <div>
                <label for="contact-subject" class="block text-sm font-medium text-gray-700 mb-1">Subject</label>
                <select id="contact-subject" name="subject"
                    class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-sm focus:border-violet-500 focus:ring-2 focus:ring-violet-200">
                    <option value="general">General Question</option>
                    <option value="listing">Listing Issue / Correction</option>
                    <option value="clinic">Clinic Owner Inquiry</option>
                    <option value="partnership">Partnership / Business</option>
                    <option value="bug">Bug Report</option>
                    <option value="other">Other</option>
                </select>
            </div>

            <div>
                <label for="contact-message" class="block text-sm font-medium text-gray-700 mb-1">Message <span class="text-red-400">*</span></label>
                <textarea id="contact-message" name="message" rows="5" required minlength="10" maxlength="5000"
                    class="w-full px-4 py-2.5 rounded-lg border border-gray-300 text-sm focus:border-violet-500 focus:ring-2 focus:ring-violet-200"
                    placeholder="How can we help?"></textarea>
            </div>

            <button type="submit" id="contact-submit"
                class="px-6 py-3 bg-violet-600 text-white font-semibold rounded-xl hover:bg-violet-700 transition-colors text-sm disabled:opacity-50">
                Send Message
            </button>

            <div id="contact-success" class="hidden mt-4 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-center" role="status" aria-live="polite">
                <p class="text-emerald-700 font-medium text-sm">Message sent! We'll get back to you soon.</p>
            </div>
            <div id="contact-error" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-xl text-center" role="alert" aria-live="assertive">
                <p class="text-red-700 font-medium text-sm">Something went wrong. Please email us directly.</p>
            </div>
        </form>
    </div>

    <p class="mt-8 text-gray-500 text-sm">
        We usually reply within one business day. If it's urgent, put "URGENT" in the subject line.
    </p>
</ContentPage>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const btn = document.getElementById('contact-submit') as HTMLButtonElement;
        const success = document.getElementById('contact-success');
        const error = document.getElementById('contact-error');

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            btn.disabled = true;
            btn.textContent = 'Sending...';
            success?.classList.add('hidden');
            error?.classList.add('hidden');

            try {
                const data = Object.fromEntries(new FormData(form));
                const res = await fetch('/api/leads', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        type: 'contact',
                        name: data.name,
                        email: data.email,
                        message: `[${data.subject}] ${data.message}`,
                        sourceUrl: '/contact',
                    }),
                });

                if (res.ok) {
                    success?.classList.remove('hidden');
                    form.reset();
                } else {
                    const errData = await res.json().catch(() => ({}));
                    if (error) {
                        error.textContent = errData.error || `Something went wrong (${res.status}). Please try again or email us directly.`;
                    }
                    error?.classList.remove('hidden');
                }
            } catch {
                if (error) error.textContent = 'Network error. Please check your connection and try again.';
                error?.classList.remove('hidden');
            } finally {
                btn.disabled = false;
                btn.textContent = 'Send Message';
            }
        });
    });
</script>
