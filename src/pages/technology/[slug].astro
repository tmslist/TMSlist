---
import Layout from '../../layouts/Layout.astro';
import { getAllClinics, getClinicsByMachine } from '../../utils/clinicData';
import { ClinicMachine } from '../../types/clinic';

export async function getStaticPaths() {
  const clinics = await getAllClinics();
  // Get all unique machines used across all clinics
  const uniqueMachines = [...new Set(clinics.flatMap(c => c.machines))];

  const paths = [];
  for (const machine of uniqueMachines) {
    const machineClinics = await getClinicsByMachine(machine);
    const slug = machine.toLowerCase().replace(/\s+/g, '-');
    
    paths.push({
      params: { slug },
      props: { machineName: machine, machineClinics },
    });
  }
  return paths;
}

const { machineName, machineClinics } = Astro.props;
const title = `${machineName} TMS Therapy Clinics - TMS List`;

const techSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "MedicalDevice",
  "name": machineName,
  "description": `${machineName} is an FDA-cleared TMS therapy device used for treating depression and other mental health conditions.`,
  "url": `https://tmslist.com/technology/${Astro.params.slug}/`,
  "manufacturer": {
    "@type": "Organization",
    "name": machineName.split(' ')[0]
  }
});
---

<Layout
  title={title}
  description={`Learn about ${machineName} TMS technology. Compare FDA-cleared devices, find clinics using this system, and understand treatment protocols.`}
  schema={techSchema}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Technology", url: "/technology/" },
    { name: machineName, url: `/technology/${Astro.params.slug}/` },
  ]}
>
  <main class="container mx-auto px-4 py-8">
    <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
      <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
      <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <a href="/technology/" class="hover:text-violet-600 transition-colors">Technology</a>
      <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span class="text-slate-700 font-medium">{machineName}</span>
    </nav>

    <div class="bg-violet-50 rounded-xl p-8 mb-8 text-center">
         <h1 class="text-3xl font-semibold text-gray-900 mb-2">{machineName} Clinics</h1>
         <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Browse all verified clinics using {machineName} technology for TMS therapy.
         </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {machineClinics.map((clinic) => (
        <article class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow">
            <div class="h-48 overflow-hidden">
                <img src={clinic.hero_image_url} alt={clinic.name} class="w-full h-full object-cover" loading="lazy" />
            </div>
             <div class="p-6">
                <h2 class="text-xl font-semibold text-gray-900 mb-2">
                    <a href={`/clinic/${clinic.slug}`} class="hover:underline text-violet-600">{clinic.name}</a>
                </h2>
                <div class="flex items-center mb-3">
                     <span class="text-yellow-500 mr-1">★</span>
                     <span class="font-semibold text-gray-900 mr-1">
                        {(typeof clinic.rating === 'number' ? clinic.rating : clinic.rating.aggregate).toFixed(1)}
                     </span>
                     <span class="text-gray-500 text-sm">({clinic.review_count} reviews)</span>
                </div>
                <p class="text-gray-600 mb-1 text-sm">{clinic.city}, {clinic.state}</p>
                 <div class="mt-4 flex justify-between items-center">
                    <div class="flex -space-x-2 overflow-hidden">
                         {clinic.machines.slice(0,3).map(m => (
                             <span class="inline-block px-2 py-0.5 text-[10px] rounded-full bg-violet-100 text-violet-800 border-white border ring-1 ring-white">{m}</span>
                         ))}
                    </div>
                    <a href={`/clinic/${clinic.slug}`} class="text-sm font-medium text-violet-600 hover:text-violet-500">
                        View Profile &rarr;
                    </a>
                 </div>
            </div>
        </article>
      ))}
    </div>
  </main>
</Layout>
