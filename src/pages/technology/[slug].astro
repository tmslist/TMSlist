---
import Layout from '../../layouts/Layout.astro';
import { getAllClinics, getClinicsByMachine } from '../../utils/clinicData';
import { ClinicMachine } from '../../types/clinic';

const { slug } = Astro.params;

// Find the machine name from slug
const allClinics = await getAllClinics();
const uniqueMachines = [...new Set(allClinics.flatMap(c => c.machines))];
const machineName = uniqueMachines.find(m => m.toLowerCase().replace(/\s+/g, '-') === slug);
if (!machineName) return Astro.redirect("/technology/");

const machineClinics = await getClinicsByMachine(machineName);
const title = `${machineName} TMS Therapy Clinics - TMS List`;

const techSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "MedicalDevice",
  "name": machineName,
  "description": `${machineName} is an FDA-cleared TMS therapy device used for treating depression and other mental health conditions.`,
  "url": `https://tmslist.com/technology/${Astro.params.slug}/`,
  "manufacturer": {
    "@type": "Organization",
    "name": machineName.split(' ')[0]
  }
});
---

<Layout
  title={title}
  description={`Learn about ${machineName} TMS technology. Compare FDA-cleared devices, find clinics using this system, and understand treatment protocols.`}
  schema={techSchema}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Technology", url: "/technology/" },
    { name: machineName, url: `/technology/${Astro.params.slug}/` },
  ]}
>
  <main class="container mx-auto px-4 py-8">
    <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
      <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
      <span class="text-slate-300">/</span>
      <a href="/technology/" class="hover:text-violet-600 transition-colors">Technology</a>
      <span class="text-slate-300">/</span>
      <span class="text-slate-700 font-medium">{machineName}</span>
    </nav>

    <div class="bg-violet-50 rounded-xl p-8 mb-8 text-center">
         <h1 class="text-3xl font-semibold text-gray-900 mb-2">{machineName} Clinics</h1>
         <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-6">
            Browse all verified clinics using {machineName} technology for TMS therapy.
         </p>
         <div class="max-w-2xl mx-auto">
           <div
             class="ai-hero-image relative overflow-hidden rounded-2xl"
             data-subject={`${machineName} TMS device`}
             data-type="hero"
             data-cache-key={`ai-img:hero:${machineName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}-tms-device`}
             data-alt={`AI illustration of ${machineName} TMS device`}
           >
             <div class="ai-img-placeholder aspect-[16/9] w-full bg-gradient-to-br from-violet-100/60 via-slate-50 to-blue-100/60 animate-pulse rounded-2xl">
               <div class="absolute inset-0 flex items-center justify-center">
                 <span class="text-xs font-medium text-slate-300 tracking-wide">Loading...</span>
               </div>
             </div>
             <img class="ai-img-result hidden w-full aspect-[16/9] object-cover rounded-2xl shadow-lg ring-1 ring-slate-200/50" alt="TMS technology illustration" width="800" height="450" />
             <div class="ai-img-fallback hidden"></div>
           </div>
         </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {machineClinics.map((clinic) => (
        <article class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow">
            <div class="h-48 overflow-hidden">
                <img src={clinic.hero_image_url} alt={clinic.name} class="w-full h-full object-cover" loading="lazy" />
            </div>
             <div class="p-6">
                <h2 class="text-xl font-semibold text-gray-900 mb-2">
                    <a href={`/clinic/${clinic.slug}`} class="hover:underline text-violet-600">{clinic.name}</a>
                </h2>
                <div class="flex items-center mb-3">
                     <svg class="w-5 h-5 text-yellow-500 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                     <span class="font-semibold text-gray-900 mr-1">
                        {(typeof clinic.rating === 'number' ? clinic.rating : clinic.rating.aggregate).toFixed(1)}
                     </span>
                     <span class="text-gray-500 text-sm">({clinic.review_count} reviews)</span>
                </div>
                <p class="text-gray-600 mb-1 text-sm">{clinic.city}, {clinic.state}</p>
                 <div class="mt-4 flex justify-between items-center">
                    <div class="flex -space-x-2 overflow-hidden">
                         {clinic.machines.slice(0,3).map(m => (
                             <span class="inline-block px-2 py-0.5 text-[10px] rounded-full bg-violet-100 text-violet-800 border-white border ring-1 ring-white">{m}</span>
                         ))}
                    </div>
                    <a href={`/clinic/${clinic.slug}`} class="text-sm font-medium text-violet-600 hover:text-violet-500">
                        View Profile &rarr;
                    </a>
                 </div>
            </div>
        </article>
      ))}
    </div>

    <!-- Related Topics -->
    <div class="mt-16 pt-12 border-t border-slate-200">
      <h3 class="text-xl font-bold text-slate-900 mb-6">Learn More About TMS</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/treatments/" class="group bg-white rounded-xl border border-slate-200 p-5 hover:border-violet-300 hover:shadow-md transition-all">
          <h4 class="font-semibold text-slate-900 group-hover:text-violet-600 mb-1">All Treatment Types</h4>
          <p class="text-sm text-slate-500">Depression, OCD, anxiety, migraine, PTSD and more.</p>
        </a>
        <a href="/protocols/" class="group bg-white rounded-xl border border-slate-200 p-5 hover:border-violet-300 hover:shadow-md transition-all">
          <h4 class="font-semibold text-slate-900 group-hover:text-violet-600 mb-1">TMS Protocols</h4>
          <p class="text-sm text-slate-500">Standard, theta burst, accelerated, and deep TMS.</p>
        </a>
        <a href="/insurance/" class="group bg-white rounded-xl border border-slate-200 p-5 hover:border-violet-300 hover:shadow-md transition-all">
          <h4 class="font-semibold text-slate-900 group-hover:text-violet-600 mb-1">Insurance Coverage</h4>
          <p class="text-sm text-slate-500">Medicare, Blue Cross, Aetna, and more.</p>
        </a>
        <a href="/quiz/am-i-a-candidate/" class="group bg-white rounded-xl border border-slate-200 p-5 hover:border-violet-300 hover:shadow-md transition-all">
          <h4 class="font-semibold text-slate-900 group-hover:text-violet-600 mb-1">Am I a Candidate?</h4>
          <p class="text-sm text-slate-500">2-minute quiz to check your TMS eligibility.</p>
        </a>
      </div>
      <div class="mt-8 text-center">
        <a href="/us/" class="inline-flex items-center gap-2 px-6 py-3 bg-violet-600 text-white font-semibold rounded-xl hover:bg-violet-700 transition-colors">
          Find a Clinic Using {machineName}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </main>
</Layout>
