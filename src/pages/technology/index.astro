---
import Layout from '../../layouts/Layout.astro';
import { TECHNOLOGY_SLUGS, PROTOCOL_SLUGS } from '../../utils/seo_slugs';

const title = "TMS Technology & Machines | NeuroStar, BrainsWay, Apollo, Exomind";
const description = "Compare FDA-cleared TMS devices including NeuroStar, BrainsWay Deep TMS, MagVenture, Apollo TMS, Exomind, and more. Learn about different protocols.";

const additionalMachines = [
    { slug: 'apollo-tms', title: 'Apollo TMS' },
    { slug: 'exomind', title: 'Exomind Wellness TMS' },
    { slug: 'nexstim', title: 'Nexstim TMS' },
    { slug: 'mag-and-more', title: 'MAG & More' },
    { slug: 'deymed', title: 'Deymed TMS' },
];

const allTech = [...TECHNOLOGY_SLUGS, ...additionalMachines];

interface DeviceMeta {
    accent: string;
    accentBg: string;
    accentBorder: string;
    desc: string;
    coilType: string;
    fdaCleared: boolean;
    highlight?: string;
}

const deviceMeta: Record<string, DeviceMeta> = {
    'neurostar': { accent: 'text-blue-600', accentBg: 'bg-blue-500', accentBorder: 'border-blue-200', desc: 'Most widely deployed TMS system in the US with the patented SenStar touchscreen treatment system and figure-8 coil design.', coilType: 'Figure-8', fdaCleared: true, highlight: 'Most Used in US' },
    'brainsway': { accent: 'text-emerald-600', accentBg: 'bg-emerald-500', accentBorder: 'border-emerald-200', desc: 'Deep TMS with proprietary H-coil technology. The only system FDA-cleared for both depression and OCD.', coilType: 'H-Coil (Deep)', fdaCleared: true, highlight: 'Deep TMS Pioneer' },
    'magventure': { accent: 'text-violet-600', accentBg: 'bg-violet-500', accentBorder: 'border-violet-200', desc: 'Versatile platform supporting multiple coil configurations. Used in both clinical treatment and research settings worldwide.', coilType: 'Multiple Options', fdaCleared: true, highlight: 'Research Standard' },
    'magstim': { accent: 'text-rose-600', accentBg: 'bg-rose-500', accentBorder: 'border-rose-200', desc: 'UK-manufactured TMS system with over 30 years of heritage. Strong research pedigree with rapid stimulation capabilities.', coilType: 'Figure-8 / Double Cone', fdaCleared: true, highlight: '30+ Year Heritage' },
    'cloudtms': { accent: 'text-sky-600', accentBg: 'bg-sky-500', accentBorder: 'border-sky-200', desc: 'Cloud-connected TMS platform with real-time treatment monitoring and analytics dashboard for clinicians.', coilType: 'Figure-8', fdaCleared: true, highlight: 'Cloud Analytics' },
    'apollo-tms': { accent: 'text-amber-600', accentBg: 'bg-amber-500', accentBorder: 'border-amber-200', desc: 'Advanced TMS system with precision targeting and ergonomic patient positioning for improved comfort.', coilType: 'Figure-8', fdaCleared: true, highlight: 'Precision Targeting' },
    'exomind': { accent: 'text-cyan-600', accentBg: 'bg-cyan-500', accentBorder: 'border-cyan-200', desc: 'Wellness-focused TMS technology with a streamlined treatment workflow designed for high-volume practices.', coilType: 'Proprietary', fdaCleared: false, highlight: 'Wellness Focus' },
    'nexstim': { accent: 'text-indigo-600', accentBg: 'bg-indigo-500', accentBorder: 'border-indigo-200', desc: 'Navigated TMS with real-time MRI-guided targeting for precise cortical stimulation mapping.', coilType: 'Navigated', fdaCleared: true, highlight: 'MRI-Guided' },
};

const defaultMeta: DeviceMeta = { accent: 'text-purple-600', accentBg: 'bg-purple-500', accentBorder: 'border-purple-200', desc: 'FDA-cleared TMS system for clinical depression treatment.', coilType: 'Standard', fdaCleared: false };

const techSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "TMS Technology & Devices",
    "description": description,
    "url": "https://tmslist.com/technology/",
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": allTech.length,
        "itemListElement": allTech.map((item, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "item": { "@type": "MedicalDevice", "name": item.title, "url": `https://tmslist.com/technology/${item.slug}/` }
        }))
    }
});
---

<Layout title={title} description={description} schema={techSchema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Technology", url: "/technology/" },
]}>
    <main>
        <!-- Hero — Dark Technical -->
        <section class="relative bg-slate-950 overflow-hidden">
            <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.3) 1px, transparent 0); background-size: 32px 32px;"></div>
            <div class="absolute top-[10%] right-[15%] w-[500px] h-[500px] bg-violet-600/10 rounded-full blur-[150px]"></div>
            <div class="absolute bottom-[10%] left-[10%] w-[400px] h-[400px] bg-cyan-500/8 rounded-full blur-[120px]"></div>

            <div class="container mx-auto px-4 pt-12 pb-20 lg:pt-16 lg:pb-28 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-500 mb-12" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
                    <span class="text-slate-700">/</span>
                    <span class="text-slate-300">Technology</span>
                </nav>

                <div class="max-w-3xl">
                    <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white leading-[0.95] mb-6">
                        TMS<br/>
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400">Technology</span>
                    </h1>
                    <p class="text-lg text-slate-400 leading-relaxed max-w-xl">
                        Compare the magnetic stimulation systems shaping modern psychiatry. From FDA-cleared clinical devices to cutting-edge research platforms.
                    </p>
                </div>

                <!-- Stats -->
                <div class="flex flex-wrap gap-4 mt-12">
                    <div class="px-6 py-4 bg-white/5 backdrop-blur border border-white/10 rounded-2xl">
                        <div class="text-3xl font-bold text-white">{allTech.length}+</div>
                        <div class="text-xs text-slate-400 font-medium mt-1">TMS Devices</div>
                    </div>
                    <div class="px-6 py-4 bg-white/5 backdrop-blur border border-white/10 rounded-2xl">
                        <div class="text-3xl font-bold text-emerald-400">6</div>
                        <div class="text-xs text-slate-400 font-medium mt-1">FDA Cleared</div>
                    </div>
                    <div class="px-6 py-4 bg-white/5 backdrop-blur border border-white/10 rounded-2xl">
                        <div class="text-3xl font-bold text-violet-400">{PROTOCOL_SLUGS.length}</div>
                        <div class="text-xs text-slate-400 font-medium mt-1">Protocols</div>
                    </div>
                </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-16 bg-white" style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"></div>
        </section>

        <!-- Devices Grid -->
        <section class="py-16 lg:py-24 bg-white">
            <div class="container mx-auto px-4">
                <div class="flex items-end justify-between mb-12">
                    <div>
                        <h2 class="text-3xl font-bold text-slate-900 tracking-tight mb-2">TMS Devices</h2>
                        <p class="text-slate-500">Compare coil types, clearances, and clinical capabilities.</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    {allTech.map(item => {
                        const meta = deviceMeta[item.slug] || defaultMeta;
                        return (
                        <a href={`/technology/${item.slug}/`}
                           class={`group relative bg-white rounded-2xl border border-slate-100 hover:${meta.accentBorder} hover:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.08)] transition-all duration-300 overflow-hidden`}>
                            <div class="p-7">
                                <div class="flex items-start justify-between mb-5">
                                    <div class="flex items-center gap-3">
                                        <div class={`w-3 h-3 rounded-full ${meta.accentBg}`}></div>
                                        <h3 class="text-xl font-bold text-slate-900 group-hover:text-violet-600 transition-colors tracking-tight">{item.title}</h3>
                                    </div>
                                    {meta.fdaCleared && (
                                        <span class="px-2 py-0.5 bg-emerald-50 text-emerald-600 text-[10px] font-bold uppercase tracking-wider rounded-md shrink-0">FDA</span>
                                    )}
                                </div>

                                <p class="text-sm text-slate-500 leading-relaxed mb-6">{meta.desc}</p>

                                <div class="flex items-center gap-6 pt-5 border-t border-slate-50">
                                    <div class="flex items-center gap-2">
                                        <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
                                        <span class="text-xs font-medium text-slate-500">{meta.coilType} Coil</span>
                                    </div>
                                    {meta.highlight && (
                                        <span class={`text-xs font-semibold ${meta.accent}`}>{meta.highlight}</span>
                                    )}
                                    <svg class="w-4 h-4 text-slate-300 group-hover:text-violet-500 group-hover:translate-x-1 transition-all ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                                </div>
                            </div>
                        </a>
                    )})}
                </div>
            </div>
        </section>

        <!-- Treatment Protocols -->
        <section class="py-16 lg:py-24 bg-slate-50">
            <div class="container mx-auto px-4">
                <div class="mb-12">
                    <h2 class="text-3xl font-bold text-slate-900 tracking-tight mb-2">Treatment Protocols</h2>
                    <p class="text-slate-500">Different stimulation patterns and targeting methods for specific conditions.</p>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                    {PROTOCOL_SLUGS.map((item, i) => (
                        <a href={`/technology/${item.slug}/`}
                           class="group bg-white rounded-2xl border border-slate-100 p-6 hover:border-violet-200 hover:shadow-[0_8px_30px_-10px_rgba(0,0,0,0.06)] transition-all duration-300">
                            <div class="flex items-center gap-3 mb-4">
                                <div class="w-8 h-8 rounded-lg bg-violet-50 flex items-center justify-center text-violet-600 text-sm font-bold">{String(i + 1).padStart(2, '0')}</div>
                                <h3 class="text-base font-bold text-slate-900 group-hover:text-violet-600 transition-colors">{item.title}</h3>
                            </div>
                            <p class="text-sm text-slate-500 leading-relaxed mb-4">Learn about session structure, targeting method, and clinical outcomes for this protocol.</p>
                            <div class="flex items-center justify-between pt-3 border-t border-slate-50">
                                <span class="text-violet-600 font-semibold text-sm">Read Guide</span>
                                <svg class="w-4 h-4 text-slate-300 group-hover:text-violet-500 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </section>
    </main>
</Layout>
