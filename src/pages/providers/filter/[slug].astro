---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import ClinicCard from '../../../components/ClinicCard.astro';
import { getOperationalClinics, COUNTRY_NAMES, COUNTRY_URL_PREFIXES } from '../../../utils/dataHelpers';
import { getVisitorCountry } from '../../../utils/visitorCountry';

const VISITOR_COUNTRY = getVisitorCountry(Astro.cookies, Astro.url);
const visitorCountryName = COUNTRY_NAMES[VISITOR_COUNTRY] || 'United States';
const visitorCountryUrl = `/${COUNTRY_URL_PREFIXES[VISITOR_COUNTRY] || VISITOR_COUNTRY.toLowerCase()}/`;

const PROVIDER_SLUGS = [
    { slug: 'female-psychiatrists', title: 'Female Psychiatrists Offering TMS', filter: { field: 'accessibility', value: 'female_provider' }, description: 'Find female psychiatrists and TMS providers near you. Many patients prefer a female provider for their mental health treatment.' },
    { slug: 'spanish-speaking-tms', title: 'Spanish Speaking TMS Providers', filter: { field: 'accessibility', value: 'spanish_speaking' }, description: 'Find TMS clinics with Spanish-speaking staff and providers. Bilingual care for the Hispanic community.' },
    { slug: 'weekend-appointments', title: 'TMS Clinics Open on Weekends', filter: { field: 'availability', value: 'weekend_hours' }, description: 'Find TMS clinics that offer Saturday and Sunday appointments for working professionals.' },
    { slug: 'evening-hours', title: 'TMS Clinics with Evening Hours', filter: { field: 'availability', value: 'evening_hours' }, description: 'Find TMS providers offering appointments after 5 PM for patients who work during the day.' },
    { slug: 'telehealth-consults', title: 'TMS Clinics with Telehealth Consultations', filter: { field: 'availability', value: 'telehealth_consults' }, description: 'Get your initial TMS consultation via video call. Many clinics now offer telehealth for the first appointment.' },
    { slug: 'accepting-new-patients', title: 'TMS Clinics Accepting New Patients', filter: { field: 'availability', value: 'accepting_new_patients' }, description: 'Clinics currently accepting new TMS patients with minimal wait times.' },
    { slug: 'hospital-based', title: 'Hospital-Based TMS Programs', filter: { field: 'provider_type', value: 'hospital' }, description: 'Find TMS programs at hospitals and academic medical centers with research-backed protocols.' },
    { slug: 'private-practice', title: 'Private Practice TMS Providers', filter: { field: 'provider_type', value: 'psychiatrist' }, description: 'Find independent psychiatrists offering TMS therapy in a private practice setting.' },
];

const { slug } = Astro.params;

const providerItem = PROVIDER_SLUGS.find(item => item.slug === slug);
if (!providerItem) return Astro.redirect("/providers/");

const { title, description, filter: { field: filterField, value: filterValue } } = providerItem;
const allClinics = await getOperationalClinics();

const matchesFilter = (c: any) => {
    if (filterField === 'accessibility') {
        const acc = c.accessibility as Record<string, boolean> | null;
        return acc?.[filterValue];
    }
    if (filterField === 'availability') {
        const avail = c.availability as Record<string, boolean> | null;
        return avail?.[filterValue];
    }
    if (filterField === 'provider_type') {
        return c.provider_type === filterValue;
    }
    return false;
};
const matchesVisitorCountry = (c: any) =>
    VISITOR_COUNTRY === 'US' ? (!c.country || c.country === 'US') : c.country === VISITOR_COUNTRY;

const inCountry = allClinics.filter(c => matchesFilter(c) && matchesVisitorCountry(c));
// US fallback if visitor's country has zero matching clinics — never show an empty page
const filteredClinics = inCountry.length > 0
    ? inCountry
    : allClinics.filter(c => matchesFilter(c) && (!c.country || c.country === 'US'));

const pageTitle = VISITOR_COUNTRY === 'US'
    ? `${title} | TMS List`
    : `${title} in ${visitorCountryName} | TMS List`;
---

<Layout title={pageTitle} description={description}>
    <main>
        <section class="relative bg-[var(--paper)] border-b border-[var(--line)] overflow-hidden">
            <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(var(--line) 1px, transparent 0); background-size: 32px 32px; opacity:0.5;"></div>
            <div class="absolute top-[-10%] right-[15%] w-[500px] h-[500px] bg-[rgba(201,101,74,0.06)] rounded-full blur-[150px]"></div>

            <div class="container mx-auto px-4 pt-12 pb-24 lg:pt-16 lg:pb-28 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-[var(--muted)] mb-12" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-[var(--accent2)] transition-colors">Home</a>
                    <span class="text-[var(--ink2)]">/</span>
                    <a href="/specialists/" class="hover:text-[var(--accent2)] transition-colors">Specialists</a>
                    <span class="text-[var(--ink2)]">/</span>
                    <span class="text-[var(--muted)]">{title}</span>
                </nav>
                <div class="max-w-2xl">
                    <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-[var(--ink)] leading-tight mb-5">{title}</h1>
                    <p class="text-lg text-[var(--muted)] leading-relaxed">{description}</p>
                    <div class="mt-8 flex items-center gap-4">
                        <div class="px-5 py-3 bg-[var(--paper2)] backdrop-blur border border-[var(--line)] rounded-2xl">
                            <span class="text-2xl font-bold text-[var(--ink)]">{filteredClinics.length}</span>
                            <span class="text-xs text-[var(--muted)] ml-2">Clinics Found</span>
                        </div>
                    </div>
                </div>
            </div>
            
        </section>

        <section class="py-12 lg:py-16 bg-[var(--paper)]">
            <div class="container mx-auto px-4 max-w-6xl">
                {filteredClinics.length > 0 ? (
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        {filteredClinics.slice(0, 30).map(clinic => (
                            <ClinicCard clinic={clinic} />
                        ))}
                    </div>
                ) : (
                    <div class="text-center py-20">
                        <div class="w-16 h-16 rounded-full bg-[var(--paper2)] flex items-center justify-center mx-auto mb-6">
                            <svg class="w-8 h-8 text-[var(--muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <h2 class="text-xl font-bold text-[var(--ink)] mb-2">No clinics match this filter yet</h2>
                        <p class="text-[var(--muted)] mb-8">We're constantly adding new clinics. Try browsing our full directory instead.</p>
                        <a href={visitorCountryUrl} class="px-6 py-3 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-colors">Browse All Clinics</a>
                    </div>
                )}

                {filteredClinics.length > 30 && (
                    <div class="text-center mt-10">
                        <a href={visitorCountryUrl} class="px-8 py-3 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-colors">View All {filteredClinics.length} Clinics</a>
                    </div>
                )}
            </div>
        </section>

        <!-- Other Filters -->
        <section class="py-12 bg-[var(--paper2)]">
            <div class="container mx-auto px-4 max-w-5xl">
                <h2 class="text-2xl font-bold text-[var(--ink)] mb-6 tracking-tight">Other Ways to Filter</h2>
                <div class="flex flex-wrap gap-3">
                    {PROVIDER_SLUGS.filter(s => s.slug !== Astro.params.slug).map(item => (
                        <a href={`/providers/filter/${item.slug}/`} class="px-4 py-2 bg-[var(--paper)] border border-[var(--line)] text-sm font-medium text-[var(--ink2)] rounded-xl hover:border-[rgba(10,22,40,0.2)] hover:text-[var(--accent)] transition-all">{item.title}</a>
                    ))}
                </div>
            </div>
        </section>

        <section class="relative py-16 bg-[var(--ink)] overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-[#0A1628]/10 via-transparent to-[rgba(10,22,40,0.10)]"></div>
            <div class="container mx-auto px-4 text-center relative z-10">
                <h2 class="text-2xl font-bold text-[var(--ink)] mb-4">Not finding what you need?</h2>
                <p class="text-[var(--muted)] mb-8">Take our assessment to find the best TMS provider for your specific needs.</p>
                <div class="flex gap-4 justify-center flex-wrap">
                    <a href="/quiz/am-i-a-candidate/" class="px-8 py-3.5 bg-[var(--ink)] hover:bg-[var(--ink2)] text-white font-semibold rounded-xl transition-colors shadow-lg shadow-[rgba(10,22,40,0.2)]">Take Assessment</a>
                    <a href={visitorCountryUrl} class="px-8 py-3.5 bg-[var(--paper2)] border border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] text-[var(--ink)] font-semibold rounded-xl transition-all">Browse All Clinics</a>
                </div>
            </div>
        </section>
    </main>
</Layout>
