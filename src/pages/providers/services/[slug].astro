---
export const prerender = true;

import ContentPage from '../../../layouts/ContentPage.astro';
import { getCollection, render } from 'astro:content';
import { COMMERCIAL_SLUGS } from '../../../utils/seo_slugs';

export async function getStaticPaths() {
  let entries: any[] = [];
  try {
    entries = await getCollection('commercial');
  } catch {}

  const contentPaths = entries.map((entry) => ({
    params: { slug: entry.id },
    props: { title: entry.data.title, description: entry.data.description, hasContent: true, entry },
  }));

  const contentSlugsSet = new Set(contentPaths.map(p => p.params.slug));
  const fallbackPaths = COMMERCIAL_SLUGS
    .filter(({ slug }) => !contentSlugsSet.has(slug))
    .map(({ slug, title }) => ({
      params: { slug },
      props: { title, description: '', hasContent: false, entry: null },
    }));

  return [...contentPaths, ...fallbackPaths];
}

const { title, description, hasContent, entry } = Astro.props;
const slug = Astro.params.slug!;
let Content: any = null;
if (hasContent && entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}
---

<ContentPage
  title={title}
  subtitle={description || "Business solutions and growth strategies for TMS clinics."}
  description={description}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Providers", url: "/providers/" },
    { name: "Services", url: "/providers/services/" },
    { name: title, url: `/providers/services/${slug}/` },
  ]}
>
  {Content ? <Content /> : null}
</ContentPage>
