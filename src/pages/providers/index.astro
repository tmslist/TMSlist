---
import Layout from "../../layouts/Layout.astro";

const title = "List Your TMS Clinic | TMS List";
const description =
    "Get your TMS practice in front of patients who are actively searching for treatment. Free listing. 5 minutes to set up.";

const benefits = [
    {
        title: "Patients who are ready to book",
        description:
            "People on TMS List aren't browsing. They've already decided they want TMS — they're looking for the right clinic. That's the lead you want.",
        icon: "�",
    },
    {
        title: "The verified badge matters",
        description:
            "Verified clinics get priority in search results and a trust badge on their profile. Patients click verified listings 3x more often.",
        icon: "verified",
    },
    {
        title: "Better Google rankings",
        description:
            "Your TMS List profile creates a high-authority backlink with structured data. We've seen listed clinics move up 5-15 positions for local TMS searches.",
        icon: "growth",
    },
    {
        title: "Know what's working",
        description:
            "Track how many people view your profile, click to your website, and call your office. No guessing.",
        icon: "analytics",
    },
];
---

<Layout title={title} description={description}>
    <!-- Hero Section -->
    <section class="relative bg-white py-20 overflow-hidden">
        <div
            class="absolute inset-0 bg-gradient-to-br from-indigo-50 to-white z-0"
        >
        </div>
        <div class="container mx-auto px-4 relative z-10">
            <div class="max-w-4xl mx-auto text-center">
                <span
                    class="inline-block px-4 py-1.5 bg-indigo-100 text-indigo-700 rounded-full text-sm font-semibold uppercase tracking-wider mb-6"
                    >For TMS Practices</span
                >
                <h1
                    class="text-5xl md:text-6xl font-semibold tracking-tight text-gray-900 mb-6 tracking-tight"
                >
                    Your next patient is <span class="text-indigo-600"
                        >already searching</span
                    >
                </h1>
                <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
                    Thousands of people search for TMS clinics on TMS List every month.
                    If your practice isn't here, they're finding someone else.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a
                        href="/add-listing/"
                        class="inline-flex items-center justify-center px-8 py-4 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-200 transform hover:-translate-y-1"
                    >
                        Add Your Clinic — Free
                        <svg
                            class="w-5 h-5 ml-2"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
                        >
                    </a>
                    <a
                        href="#benefits"
                        class="inline-flex items-center justify-center px-8 py-4 bg-white text-gray-700 font-semibold rounded-xl border border-gray-200 hover:bg-gray-50 transition-all"
                    >
                        See How It Works
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Benefits Grid -->
    <section id="benefits" class="py-20 bg-white">
        <div class="container mx-auto px-4">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-gray-900 mb-4">
                    What you get
                </h2>
                <p class="text-lg text-gray-600">
                    A listing that actually brings patients through the door.
                </p>
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto"
            >
                {
                    benefits.map((benefit) => (
                        <div class="p-8 rounded-2xl bg-gray-50 border border-gray-100 hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:bg-white hover:border-indigo-100 transition-all group">
                            <div class="w-14 h-14 rounded-xl bg-indigo-100 flex items-center justify-center mb-6 group-hover:bg-indigo-600 group-hover:text-white transition-colors text-indigo-600">
                                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            </div>
                            <h3 class="text-xl font-semibold text-gray-900 mb-3">
                                {benefit.title}
                            </h3>
                            <p class="text-gray-600 leading-relaxed">
                                {benefit.description}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Social Proof -->
    <section class="py-20 bg-gray-900 text-slate-900">
        <div class="container mx-auto px-4 text-center">
            <h2 class="text-3xl font-semibold tracking-tight mb-6">
                900+ clinics already listed
            </h2>
            <p class="text-gray-400 mb-12 max-w-xl mx-auto">
                From single-provider practices to multi-location networks — clinics using NeuroStar, BrainsWay, MagVenture, and more.
            </p>
            <div
                class="grid grid-cols-2 md:grid-cols-4 gap-8 opacity-60 grayscale hover:grayscale-0 transition-all duration-500"
            >
                <div
                    class="flex items-center justify-center text-xl font-semibold border-2 border-slate-200 rounded-xl p-4"
                >
                    NeuroStar
                </div>
                <div
                    class="flex items-center justify-center text-xl font-semibold border-2 border-slate-200 rounded-xl p-4"
                >
                    BrainsWay
                </div>
                <div
                    class="flex items-center justify-center text-xl font-semibold border-2 border-slate-200 rounded-xl p-4"
                >
                    MagVenture
                </div>
                <div
                    class="flex items-center justify-center text-xl font-semibold border-2 border-slate-200 rounded-xl p-4"
                >
                    CloudTMS
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Footer -->
    <section class="py-24 bg-gradient-to-br from-indigo-600 to-blue-700">
        <div class="container mx-auto px-4 text-center text-slate-900">
            <h2 class="text-4xl font-semibold tracking-tight mb-6">
                Takes 5 minutes. Costs nothing.
            </h2>
            <p class="text-xl text-indigo-100 mb-10 max-w-2xl mx-auto">
                Add your clinic, get verified, and start showing up when patients search for TMS in your area.
            </p>
            <a
                href="/add-listing/"
                class="inline-flex items-center justify-center px-10 py-5 bg-white text-indigo-600 font-semibold text-lg rounded-xl shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:bg-gray-50 transform hover:-translate-y-1 transition-all"
            >
                Get Listed Now
            </a>
        </div>
    </section>
</Layout>
