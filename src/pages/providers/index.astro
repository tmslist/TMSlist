---
import Layout from "../../layouts/Layout.astro";
import EditorialHero from "../../components/editorial/EditorialHero.astro";
import EditorialSection from "../../components/editorial/EditorialSection.astro";
import EditorialCard from "../../components/editorial/EditorialCard.astro";
import EditorialCTA from "../../components/editorial/EditorialCTA.astro";

const title = "For TMS Providers | List Your Practice";
const description = "Get your TMS practice in front of patients who are actively searching for treatment. Free listing. 5 minutes to set up.";

const benefits = [
    { title: "Patients ready to book", description: "People on TMS List aren't browsing. They've already decided they want TMS — they're looking for the right clinic." },
    { title: "The verified badge", description: "Verified clinics get priority in search results and a trust badge on their profile. Patients click verified listings 3× more often." },
    { title: "Better Google rankings", description: "Your TMS List profile creates a high-authority backlink with structured data. Listed clinics often move up 5–15 positions for local TMS searches." },
    { title: "Real analytics", description: "Track how many people view your profile, click to your website, and call your office. No guessing." },
];
---

<Layout title={title} description={description} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "List Your Clinic", url: "/providers/" },
]}>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow="For TMS Practices"
    eyebrowDot="#22c55e"
    title="Your next patient"
    titleAccent="is already searching."
    description="Thousands of people search for TMS clinics on TMS List every month. If your practice isn't here, they're finding someone else."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "For Providers" }]}
    ctas={[
      { label: "Add Your Clinic — Free", href: "/add-listing/" },
      { label: "How It Works", href: "#benefits", variant: "outline" },
    ]}
    stats={[
      { value: "1,250+", label: "Listed Clinics", color: "ink" },
      { value: "5 min", label: "Setup Time", color: "accent" },
      { value: "$0", label: "To Get Listed", color: "warm" },
    ]}
  />

  <EditorialSection
    title="What you get"
    intro="A listing that actually brings patients through the door."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>'
    tone="success"
  >
    <div id="benefits" class="grid sm:grid-cols-2 gap-5">
      {benefits.map((b) => (
        <div style="background:var(--paper2); border:1px solid var(--line); border-radius:1.5rem; padding:1.75rem;">
          <h3 class="serif" style="font-size:1.5rem; color:var(--ink); margin:0 0 0.75rem; line-height:1.15;">{b.title}</h3>
          <p style="font-size:14px; color:var(--muted); line-height:1.65; margin:0;">{b.description}</p>
        </div>
      ))}
    </div>
  </EditorialSection>

  <EditorialSection
    title="Already listed: 1,250+ clinics"
    intro="From single-provider practices to multi-location networks — clinics using every major TMS device."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>'
    tone="accent"
    background="paper2"
    noBorder
  >
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      {["NeuroStar", "BrainsWay", "MagVenture", "CloudTMS"].map((brand) => (
        <div style="background:var(--paper); border:1px solid var(--line); border-radius:1rem; padding:1.25rem; text-align:center;">
          <span class="serif" style="font-size:1.25rem; color:var(--ink);">{brand}</span>
        </div>
      ))}
    </div>
  </EditorialSection>

  <EditorialCTA
    title="Takes 5 minutes. Costs nothing."
    description="Add your clinic, get verified, and start showing up when patients search for TMS in your area."
    ctas={[
      { label: "Get Listed Now", href: "/add-listing/" },
      { label: "Already listed? Claim it", href: "/claim-listing/", variant: "outline" },
    ]}
    stickyMobile
  />
</main>

</Layout>
