---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import BrainAtlas from '../../components/react/education/BrainAtlas';
import ProtocolAcademy from '../../components/react/education/ProtocolAcademy';
import { TMSProvider } from '../../components/react/TMSViewer/TMSContext';

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const pageSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "EducationalPage",
  "headline": "TMS Education Hub",
  "description": "Learn how transcranial magnetic stimulation (TMS) works, explore brain anatomy, and understand treatment protocols.",
  "url": `${siteUrl}/education/`,
  "author": { "@type": "Organization", "name": "TMS List", "url": siteUrl },
  "publisher": { "@type": "Organization", "name": "TMS List", "url": siteUrl, "logo": { "@type": "ImageObject", "url": `${siteUrl}/favicon.svg` } },
  "reviewedBy": { "@type": "Person", "name": "Dr. Karan Narwal", "jobTitle": "Mental Health Specialist & Consultant" },
});
---

<Layout
  title="TMS Education Hub | Interactive Brain Anatomy & Protocol Guide"
  description="Learn how TMS works, explore interactive brain anatomy diagrams, and understand treatment protocols in this comprehensive educational resource."
  schema={pageSchema}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Education", url: "/education/" },
  ]}
>
  <!-- Hero Section -->
  <section class="relative bg-slate-950 overflow-hidden border-b border-slate-800/50">
    <!-- Ambient background -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_0%,rgba(79,70,229,0.15),transparent_60%)]"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-violet-600/10 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute top-0 right-1/4 w-80 h-80 bg-cyan-600/10 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="container mx-auto px-6 pt-28 pb-16 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <!-- Breadcrumb -->
        <nav class="flex items-center justify-center gap-2 text-[10px] text-slate-500 mb-8 uppercase tracking-widest font-semibold">
          <a href="/" class="hover:text-slate-300 transition-colors">Home</a>
          <span>/</span>
          <span class="text-slate-300">Education</span>
        </nav>

        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-violet-500/10 border border-violet-500/20 rounded-full mb-6">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="#a78bfa" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"/>
          </svg>
          <span class="text-[10px] font-bold text-violet-300 uppercase tracking-widest">Interactive Education</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 leading-tight tracking-tight">
          TMS <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-violet-400 to-fuchsia-400">Education Hub</span>
        </h1>
        <p class="text-lg text-slate-400 leading-relaxed max-w-2xl mx-auto mb-10">
          Understand the science behind transcranial magnetic stimulation. Explore interactive brain anatomy,
          learn how different protocols target specific regions, and see what a typical treatment journey looks like.
        </p>

        <!-- Quick nav pills -->
        <div class="flex flex-wrap items-center justify-center gap-3">
          {[
            { label: "How TMS Works", href: "#how-tms-works" },
            { label: "Brain Anatomy", href: "#brain-anatomy" },
            { label: "Protocols", href: "#protocols" },
            { label: "What to Expect", href: "#what-to-expect" },
          ].map(link => (
            <a
              href={link.href}
              class="px-4 py-2 bg-slate-800/60 border border-slate-700/40 rounded-full text-[11px] font-semibold text-slate-300 hover:text-white hover:bg-slate-700/80 hover:border-slate-600/50 transition-all"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Section 1: How TMS Works -->
  <section id="how-tms-works" class="bg-slate-900/50 py-20 border-b border-slate-800/40">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <!-- Section Header -->
        <div class="text-center mb-14">
          <span class="inline-block text-[9px] font-bold uppercase tracking-widest text-cyan-400 mb-3 border border-cyan-400/20 px-3 py-1 rounded-full bg-cyan-400/5">
            The Science
          </span>
          <h2 class="text-3xl md:text-4xl font-black text-white mb-4">How TMS Works</h2>
          <p class="text-[11px] text-slate-400 max-w-xl mx-auto leading-relaxed">
            Transcranial magnetic stimulation uses focused electromagnetic pulses to selectively activate
            or inhibit specific brain regions — without surgery, sedation, or systemic side effects.
          </p>
        </div>

        <!-- 4 Steps -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          {[
            {
              step: 1,
              title: "Magnetic Pulse",
              desc: "A coil placed on the scalp generates a brief, powerful magnetic field — similar to an MRI — lasting ~200 microseconds per pulse.",
              icon: "M13 10V3L4 14h7v7l9-11h-7z",
              color: "cyan",
              bgColor: "bg-cyan-500/10",
              borderColor: "border-cyan-500/20",
              iconBg: "bg-cyan-500/20",
              iconColor: "text-cyan-400",
            },
            {
              step: 2,
              title: "Induces Current",
              desc: "The magnetic field painlessly passes through the skull and induces a small electric current in the underlying cortical neurons.",
              icon: "M9 3v2m6-2v2M9 19v2m6-2v2M3 9h2m14 0h2M3 15h2m14 0h2M7 7h10a2 2 0 012 2v6a2 2 0 01-2 2H7a2 2 0 01-2-2V9a2 2 0 012-2z",
              color: "violet",
              bgColor: "bg-violet-500/10",
              borderColor: "border-violet-500/20",
              iconBg: "bg-violet-500/20",
              iconColor: "text-violet-400",
            },
            {
              step: 3,
              title: "Neurons Fire",
              desc: "The induced current causes neurons to depolarize and fire action potentials, releasing neurotransmitters and modulating brain networks.",
              icon: "M13 10V3L4 14h7v7l9-11h-7z",
              color: "fuchsia",
              bgColor: "bg-fuchsia-500/10",
              borderColor: "border-fuchsia-500/20",
              iconBg: "bg-fuchsia-500/20",
              iconColor: "text-fuchsia-400",
            },
            {
              step: 4,
              title: "Network Effect",
              desc: "Repeated sessions strengthen synaptic connections, normalize dysfunctional circuits, and produce lasting changes in mood and cognition.",
              icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
              color: "emerald",
              bgColor: "bg-emerald-500/10",
              borderColor: "border-emerald-500/20",
              iconBg: "bg-emerald-500/20",
              iconColor: "text-emerald-400",
            },
          ].map((item, i) => (
            <div class={`${item.bgColor} border ${item.borderColor} rounded-2xl p-6 relative hover-lift group`}>
              <!-- Step number -->
              <div class={`absolute -top-3 left-5 w-6 h-6 ${item.iconBg} border ${item.borderColor} rounded-full flex items-center justify-center`}>
                <span class={`text-[10px] font-black ${item.iconColor}`}>{item.step}</span>
              </div>
              <!-- Connector line (except last) -->
              {i < 3 && (
                <div class="hidden lg:block absolute top-1/2 -right-4 w-8 h-px bg-gradient-to-r from-slate-700 to-transparent pointer-events-none z-10"></div>
              )}

              <!-- Icon -->
              <div class={`w-12 h-12 ${item.iconBg} rounded-xl flex items-center justify-center mb-4 mt-2`}>
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" class={item.iconColor} strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round">
                  <path d={item.icon} />
                </svg>
              </div>

              <h3 class="text-sm font-bold text-white mb-2">{item.title}</h3>
              <p class="text-[11px] text-slate-400 leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>

        <!-- Key facts bar -->
        <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4">
          {[
            { value: "200μs", label: "Pulse Duration", color: "text-cyan-400" },
            { value: "1.5–2T", label: "Field Strength", color: "text-violet-400" },
            { value: "~19 min", label: "Standard Session", color: "text-fuchsia-400" },
            { value: "36", label: "Typical Sessions", color: "text-emerald-400" },
          ].map(fact => (
            <div class="text-center p-4 bg-slate-800/40 rounded-xl border border-slate-700/30">
              <div class={`text-2xl font-black font-mono ${fact.color} mb-1`}>{fact.value}</div>
              <div class="text-[10px] text-slate-500 uppercase tracking-wider">{fact.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Brain Anatomy Guide -->
  <section id="brain-anatomy" class="bg-slate-950/50 py-20 border-b border-slate-800/40">
    <div class="container mx-auto px-6">
      <div class="max-w-5xl mx-auto">
        <!-- Section Header -->
        <div class="text-center mb-14">
          <span class="inline-block text-[9px] font-bold uppercase tracking-widest text-violet-400 mb-3 border border-violet-400/20 px-3 py-1 rounded-full bg-violet-400/5">
            Interactive Tool
          </span>
          <h2 class="text-3xl md:text-4xl font-black text-white mb-4">Brain Anatomy Guide</h2>
          <p class="text-[11px] text-slate-400 max-w-2xl mx-auto leading-relaxed">
            Explore the major TMS-relevant brain regions on a 2D anatomical atlas. Click any region to learn
            its function, clinical significance, and TMS indication. Toggle between lateral (side) and
            medial (inner) views.
          </p>
        </div>

        <!-- BrainAtlas with TMSProvider wrapper -->
        <div class="glass-panel rounded-2xl p-6 md:p-8">
          <TMSProvider>
            <BrainAtlas client:only="react" />
          </TMSProvider>
        </div>

        <!-- Usage hint -->
        <div class="mt-4 flex items-center gap-4 text-[10px] text-slate-500 justify-center">
          <span class="flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="12" cy="12" r="1"/><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
            Hover over regions to learn more
          </span>
          <span class="text-slate-700">|</span>
          <span class="flex items-center gap-1.5">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5"/></svg>
            Click to select a TMS target
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Protocol Academy -->
  <section id="protocols" class="bg-slate-900/50 py-20 border-b border-slate-800/40">
    <div class="container mx-auto px-6">
      <div class="max-w-5xl mx-auto">
        <!-- Section Header -->
        <div class="text-center mb-14">
          <span class="inline-block text-[9px] font-bold uppercase tracking-widest text-fuchsia-400 mb-3 border border-fuchsia-400/20 px-3 py-1 rounded-full bg-fuchsia-400/5">
            Protocol Guide
          </span>
          <h2 class="text-3xl md:text-4xl font-black text-white mb-4">Protocol Academy</h2>
          <p class="text-[11px] text-slate-400 max-w-2xl mx-auto leading-relaxed">
            TMS protocols differ in frequency, intensity, pulse pattern, and target region. Explore the six
            major clinical protocols and understand which conditions each is designed to treat.
          </p>
        </div>

        <!-- ProtocolAcademy -->
        <ProtocolAcademy client:only="react" />
      </div>
    </div>
  </section>

  <!-- Section 4: What to Expect -->
  <section id="what-to-expect" class="bg-slate-950/50 py-20">
    <div class="container mx-auto px-6">
      <div class="max-w-4xl mx-auto">
        <!-- Section Header -->
        <div class="text-center mb-14">
          <span class="inline-block text-[9px] font-bold uppercase tracking-widest text-emerald-400 mb-3 border border-emerald-400/20 px-3 py-1 rounded-full bg-emerald-400/5">
            Patient Journey
          </span>
          <h2 class="text-3xl md:text-4xl font-black text-white mb-4">What to Expect</h2>
          <p class="text-[11px] text-slate-400 max-w-xl mx-auto leading-relaxed">
            A typical TMS treatment course spans 6–9 weeks. Here's what your journey looks like from
            first enquiry to completion.
          </p>
        </div>

        <!-- 6-Week Journey Timeline -->
        <div class="relative">
          <!-- Vertical line -->
          <div class="absolute left-8 top-0 bottom-0 w-px bg-gradient-to-b from-slate-700 via-violet-600/30 to-slate-700 hidden md:block"></div>

          {[
            {
              week: "Week 1",
              title: "Consultation & Mapping",
              desc: "Your first visit includes a psychiatric evaluation, review of your history, and motor threshold mapping. The clinician finds the optimal coil position by stimulating your motor cortex and measuring the smallest pulse needed to cause a finger twitch.",
              icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01",
              color: "cyan",
              dotColor: "bg-cyan-500",
              borderColor: "border-cyan-500/20",
              bgColor: "bg-cyan-500/5",
            },
            {
              week: "Week 2–3",
              title: "Early Treatment Phase",
              desc: "Daily sessions (Monday–Friday) begin. You'll sit in a comfortable chair, the coil is positioned, and you hear a clicking sound with each pulse. Most patients describe it as a mild tapping sensation on the scalp. Sessions last 19–37 minutes depending on the protocol.",
              icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
              color: "violet",
              dotColor: "bg-violet-500",
              borderColor: "border-violet-500/20",
              bgColor: "bg-violet-500/5",
            },
            {
              week: "Week 3–4",
              title: "Building Response",
              desc: "Many patients start noticing subtle improvements in mood, energy, and sleep around week 3. Some may feel worse before feeling better (an 'initial dip' in weeks 2–3 is normal). Keep attending sessions even if effects aren't yet obvious.",
              icon: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6",
              color: "fuchsia",
              dotColor: "bg-fuchsia-500",
              borderColor: "border-fuchsia-500/20",
              bgColor: "bg-fuchsia-500/5",
            },
            {
              week: "Week 4–5",
              title: "Peak Treatment Window",
              desc: "Maximum clinical response typically develops between weeks 4–6. Your clinician may adjust intensity or pulse count based on your response. Avoid stopping early — the full course is essential for durable remission.",
              icon: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z",
              color: "amber",
              dotColor: "bg-amber-500",
              borderColor: "border-amber-500/20",
              bgColor: "bg-amber-500/5",
            },
            {
              week: "Week 6",
              title: "Completion & Assessment",
              desc: "After your final session, your clinician performs a reassessment. If you've achieved remission or significant improvement, you transition to a maintenance or monitoring phase. Partial responders may discuss additional sessions.",
              icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
              color: "emerald",
              dotColor: "bg-emerald-500",
              borderColor: "border-emerald-500/20",
              bgColor: "bg-emerald-500/5",
            },
            {
              week: "Ongoing",
              title: "Maintenance & Follow-up",
              desc: "About 30–40% of patients experience relapse within 6–12 months. Options include booster sessions (single pulses every few weeks), maintenance protocols, or combining TMS with medication. Regular follow-up is essential for long-term success.",
              icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
              color: "rose",
              dotColor: "bg-rose-500",
              borderColor: "border-rose-500/20",
              bgColor: "bg-rose-500/5",
            },
          ].map((item) => (
            <div class="relative flex gap-6 mb-6 group">
              <!-- Timeline dot -->
              <div class="relative shrink-0 hidden md:flex flex-col items-center">
                <div class={`w-4 h-4 rounded-full ${item.dotColor} border-2 border-slate-950 shadow-lg z-10 group-hover:scale-125 transition-transform`}></div>
              </div>

              <!-- Card -->
              <div class={`flex-1 ${item.bgColor} border ${item.borderColor} rounded-2xl p-6 hover-lift`}>
                <div class="flex items-start gap-4">
                  <!-- Icon -->
                  <div class={`w-10 h-10 rounded-xl flex items-center justify-center shrink-0 bg-slate-800/60`}>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" class={`text-${item.color}-400`} strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round">
                      <path d={item.icon} />
                    </svg>
                  </div>

                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 flex-wrap mb-2">
                      <span class={`text-[9px] font-black uppercase tracking-widest px-2 py-0.5 rounded-full border ${
                        item.color === 'cyan' ? 'text-cyan-400 border-cyan-500/30 bg-cyan-500/10' :
                        item.color === 'violet' ? 'text-violet-400 border-violet-500/30 bg-violet-500/10' :
                        item.color === 'fuchsia' ? 'text-fuchsia-400 border-fuchsia-500/30 bg-fuchsia-500/10' :
                        item.color === 'amber' ? 'text-amber-400 border-amber-500/30 bg-amber-500/10' :
                        item.color === 'emerald' ? 'text-emerald-400 border-emerald-500/30 bg-emerald-500/10' :
                        'text-rose-400 border-rose-500/30 bg-rose-500/10'
                      }`}>
                        {item.week}
                      </span>
                      <h3 class="text-sm font-bold text-white">{item.title}</h3>
                    </div>
                    <p class="text-[11px] text-slate-400 leading-relaxed">{item.desc}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <!-- Bottom CTA -->
        <div class="mt-16 text-center">
          <div class="glass-panel rounded-2xl p-8 max-w-lg mx-auto">
            <h3 class="text-lg font-bold text-white mb-3">Ready to explore treatment options?</h3>
            <p class="text-[11px] text-slate-400 mb-6 leading-relaxed">
              Browse verified TMS clinics across the United States with real patient reviews,
              insurance information, and provider credentials.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-3">
              <a href="/us/" class="inline-flex items-center gap-2 px-6 py-3 bg-violet-600 hover:bg-violet-500 text-white font-semibold text-[11px] rounded-xl transition-all shadow-lg shadow-violet-900/30">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                Find a TMS Clinic
              </a>
              <a href="/quiz/am-i-a-candidate/" class="inline-flex items-center gap-2 px-6 py-3 bg-slate-800 hover:bg-slate-700 text-slate-300 font-semibold text-[11px] rounded-xl transition-all border border-slate-700">
                Take the Quiz
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
