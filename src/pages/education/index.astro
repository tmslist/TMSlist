---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import EditorialSection from '../../components/editorial/EditorialSection.astro';
import EditorialCard from '../../components/editorial/EditorialCard.astro';
import EditorialCTA from '../../components/editorial/EditorialCTA.astro';
import BrainAtlasWithProvider from '../../components/react/education/BrainAtlasWithProvider';
import ProtocolAcademy from '../../components/react/education/ProtocolAcademy';
import EducationSimulator from '../../components/react/education/EducationSimulator';

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const pageSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "EducationalPage",
  "headline": "TMS Education Hub",
  "description": "Learn how transcranial magnetic stimulation (TMS) works, explore brain anatomy, and understand treatment protocols.",
  "url": `${siteUrl}/education/`,
  "author": { "@type": "Organization", "name": "TMS List", "url": siteUrl },
  "publisher": { "@type": "Organization", "name": "TMS List", "url": siteUrl, "logo": { "@type": "ImageObject", "url": `${siteUrl}/favicon.svg` } },
  "reviewedBy": { "@type": "Person", "name": "Dr. Karan Narwal", "jobTitle": "Mental Health Specialist & Consultant" },
});

const fourSteps = [
  {
    n: 1,
    title: "Magnetic Pulse",
    desc: "A coil placed on the scalp generates a brief, powerful magnetic field — similar to an MRI — lasting about 200 microseconds per pulse.",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>',
  },
  {
    n: 2,
    title: "Induces Current",
    desc: "The magnetic field passes through the skull painlessly and induces a small electrical current in the underlying cortical neurons.",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M3 9h2m14 0h2M3 15h2m14 0h2M7 7h10a2 2 0 012 2v6a2 2 0 01-2 2H7a2 2 0 01-2-2V9a2 2 0 012-2z"/>',
  },
  {
    n: 3,
    title: "Neurons Fire",
    desc: "The induced current causes target neurons to depolarize and fire, releasing neurotransmitters and modulating downstream brain networks.",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>',
  },
  {
    n: 4,
    title: "Network Effect",
    desc: "Repeated sessions strengthen synaptic connections, normalize dysfunctional circuits, and produce lasting changes in mood and cognition.",
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>',
  },
];

const keyFacts = [
  { value: "200μs", label: "Pulse Duration" },
  { value: "1.5–2T", label: "Field Strength" },
  { value: "~19 min", label: "Standard Session" },
  { value: "30–36", label: "Typical Sessions" },
];

const journey = [
  {
    week: "Week 0",
    phase: "Consultation",
    desc: "Psychiatric evaluation, diagnosis confirmation, baseline PHQ-9 / HAM-D scores, and insurance pre-authorization.",
  },
  {
    week: "Day 1",
    phase: "Motor Threshold Mapping",
    desc: "Calibration session — coil placement is fine-tuned and treatment intensity (typically 80–120% MT) is set.",
  },
  {
    week: "Weeks 1–2",
    phase: "Early Treatment",
    desc: "Daily 20–37 minute sessions, Mon–Fri. You sit in a recliner; mild scalp tapping is normal. Resume normal activity immediately.",
  },
  {
    week: "Weeks 3–5",
    phase: "Building Response",
    desc: "First signs of improvement — better sleep, more energy, lifting mood. Side effects diminish.",
  },
  {
    week: "Week 6",
    phase: "Consolidation",
    desc: "Final sessions. PHQ-9 reassessed and often significantly reduced. Discussion of maintenance plan.",
  },
  {
    week: "Month 2+",
    phase: "Maintenance",
    desc: "Optional periodic sessions to sustain gains. Long-term outcome follow-up at 1, 3, and 6 months.",
  },
];

const lessons = [
  { title: "How rTMS Works", href: "/answers/what-is-tms-therapy/", desc: "The mechanism behind repetitive transcranial magnetic stimulation." },
  { title: "Deep TMS", href: "/technology/brainsway-deep-tms/", desc: "BrainsWay H-coil technology and what it reaches that figure-8 coils can't." },
  { title: "Theta Burst (TBS)", href: "/protocols/theta-burst-stimulation/", desc: "The 3-minute condensed protocol — same efficacy as standard rTMS." },
  { title: "SAINT Protocol", href: "/protocols/saint-protocol/", desc: "Stanford's 5-day accelerated course with 79% remission in trials." },
  { title: "Neuroplasticity & TMS", href: "/research/neuroplasticity-and-tms/", desc: "How TMS rewires brain circuits — fMRI evidence and LTP science." },
  { title: "FDA Clearance History", href: "/research/fda-clearance-history/", desc: "Timeline from 2008 to present — devices, indications, and trial data." },
];
---

<Layout
  title="TMS Education Hub | Interactive Brain Anatomy & Protocol Guide"
  description="Learn how TMS works, explore interactive brain anatomy, and understand treatment protocols in this comprehensive educational resource."
  schema={pageSchema}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Education", url: "/education/" },
  ]}
>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow="Interactive Education"
    eyebrowDot="#22c55e"
    title="The science"
    titleAccent="behind TMS."
    description="Explore the mechanism, brain anatomy, treatment protocols, and the patient journey — written for clinicians and patients alike."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Education" }]}
    ctas={[
      { label: "Try the Simulator", href: "#simulator" },
      { label: "Patient Journey", href: "#journey", variant: "outline" },
    ]}
    stats={[
      { value: "Live", label: "Simulator", color: "warm" },
      { value: "16", label: "Brain Regions", color: "ink" },
      { value: "6", label: "Protocols", color: "accent" },
    ]}
  />

  <!-- Section 1: How TMS Works -->
  <EditorialSection
    title="How TMS Works"
    intro="Transcranial magnetic stimulation uses focused electromagnetic pulses to selectively activate or inhibit specific brain regions — without surgery, sedation, or systemic side effects."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>'
    tone="warm"
  >
    <div id="how-tms-works" class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {fourSteps.map((step) => (
        <div style="background:var(--paper2); border:1px solid var(--line); border-radius:1.5rem; padding:1.75rem; position:relative;">
          <span class="serif" style="position:absolute; top:1.25rem; right:1.5rem; font-size:2.5rem; line-height:1; color:rgba(201,101,74,0.25);">
            0{step.n}
          </span>
          <div style="width:2.5rem; height:2.5rem; border-radius:0.75rem; background:rgba(201,101,74,0.1); color:var(--warm); display:flex; align-items:center; justify-content:center; margin-bottom:1.25rem;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" set:html={step.icon} />
          </div>
          <h3 class="serif" style="font-size:1.25rem; color:var(--ink); margin:0 0 0.5rem;">{step.title}</h3>
          <p style="font-size:14px; color:var(--muted); line-height:1.6; margin:0;">{step.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4">
      {keyFacts.map((fact) => (
        <div style="background:var(--paper); border:1px solid var(--line); border-radius:1rem; padding:1.25rem 1rem; text-align:center;">
          <div class="serif" style="font-size:2rem; line-height:1; color:var(--warm);">{fact.value}</div>
          <div style="font-size:11px; font-weight:500; text-transform:uppercase; letter-spacing:0.075em; color:var(--muted); margin-top:0.5rem;">{fact.label}</div>
        </div>
      ))}
    </div>
  </EditorialSection>

  <!-- Section 2: Interactive Simulator -->
  <EditorialSection
    title="Try the simulator"
    intro="Adjust the coil parameters and watch the magnetic field penetrate the cortex. Pick a clinical protocol or design your own — the readouts update live."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>'
    tone="warm"
    background="paper2"
    actionLabel="Open full 3D simulator"
    actionHref="/simulation/"
  >
    <div
      id="simulator"
      style="background:var(--paper); border:1px solid var(--line); border-radius:1.5rem; padding:1.5rem; box-shadow:0 8px 32px -12px rgba(10,22,40,0.08);"
    >
      <EducationSimulator client:visible />
    </div>
  </EditorialSection>

  <!-- Section 3: Interactive Brain Atlas -->
  <EditorialSection
    title="Interactive Brain Atlas"
    intro="Explore the brain regions targeted by TMS for each FDA-cleared condition. Click any region to see protocols and outcome data — toggle 'Connect to simulator' above to update the coil target."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m18 0h-2M5 15H3m18 0h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z"/>'
    tone="accent"
  >
    <div id="brain-anatomy" style="background:var(--paper); border:1px solid var(--line); border-radius:1.5rem; padding:1.25rem; overflow:hidden;">
      <BrainAtlasWithProvider client:visible />
    </div>
  </EditorialSection>

  <!-- Section 4: Protocols -->
  <EditorialSection
    title="Treatment Protocols"
    intro="Compare the major TMS protocols used in clinical practice — frequency, session count, target conditions."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>'
    tone="warm"
    background="paper2"
  >
    <div id="protocols">
      <ProtocolAcademy client:visible />
    </div>
  </EditorialSection>

  <!-- Section 5: Patient Journey -->
  <EditorialSection
    title="The Patient Journey"
    intro="From first consultation to lasting results — what to expect at every stage of a 6-week course."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>'
    tone="accent"
    background="paper2"
  >
    <div id="journey" class="relative">
      <!-- Vertical line -->
      <div class="absolute left-6 top-2 bottom-2 hidden md:block" style="width:2px; background:linear-gradient(to bottom, var(--warm), var(--ink), transparent);"></div>

      <ol class="flex flex-col gap-6">
        {journey.map((step, i) => (
          <li class="relative md:pl-20">
            <!-- Dot -->
            <div class="hidden md:flex items-center justify-center absolute left-0" style="top:0.5rem; width:3rem; height:3rem; border-radius:50%; background:var(--paper); border:2px solid var(--warm); color:var(--warm); font-family:'Instrument Serif', Georgia, serif; font-size:1.125rem;">
              {i + 1}
            </div>
            <div style="background:var(--paper); border:1px solid var(--line); border-radius:1.25rem; padding:1.5rem 1.75rem;">
              <div class="flex items-center gap-3 mb-2">
                <span style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.075em; color:var(--warm);">{step.week}</span>
              </div>
              <h3 class="serif" style="font-size:1.5rem; color:var(--ink); margin:0 0 0.5rem; line-height:1.15;">{step.phase}</h3>
              <p style="font-size:15px; color:var(--muted); line-height:1.65; margin:0;">{step.desc}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </EditorialSection>

  <!-- Section 5: Continue Learning -->
  <EditorialSection
    title="Continue Learning"
    intro="Deeper-dives into the most-asked TMS topics."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>'
    tone="warm"
    noBorder
  >
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {lessons.map((lesson) => (
        <EditorialCard
          href={lesson.href}
          tag="Lesson"
          tagTone="accent"
          title={lesson.title}
          description={lesson.desc}
          size="lg"
        />
      ))}
    </div>
  </EditorialSection>

  <EditorialCTA
    title="Ready to take the next step?"
    description="The science is clear. Find out if TMS therapy is right for your situation."
    ctas={[
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: "Find a TMS Clinic", href: "/us/", variant: "outline" },
    ]}
    stickyMobile
  />
</main>

</Layout>
