---
import Layout from "../../layouts/Layout.astro";

const title = "Careers at TMS List | Join Our Team";
const description = "Join TMS List and help make TMS therapy accessible worldwide. View open positions, company values, and benefits.";

const values = [
    { title: "Transparency", description: "We publish honest, evidence-based information. No hidden agendas, no pay-for-placement rankings. Our users trust us because we earn it.", icon: "M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" },
    { title: "Patient-First", description: "Every feature, every page, every decision starts with one question: does this help someone find the right TMS care? If not, we don't build it.", icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" },
    { title: "Evidence-Based", description: "We reference peer-reviewed research, cite our sources, and update content as new studies emerge. Accuracy is non-negotiable.", icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" },
    { title: "Global Access", description: "TMS therapy shouldn't be limited by geography. We're building the most comprehensive worldwide directory so patients everywhere can find care.", icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
];

const benefits = [
    { title: "Remote-First", description: "Work from anywhere in the world. We're a distributed team across multiple time zones." },
    { title: "Health Insurance", description: "Comprehensive medical, dental, and vision coverage for you and your dependents." },
    { title: "Education Budget", description: "$2,000/year for courses, conferences, books, or any learning that makes you better at your craft." },
    { title: "Flexible Hours", description: "We care about output, not hours. Structure your day around your life, not the other way around." },
    { title: "Paid Time Off", description: "Generous PTO policy plus company-wide recharge days. We believe rest fuels better work." },
    { title: "Equipment Stipend", description: "Budget for your home office setup so you have the tools you need to do great work." },
];
---

<Layout title={title} description={description} breadcrumbs={[{ name: "Home", url: "/" }, { name: "Careers", url: "/careers/" }]}>
    <main>
        <!-- Hero -->
        <section class="relative bg-slate-950 overflow-hidden">
            <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.3) 1px, transparent 0); background-size: 32px 32px;"></div>
            <div class="absolute top-[-10%] left-[20%] w-[500px] h-[500px] bg-violet-600/10 rounded-full blur-[150px]"></div>
            <div class="absolute bottom-[10%] right-[15%] w-[400px] h-[400px] bg-cyan-500/8 rounded-full blur-[120px]"></div>

            <div class="container mx-auto px-4 pt-12 pb-24 lg:pt-16 lg:pb-28 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-500 mb-12" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
                    <span class="text-slate-700">/</span>
                    <span class="text-slate-300">Careers</span>
                </nav>
                <div class="max-w-3xl">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-violet-500/10 border border-violet-500/20 rounded-full mb-6">
                        <div class="w-1.5 h-1.5 rounded-full bg-violet-400"></div>
                        <span class="text-xs font-semibold text-violet-400 tracking-wider uppercase">Join Our Team</span>
                    </div>
                    <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white leading-[0.95] mb-5">
                        Careers at<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-cyan-400">TMS List</span>
                    </h1>
                    <p class="text-lg text-slate-400 leading-relaxed max-w-xl">
                        We're on a mission to make TMS therapy accessible to everyone, everywhere. Help us build the world's most trusted TMS directory.
                    </p>
                </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-16 bg-white" style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"></div>
        </section>

        <!-- Mission -->
        <section class="py-16 lg:py-24 bg-white">
            <div class="container mx-auto px-4 max-w-4xl">
                <div class="text-center mb-16">
                    <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 tracking-tight mb-5">Our Mission</h2>
                    <p class="text-lg text-slate-500 leading-relaxed max-w-2xl mx-auto">
                        Millions of people with treatment-resistant depression, OCD, and other conditions could benefit from TMS therapy — but most don't know it exists, and those who do struggle to find a provider. We're changing that by building the most comprehensive, transparent, and accessible TMS clinic directory in the world.
                    </p>
                </div>
            </div>
        </section>

        <!-- Values -->
        <section class="py-16 lg:py-24 bg-slate-50 border-y border-slate-100">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="text-center mb-14">
                    <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 tracking-tight mb-4">What We Stand For</h2>
                    <p class="text-slate-500 text-lg max-w-xl mx-auto">These values guide every decision we make, from product features to content policies.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {values.map(v => (
                        <div class="bg-white rounded-2xl border border-slate-100 p-7 hover:shadow-md transition-shadow">
                            <div class="w-12 h-12 rounded-xl bg-violet-50 flex items-center justify-center text-violet-600 mb-5">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={v.icon}/></svg>
                            </div>
                            <h3 class="text-lg font-bold text-slate-900 mb-2">{v.title}</h3>
                            <p class="text-sm text-slate-500 leading-relaxed">{v.description}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Open Positions -->
        <section class="py-16 lg:py-24 bg-white">
            <div class="container mx-auto px-4 max-w-4xl">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
                        <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    </div>
                    <h2 class="text-2xl font-bold text-slate-900">Open Positions</h2>
                </div>

                <div class="space-y-4">
                    <div class="bg-white border border-slate-200 rounded-2xl p-6 hover:border-violet-200 hover:shadow-md transition-all">
                        <div class="flex flex-wrap items-start justify-between gap-4">
                            <div>
                                <h3 class="text-lg font-bold text-slate-900 mb-1">Content Writer — Healthcare</h3>
                                <p class="text-slate-500 text-sm mb-3">Create evidence-based TMS therapy guides, patient resources, and clinic comparison content.</p>
                                <div class="flex flex-wrap gap-2">
                                    <span class="px-2.5 py-1 bg-blue-50 text-blue-700 text-xs font-medium rounded-full">Remote</span>
                                    <span class="px-2.5 py-1 bg-emerald-50 text-emerald-700 text-xs font-medium rounded-full">Full-time</span>
                                    <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-medium rounded-full">Content</span>
                                </div>
                            </div>
                            <a href="mailto:careers@tmslist.com?subject=Application: Content Writer" class="px-5 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold rounded-xl transition-colors shrink-0">Apply</a>
                        </div>
                    </div>

                    <div class="bg-white border border-slate-200 rounded-2xl p-6 hover:border-violet-200 hover:shadow-md transition-all">
                        <div class="flex flex-wrap items-start justify-between gap-4">
                            <div>
                                <h3 class="text-lg font-bold text-slate-900 mb-1">Full-Stack Developer</h3>
                                <p class="text-slate-500 text-sm mb-3">Build features for our clinic directory, patient tools, and provider portal. Astro, React, PostgreSQL.</p>
                                <div class="flex flex-wrap gap-2">
                                    <span class="px-2.5 py-1 bg-blue-50 text-blue-700 text-xs font-medium rounded-full">Remote</span>
                                    <span class="px-2.5 py-1 bg-emerald-50 text-emerald-700 text-xs font-medium rounded-full">Full-time</span>
                                    <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-medium rounded-full">Engineering</span>
                                </div>
                            </div>
                            <a href="mailto:careers@tmslist.com?subject=Application: Full-Stack Developer" class="px-5 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold rounded-xl transition-colors shrink-0">Apply</a>
                        </div>
                    </div>

                    <div class="bg-white border border-slate-200 rounded-2xl p-6 hover:border-violet-200 hover:shadow-md transition-all">
                        <div class="flex flex-wrap items-start justify-between gap-4">
                            <div>
                                <h3 class="text-lg font-bold text-slate-900 mb-1">Clinic Data Researcher</h3>
                                <p class="text-slate-500 text-sm mb-3">Verify clinic information, research insurance policies, and maintain the accuracy of our directory data.</p>
                                <div class="flex flex-wrap gap-2">
                                    <span class="px-2.5 py-1 bg-blue-50 text-blue-700 text-xs font-medium rounded-full">Remote</span>
                                    <span class="px-2.5 py-1 bg-amber-50 text-amber-700 text-xs font-medium rounded-full">Part-time</span>
                                    <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-medium rounded-full">Research</span>
                                </div>
                            </div>
                            <a href="mailto:careers@tmslist.com?subject=Application: Data Researcher" class="px-5 py-2.5 bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold rounded-xl transition-colors shrink-0">Apply</a>
                        </div>
                    </div>
                </div>

                <p class="text-center text-slate-500 text-sm mt-8">
                    Don't see your role? <a href="mailto:careers@tmslist.com" class="text-violet-600 font-semibold hover:text-violet-500">Send us your resume anyway</a> — we're always looking for great people.
                </p>
            </div>
        </section>

        <!-- Benefits -->
        <section class="py-16 lg:py-24 bg-slate-50 border-y border-slate-100">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="text-center mb-14">
                    <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 tracking-tight mb-4">Benefits & Perks</h2>
                    <p class="text-slate-500 text-lg max-w-xl mx-auto">We take care of our team so they can focus on building something meaningful.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                    {benefits.map(b => (
                        <div class="bg-white rounded-2xl border border-slate-100 p-6">
                            <h3 class="text-base font-bold text-slate-900 mb-2">{b.title}</h3>
                            <p class="text-sm text-slate-500 leading-relaxed">{b.description}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="py-16 lg:py-24 bg-white">
            <div class="container mx-auto px-4 max-w-4xl">
                <div class="relative bg-slate-950 rounded-3xl p-10 lg:p-14 overflow-hidden text-center">
                    <div class="absolute inset-0 bg-gradient-to-r from-violet-600/10 via-transparent to-cyan-600/10"></div>
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
                    <div class="relative z-10">
                        <p class="text-sm font-semibold text-violet-400 tracking-wider uppercase mb-3">Get in Touch</p>
                        <h3 class="text-2xl lg:text-3xl font-bold text-white mb-4 tracking-tight">Interested in Joining Us?</h3>
                        <p class="text-slate-400 max-w-lg mx-auto mb-8">Send your resume and a note about why you're excited about making TMS therapy more accessible. We read every email.</p>
                        <a href="mailto:careers@tmslist.com" class="inline-block px-8 py-4 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl transition-colors shadow-lg shadow-violet-600/25">Email careers@tmslist.com</a>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
