---
import Layout from "../../layouts/Layout.astro";
import JobApplyForm from "../../components/react/JobApplyForm";
import JobCard from "../../components/react/JobCard";

export const prerender = false;

const { id } = Astro.params;

let job: any = null;
let error: string | null = null;

try {
  const res = await fetch(`${Astro.url.origin}/api/jobs/${id}`);
  if (res.ok) {
    const data = await res.json();
    job = data.data;
  } else if (res.status === 404) {
    error = "Job not found";
  } else if (res.status === 410) {
    error = "This job is no longer accepting applications";
  } else {
    error = "Failed to load job";
  }
} catch (e) {
  error = "Failed to load job";
}

if (error || !job) {
  return Astro.redirect("/careers/");
}

const title = `${job.title} at ${job.clinicName} | TMS List Jobs`;
const description = `Apply for ${job.title} at ${job.clinicName} in ${job.clinicCity}, ${job.clinicState}. ${job.description?.slice(0, 150)}...`;

const jobJsonLd = {
  "@context": "https://schema.org",
  "@type": "JobPosting",
  "title": job.title,
  "description": job.description,
  "identifier": { "@type": "PropertyValue", "name": "TMS List", "value": job.id },
  "hiringOrganization": {
    "@type": "Organization",
    "name": job.clinicName,
    "sameAs": job.clinicWebsite ? `https://${job.clinicWebsite.replace(/^https?:\/\//, '')}` : undefined,
  },
  "jobLocation": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": job.clinicCity,
      "addressRegion": job.clinicState,
      "postalCode": job.clinicZip,
      "streetAddress": job.clinicAddress,
      "addressCountry": "US",
    },
  },
  "employmentType": job.employmentType === "full_time" ? "FULL_TIME" :
    job.employmentType === "part_time" ? "PART_TIME" :
    job.employmentType === "contract" ? "CONTRACTOR" : "OTHER",
  "remote": job.remote ? { "@type": "PropertyValue", "value": "true" } : undefined,
  "datePosted": job.createdAt?.slice(0, 10),
  "validThrough": job.expiresAt ? job.expiresAt.slice(0, 10) : undefined,
  "description": job.description,
  "skills": job.requirements || undefined,
  "responsibilities": job.responsibilities || undefined,
  "benefits": job.benefits || undefined,
  "baseSalary": (job.salaryMin || job.salaryMax) ? {
    "@type": "MonetaryAmount",
    "currency": "USD",
    "value": {
      "@type": "QuantitativeValue",
      "minValue": job.salaryMin ? Math.round(job.salaryMin / 100) / 10 : undefined,
      "maxValue": job.salaryMax ? Math.round(job.salaryMax / 100) / 10 : undefined,
      "unitText": "YEAR",
    },
  } : undefined,
};

const clinicLogo = job.clinicLogo as { logo_url?: string } | null;
---

<Layout title={title} description={description} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "Careers", url: "/careers/" },
  { name: job.title, url: `/careers/${id}/` },
]} schema={JSON.stringify(jobJsonLd)}>
  <main>
    <!-- Hero -->
    <section class="relative bg-slate-950 overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.3) 1px, transparent 0); background-size: 32px 32px;"></div>
      <div class="absolute top-[-10%] left-[20%] w-[500px] h-[500px] bg-violet-600/10 rounded-full blur-[150px]"></div>

      <div class="container mx-auto px-4 pt-12 pb-16 lg:pt-16 relative z-10">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-10" aria-label="Breadcrumb">
          <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
          <span class="text-slate-700">/</span>
          <a href="/careers/" class="hover:text-violet-400 transition-colors">Careers</a>
          <span class="text-slate-700">/</span>
          <span class="text-slate-300 truncate max-w-xs">{job.title}</span>
        </nav>

        <div class="flex flex-col md:flex-row items-start md:items-center gap-6 max-w-4xl">
          <!-- Clinic info -->
          <div class="flex items-center gap-4">
            {clinicLogo?.logo_url ? (
              <img src={clinicLogo.logo_url} alt={job.clinicName} class="w-16 h-16 rounded-2xl object-cover bg-white" />
            ) : (
              <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-violet-100 to-cyan-100 flex items-center justify-center text-violet-700 font-bold text-2xl">
                {job.clinicName.charAt(0)}
              </div>
            )}
            <div>
              <p class="text-sm text-slate-400 mb-0.5">{job.clinicName}</p>
              <a href={`/clinics/${job.clinicSlug}/`} class="text-xs text-violet-400 hover:text-violet-300 transition-colors">
                View clinic profile →
              </a>
            </div>
          </div>

          <div class="flex-1">
            <h1 class="text-3xl lg:text-4xl font-bold text-white tracking-tight mb-2">{job.title}</h1>
            <div class="flex flex-wrap items-center gap-3 text-sm text-slate-400">
              <span class="flex items-center gap-1.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                {job.location}
              </span>
              {job.remote && (
                <span class="flex items-center gap-1.5 px-2.5 py-0.5 bg-emerald-500/10 text-emerald-400 rounded-full text-xs font-medium">
                  Remote OK
                </span>
              )}
              <span class="px-2.5 py-0.5 bg-violet-500/10 text-violet-400 rounded-full text-xs font-medium capitalize">
                {job.employmentType.replace('_', ' ')}
              </span>
            </div>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-12 bg-white" style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"></div>
    </section>

    <!-- Body -->
    <section class="py-12 lg:py-16 bg-slate-50">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="flex flex-col lg:flex-row gap-8">

          <!-- Main content -->
          <div class="flex-1 min-w-0 space-y-8">
            <!-- Description -->
            <div class="bg-white rounded-2xl border border-slate-200 p-6 lg:p-8">
              <h2 class="text-lg font-bold text-slate-900 mb-4">About This Role</h2>
              <div class="prose prose-slate max-w-none">
                <p class="text-slate-600 leading-relaxed whitespace-pre-wrap">{job.description}</p>
              </div>
            </div>

            {job.requirements && (
              <div class="bg-white rounded-2xl border border-slate-200 p-6 lg:p-8">
                <h2 class="text-lg font-bold text-slate-900 mb-4">Requirements</h2>
                <div class="prose prose-slate max-w-none">
                  <p class="text-slate-600 leading-relaxed whitespace-pre-wrap">{job.requirements}</p>
                </div>
              </div>
            )}

            {job.responsibilities && (
              <div class="bg-white rounded-2xl border border-slate-200 p-6 lg:p-8">
                <h2 class="text-lg font-bold text-slate-900 mb-4">Responsibilities</h2>
                <div class="prose prose-slate max-w-none">
                  <p class="text-slate-600 leading-relaxed whitespace-pre-wrap">{job.responsibilities}</p>
                </div>
              </div>
            )}

            {job.benefits && (
              <div class="bg-white rounded-2xl border border-slate-200 p-6 lg:p-8">
                <h2 class="text-lg font-bold text-slate-900 mb-4">Benefits</h2>
                <div class="prose prose-slate max-w-none">
                  <p class="text-slate-600 leading-relaxed whitespace-pre-wrap">{job.benefits}</p>
                </div>
              </div>
            )}

            <!-- Back -->
            <a href="/careers/" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-700 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              Back to all jobs
            </a>
          </div>

          <!-- Sidebar -->
          <div class="lg:w-96 shrink-0 space-y-5">
            <!-- Apply card -->
            <div class="bg-white rounded-2xl border border-slate-200 p-6 sticky top-6">
              <h2 class="text-lg font-bold text-slate-900 mb-1">Apply for this Position</h2>

              <!-- Salary & meta -->
              <div class="flex flex-wrap gap-2 mb-5">
                {(job.salaryDisplay || job.salaryMin || job.salaryMax) && (
                  <div class="flex items-center gap-1.5 text-sm font-semibold text-slate-700">
                    <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    {job.salaryDisplay || (job.salaryMin && job.salaryMax
                      ? `$${(job.salaryMin/1000).toFixed(0)}k – $${(job.salaryMax/1000).toFixed(0)}k`
                      : job.salaryMin ? `From $${(job.salaryMin/1000).toFixed(0)}k` : `Up to $${(job.salaryMax/1000).toFixed(0)}k`)}
                  </div>
                )}
              </div>

              <!-- Clinic contact info -->
              <div class="bg-slate-50 rounded-xl p-4 mb-5 space-y-2">
                {job.clinicAddress && (
                  <div class="flex items-start gap-2 text-xs text-slate-500">
                    <svg class="w-3.5 h-3.5 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span>{[job.clinicAddress, job.clinicCity, job.clinicState, job.clinicZip].filter(Boolean).join(', ')}</span>
                  </div>
                )}
                {job.clinicPhone && (
                  <div class="flex items-center gap-2 text-xs text-slate-500">
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    <a href={`tel:${job.clinicPhone}`} class="hover:text-violet-600">{job.clinicPhone}</a>
                  </div>
                )}
                {job.clinicWebsite && (
                  <div class="flex items-center gap-2 text-xs text-slate-500">
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                    <a href={job.clinicWebsite} target="_blank" rel="noopener noreferrer" class="hover:text-violet-600 truncate">{job.clinicWebsite.replace(/^https?:\/\//, '')}</a>
                  </div>
                )}
              </div>

              <!-- Apply form or external redirect -->
              <JobApplyForm
                client:load
                jobId={job.id}
                jobTitle={job.title}
                clinicName={job.clinicName}
                applicationUrl={job.applicationUrl}
              />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
