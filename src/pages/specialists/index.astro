---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import EditorialHero from "../../components/editorial/EditorialHero.astro";
import { getDoctorPhoto, COUNTRY_NAMES, COUNTRY_URL_PREFIXES } from "../../utils/dataHelpers";
import { getAllDoctors } from "../../utils/jsonData";
import { getVisitorCountry } from "../../utils/visitorCountry";

const VISITOR_COUNTRY = getVisitorCountry(Astro.cookies, Astro.url);
const visitorCountryName = COUNTRY_NAMES[VISITOR_COUNTRY] || 'United States';
const visitorCountryUrl = `/${COUNTRY_URL_PREFIXES[VISITOR_COUNTRY] || VISITOR_COUNTRY.toLowerCase()}/`;

// Load all doctors from the data store (JSON-backed)
interface Doctor {
    slug: string;
    firstName: string;
    lastName: string;
    fullName: string;
    title: string;
    school: string;
    yearsExperience: number;
    specialties: string[];
    bioFocus: string;
    bio: string;
    imageUrl: string;
    clinicName: string;
    clinicSlug: string;
    clinicCity: string;
    clinicState: string;
    clinicPhone?: string;
    clinicImage: string;
}

// Try visitor country first; fall back to US if their country has no slugged specialists yet.
// We require a slug because the page links to /specialist/[slug] — doctors without a slug
// would render as broken cards.
const inCountry = await getAllDoctors({ country: VISITOR_COUNTRY });
const inCountrySlugged = inCountry.filter(({ doctor }) => doctor.slug);
const allDoctorData = inCountrySlugged.length > 0
    ? inCountrySlugged
    : await getAllDoctors({ country: 'US' });
const doctorMap = new Map<string, Doctor>();

allDoctorData.forEach(({ doctor: doc, clinicName, clinicSlug, clinicCity, clinicState }) => {
    if (doc.slug && !doctorMap.has(doc.slug)) {
        doctorMap.set(doc.slug, {
            slug: doc.slug,
            firstName: doc.firstName || "",
            lastName: doc.lastName || "",
            fullName: doc.name || `${doc.firstName || ""} ${doc.lastName || ""}`.trim(),
            title: doc.title || "TMS Provider",
            school: doc.school || "",
            yearsExperience: doc.yearsExperience || 0,
            specialties: doc.specialties || [],
            bioFocus: "",
            bio: doc.bio || "",
            imageUrl: doc.imageUrl || "/images/doctor-placeholder.jpg",
            clinicName,
            clinicSlug,
            clinicCity,
            clinicState,
            clinicImage: "",
        });
    }
});

const doctors = Array.from(doctorMap.values());

// Group by state
const stateGroups = doctors.reduce(
    (acc, doc) => {
        const state = doc.clinicState;
        if (!acc[state]) acc[state] = [];
        acc[state].push(doc);
        return acc;
    },
    {} as Record<string, Doctor[]>,
);

// Sort states by doctor count
const sortedStates = Object.entries(stateGroups).sort(
    (a, b) => b[1].length - a[1].length,
);

// Get all unique specialties for filters
const allSpecialties = [
    ...new Set(doctors.flatMap((d) => d.specialties)),
].sort();

// Experience ranges
const experienceRanges = [
    { label: "5+ years", min: 5, max: 100 },
    { label: "10+ years", min: 10, max: 100 },
    { label: "15+ years", min: 15, max: 100 },
    { label: "20+ years", min: 20, max: 100 },
];

const stateNames: Record<string, string> = {
    DC: "Washington DC",
    CA: "California",
    FL: "Florida",
    IL: "Illinois",
    NY: "New York",
    TX: "Texas",
    WA: "Washington",
    AZ: "Arizona",
    CO: "Colorado",
    GA: "Georgia",
    PA: "Pennsylvania",
    OH: "Ohio",
    MI: "Michigan",
    CT: "Connecticut",
    NJ: "New Jersey",
    AL: "Alabama",
    AK: "Alaska",
    AR: "Arkansas",
    DE: "Delaware",
    HI: "Hawaii",
    ID: "Idaho",
    IN: "Indiana",
    IA: "Iowa",
    KS: "Kansas",
    KY: "Kentucky",
    LA: "Louisiana",
    ME: "Maine",
    MD: "Maryland",
    MA: "Massachusetts",
    MN: "Minnesota",
    MS: "Mississippi",
    MO: "Missouri",
    MT: "Montana",
    NE: "Nebraska",
    NV: "Nevada",
    NH: "New Hampshire",
    NM: "New Mexico",
    NC: "North Carolina",
    ND: "North Dakota",
    OK: "Oklahoma",
    OR: "Oregon",
    RI: "Rhode Island",
    SC: "South Carolina",
    SD: "South Dakota",
    TN: "Tennessee",
    UT: "Utah",
    VT: "Vermont",
    VA: "Virginia",
    WV: "West Virginia",
    WI: "Wisconsin",
    WY: "Wyoming",
};

const title = `Find TMS Specialists | ${doctors.length} Verified Providers`;
const description = `Browse ${doctors.length} verified TMS therapy specialists across ${Object.keys(stateGroups).length} states. Find experienced doctors specializing in depression, anxiety, OCD, and more.`;

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "TMS Specialists Directory",
    description:
        "Find board-certified TMS psychiatrists and specialists near you.",
    url: "https://tmslist.com/specialists/",
    mainEntity: {
        "@type": "ItemList",
        itemListElement: doctors.slice(0, 20).map((doc, index) => ({
            "@type": "ListItem",
            position: index + 1,
            item: {
                "@type": "Physician",
                name: doc.fullName,
                image: doc.imageUrl.startsWith("/")
                    ? `https://tmslist.com${doc.imageUrl}`
                    : doc.imageUrl,
                url: `https://tmslist.com/specialist/${doc.slug}/`,
            },
        })),
    },
});
---

<Layout title={title} description={description} schema={schema} canonical="https://tmslist.com/specialists/" breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Specialists", url: "/specialists/" },
]}>
    <main style="background:var(--paper)">
        <EditorialHero
            eyebrow="Board Certified Providers"
            eyebrowDot="#22c55e"
            title="Find your TMS"
            titleAccent="specialist."
            description={`Browse ${doctors.length} verified TMS therapy specialists across ${Object.keys(stateGroups).length} states. Doctors specializing in depression, anxiety, OCD, and more.`}
            breadcrumbs={[{ label: "Home", href: "/" }, { label: "Find a Specialist" }]}
            ctas={[
                { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
                { label: "Find a TMS Clinic", href: visitorCountryUrl, variant: "outline" },
            ]}
            stats={[
                { value: doctors.length, label: "Specialists", color: "ink" },
                { value: Object.keys(stateGroups).length, label: "States", color: "accent" },
                { value: `${allSpecialties.length}+`, label: "Conditions", color: "warm" },
            ]}
        />

        <!-- Filter Bar for Mobile -->
        <div class="lg:hidden bg-[var(--paper)] border-b sticky top-0 z-30 py-3 px-4">
            <button
                id="mobileFilterBtn"
                class="w-full flex items-center justify-center gap-2 py-3 px-6 bg-[var(--accent)] text-[var(--ink)] font-semibold rounded-xl"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"
                    ></path>
                </svg>
                Filters
            </button>
        </div>

        <!-- Main Content with Sidebar -->
        <section class="py-8 md:py-12">
            <div class="container mx-auto px-4 md:px-6">
                <div class="flex flex-col lg:flex-row gap-8">
                    <!-- Filter Sidebar -->
                    <aside
                        id="filterSidebar"
                        class="hidden lg:block lg:w-80 shrink-0"
                    >
                        <div
                            class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] shadow-sm sticky top-24 max-h-[calc(100vh-120px)] overflow-y-auto"
                        >
                            <div class="p-6 border-b border-[var(--line)]">
                                <div class="flex items-center justify-between">
                                    <h3 class="text-lg font-semibold text-[var(--ink)]">
                                        Filters
                                    </h3>
                                    <button
                                        id="clearFilters"
                                        class="text-sm text-[var(--accent)] hover:text-[var(--accent)] font-medium"
                                        >Clear All</button
                                    >
                                </div>
                                <p class="text-sm text-[var(--muted)] mt-1">
                                    Showing <span id="filteredCount"
                                        >{doctors.length}</span
                                    > specialists
                                </p>
                            </div>

                            <!-- Search -->
                            <div class="p-4 border-b border-[var(--line)]">
                                <label
                                    class="block text-sm font-semibold text-[var(--ink)] mb-2"
                                    >Search by Name</label
                                >
                                <input
                                    type="text"
                                    id="searchInput"
                                    placeholder="Enter doctor name..."
                                    class="w-full rounded-xl border-[var(--line)] text-sm focus:ring-[rgba(10,22,40,0.15)] focus:border-[rgba(10,22,40,0.2)] px-4 py-2"
                                />
                            </div>

                            <!-- State Filter -->
                            <div class="p-4 border-b border-[var(--line)]">
                                <label
                                    class="block text-sm font-semibold text-[var(--ink)] mb-2"
                                    >Filter by State</label
                                >
                                <select
                                    id="stateFilter"
                                    class="w-full rounded-xl border-[var(--line)] text-sm focus:ring-[rgba(10,22,40,0.15)] focus:border-[rgba(10,22,40,0.2)]"
                                >
                                    <option value="">All States</option>
                                    {
                                        sortedStates.map(([code, list]) => (
                                            <option value={code}>
                                                {stateNames[code] || code} (
                                                {list.length})
                                            </option>
                                        ))
                                    }
                                </select>
                            </div>

                            <!-- Specialty Section -->
                            <div class="border-b border-[var(--line)]">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="specialty"
                                >
                                    <span class="font-semibold text-[var(--ink)]"
                                        >Specialty</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-[var(--muted)] transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path>
                                    </svg>
                                </button>
                                <div
                                    id="section-specialty"
                                    class="hidden px-4 pb-4 space-y-1.5 max-h-60 overflow-y-auto"
                                >
                                    {
                                        allSpecialties
                                            .slice(0, 15)
                                            .map((spec) => (
                                                <label class="flex items-center gap-2 cursor-pointer hover:bg-[var(--paper2)] p-1.5 rounded-lg">
                                                    <input
                                                        type="checkbox"
                                                        class="filter-checkbox rounded border-[var(--line)] text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]"
                                                        data-filter="specialty"
                                                        data-value={spec.toLowerCase()}
                                                    />
                                                    <span class="text-sm text-[var(--ink2)]">
                                                        {spec}
                                                    </span>
                                                </label>
                                            ))
                                    }
                                </div>
                            </div>

                            <!-- Experience Section -->
                            <div class="border-b border-[var(--line)]">
                                <button
                                    class="filter-toggle w-full p-4 flex items-center justify-between text-left"
                                    data-section="experience"
                                >
                                    <span class="font-semibold text-[var(--ink)]"
                                        >Experience Level</span
                                    >
                                    <svg
                                        class="w-5 h-5 text-[var(--muted)] transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"></path>
                                    </svg>
                                </button>
                                <div
                                    id="section-experience"
                                    class="hidden px-4 pb-4 space-y-1.5"
                                >
                                    {
                                        experienceRanges.map((range) => (
                                            <label class="flex items-center gap-2 cursor-pointer hover:bg-[var(--paper2)] p-1.5 rounded-lg">
                                                <input
                                                    type="radio"
                                                    name="experience"
                                                    class="text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]"
                                                    data-filter="experience"
                                                    data-value={range.min}
                                                />
                                                <span class="text-sm text-[var(--ink2)]">
                                                    {range.label}
                                                </span>
                                            </label>
                                        ))
                                    }
                                </div>
                            </div>

                            <!-- Title Filter -->
                            <div class="p-4">
                                <label
                                    class="block text-sm font-semibold text-[var(--ink)] mb-2"
                                    >Provider Type</label
                                >
                                <div class="space-y-1.5">
                                    <label
                                        class="flex items-center gap-2 cursor-pointer hover:bg-[var(--paper2)] p-1.5 rounded-lg"
                                    >
                                        <input
                                            type="checkbox"
                                            class="filter-checkbox rounded border-[var(--line)] text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]"
                                            data-filter="title"
                                            data-value="psychiatrist"
                                        />
                                        <span class="text-sm text-[var(--ink2)]"
                                            >Psychiatrist</span
                                        >
                                    </label>
                                    <label
                                        class="flex items-center gap-2 cursor-pointer hover:bg-[var(--paper2)] p-1.5 rounded-lg"
                                    >
                                        <input
                                            type="checkbox"
                                            class="filter-checkbox rounded border-[var(--line)] text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]"
                                            data-filter="title"
                                            data-value="neurologist"
                                        />
                                        <span class="text-sm text-[var(--ink2)]"
                                            >Neurologist</span
                                        >
                                    </label>
                                    <label
                                        class="flex items-center gap-2 cursor-pointer hover:bg-[var(--paper2)] p-1.5 rounded-lg"
                                    >
                                        <input
                                            type="checkbox"
                                            class="filter-checkbox rounded border-[var(--line)] text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]"
                                            data-filter="title"
                                            data-value="director"
                                        />
                                        <span class="text-sm text-[var(--ink2)]"
                                            >Medical Director</span
                                        >
                                    </label>
                                </div>
                            </div>
                        </div>
                    </aside>

                    <!-- Doctors Grid -->
                    <div class="flex-1" id="doctorsContainer">
                        {
                            sortedStates.map(([stateCode, stateDoctors]) => (
                                <div
                                    class="mb-16 state-section"
                                    data-state={stateCode}
                                >
                                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-6 flex items-center gap-3">
                                        <span class="w-10 h-10 rounded-lg bg-[rgba(10,22,40,0.1)] text-[var(--accent)] flex items-center justify-center font-semibold text-sm">
                                            {stateCode}
                                        </span>
                                        {stateNames[stateCode] || stateCode}
                                        <span class="text-sm font-normal text-[var(--muted)] ml-2">
                                            ({stateDoctors.length}{" "}
                                            {stateDoctors.length === 1
                                                ? "specialist"
                                                : "specialists"}
                                            )
                                        </span>
                                    </h2>

                                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                                        {stateDoctors.map((doctor) => (
                                            <article
                                                class="doctor-card bg-[var(--paper)] rounded-2xl overflow-hidden border border-[var(--line)] shadow-sm hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all"
                                                data-name={doctor.fullName.toLowerCase()}
                                                data-state={doctor.clinicState}
                                                data-specialties={doctor.specialties
                                                    .join(",")
                                                    .toLowerCase()}
                                                data-experience={
                                                    doctor.yearsExperience
                                                }
                                                data-title={doctor.title.toLowerCase()}
                                            >
                                                {/* Clinic banner image */}
                                                {doctor.clinicImage && !doctor.clinicImage.includes('tms_chair') && (
                                                    <div class="h-24 overflow-hidden relative">
                                                        <img src={doctor.clinicImage} alt={`${doctor.clinicName}`} class="w-full h-full object-cover" loading="lazy" />
                                                        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-white/90"></div>
                                                    </div>
                                                )}
                                                <div class={`p-6 ${doctor.clinicImage && !doctor.clinicImage.includes('tms_chair') ? '-mt-6 relative z-10' : ''}`}>
                                                    <div class="flex items-start gap-4 mb-4">
                                                        <div class="w-20 h-20 rounded-full overflow-hidden shrink-0 border-2 border-white shadow-md bg-[var(--paper2)]">
                                                                <img
                                                                    src={getDoctorPhoto({ name: doctor.fullName, image_url: doctor.imageUrl, slug: doctor.slug })}
                                                                    alt={`${doctor.fullName} - TMS specialist in ${doctor.clinicCity}`}
                                                                    class="w-full h-full object-cover"
                                                                    loading="lazy"
                                                                    width="80"
                                                                    height="80"
                                                                />
                                                        </div>
                                                        <div class="flex-1 min-w-0">
                                                            <h3 class="text-lg font-semibold text-[var(--ink)] truncate">
                                                                {doctor.fullName}
                                                            </h3>
                                                            <p class="text-[var(--accent)] text-sm font-medium">
                                                                {doctor.title}
                                                            </p>
                                                            <p class="text-[var(--muted)] text-sm">
                                                                {doctor.clinicCity}, {doctor.clinicState}
                                                            </p>
                                                        </div>
                                                    </div>

                                                    <div class="flex flex-wrap items-center gap-2 mb-3">
                                                        <span class="px-2.5 py-0.5 bg-[rgba(10,22,40,0.1)] text-[var(--accent)] text-xs font-semibold rounded-full">
                                                            Verified
                                                        </span>
                                                        {doctor.yearsExperience > 0 && (
                                                            <span class="text-xs text-[var(--muted)]">
                                                                {doctor.yearsExperience}+ years
                                                            </span>
                                                        )}
                                                        {doctor.school && (
                                                            <span class="text-xs text-[var(--muted)] truncate max-w-[140px]" title={doctor.school}>
                                                                {doctor.school}
                                                            </span>
                                                        )}
                                                    </div>

                                                    {/* Bio snippet */}
                                                    {doctor.bio && (
                                                        <p class="text-[var(--muted)] text-sm mb-3 line-clamp-2">{doctor.bio}</p>
                                                    )}

                                                    <div class="flex flex-wrap gap-1.5 mb-4">
                                                        {doctor.specialties
                                                            .slice(0, 3)
                                                            .map((spec: string) => (
                                                                <span class="px-2 py-1 bg-[rgba(10,22,40,0.08)] text-[var(--accent)] text-xs font-medium rounded">
                                                                    {spec}
                                                                </span>
                                                            ))}
                                                        {doctor.specialties.length > 3 && (
                                                            <span class="px-2 py-1 bg-[var(--paper2)] text-[var(--muted)] text-xs font-medium rounded">
                                                                +{doctor.specialties.length - 3} more
                                                            </span>
                                                        )}
                                                    </div>

                                                    <div class="pt-4 border-t border-[var(--line)] flex flex-col gap-2">
                                                        {/* Clinic info row */}
                                                        <div class="flex items-center justify-between">
                                                            <a
                                                                href={`/clinic/${doctor.clinicSlug}/`}
                                                                class="text-sm text-[var(--muted)] hover:text-[var(--accent)] truncate max-w-[55%]"
                                                            >
                                                                at {doctor.clinicName}
                                                            </a>
                                                            {doctor.clinicPhone && (
                                                                <a
                                                                    href={`tel:${doctor.clinicPhone.replace(/\D/g,'')}`}
                                                                    class="inline-flex items-center gap-1 text-sm text-[var(--accent)] font-medium hover:underline"
                                                                >
                                                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                                                    {doctor.clinicPhone}
                                                                </a>
                                                            )}
                                                        </div>
                                                        {/* Action buttons row */}
                                                        <div class="flex gap-2">
                                                            <a
                                                                href={`/specialist/${doctor.slug}/`}
                                                                class="flex-1 text-center px-3 py-2 text-[var(--ink2)] font-semibold text-sm rounded-lg transition-all border"
                                                                style="background:var(--paper2); border-color:var(--line);"
                                                            >
                                                                View Profile
                                                            </a>
                                                            <button
                                                                data-request-callback
                                                                data-clinic-name={doctor.clinicName}
                                                                data-clinic-id={doctor.clinicSlug}
                                                                class="px-3 py-2 text-white font-semibold text-sm rounded-lg transition-all"
                                                                style="background:var(--warm);"
                                                                aria-label="Request Callback"
                                                            >
                                                                Request Callback
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </article>
                                        ))}
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </section>

        <!-- SEO Content Section -->
        <section class="py-16 bg-[var(--paper)] border-t border-[var(--line)]">
            <div class="container mx-auto px-6 max-w-4xl">
                <h2 class="text-3xl font-semibold text-[var(--ink)] mb-8">Finding the Right TMS Specialist</h2>
                <div class="prose prose-lg max-w-none text-[var(--muted)]">
                    <p>Our directory features {doctors.length} board-certified TMS specialists across {Object.keys(stateGroups).length} states. Each provider has been verified and brings specialized expertise in Transcranial Magnetic Stimulation therapy for conditions including depression, anxiety, OCD, PTSD, and more.</p>
                    <h3>What Makes a Great TMS Specialist?</h3>
                    <p>The best TMS specialists combine psychiatric expertise with hands-on neuromodulation experience. Look for providers who have treated hundreds of patients, use FDA-cleared TMS technology, and take a personalized approach to treatment planning. Many of our listed specialists have completed advanced training at institutions like Stanford, UCLA, Johns Hopkins, and Columbia.</p>
                    <h3>Explore More</h3>
                    <ul>
                        <li><a href="/treatments/">Conditions Treated with TMS</a> — depression, anxiety, OCD, PTSD and more</li>
                        <li><a href="/technology/">Compare TMS Devices</a> — NeuroStar, BrainsWay, MagVenture</li>
                        <li><a href="/insurance/">Insurance Coverage Guides</a> — plan-specific details</li>
                        <li><a href="/quiz/am-i-a-candidate/">Am I a Candidate?</a> — take the 2-minute eligibility quiz</li>
                        <li><a href="/blog/tms-cost-insurance-guide-2026/">TMS Cost &amp; Insurance Guide</a> — coverage, out-of-pocket costs, and appeals</li>
                        <li><a href="/blog/questions-to-ask-tms-clinic/">Questions to Ask Your TMS Clinic</a> — 18 essential questions before you book</li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="py-12 bg-[var(--paper2)] border-t border-[var(--line)]">
            <div class="container mx-auto px-4 md:px-6 text-center">
                <p class="text-[var(--muted)] text-sm max-w-2xl mx-auto">
                    Are you a TMS specialist? <a
                        href="/add-listing/"
                        class="text-[var(--accent)] font-medium">Add your profile</a
                    >
                    to our directory and connect with patients seeking TMS therapy.
                </p>
            </div>
        </section>

        <!-- Learn More Links -->
        <section class="py-10 bg-[var(--paper)] border-t border-[var(--line)]">
            <div class="container mx-auto px-4 md:px-6">
                <div class="flex flex-wrap justify-center gap-3 max-w-4xl mx-auto">
                    <a href="/blog/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">TMS Research Blog</a>
                    <a href="/blog/tms-for-depression/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">TMS for Depression</a>
                    <a href="/blog/tms-for-veterans-ptsd-military/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">TMS for PTSD</a>
                    <a href="/blog/preparing-for-first-tms-session/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Preparing for First Session</a>
                    <a href="/blog/maintenance-tms-guide/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Maintenance TMS</a>
                    <a href="/blog/how-to-find-tms-clinic-guide/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">How to Find a Clinic</a>
                </div>
            </div>
        </section>
    </main>

    <!-- Filter JavaScript -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const searchInput = document.getElementById(
                "searchInput",
            ) as HTMLInputElement;
            const stateFilter = document.getElementById(
                "stateFilter",
            ) as HTMLSelectElement;
            const checkboxes = document.querySelectorAll(".filter-checkbox");
            const radioButtons = document.querySelectorAll(
                'input[type="radio"][data-filter]',
            );
            const clearBtn = document.getElementById("clearFilters");
            const filteredCount = document.getElementById("filteredCount");
            const doctorCards = document.querySelectorAll(".doctor-card");
            const stateSections = document.querySelectorAll(".state-section");

            // Toggle filter sections
            document.querySelectorAll(".filter-toggle").forEach((btn) => {
                btn.addEventListener("click", () => {
                    const section = btn.getAttribute("data-section");
                    const content = document.getElementById(
                        `section-${section}`,
                    );
                    const arrow = btn.querySelector("svg");
                    if (content) {
                        content.classList.toggle("hidden");
                        arrow?.classList.toggle("rotate-180");
                    }
                });
            });

            // Mobile filter toggle
            const mobileBtn = document.getElementById("mobileFilterBtn");
            const sidebar = document.getElementById("filterSidebar");
            if (mobileBtn && sidebar) {
                mobileBtn.addEventListener("click", () => {
                    sidebar.classList.toggle("hidden");
                    sidebar.classList.toggle("fixed");
                    sidebar.classList.toggle("inset-0");
                    sidebar.classList.toggle("z-50");
                    sidebar.classList.toggle("bg-[var(--paper)]");
                    sidebar.classList.toggle("overflow-y-auto");
                    sidebar.classList.toggle("p-4");
                });
            }

            function applyFilters() {
                const searchTerm = searchInput?.value.toLowerCase() || "";
                const selectedState = stateFilter?.value || "";
                const selectedSpecialties: string[] = [];
                const selectedTitles: string[] = [];
                let minExperience = 0;

                checkboxes.forEach((cb) => {
                    const checkbox = cb as HTMLInputElement;
                    if (checkbox.checked) {
                        const filter = checkbox.dataset.filter;
                        const value = checkbox.dataset.value || "";
                        if (filter === "specialty")
                            selectedSpecialties.push(value);
                        if (filter === "title") selectedTitles.push(value);
                    }
                });

                radioButtons.forEach((rb) => {
                    const radio = rb as HTMLInputElement;
                    if (
                        radio.checked &&
                        radio.dataset.filter === "experience"
                    ) {
                        minExperience = parseInt(radio.dataset.value || "0");
                    }
                });

                let visibleCount = 0;

                doctorCards.forEach((card) => {
                    const el = card as HTMLElement;
                    const name = el.dataset.name || "";
                    const state = el.dataset.state || "";
                    const specialties = el.dataset.specialties || "";
                    const experience = parseInt(el.dataset.experience || "0");
                    const title = el.dataset.title || "";

                    let visible = true;

                    // Search filter
                    if (searchTerm && !name.includes(searchTerm))
                        visible = false;

                    // State filter
                    if (selectedState && state !== selectedState)
                        visible = false;

                    // Specialty filter
                    if (selectedSpecialties.length > 0) {
                        const hasSpecialty = selectedSpecialties.some((s) =>
                            specialties.includes(s),
                        );
                        if (!hasSpecialty) visible = false;
                    }

                    // Title filter
                    if (selectedTitles.length > 0) {
                        const hasTitle = selectedTitles.some((t) =>
                            title.includes(t),
                        );
                        if (!hasTitle) visible = false;
                    }

                    // Experience filter
                    if (minExperience > 0 && experience < minExperience)
                        visible = false;

                    el.style.display = visible ? "" : "none";
                    if (visible) visibleCount++;
                });

                // Hide empty state sections
                stateSections.forEach((section) => {
                    const sectionEl = section as HTMLElement;
                    const visibleCards = sectionEl.querySelectorAll(
                        '.doctor-card:not([style*="display: none"])',
                    );
                    sectionEl.style.display =
                        visibleCards.length > 0 ? "" : "none";
                });

                if (filteredCount)
                    filteredCount.textContent = visibleCount.toString();
            }

            // Event listeners
            searchInput?.addEventListener("input", applyFilters);
            stateFilter?.addEventListener("change", applyFilters);
            checkboxes.forEach((cb) =>
                cb.addEventListener("change", applyFilters),
            );
            radioButtons.forEach((rb) =>
                rb.addEventListener("change", applyFilters),
            );

            // Clear filters
            clearBtn?.addEventListener("click", () => {
                if (searchInput) searchInput.value = "";
                if (stateFilter) stateFilter.value = "";
                checkboxes.forEach(
                    (cb) => ((cb as HTMLInputElement).checked = false),
                );
                radioButtons.forEach(
                    (rb) => ((rb as HTMLInputElement).checked = false),
                );
                applyFilters();
            });
        });
    </script>
</Layout>
