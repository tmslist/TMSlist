---
import Layout from '../layouts/Layout.astro';
import TMSViewerLazy from '../components/react/TMSViewerLazy';
---

<Layout title="TMS Simulation | Interactive Brain Stimulation Visualizer" description="Explore an interactive 3D visualization of transcranial magnetic stimulation (TMS). See how electromagnetic fields target specific brain regions for depression, anxiety, and more.">

    <!-- Hero -->
    <section class="relative bg-slate-950 overflow-hidden min-h-[60vh] flex items-center border-b border-indigo-500/20">
        <!-- Deep Space Animated Background -->
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900/40 via-slate-950 to-slate-950"></div>
        <div class="absolute top-0 left-0 right-0 h-[500px] bg-gradient-to-b from-fuchsia-600/10 via-cyan-500/5 to-transparent blur-[100px] pointer-events-none"></div>
        <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02),rgba(255,255,255,0.02)),url('/grid.svg')] opacity-40 bg-[length:30px_30px] [mask-image:linear-gradient(to_bottom,white,transparent)] animate-[pulse_4s_ease-in-out_infinite_alternate]"></div>
        <div class="absolute bottom-0 right-0 w-[600px] h-[600px] bg-cyan-600/20 rounded-full blur-[150px] pointer-events-none"></div>
        <div class="absolute top-1/2 left-1/4 w-[400px] h-[400px] bg-violet-600/30 rounded-full blur-[120px] pointer-events-none"></div>

        <div class="container mx-auto px-6 pt-28 pb-20 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-[1.2fr_400px] gap-12 items-center max-w-6xl mx-auto">
                <!-- Left: Headline + CTA -->
                <div>
                    <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-gradient-to-r from-violet-500/20 to-fuchsia-500/20 border border-violet-400/30 rounded-full mb-8 shadow-[0_0_20px_rgba(139,92,246,0.3)] backdrop-blur-md">
                        <div class="relative w-2 h-2">
                           <div class="absolute inset-0 rounded-full bg-cyan-400 animate-ping opacity-75"></div>
                           <div class="relative rounded-full w-2 h-2 bg-cyan-300"></div>
                        </div>
                        <span class="text-[11px] font-bold text-violet-100 tracking-widest uppercase glow-text">Interactive Simulation</span>
                    </div>
                    <h1 class="text-5xl lg:text-7xl font-black tracking-tight text-white mb-6 leading-[1.05] drop-shadow-xl">
                        See How <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-violet-400 to-fuchsia-400 animate-gradient-xy">TMS</span><br class="hidden sm:block" />
                        Targets the Brain
                    </h1>
                    <p class="text-xl text-indigo-100/80 font-light leading-relaxed mb-10 max-w-xl drop-shadow-md">
                        Transcranial magnetic stimulation uses focused electromagnetic fields to stimulate specific cortical regions. Explore the science in real time.
                    </p>

                    <!-- Quick stats -->
                    <div class="flex flex-wrap gap-4 mb-10">
                        {[
                            { value: '36', label: 'Sessions typical', color: 'cyan', shadow: 'shadow-cyan-500/20' },
                            { value: '5–9', label: 'Weeks to complete', color: 'violet', shadow: 'shadow-violet-500/20' },
                            { value: '2008', label: 'FDA-cleared', color: 'emerald', shadow: 'shadow-emerald-500/20' },
                        ].map((stat) => (
                            <div class={`bg-slate-900/60 backdrop-blur-md border border-${stat.color}-500/30 rounded-2xl px-5 py-3 shadow-[0_4px_20px_rgba(0,0,0,0.2)] hover:scale-105 hover:bg-slate-800/80 hover:border-${stat.color}-400/50 hover:${stat.shadow} hover:shadow-lg transition-all duration-300 cursor-default group`}>
                                <div class={`text-2xl font-black font-mono text-${stat.color}-400 group-hover:text-${stat.color}-300 transition-colors drop-shadow-md`}>{stat.value}</div>
                                <div class="text-[11px] text-slate-400 font-medium uppercase tracking-wider mt-1">{stat.label}</div>
                            </div>
                        ))}
                    </div>

                    <!-- CTA -->
                    <div class="flex flex-wrap items-center gap-4">
                        <a
                            href="#simulation"
                            class="group relative inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-cyan-500 to-violet-600 text-white font-bold rounded-2xl overflow-hidden transition-all hover:scale-[1.02] hover:shadow-[0_0_40px_rgba(139,92,246,0.6)]"
                        >
                            <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-in-out"></div>
                            <svg class="w-6 h-6 relative z-10" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M8 5v14l11-7z"/>
                            </svg>
                            <span class="relative z-10 text-lg uppercase tracking-wide">Launch Simulation</span>
                        </a>
                        <a
                            href="#how-it-works"
                            class="inline-flex items-center gap-2 px-6 py-4 bg-slate-900/50 backdrop-blur border border-slate-700/80 hover:border-slate-500 text-slate-300 hover:text-white hover:bg-slate-800 font-semibold rounded-2xl transition-all shadow-xl hover:shadow-2xl"
                        >
                            How TMS Works
                        </a>
                    </div>
                </div>

                <!-- Right: Brain preview -->
                <div class="hidden lg:block relative">
                    <div class="relative rounded-3xl overflow-hidden border border-indigo-500/20 shadow-[0_0_50px_-12px_rgba(139,92,246,0.25)] bg-slate-900/40 backdrop-blur-md" style="height: 340px;">
                        <!-- Tech Grid Background -->
                        <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.03),rgba(255,255,255,0.03)),url('/grid.svg')] opacity-50 bg-[length:20px_20px]"></div>
                        
                        <!-- Radar Sweep -->
                        <div class="absolute inset-0 opacity-20 bg-[conic-gradient(from_0deg,transparent_0deg,rgba(34,211,238,0.4)_360deg)] animate-[spin_4s_linear_infinite] rounded-full scale-[1.5]"></div>
                        
                        <div class="absolute inset-0 flex items-center justify-center" style="transform: perspective(600px) rotateX(15deg) rotateY(-15deg);">
                            <div class="relative w-48 h-40">
                                <!-- Brain Outer Halo -->
                                <div class="absolute inset-0 rounded-[4rem] border-2 border-indigo-500/30 bg-indigo-900/20 shadow-[0_0_40px_rgba(139,92,246,0.2)] flex items-center justify-center overflow-hidden">
                                    <!-- Scanning Lines -->
                                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-cyan-400/20 to-transparent w-full h-[20%] animate-[slideDown_3s_ease-in-out_infinite_alternate]"></div>
                                    <!-- Inner Brain Core -->
                                    <div class="w-36 h-28 rounded-[3rem] border border-fuchsia-500/30 bg-gradient-to-br from-indigo-500/20 to-fuchsia-500/10 backdrop-blur shadow-[inset_0_0_20px_rgba(139,92,246,0.3)]">
                                        <!-- Active Target Region -->
                                        <div class="absolute top-[25%] left-[20%] w-10 h-10 rounded-full bg-cyan-400/20 mix-blend-screen shadow-[0_0_20px_rgba(34,211,238,0.6)] animate-pulse border border-cyan-300/40"></div>
                                        <!-- Nodes -->
                                        <svg class="absolute inset-0 w-full h-full stroke-indigo-400/30" fill="none" stroke-width="1.5">
                                            <path d="M40 30 Q 70 20 100 50 T 130 80" />
                                            <circle cx="40" cy="30" r="3" fill="#818cf8"/>
                                            <circle cx="100" cy="50" r="2" fill="#818cf8"/>
                                            <circle cx="130" cy="80" r="4" fill="#a78bfa" class="animate-pulse"/>
                                        </svg>
                                    </div>
                                </div>
                                
                                <!-- Coil Prop -->
                                <div class="absolute -top-12 left-1/2 -translate-x-1/2 flex flex-col items-center drop-shadow-[0_10px_10px_rgba(0,0,0,0.5)]">
                                    <div class="w-8 h-10 bg-slate-700/90 rounded-t border-t border-slate-500/50 mb-0.5 relative z-10 flex flex-col justify-end pb-1 items-center gap-1">
                                        <div class="w-4 h-[2px] bg-cyan-400"></div>
                                        <div class="w-4 h-[2px] bg-amber-400"></div>
                                    </div>
                                    <div class="flex gap-[4px] relative -mt-2">
                                        <!-- Pulse Rings -->
                                        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-24 h-24 border border-cyan-400/50 rounded-full animate-[ping_2s_cubic-bezier(0,0,0.2,1)_infinite]"></div>
                                        <!-- Coil Rings -->
                                        <div class="w-12 h-12 rounded-full border-4 border-slate-800 bg-gradient-to-br from-cyan-500 to-indigo-500 shadow-[0_0_20px_rgba(34,211,238,0.5)] flex items-center justify-center">
                                            <div class="w-6 h-6 rounded-full border-2 border-slate-900 bg-cyan-400/20"></div>
                                        </div>
                                        <div class="w-12 h-12 rounded-full border-4 border-slate-800 bg-gradient-to-br from-fuchsia-500 to-violet-500 shadow-[0_0_20px_rgba(167,139,250,0.5)] flex items-center justify-center">
                                            <div class="w-6 h-6 rounded-full border-2 border-slate-900 bg-violet-400/20"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Overlay UI HUD -->
                        <div class="absolute top-4 left-4 bg-slate-900/80 backdrop-blur-md border border-indigo-500/30 rounded-lg px-3 py-2 flex items-center gap-3">
                            <div class="relative flex h-3 w-3">
                              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
                              <span class="relative inline-flex rounded-full h-3 w-3 bg-cyan-500"></span>
                            </div>
                            <div>
                                <div class="text-[9px] text-slate-400 uppercase tracking-widest leading-none mb-1">Status</div>
                                <div class="text-[11px] font-bold text-white leading-none">Simulation Active</div>
                            </div>
                        </div>
                        
                        <div class="absolute bottom-4 left-4 bg-slate-900/80 backdrop-blur-md border border-slate-700/50 rounded-lg px-3 py-2">
                            <div class="text-[10px] text-slate-400 uppercase tracking-wider mb-1">Target Cortex</div>
                            <div class="flex items-center gap-2">
                                <span class="text-cyan-400 font-mono text-xs font-bold">L-DLPFC</span>
                                <span class="text-amber-400 text-[10px]">120% MT</span>
                            </div>
                        </div>

                        <div class="absolute bottom-4 right-4 bg-slate-900/80 backdrop-blur-md border border-slate-700/50 rounded-lg px-3 py-2">
                            <div class="flex justify-end gap-1 mb-1">
                                {[1, 2, 3, 4, 5].map((i) => (
                                    <div class={`w-1 h-3 rounded-sm ${i <= 3 ? 'bg-cyan-400' : 'bg-slate-700'}`}></div>
                                ))}
                            </div>
                            <div class="text-[10px] text-slate-400 uppercase tracking-wider text-right">E-Field Str</div>
                        </div>
                        
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Simulation Main -->
    <section id="simulation" class="bg-slate-950 pb-32 relative">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,_var(--tw-gradient-stops))] from-indigo-900/20 via-slate-950 to-slate-950 pointer-events-none"></div>
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <!-- Toolbar -->
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-3">
                    <div class="relative w-2.5 h-2.5">
                        <div class="absolute inset-0 rounded-full bg-cyan-400 animate-pulse opacity-80 blur-[2px]"></div>
                        <div class="absolute inset-0 rounded-full bg-cyan-300"></div>
                    </div>
                    <span class="text-sm font-bold text-slate-200 tracking-wide">Interactive Simulator</span>
                </div>
                <div class="flex items-center gap-3">
                    <button
                        id="share-btn"
                        class="flex items-center gap-1.5 px-4 py-2 bg-slate-800/80 backdrop-blur border border-slate-700/80 hover:border-cyan-500/50 hover:bg-slate-800 hover:shadow-[0_0_15px_rgba(34,211,238,0.2)] rounded-xl text-xs font-semibold text-slate-300 hover:text-white transition-all shadow-md group"
                        title="Copy share link"
                    >
                        <svg class="w-4 h-4 text-slate-400 group-hover:text-cyan-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                        </svg>
                        Share
                    </button>
                    <a
                        href="#how-it-works"
                        class="flex items-center gap-1.5 px-4 py-2 bg-slate-800/80 backdrop-blur border border-slate-700/80 hover:border-violet-500/50 hover:bg-slate-800 hover:shadow-[0_0_15px_rgba(139,92,246,0.2)] rounded-xl text-xs font-semibold text-slate-300 hover:text-white transition-all shadow-md group"
                    >
                        <svg class="w-4 h-4 text-slate-400 group-hover:text-violet-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        Help
                    </a>
                </div>
            </div>

            <!-- Gradient border container -->
            <div class="relative rounded-[2rem] p-[1px] bg-gradient-to-b from-indigo-500/30 via-slate-800 to-slate-900 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.5)]">
                <div class="relative bg-slate-900/90 backdrop-blur-2xl rounded-[2rem] p-4 md:p-6 border border-slate-800/50">
                    <TMSViewerLazy client:only="react" />
                </div>
            </div>
        </div>
    </section>

    <!-- How TMS Works -->
    <section id="how-it-works" class="bg-gradient-to-br from-indigo-50/50 via-white to-cyan-50/50 py-24 relative overflow-hidden">
        <!-- Decorative subtle background elements -->
        <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.8),rgba(255,255,255,0.8)),url('/grid.svg')] opacity-40"></div>
        
        <div class="container mx-auto px-6 max-w-5xl relative z-10">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-5xl font-semibold tracking-tight text-slate-900 mb-4">How TMS Works</h2>
                <p class="text-xl text-slate-500 max-w-2xl mx-auto font-light leading-relaxed">
                    A clear, step-by-step explanation of the biological and physical processes that happen during a single session.
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative">
                <!-- Connecting Line (Desktop) -->
                <div class="hidden md:block absolute top-[45px] left-[15%] right-[15%] h-[2px] bg-gradient-to-r from-violet-200 via-cyan-200 to-emerald-200 z-0"></div>

                <div class="bg-white p-8 rounded-3xl border border-slate-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)] relative z-10 hover:-translate-y-1 hover:shadow-[0_12px_40px_rgb(0,0,0,0.06)] transition-all duration-300">
                    <div class="w-16 h-16 mx-auto bg-gradient-to-br from-violet-100 to-violet-50 rounded-2xl flex items-center justify-center text-violet-600 mb-6 shadow-sm border border-violet-100/50">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                    </div>
                    <div class="text-center">
                        <div class="text-xs font-bold text-violet-500 uppercase tracking-widest mb-3">Step 1</div>
                        <h3 class="text-xl font-semibold text-slate-900 mb-3 tracking-tight">Precision Targeting</h3>
                        <p class="text-[15px] text-slate-500 leading-relaxed font-light">
                            A specialized electromagnetic coil is precisely positioned over the targeted brain region, such as the left dorsolateral prefrontal cortex (DLPFC).
                        </p>
                    </div>
                </div>

                <div class="bg-white p-8 rounded-3xl border border-slate-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)] relative z-10 hover:-translate-y-1 hover:shadow-[0_12px_40px_rgb(0,0,0,0.06)] transition-all duration-300">
                    <div class="w-16 h-16 mx-auto bg-gradient-to-br from-cyan-100 to-cyan-50 rounded-2xl flex items-center justify-center text-cyan-600 mb-6 shadow-sm border border-cyan-100/50">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    </div>
                    <div class="text-center">
                        <div class="text-xs font-bold text-cyan-500 uppercase tracking-widest mb-3">Step 2</div>
                        <h3 class="text-xl font-semibold text-slate-900 mb-3 tracking-tight">Magnetic Pulses</h3>
                        <p class="text-[15px] text-slate-500 leading-relaxed font-light">
                            Rapidly alternating current in the coil generates a highly focused magnetic field (up to 3 Tesla) that painlessly passes through the skull.
                        </p>
                    </div>
                </div>

                <div class="bg-white p-8 rounded-3xl border border-slate-100 shadow-[0_8px_30px_rgb(0,0,0,0.04)] relative z-10 hover:-translate-y-1 hover:shadow-[0_12px_40px_rgb(0,0,0,0.06)] transition-all duration-300">
                    <div class="w-16 h-16 mx-auto bg-gradient-to-br from-emerald-100 to-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600 mb-6 shadow-sm border border-emerald-100/50">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    </div>
                    <div class="text-center">
                        <div class="text-xs font-bold text-emerald-500 uppercase tracking-widest mb-3">Step 3</div>
                        <h3 class="text-xl font-semibold text-slate-900 mb-3 tracking-tight">Neural Activation</h3>
                        <p class="text-[15px] text-slate-500 leading-relaxed font-light">
                            The changing magnetic field induces a localized electric current in cortical neurons, triggering depolarization and releasing neurotransmitters.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Treatment Targets by Condition -->
    <section class="py-24 bg-white border-y border-slate-100 relative overflow-hidden">
        <div class="container mx-auto px-6 max-w-6xl relative z-10">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-5xl font-semibold tracking-tight text-slate-900 mb-4">Treatment Targets</h2>
                <p class="text-xl text-slate-500 max-w-2xl mx-auto font-light leading-relaxed">
                    Protocols adapt specific frequencies and targets based on the condition being treated.
                </p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {[
                    { condition: 'Major Depressive Disorder', target: 'Left DLPFC', frequency: '10 Hz (high-frequency)', sessions: '36 over 9 weeks', badge: 'FDA Cleared 2008', color: 'violet' },
                    { condition: 'Anxiety & Depression', target: 'Right DLPFC', frequency: '1 Hz (low-frequency)', sessions: '30–36 sessions', badge: 'Off-label', color: 'cyan' },
                    { condition: 'OCD', target: 'mPFC / ACC', frequency: '20 Hz ITB', sessions: '29 over 6 weeks', badge: 'FDA Cleared 2018', color: 'amber' },
                    { condition: 'Smoking Cessation', target: 'Left Insula / DLPFC', frequency: '10 Hz', sessions: '13 over 3 weeks', badge: 'FDA Cleared 2020', color: 'emerald' },
                    { condition: 'Migraine', target: 'Motor Cortex', frequency: 'Single-pulse', sessions: 'Variable', badge: 'FDA Cleared', color: 'rose' },
                    { condition: 'PTSD', target: 'Right DLPFC / mPFC', frequency: '1 Hz low-frequency', sessions: '36 sessions', badge: 'Research Protocol', color: 'indigo' },
                ].map((item) => (
                    <div class="bg-slate-50 rounded-3xl border border-slate-100 p-8 hover:bg-white hover:border-slate-200 hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] transition-all duration-300 group">
                        <div class="flex items-start justify-between mb-5">
                            <h3 class="text-lg font-semibold text-slate-900 tracking-tight leading-tight group-hover:text-blue-600 transition-colors pr-4">{item.condition}</h3>
                            <span class={`shrink-0 text-[10px] font-bold px-2.5 py-1 rounded-full bg-${item.color}-100/80 text-${item.color}-700 uppercase tracking-wide border border-${item.color}-200/50`}>{item.badge}</span>
                        </div>
                        <div class="space-y-3">
                            <div class="flex items-center gap-3">
                                <div class="w-6 h-6 rounded-full bg-white shadow-sm flex items-center justify-center text-slate-400 shrink-0 border border-slate-100">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                                </div>
                                <span class="text-[14px] text-slate-500 font-light">Target: <span class="text-slate-800 font-medium">{item.target}</span></span>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-6 h-6 rounded-full bg-white shadow-sm flex items-center justify-center text-slate-400 shrink-0 border border-slate-100">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                </div>
                                <span class="text-[14px] text-slate-500 font-light">{item.frequency}</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-6 h-6 rounded-full bg-white shadow-sm flex items-center justify-center text-slate-400 shrink-0 border border-slate-100">
                                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                                </div>
                                <span class="text-[14px] text-slate-500 font-light">{item.sessions}</span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- E-Field Science -->
