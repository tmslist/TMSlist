<script>
// Frequency slider
const freqSlider = document.getElementById('freq-slider') as HTMLInputElement;
const freqDisplay = document.getElementById('freq-display');
freqSlider?.addEventListener('input', () => {
  if (freqDisplay) freqDisplay.textContent = `${freqSlider.value} Hz`;
});

// Intensity slider
const intensSlider = document.getElementById('intens-slider') as HTMLInputElement;
const intensDisplay = document.getElementById('intens-display');
intensSlider?.addEventListener('input', () => {
  if (intensDisplay) intensDisplay.textContent = `${intensSlider.value}% MT`;
});

// Protocol preset buttons
document.querySelectorAll('.protocol-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const freq = (btn as HTMLElement).dataset.freq;
    const intens = (btn as HTMLElement).dataset.intens;
    if (freq && freqSlider && freqDisplay) {
      freqSlider.value = freq;
      freqDisplay.textContent = `${freq} Hz`;
    }
    if (intens && intensSlider && intensDisplay) {
      intensSlider.value = intens;
      intensDisplay.textContent = `${intens}% MT`;
    }
    // Update active state
    document.querySelectorAll('.protocol-btn').forEach(b => {
      b.classList.remove('border-[color:var(--cyan)]', 'border-opacity-60');
      b.classList.add('bd');
      b.querySelector('span')?.classList.replace('bg-[color:var(--cyan)]', 'bg-white/20');
    });
    btn.classList.add('border-[color:var(--cyan)]', 'border-opacity-60');
    btn.classList.remove('bd');
  });
});

// Region buttons
document.querySelectorAll('.region-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.region-btn').forEach(b => {
      b.classList.remove('border-[color:var(--cyan)]', 'bg-[color:var(--cyan)]/5');
      b.classList.add('bd2');
      (b.querySelector('div') as HTMLElement)?.classList.remove('cyan');
    });
    btn.classList.add('border-[color:var(--cyan)]', 'bg-[color:var(--cyan)]/5');
    btn.classList.remove('bd2');
    (btn.querySelector('div') as HTMLElement)?.classList.add('cyan');
  });
});
</script>

</Layout>
