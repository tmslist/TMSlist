---
import Layout from '../layouts/Layout.astro';
import EditorialHero from '../components/editorial/EditorialHero.astro';
import EditorialSection from '../components/editorial/EditorialSection.astro';
import TMSViewerLazy from '../components/react/TMSViewerLazy';

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const pageSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "headline": "TMS Simulation",
  "description": "Interactive 3D visualization of how transcranial magnetic stimulation reaches the brain. See coil placement, magnetic fields, and target regions in real time.",
  "url": `${siteUrl}/simulation/`,
  "publisher": { "@type": "Organization", "name": "TMS List", "url": siteUrl },
});

const howToUse = [
  {
    n: 1,
    title: "Pick a target",
    desc: "Choose a brain region — like L-DLPFC for depression or OFC for OCD. The coil moves to the right spot above the scalp.",
  },
  {
    n: 2,
    title: "Adjust the pulse",
    desc: "Change frequency and intensity to see how the magnetic field shape, depth, and reach are affected in real time.",
  },
  {
    n: 3,
    title: "Watch it work",
    desc: "Run a session to see neurons fire, the field penetrate, and the connected network light up in 3D.",
  },
];

const mechanism = [
  {
    n: 1,
    stat: "1.5 kA · 100 μs",
    title: "Current enters the coil",
    desc: "A capacitor discharges roughly 1,500 amps through copper windings in under a tenth of a millisecond, producing a rapidly-changing magnetic field perpendicular to the scalp.",
  },
  {
    n: 2,
    stat: "1.5 T · 1–3 cm",
    title: "Field passes through skull",
    desc: "The field reaches about 1.5 tesla at the coil face — strong enough to pass through bone and dura. It peaks 1 to 3 cm below the scalp and falls off quickly with depth.",
  },
  {
    n: 3,
    stat: "~100 V/m · threshold",
    title: "Neurons depolarize",
    desc: "The induced electric field reaches roughly 100 V/m in the target cortex, bringing pyramidal neurons to firing threshold. A single pulse triggers action potentials across millions of cells.",
  },
];

const milestones = [
  { year: "2008", title: "First FDA clearance", desc: "NeuroStar approved for treatment-resistant major depressive disorder in adults." },
  { year: "2013", title: "Deep TMS", desc: "BrainsWay's H-coil reaches deeper structures than standard figure-of-eight designs." },
  { year: "2018", title: "iTBS · OCD", desc: "Theta-burst protocol (3 min) shown non-inferior to 37-min sessions. OCD indication added." },
  { year: "2020", title: "SAINT protocol", desc: "Accelerated iTBS achieves ~90% remission in a small RCT for severe TRD." },
  { year: "2024", title: "Adolescent (15+)", desc: "First TMS device cleared for adolescent major depressive disorder." },
];
---

<Layout
  title="TMS Simulation | Interactive 3D Brain Stimulation Visualizer"
  description="Interactive 3D simulation of transcranial magnetic stimulation. See how the coil, magnetic field, and target regions interact — adjust frequency, intensity, and target in real time."
  schema={pageSchema}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Simulation", url: "/simulation/" },
  ]}
>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow="Interactive 3D Simulation"
    eyebrowDot="#22c55e"
    title="See how a magnetic pulse"
    titleAccent="reaches the brain."
    description="Adjust the coil, frequency, and target region. Watch the field penetrate the cortex and trigger neuronal activity — all in 3D, in real time."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Simulation" }]}
    ctas={[
      { label: "Try the simulator", href: "#simulator" },
      { label: "How it works", href: "#mechanism", variant: "outline" },
    ]}
    stats={[
      { value: "Real-time", label: "3D model", color: "ink" },
      { value: "10+", label: "Brain regions", color: "accent" },
      { value: "Free", label: "No sign-up", color: "warm" },
    ]}
  />

  <!-- HOW TO USE — quick 3-step guide -->
  <EditorialSection
    title="Three steps to try it"
    intro="The simulator is educational — not a treatment-planning tool. Use it to explore how TMS parameters change what reaches the brain."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>'
    tone="warm"
  >
    <div class="grid sm:grid-cols-3 gap-5">
      {howToUse.map((step) => (
        <div style="background:var(--paper2); border:1px solid var(--line); border-radius:1.25rem; padding:1.5rem; position:relative;">
          <span class="serif" style="position:absolute; top:1rem; right:1.25rem; font-size:2.5rem; line-height:1; color:rgba(201,101,74,0.22);">
            0{step.n}
          </span>
          <div style="width:2.25rem; height:2.25rem; border-radius:0.625rem; background:rgba(201,101,74,0.12); color:var(--warm); display:flex; align-items:center; justify-content:center; margin-bottom:1rem; font-weight:700; font-size:13px;">
            {step.n}
          </div>
          <h3 class="serif" style="font-size:1.25rem; color:var(--ink); margin:0 0 0.5rem; line-height:1.2;">{step.title}</h3>
          <p style="font-size:14px; color:var(--muted); line-height:1.6; margin:0;">{step.desc}</p>
        </div>
      ))}
    </div>
  </EditorialSection>

  <!-- SIMULATOR -->
  <EditorialSection
    title="The simulator"
    intro="Drag to rotate · scroll to zoom · click any region to target it. Controls live inside the panel — they update the 3D model immediately."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>'
    tone="accent"
    background="paper2"
  >
    <div id="simulator">
      <TMSViewerLazy client:only="react" />
    </div>
  </EditorialSection>

  <!-- MECHANISM EXPLAINER -->
  <EditorialSection
    title="How TMS actually works"
    intro="Three physical steps. Each happens in under a millisecond, repeated thousands of times in a session."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M3 9h2m14 0h2M3 15h2m14 0h2M7 7h10a2 2 0 012 2v6a2 2 0 01-2 2H7a2 2 0 01-2-2V9a2 2 0 012-2z"/>'
    tone="warm"
  >
    <div id="mechanism" class="grid md:grid-cols-3 gap-5">
      {mechanism.map((step) => (
        <div style="background:var(--paper2); border:1px solid var(--line); border-radius:1.25rem; padding:1.75rem;">
          <div style="font-family:ui-monospace,'SF Mono',Menlo,monospace; font-size:11px; color:var(--warm); letter-spacing:0.1em; margin-bottom:0.75rem;">
            STEP 0{step.n}
          </div>
          <div style="background:var(--paper); border:1px solid var(--line); border-radius:0.75rem; padding:0.875rem 1rem; margin-bottom:1.25rem; font-family:ui-monospace,'SF Mono',Menlo,monospace; font-size:12px; color:var(--ink); text-align:center; letter-spacing:0.04em;">
            {step.stat}
          </div>
          <h3 class="serif" style="font-size:1.375rem; color:var(--ink); margin:0 0 0.625rem; line-height:1.2;">{step.title}</h3>
          <p style="font-size:14px; color:var(--muted); line-height:1.65; margin:0;">{step.desc}</p>
        </div>
      ))}
    </div>
  </EditorialSection>

  <!-- EVIDENCE / MILESTONES -->
  <EditorialSection
    title="The evidence base"
    intro="TMS has accumulated one of the largest bodies of randomized clinical trial data in psychiatry. A few of the milestones that mattered:"
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>'
    tone="accent"
    background="paper2"
  >
    <ol style="list-style:none; padding:0; margin:0; position:relative;">
      <div style="position:absolute; top:1.5rem; bottom:1.5rem; left:88px; width:1px; background:linear-gradient(to bottom, var(--warm), rgba(201,101,74,0.15), transparent);"></div>
      {milestones.map((m) => (
        <li style="display:grid; grid-template-columns:80px 1fr; gap:2rem; align-items:start; padding:1rem 0;">
          <div class="serif" style="font-size:1.5rem; color:var(--ink); line-height:1; text-align:right; padding-top:0.25rem;">
            {m.year}
          </div>
          <div style="position:relative; padding-left:1.5rem;">
            <span style="position:absolute; left:-5px; top:0.625rem; width:11px; height:11px; border-radius:50%; background:var(--paper); border:2px solid var(--warm);"></span>
            <h3 class="serif" style="font-size:1.25rem; color:var(--ink); margin:0 0 0.375rem; line-height:1.25;">{m.title}</h3>
            <p style="font-size:14px; color:var(--muted); line-height:1.6; margin:0; max-width:36rem;">{m.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </EditorialSection>

  <!-- CTA -->
  <section style="background:var(--paper); padding:5rem 0; border-top:1px solid var(--line); text-align:center;">
    <div style="max-width:42rem; margin:0 auto; padding:0 1.5rem;">
      <h2 class="serif" style="font-size:clamp(2rem,4vw,3rem); line-height:1.05; color:var(--ink); margin:0 0 1rem;">
        Ready to take the
        <span class="italic" style="color:var(--warm);">next step</span>?
      </h2>
      <p style="font-size:17px; line-height:1.65; color:var(--muted); margin:0 auto 2rem; max-width:32rem;">
        Find a verified TMS clinic that accepts your insurance and has availability in your area. No sign-up required.
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:0.75rem; justify-content:center;">
        <a href="/us/" style="display:inline-flex; align-items:center; gap:0.5rem; height:48px; padding:0 1.75rem; border-radius:9999px; font-weight:600; font-size:15px; color:white; background:var(--ink); text-decoration:none; transition:background 0.15s ease;" onmouseover="this.style.background='var(--ink2)'" onmouseout="this.style.background='var(--ink)'">
          Find a clinic near you
          <span aria-hidden="true">→</span>
        </a>
        <a href="/quiz/am-i-a-candidate/" style="display:inline-flex; align-items:center; height:48px; padding:0 1.5rem; border-radius:9999px; font-weight:500; font-size:14px; color:var(--ink); background:transparent; border:1px solid var(--line); text-decoration:none; transition:border-color 0.15s ease;" onmouseover="this.style.borderColor='var(--ink)'" onmouseout="this.style.borderColor='var(--line)'">
          Take the 2-min quiz
        </a>
      </div>
    </div>
  </section>
</main>

</Layout>
