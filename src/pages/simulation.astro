---
import Layout from '../layouts/Layout.astro';
import TMSViewerLazy from '../components/react/TMSViewerLazy';
---

<Layout title="TMS Simulation | Interactive Brain Stimulation Visualizer" description="Explore an interactive visualization of transcranial magnetic stimulation (TMS). See how electromagnetic fields target specific brain regions for depression, OCD, anxiety, and more.">

<style>
  /* Dark cosmic design system for simulation page */
  :root{
    --bg:#060910;
    --sim-ink:#E9EEF8;
    --sim-ink2:#A4B0C8;
    --sim-ink3:#5F6A82;
    --sim-line:#1A2132;
    --sim-line2:#2A3250;
    --sim-panel:#0B1120;
    --sim-panel2:#0E1528;
    --cyan:#3DD9EB;
    --violet:#9E7BFF;
    --magenta:#E462C9;
    --amber:#F6B84B;
  }
  .sim-page{background:var(--bg);color:var(--sim-ink);font-family:'Inter',system-ui;-webkit-font-smoothing:antialiased}
  .serif{font-family:'Instrument Serif',Georgia,serif;letter-spacing:-0.01em}
  .mono{font-family:'JetBrains Mono','Fira Mono',monospace;font-feature-settings:'tnum' on}
  .sim-ink2{color:var(--sim-ink2)}.sim-ink3{color:var(--sim-ink3)}
  .bd{border-color:var(--sim-line)}.bd2{border-color:var(--sim-line2)}
  .panel{background:var(--sim-panel)}.panel2{background:var(--sim-panel2)}
  .cyan{color:var(--cyan)}.violet-c{color:var(--violet)}
  .starfield{
    background:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgba(158,123,255,0.18), transparent 60%),
      radial-gradient(ellipse 60% 50% at 110% 40%, rgba(61,217,235,0.15), transparent 60%),
      radial-gradient(ellipse 40% 40% at -10% 70%, rgba(228,98,201,0.12), transparent 60%),
      var(--bg);
  }
  .grid-fade{
    background-image:linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px);
    background-size:32px 32px;
    mask-image:linear-gradient(to bottom,black 10%,transparent 90%);
    -webkit-mask-image:linear-gradient(to bottom,black 10%,transparent 90%);
  }
  .glow-cyan{box-shadow:0 0 40px -8px rgba(61,217,235,0.6),0 0 80px -20px rgba(61,217,235,0.4)}
  .glow-violet{box-shadow:0 0 40px -8px rgba(158,123,255,0.6),0 0 80px -20px rgba(158,123,255,0.4)}
  .glass{background:rgba(11,17,32,0.55);backdrop-filter:blur(14px);border:1px solid rgba(255,255,255,0.06)}
  @keyframes pulse-sim{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.25);opacity:.7}}
  .pulse-sim{animation:pulse-sim 2.4s ease-in-out infinite}
  @keyframes emit-sim{0%{r:20;opacity:.9}100%{r:120;opacity:0}}
  .emit-sim{animation:emit-sim 2.4s ease-out infinite}
  @keyframes draw-sim{to{stroke-dashoffset:0}}
  .draw-sim{stroke-dasharray:400;stroke-dashoffset:400;animation:draw-sim 3s ease-out infinite}
  @keyframes scan-sim{0%{transform:translateY(-100%)}100%{transform:translateY(100%)}}
  .scan-sim{animation:scan-sim 3s linear infinite}
  @keyframes wave-sim{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
  @keyframes twinkle{0%,100%{opacity:.6}50%{opacity:1}}
  .stars::before{
    content:'';position:absolute;inset:0;pointer-events:none;
    background-image:
      radial-gradient(1px 1px at 20% 30%,rgba(255,255,255,.8),transparent),
      radial-gradient(1px 1px at 60% 70%,rgba(255,255,255,.6),transparent),
      radial-gradient(1px 1px at 80% 10%,rgba(255,255,255,.7),transparent),
      radial-gradient(1px 1px at 40% 80%,rgba(255,255,255,.5),transparent),
      radial-gradient(1px 1px at 90% 50%,rgba(255,255,255,.8),transparent),
      radial-gradient(1.5px 1.5px at 15% 60%,rgba(255,255,255,.9),transparent),
      radial-gradient(1px 1px at 75% 25%,rgba(255,255,255,.5),transparent);
    background-size:400px 400px;
    animation:twinkle 8s linear infinite;
  }
</style>

<div class="sim-page">

  <!-- HERO / INTERACTIVE SECTION -->
  <section class="relative pt-24 pb-16 overflow-hidden starfield" id="simulation">
    <div class="stars absolute inset-0 pointer-events-none"></div>
    <div class="grid-fade absolute inset-0 pointer-events-none"></div>

    <div class="relative max-w-[1500px] mx-auto px-6 lg:px-8">
      <!-- Meta strip -->
      <div class="flex items-center gap-6 mb-10 text-[11px] sim-ink3 mono uppercase tracking-[0.18em] flex-wrap">
        <span class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full pulse-sim" style="background:var(--cyan)"></span>
          Interactive simulation
        </span>
        <span>·</span>
        <span>Educational · not for treatment planning</span>
        <span class="ml-auto hidden lg:inline">Build 2026.04</span>
      </div>

      <!-- Two-col layout: copy + brain viz -->
      <div class="grid lg:grid-cols-[1fr_640px] gap-12 items-center mb-14">
        <!-- Left: hero copy -->
        <div>
          <h1 class="serif leading-[0.95] tracking-tight mb-8" style="font-size:clamp(48px,6.5vw,88px)">
            See how a <span class="italic" style="color:var(--cyan)">magnetic pulse</span><br/>
            reaches the depressed brain.
          </h1>
          <p class="text-[17px] sim-ink2 leading-relaxed max-w-xl mb-8">
            TMS delivers focused magnetic fields through the scalp, inducing small electrical currents in specific cortical regions. Adjust frequency, intensity, and target below — the visualization updates in real time.
          </p>

          <!-- Session progress card -->
          <div class="glass rounded-2xl p-5 flex items-center gap-6 max-w-xl mb-6">
            <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 glow-cyan" style="background:linear-gradient(135deg,var(--cyan),var(--violet))">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="color:var(--bg)"><polygon points="5,3 21,12 5,21"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-[11px] sim-ink3 mono uppercase tracking-widest">Session</span>
                <span class="mono text-[13px]">14 / 36</span>
                <span class="ml-auto text-[11px] sim-ink3 mono">Week 3 of 7</span>
              </div>
              <div class="h-1.5 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.05)">
                <div class="h-full rounded-full" style="width:38.8%;background:linear-gradient(to right,var(--cyan),var(--violet))"></div>
              </div>
              <div class="flex items-center gap-4 mt-3 text-[11px] sim-ink3 mono">
                <span>10 Hz</span><span>·</span><span>120% MT</span><span>·</span><span>L-DLPFC</span><span>·</span><span>3000 pulses</span>
              </div>
            </div>
            <div class="hidden md:flex flex-col items-end gap-1 pl-5" style="border-left:1px solid var(--sim-line2)">
              <span class="text-[10px] sim-ink3 uppercase tracking-widest">Next in</span>
              <span class="mono text-[22px]">00:14:22</span>
            </div>
          </div>

          <!-- Quick stats -->
          <div class="flex flex-wrap gap-3">
            {[
              { v: '36', l: 'Sessions typical', c: 'var(--cyan)' },
              { v: '5–9', l: 'Weeks to complete', c: 'var(--violet)' },
              { v: '2008', l: 'FDA-cleared', c: 'var(--amber)' },
              { v: '58%', l: 'Response rate', c: '#4ade80' },
            ].map((s) => (
              <div class="panel border bd rounded-xl px-4 py-3">
                <div class="mono text-[20px] font-semibold" style={`color:${s.c}`}>{s.v}</div>
                <div class="text-[10px] sim-ink3 mono uppercase tracking-wider mt-0.5">{s.l}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: SVG brain visualization (static preview — React island below handles interactive) -->
        <div class="relative">
          <div class="panel border bd rounded-2xl p-4 glow-violet relative overflow-hidden" style="aspect-ratio:1.1/1">
            <!-- Corner marks -->
            <div class="absolute top-3 left-3 text-[10px] mono sim-ink3">REC · LIVE</div>
            <div class="absolute top-3 right-3 text-[10px] mono cyan flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full pulse-sim" style="background:var(--cyan)"></span>
              LIVE
            </div>
            <div class="absolute bottom-3 left-3 text-[10px] mono sim-ink3">ch1 · 75kV/m peak</div>
            <div class="absolute bottom-3 right-3 text-[10px] mono sim-ink3">λ 0.5ms · biphasic</div>

            <!-- SVG brain -->
            <svg viewBox="0 0 420 380" class="w-full h-full">
              <defs>
                <radialGradient id="brainGrad" cx="50%" cy="50%" r="60%">
                  <stop offset="0%" stop-color="#1A2340" stop-opacity="0.8"/>
                  <stop offset="100%" stop-color="#060910" stop-opacity="0"/>
                </radialGradient>
                <linearGradient id="skullStroke" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="#9E7BFF"/>
                  <stop offset="100%" stop-color="#3DD9EB"/>
                </linearGradient>
                <radialGradient id="pulseGrad">
                  <stop offset="0%" stop-color="#3DD9EB" stop-opacity="0.9"/>
                  <stop offset="100%" stop-color="#3DD9EB" stop-opacity="0"/>
                </radialGradient>
              </defs>
              <circle cx="210" cy="180" r="170" fill="url(#brainGrad)"/>
              {[60,90,120,150].map((r, i) => (
                <circle cx="210" cy="180" r={r} fill="none" stroke="rgba(158,123,255,0.12)" stroke-width="0.5" stroke-dasharray="2 6"/>
              ))}
              <g stroke="url(#skullStroke)" stroke-width="1.2" fill="none" opacity="0.75">
                <path d="M 120 180 Q 120 90 210 85 Q 310 85 320 160 Q 325 210 305 240 Q 285 265 250 270 L 235 290 Q 225 300 215 295 L 205 275 Q 175 272 155 260 Q 125 240 120 200 Z"/>
                <path d="M 140 150 Q 170 140 200 150 Q 230 160 260 150" opacity="0.5"/>
                <path d="M 135 180 Q 170 175 210 180 Q 250 185 285 178" opacity="0.5"/>
                <path d="M 145 210 Q 175 205 210 212 Q 245 218 275 210" opacity="0.5"/>
                <path d="M 210 95 Q 218 130 225 170 Q 235 210 245 250" opacity="0.55"/>
                <path d="M 155 210 Q 200 230 260 220" opacity="0.45"/>
              </g>
              <path d="M 120 180 Q 120 90 210 85 Q 310 85 320 160 Q 325 210 305 240 Q 285 265 250 270 L 235 290 Q 225 300 215 295 L 205 275 Q 175 272 155 260 Q 125 240 120 200 Z" fill="rgba(158,123,255,0.04)"/>
              <!-- DLPFC target -->
              <g>
                <circle cx="145" cy="140" r="20" fill="none" stroke="#3DD9EB" stroke-width="1" style="animation:emit-sim 2.4s ease-out 0s infinite;transform-origin:145px 140px"/>
                <circle cx="145" cy="140" r="20" fill="none" stroke="#3DD9EB" stroke-width="1" style="animation:emit-sim 2.4s ease-out 0.8s infinite;transform-origin:145px 140px"/>
                <circle cx="145" cy="140" r="20" fill="none" stroke="#3DD9EB" stroke-width="1" style="animation:emit-sim 2.4s ease-out 1.6s infinite;transform-origin:145px 140px"/>
                <circle cx="145" cy="140" r="12" fill="url(#pulseGrad)" class="pulse-sim"/>
                <circle cx="145" cy="140" r="4" fill="#3DD9EB"/>
                <text x="160" y="132" fill="#3DD9EB" font-size="10" font-family="monospace" font-weight="600">L-DLPFC</text>
                <text x="160" y="144" fill="rgba(61,217,235,0.6)" font-size="8.5" font-family="monospace">10Hz · 120% MT</text>
              </g>
              <!-- Coil above target -->
              <g transform="translate(105, 50) rotate(-25)">
                <ellipse cx="0" cy="0" rx="20" ry="8" fill="none" stroke="#E462C9" stroke-width="2.5"/>
                <ellipse cx="35" cy="0" rx="20" ry="8" fill="none" stroke="#E462C9" stroke-width="2.5"/>
                <ellipse cx="0" cy="0" rx="14" ry="5" fill="none" stroke="rgba(228,98,201,0.5)" stroke-width="1"/>
                <ellipse cx="35" cy="0" rx="14" ry="5" fill="none" stroke="rgba(228,98,201,0.5)" stroke-width="1"/>
                <line x1="17.5" y1="-8" x2="35" y2="-28" stroke="#E462C9" stroke-width="3" stroke-linecap="round"/>
              </g>
              <!-- Neural propagation lines -->
              <g stroke="#9E7BFF" stroke-width="1" fill="none" opacity="0.6">
                <path d="M 145 140 Q 185 160 225 180" class="draw-sim"/>
                <path d="M 145 140 Q 165 190 195 220" class="draw-sim" style="animation-delay:1s"/>
                <path d="M 145 140 Q 125 180 115 210" class="draw-sim" style="animation-delay:2s"/>
              </g>
              <!-- Crosshair -->
              <g stroke="rgba(61,217,235,0.3)" stroke-width="0.8">
                <line x1="120" y1="140" x2="137" y2="140"/><line x1="153" y1="140" x2="170" y2="140"/>
                <line x1="145" y1="115" x2="145" y2="132"/><line x1="145" y1="148" x2="145" y2="165"/>
              </g>
              <text x="20" y="375" fill="rgba(255,255,255,0.25)" font-size="9" font-family="monospace">SAGITTAL VIEW · L</text>
              <text x="340" y="375" fill="rgba(255,255,255,0.25)" font-size="9" font-family="monospace">R ANT</text>
            </svg>

            <!-- Scan line overlay -->
            <div class="absolute inset-4 overflow-hidden pointer-events-none rounded-xl">
              <div class="h-8 scan-sim" style="background:linear-gradient(to bottom,transparent,rgba(61,217,235,0.3),transparent)"></div>
            </div>
          </div>

          <!-- Waveform -->
          <div class="panel border bd rounded-xl p-3 mt-3">
            <div class="flex items-center justify-between mb-1">
              <span class="text-[10px] mono sim-ink3 uppercase tracking-widest">Pulse train · realtime</span>
              <span class="text-[10px] mono cyan">10 Hz · train 4s · ISI 26s</span>
            </div>
            <svg viewBox="0 0 600 80" class="w-full h-14">
              <line x1="0" y1="40" x2="600" y2="40" stroke="rgba(255,255,255,0.1)" stroke-dasharray="3 3"/>
              <text x="5" y="12" fill="rgba(255,255,255,0.3)" font-size="9" font-family="monospace">+2T</text>
              <text x="5" y="72" fill="rgba(255,255,255,0.3)" font-size="9" font-family="monospace">-2T</text>
              {Array.from({length: 10}).map((_, i) => {
                const x = 10 + i * 58;
                return (
                  <g>
                    <line x1={x} y1="40" x2={x} y2="10" stroke="#3DD9EB" stroke-width="1.5"/>
                    <line x1={x} y1="10" x2={x+3} y2="10" stroke="#3DD9EB" stroke-width="1.5"/>
                    <line x1={x+3} y1="10" x2={x+3} y2="70" stroke="#3DD9EB" stroke-width="1.5"/>
                    <line x1={x+3} y1="70" x2={x+6} y2="70" stroke="#3DD9EB" stroke-width="1.5"/>
                    <line x1={x+6} y1="70" x2={x+6} y2="40" stroke="#3DD9EB" stroke-width="1.5"/>
                  </g>
                );
              })}
            </svg>
          </div>
        </div>
      </div>

      <!-- PROTOCOL PRESETS -->
      <div class="mb-10">
        <div class="flex items-baseline justify-between mb-4">
          <h3 class="serif text-2xl">Try a real clinical protocol</h3>
          <span class="text-[11px] mono sim-ink3 uppercase tracking-widest">5 of 24 protocols</span>
        </div>
        <div class="grid md:grid-cols-5 gap-2.5">
          {[
            { k:'standard', l:'Standard HF-rTMS', freq:10, intens:120, region:'DLPFC', dur:'37.5 min', sess:36, cond:'Depression', active:true },
            { k:'itbs', l:'iTBS (accelerated)', freq:50, intens:80, region:'DLPFC', dur:'3 min', sess:36, cond:'Depression', active:false },
            { k:'saint', l:'SAINT', freq:50, intens:90, region:'DLPFC', dur:'10 ses/day', sess:50, cond:'Depression', active:false },
            { k:'ocd', l:'Deep TMS (OCD)', freq:20, intens:100, region:'OFC', dur:'19 min', sess:29, cond:'OCD', active:false },
            { k:'low', l:'LF-rTMS', freq:1, intens:110, region:'ACC', dur:'30 min', sess:20, cond:'Anxiety', active:false },
          ].map((p) => (
            <div class={`protocol-btn text-left panel border rounded-xl p-4 cursor-pointer transition-all hover:border-[color:var(--sim-line2)] ${p.active ? 'border-[color:var(--cyan)] border-opacity-60' : 'bd'}`}
              data-freq={p.freq} data-intens={p.intens} data-region={p.region}>
              <div class="flex items-center gap-2 mb-2">
                <span class={`w-2 h-2 rounded-full ${p.active ? 'bg-[color:var(--cyan)]' : 'bg-white/20'}`}></span>
                <span class="text-[10px] mono sim-ink3 uppercase tracking-widest">{p.cond}</span>
              </div>
              <div class="font-medium mb-3 text-[14px]">{p.l}</div>
              <div class="grid grid-cols-2 gap-2 text-[11px]">
                <div><span class="sim-ink3 mono">Freq</span><div class="mono">{p.freq} Hz</div></div>
                <div><span class="sim-ink3 mono">Int</span><div class="mono">{p.intens}% MT</div></div>
                <div><span class="sim-ink3 mono">Time</span><div>{p.dur}</div></div>
                <div><span class="sim-ink3 mono">Sess</span><div class="mono">{p.sess}</div></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Parameter controls -->
      <div class="grid md:grid-cols-3 gap-3">
        <div class="panel border bd rounded-xl p-5">
          <div class="text-[10px] mono sim-ink3 uppercase tracking-widest mb-3">Target region</div>
          <div class="grid grid-cols-2 gap-2">
            {[
              { k:'DLPFC', l:'L-DLPFC', n:'Depression', active:true },
              { k:'OFC', l:'OFC', n:'OCD', active:false },
              { k:'ACC', l:'ACC', n:'Anxiety', active:false },
              { k:'M1', l:'Motor cortex', n:'Calibration', active:false },
            ].map((r) => (
              <button class={`region-btn text-left px-3 py-2 rounded-lg border transition-all ${r.active ? 'border-[color:var(--cyan)] bg-[color:var(--cyan)]/5' : 'bd2 hover:bg-white/5'}`} data-region={r.k}>
                <div class={`text-[12.5px] font-medium ${r.active ? 'cyan' : ''}`}>{r.l}</div>
                <div class="text-[10.5px] sim-ink3 mono">{r.n}</div>
              </button>
            ))}
          </div>
        </div>

        <div class="panel border bd rounded-xl p-5">
          <div class="flex items-center justify-between mb-3">
            <span class="text-[10px] mono sim-ink3 uppercase tracking-widest">Frequency</span>
            <span id="freq-display" class="mono cyan text-[14px]">10 Hz</span>
          </div>
          <input id="freq-slider" type="range" min="1" max="50" value="10" class="w-full mb-2 accent-cyan-400"/>
          <div class="flex justify-between text-[10px] mono sim-ink3">
            <span>1 Hz · LF</span><span>10 Hz · std</span><span>50 Hz · iTBS</span>
          </div>
        </div>

        <div class="panel border bd rounded-xl p-5">
          <div class="flex items-center justify-between mb-3">
            <span class="text-[10px] mono sim-ink3 uppercase tracking-widest">Intensity</span>
            <span id="intens-display" class="mono violet-c text-[14px]">120% MT</span>
          </div>
          <input id="intens-slider" type="range" min="60" max="140" value="120" class="w-full mb-2 accent-violet-400"/>
          <div class="flex justify-between text-[10px] mono sim-ink3">
            <span>60%</span><span>Subthreshold &lt;100</span><span>140%</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INTERACTIVE REACT ISLAND -->
  <section class="py-0" style="background:#080C16">
    <div class="max-w-[1500px] mx-auto px-6 lg:px-8 py-10">
      <div class="panel border bd rounded-2xl p-6">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-2 h-2 rounded-full pulse-sim" style="background:var(--cyan)"></span>
          <span class="text-[13px] font-semibold tracking-wide">Full Interactive Simulator</span>
        </div>
        <TMSViewerLazy client:visible />
      </div>
    </div>
  </section>

  <!-- MECHANISM EXPLAINER -->
  <section class="py-24 relative" style="background:#080C16">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
      <div class="max-w-2xl mb-16">
        <div class="text-[11px] mono sim-ink3 uppercase tracking-[0.18em] mb-4">§ 01 · The mechanism</div>
        <h2 class="serif leading-[1] mb-6" style="font-size:clamp(2.5rem,5vw,3.75rem)">
          Electromagnetic induction,<br/>at the speed of thought.
        </h2>
        <p class="text-[17px] sim-ink2 leading-relaxed">
          A coil sits against the scalp. When current flows through it, it produces a magnetic field strong enough — briefly — to pass through bone. That field induces a small electrical current in the cortex underneath, depolarizing neurons near the target.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-px rounded-2xl overflow-hidden" style="background:var(--sim-line); border:1px solid var(--sim-line)">
        {[
          {
            n:'01', t:'Current enters the coil',
            d:'A capacitor discharges ~1.5kA through copper windings in under 100μs. This produces a rapidly-changing magnetic field perpendicular to the scalp.',
            stat:'1.5 kA · 100 μs rise',
          },
          {
            n:'02', t:'Magnetic field passes through skull',
            d:'The field is ~1.5 tesla at the coil face — strong enough to pass through bone and dura. It peaks within 1–3 cm of the scalp and falls off quickly with depth.',
            stat:'1.5 T peak · 1–3 cm depth',
          },
          {
            n:'03', t:'Neurons depolarize',
            d:'The induced electric field reaches ~100 V/m in the target cortex, enough to bring pyramidal neurons to threshold. A single pulse triggers action potentials across millions of cells.',
            stat:'~100 V/m · threshold',
          },
        ].map((s) => (
          <div style="background:var(--bg); padding:2rem">
            <div class="flex items-center gap-3 mb-5">
              <span class="mono text-[11px] sim-ink3 tracking-widest">STEP {s.n}</span>
              <div class="flex-1 h-px" style="background:var(--sim-line)"></div>
            </div>
            <div class="h-24 mb-5 rounded-xl flex items-center justify-center" style="background:var(--sim-panel)">
              <span class="mono text-[11px] sim-ink3 tracking-wider">{s.stat}</span>
            </div>
            <h3 class="serif text-2xl mt-2 mb-3 leading-tight">{s.t}</h3>
            <p class="text-[13.5px] sim-ink2 leading-relaxed">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EVIDENCE TIMELINE -->
  <section class="py-24 relative" style="background:#080C16; border-top:1px solid var(--sim-line)">
    <div class="max-w-[1100px] mx-auto px-6 lg:px-8">
      <div class="mb-16 max-w-2xl">
        <div class="text-[11px] mono sim-ink3 uppercase tracking-[0.18em] mb-4">§ 02 · The evidence base</div>
