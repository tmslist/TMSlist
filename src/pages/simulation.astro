            { y:'2008', t:'FDA clears NeuroStar', d:'First approval for treatment-resistant major depression in adults. A turning point for psychiatry.', c:'violet' },
            { y:'2013', t:'Deep TMS cleared (BrainsWay)', d:'H-coil geometry reaches deeper structures than standard figure-of-eight designs.', c:'violet' },
            { y:'2018', t:'iTBS approved + OCD indication', d:'Theta-burst protocol (3 min) shows non-inferiority to standard 37-min sessions. OCD cleared.', c:'cyan' },
            { y:'2020', t:'SAINT protocol published', d:'Accelerated iTBS achieves 90% remission in a small RCT for severe treatment-resistant depression.', c:'cyan' },
            { y:'2024', t:'Adolescent approval (15+)', d:'First TMS device cleared for adolescent major depressive disorder. Adolescent TMS era begins.', c:'violet' },
