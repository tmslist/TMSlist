---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import BlogCover from '../../components/BlogCover.astro';
import FindClinicCTA from '../../components/FindClinicCTA.astro';
import SectionLinks from '../../components/SectionLinks.astro';
import LeadMagnetCta from '../../components/LeadMagnetCta.astro';
import { getCollection, render } from 'astro:content';
import { BLOG_SLUGS } from '../../utils/seo_slugs';

// Blog metadata for cover rendering (category, date, readTime)
const blogMeta: Record<string, { category?: string; date?: string; readTime?: string }> = {
  'stanford-neuromodulation-therapy-snt-2026': { category: 'Research', date: 'April 2026', readTime: '9 min' },
  'tms-for-postpartum-depression': { category: 'Treatment', date: 'April 2026', readTime: '7 min' },
  'ai-guided-tms-targeting-2026': { category: 'Research', date: 'April 2026', readTime: '8 min' },
  'tms-covered-by-medicare-2026-update': { category: 'Insurance', date: 'April 2026', readTime: '6 min' },
  'tms-for-anxiety-fda-breakthrough': { category: 'Research', date: 'March 2026', readTime: '7 min' },
  'theta-burst-vs-standard-tms': { category: 'Treatment', date: 'March 2026', readTime: '8 min' },
  'real-cost-of-tms-therapy-2026': { category: 'Insurance', date: 'March 2026', readTime: '10 min' },
  'tms-and-ketamine-together': { category: 'Treatment', date: 'March 2026', readTime: '9 min' },
  'tms-at-home-devices-2026': { category: 'FAQ', date: 'March 2026', readTime: '7 min' },
  'choosing-tms-clinic-red-flags': { category: 'Patient Guide', date: 'February 2026', readTime: '8 min' },
  'tms-for-ocd-deep-tms-results': { category: 'Research', date: 'February 2026', readTime: '7 min' },
  'what-tms-actually-feels-like': { category: 'Patient Guide', date: 'February 2026', readTime: '6 min' },
  'tms-for-veterans-va-coverage': { category: 'Insurance', date: 'February 2026', readTime: '8 min' },
  'tms-during-pregnancy-safety-data': { category: 'Research', date: 'February 2026', readTime: '7 min' },
  'tms-success-rates-2026': { category: 'Research', date: 'January 2026', readTime: '8 min' },
  'tms-vs-medication': { category: 'Treatment', date: 'January 2026', readTime: '10 min' },
  'how-to-prepare-for-tms': { category: 'Patient Guide', date: 'January 2026', readTime: '5 min' },
  'does-tms-cause-memory-loss': { category: 'FAQ', date: 'January 2026', readTime: '6 min' },
  'can-i-drive-after-tms': { category: 'Patient Guide', date: 'January 2026', readTime: '4 min' },
  'how-long-does-tms-last': { category: 'Research', date: 'January 2026', readTime: '7 min' },
};

export async function getStaticPaths() {
  const entries = await getCollection('blog');

  const contentPaths = entries.map((entry) => ({
    params: { slug: entry.id },
    props: { title: entry.data.title, description: entry.data.description, hasContent: true, entry },
  }));

  const contentSlugsSet = new Set(contentPaths.map(p => p.params.slug));
  const fallbackPaths = BLOG_SLUGS
    .filter(({ slug }) => !contentSlugsSet.has(slug))
    .map(({ slug, title }) => ({
      params: { slug },
      props: { title, description: `Expert insights on ${title} — evidence-based information on TMS therapy from the TMS List editorial team.`, hasContent: false, entry: null },
    }));

  return [...contentPaths, ...fallbackPaths];
}

const { title, description, hasContent, entry } = Astro.props;
const slug = Astro.params.slug!;
const meta = blogMeta[slug] || {};

let Content: any = null;
if (hasContent && entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

// Pick a contextual lead magnet based on blog category.
const magnetByCategory: Record<string, { slug: string; heading: string; sub: string; cta: string }> = {
  Insurance: {
    slug: 'insurance-checklist',
    heading: 'TMS Insurance Coverage Checklist',
    sub: 'Free 1-page checklist — exactly what to ask your insurer to confirm TMS coverage and start prior authorization.',
    cta: 'Get the Free Checklist',
  },
  Treatment: {
    slug: 'tms-vs-medication',
    heading: 'TMS vs. Medication: A Side-by-Side Guide',
    sub: 'Free PDF — compare effectiveness, side effects, cost, and timelines so you can choose with confidence.',
    cta: 'Download the Free Guide',
  },
  Research: {
    slug: 'tms-buyers-guide',
    heading: "The TMS Patient Buyer's Guide",
    sub: 'Free 22-page guide — questions to ask, red flags, and how to choose the right provider.',
    cta: "Get the Buyer's Guide",
  },
  'Patient Guide': {
    slug: 'tms-buyers-guide',
    heading: "The TMS Patient Buyer's Guide",
    sub: 'Everything to know before your first consult — questions to ask, what to expect, and how to compare providers.',
    cta: "Get the Buyer's Guide",
  },
  FAQ: {
    slug: 'tms-buyers-guide',
    heading: "Still have questions? Get the full Buyer's Guide.",
    sub: 'A free 22-page primer answering every common question about TMS therapy.',
    cta: 'Download Free PDF',
  },
};
const blogMagnet = magnetByCategory[meta.category || ''] || magnetByCategory['Patient Guide'];

const reviewerName = "Dr. Karan Narwal";
const reviewerTitle = "Mental Health Specialist & Consultant";
const reviewerImage = "https://img1.wsimg.com/isteam/ip/f791d9b9-2f6c-4539-b9b3-61b4c8a8a446/Screenshot%202024-11-16%20at%204.26.32%E2%80%AFPM.png/:/cr=t:0%25,l:6.95%25,w:86.1%25,h:100%25/rs=w:600,h:600,cg:true";
const reviewerBio = "Dr. Narwal is a mental health specialist with extensive experience in neuromodulation therapies. He reviews all clinical content on TMS List for medical accuracy and alignment with current treatment guidelines.";

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const blogTags = hasContent && entry ? (entry.data.tags || []) : [];
const aboutSchema = blogTags.length > 0 ? {
    "about": blogTags.map(tag => ({ "@type": "Thing", "name": tag }))
} : {};

// HowTo schema for preparation guide
const howToSchema = slug === 'how-to-prepare-for-tms' ? JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": title,
    "description": description || "A step-by-step guide to preparing for transcranial magnetic stimulation (TMS) therapy.",
    "image": `${siteUrl}/images/blog-covers/${slug}.svg`,
    "totalTime": "P45D",
    "step": [
        { "@type": "HowToStep", "position": 1, "name": "Consult your doctor", "text": "Discuss whether TMS is appropriate for your condition. TMS is typically recommended for treatment-resistant depression, OCD, or other conditions where medications haven't provided sufficient relief." },
        { "@type": "HowToStep", "position": 2, "name": "Verify insurance coverage", "text": "Contact your insurance provider to confirm TMS coverage, understand your copay obligations, and begin the prior authorization process if required." },
        { "@type": "HowToStep", "position": 3, "name": "Complete intake assessment", "text": "Your TMS provider will conduct a psychological evaluation, determine your motor threshold, and review your medical history to personalize the treatment plan." },
        { "@type": "HowToStep", "position": 4, "name": "Attend TMS sessions (20–36 sessions)", "text": "Complete the full treatment course — typically 5 sessions per week over 6–9 weeks. Each session lasts 19–37 minutes for standard rTMS, or about 3 minutes for theta burst stimulation (iTBS)." },
        { "@type": "HowToStep", "position": 5, "name": "Track your progress", "text": "Monitor symptom changes using standardized scales like PHQ-9 for depression. Discuss any side effects with your provider. Maintenance sessions may be recommended to sustain results." },
    ],
}) : null;

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": ["Article", "BlogPosting"],
  "headline": title,
  "description": description || `Expert insights on ${title} — evidence-based information on TMS therapy.`,
  "image": `${siteUrl}/images/blog-covers/${slug}.svg`,
  "author": {
    "@type": "Organization",
    "name": "TMS List Editorial Team",
    "url": siteUrl,
  },
  "dateModified": new Date().toISOString().split('T')[0],
  "publisher": {
    "@type": "Organization",
    "name": "TMS List",
    "url": siteUrl,
    "logo": { "@type": "ImageObject", "url": `${siteUrl}/favicon.svg` },
  },
  "datePublished": meta.date ? new Date(`${meta.date} 1, ${new Date().getFullYear()}`).toISOString().split('T')[0] : undefined,
  "mainEntityOfPage": { "@type": "WebPage", "@id": `${siteUrl}/blog/${slug}/` },
  "reviewedBy": {
    "@type": "Person",
    "name": reviewerName,
    "jobTitle": reviewerTitle,
  },
  ...aboutSchema,
});
---

<Layout title={`${title} | TMS List`} description={description} schema={articleSchema} extraSchemas={howToSchema ? [howToSchema] : []} contentType="blog" canonical={`${siteUrl}/blog/${slug}/`} image={`${siteUrl}/images/blog-covers/${slug}.svg`} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "Blog", url: "/blog/" },
  { name: title, url: `/blog/${slug}/` },
]}>
  <BlogCover
    title={title}
    subtitle={description || "Expert insights and evidence-based information on TMS therapy."}
    category={meta.category}
    date={meta.date}
    readTime={meta.readTime}
    slug={slug}
  />

  <main class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Article Column -->
      <article class="lg:col-span-8 prose prose-lg prose-blue max-w-none prose-headings:font-display prose-headings:tracking-tight prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h3:text-xl prose-a:text-[var(--accent)] prose-a:no-underline hover:prose-a:underline prose-strong:text-[var(--ink)] prose-table:border prose-table:border-[var(--line)] prose-th:bg-[var(--paper2)] prose-th:px-4 prose-th:py-2 prose-td:px-4 prose-td:py-2 prose-td:border-t prose-td:border-[var(--line)] prose-img:rounded-xl prose-img:shadow-lg">
        <p class="lead text-xl text-[var(--muted)] mb-8">
          Everything you need to know about <strong>{title}</strong> — how it works, what it costs, and how to find a provider who actually knows what they're doing.
        </p>

        {Content && (
          <div class="not-prose">
            <LeadMagnetCta
              variant="article-end"
              useModal={true}
              slug={blogMagnet.slug}
              heading={blogMagnet.heading}
              subheading={blogMagnet.sub}
              cta={blogMagnet.cta}
              format="PDF Guide"
              accent="#0A1628"
            />
          </div>
        )}

        {Content ? <Content /> : (
          <div>
            <div class="bg-[var(--paper2)] border-l-4 border-primary p-6 mb-8 rounded-r-xl">
              <h3 class="text-primary font-semibold mt-0">Current as of 2026</h3>
              <p class="mb-0">This guide reflects the latest regulatory approvals and clinical data for {title}.</p>
            </div>

            <h2>What is {title}?</h2>
            <p>TMS uses magnetic pulses to wake up parts of the brain that aren't firing the way they should. For depression, that's usually the left dorsolateral prefrontal cortex — a region that tends to be underactive in people with treatment-resistant symptoms.</p>
            <p>It's not experimental. TMS was first cleared for depression in 2008, later for OCD and smoking cessation. It's now approved by regulatory bodies worldwide including the FDA (US), NICE (UK), TGA (Australia), and Health Canada. Over a million treatments have been performed globally.</p>

            <h3>What to expect</h3>
            <ul>
              <li><strong>No surgery, no sedation.</strong> You sit in a chair. A coil sits against your head. Sessions take 20-40 minutes.</li>
              <li><strong>It works for a lot of people.</strong> About 50-60% of patients with treatment-resistant depression see meaningful improvement. Around a third achieve full remission.</li>
              <li><strong>Side effects are mild.</strong> Most people report some scalp discomfort during the first few sessions. It usually fades.</li>
              <li><strong>Approved and increasingly covered by insurance.</strong> In the US, Medicare and most major plans cover TMS. In the UK, Australia, and other countries, public and private coverage is expanding.</li>
            </ul>

            <h2>Does insurance cover it?</h2>
            <p>Short answer: probably, if you meet the criteria. Most plans require:</p>
            <ul>
              <li>A diagnosis of Major Depressive Disorder (MDD)</li>
              <li>You've tried 2-4 antidepressants that didn't work well enough</li>
              <li>Prior authorization from your insurance company</li>
            </ul>
            <p>The prior auth process can take a few days to a couple weeks. Many TMS clinics handle this for you — it's worth asking when you call.</p>

            <h2>How to pick a provider</h2>
            <p>Not all TMS clinics are the same. Here's what matters:</p>
            <ul>
              <li><strong>The device they use.</strong> NeuroStar, BrainsWay, and MagVenture are the big three. Each has different strengths.</li>
              <li><strong>Who's supervising treatment.</strong> A board-certified psychiatrist should be involved in your care, not just a technician.</li>
              <li><strong>Patient reviews.</strong> What do other people say about the experience? That tells you more than any brochure.</li>
            </ul>

            <div class="not-prose mt-12 p-8 bg-[var(--accent)] rounded-2xl text-white text-center">
              <h3 class="text-2xl font-semibold mb-4">Ready to find a clinic?</h3>
              <p class="text-[var(--muted)] mb-8">Browse verified TMS providers with real reviews and insurance info.</p>
              <a href="/us/" class="inline-block bg-[var(--paper)] text-[var(--accent)] font-semibold py-3 px-8 rounded-xl hover:bg-[var(--paper2)] transition-colors">Find a Clinic Near You</a>
            </div>
          </div>
        )}
      </article>

      <!-- Sidebar -->
      <aside class="lg:col-span-4 space-y-8">
        <div class="bg-[var(--paper)] p-6 rounded-2xl border border-[var(--line)] shadow-sm">
          <h4 class="font-semibold text-[var(--ink)] mb-4 uppercase text-xs tracking-wider">Medically Reviewed By</h4>
          <div class="flex items-center gap-4">
            <img src={reviewerImage} alt={reviewerName} class="w-12 h-12 rounded-full object-cover border-2 border-[rgba(10,22,40,0.1)]" width="48" height="48" loading="lazy" />
            <div>
              <div class="font-semibold text-[var(--ink)]">{reviewerName}</div>
              <div class="text-xs text-[var(--muted)]">{reviewerTitle}</div>
            </div>
          </div>
          <p class="text-xs text-[var(--muted)] mt-3 leading-relaxed">{reviewerBio}</p>
        </div>

        <div class="bg-[var(--paper2)] p-6 rounded-2xl">
          <h4 class="font-semibold text-[var(--ink)] mb-4 uppercase text-xs tracking-wider">Related Topics</h4>
          <ul class="space-y-3 text-sm">
            <li><a href="/insurance/medicare/" class="text-[var(--muted)] hover:text-primary transition-colors">Does Medicare Cover TMS?</a></li>
            <li><a href="/technology/neurostar/" class="text-[var(--muted)] hover:text-primary transition-colors">How NeuroStar Works</a></li>
            <li><a href="/treatments/anxiety/" class="text-[var(--muted)] hover:text-primary transition-colors">TMS for Anxiety</a></li>
            <li><a href="/compare/tms-vs-antidepressants/" class="text-[var(--muted)] hover:text-primary transition-colors">TMS vs. Medication</a></li>
            <li><a href="/quiz/am-i-a-candidate/" class="text-[var(--muted)] hover:text-primary transition-colors">Am I a Candidate?</a></li>
          </ul>
        </div>

        <LeadMagnetCta
          variant="sidebar"
          useModal={true}
          slug={blogMagnet.slug}
          heading={blogMagnet.heading}
          subheading={blogMagnet.sub}
          cta={blogMagnet.cta}
          format="PDF Guide"
          accent="#0A1628"
        />

        <div class="bg-gradient-to-br from-[#0A1628] to-[#0A1628] p-6 rounded-2xl text-white">
          <h4 class="font-semibold mb-2 text-sm">Not sure where to start?</h4>
          <p class="text-sm text-white/60 mb-4">Take a 2-minute quiz to see if TMS might be right for you.</p>
          <a href="/quiz/am-i-a-candidate/" class="inline-block text-sm font-semibold bg-[var(--paper)] text-[var(--accent)] px-4 py-2 rounded-lg hover:bg-[rgba(10,22,40,0.08)] transition-colors">Take the Quiz</a>
        </div>
      </aside>
    </div>
  </main>

  <SectionLinks sections={[
    { heading: 'Treatments', links: [
      { title: 'TMS for Depression', href: '/treatments/depression/' },
      { title: 'TMS for Anxiety', href: '/treatments/anxiety/' },
      { title: 'TMS for OCD', href: '/treatments/ocd/' },
      { title: 'All Treatments', href: '/treatments/' },
    ]},
    { heading: 'Insurance & Cost', links: [
      { title: 'Medicare Coverage', href: '/insurance/medicare/' },
      { title: 'TMS Cost Guide', href: '/tms-cost-guide/' },
      { title: 'Insurance Eligibility', href: '/quiz/am-i-a-candidate/' },
    ]},
    { heading: 'Compare Options', links: [
      { title: 'TMS vs. Medication', href: '/compare/tms-vs-antidepressants/' },
      { title: 'TMS vs. ECT', href: '/compare/tms-vs-ect/' },
      { title: 'TMS vs. Ketamine', href: '/compare/tms-vs-ketamine/' },
    ]},
  ]} />
  <FindClinicCTA />
</Layout>
