        category: "Treatment",
        date: "April 2026",
        readTime: "7 min read",
        image: "/images/tms_chair_luxury_1769446442231.jpg",
    },
    {
        slug: "ai-guided-tms-targeting-2026",
        title: "AI-Guided TMS Targeting: How Machine Learning Is Improving Treatment Precision",
        excerpt: "New AI systems can now identify the exact brain region to target for each patient. How this personalized approach is boosting response rates.",
