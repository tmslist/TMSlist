---
import Layout from "../../layouts/Layout.astro";
import EditorialHero from "../../components/editorial/EditorialHero.astro";
import BlogCardCover from "../../components/BlogCardCover.astro";
import { getCollection } from "astro:content";

const SITE_URL = (import.meta.env.SITE_URL || "https://tmslist.com").replace(/\/$/, "");

// Normalize lowercase content categories to display labels.
const CATEGORY_LABEL: Record<string, string> = {
  research: "Research",
  treatment: "Treatment",
  "patient-guide": "Patient Guide",
  faq: "FAQ",
};

const monthShort = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
function fmtDate(d: Date): string {
  return `${monthShort[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;
}
function fmtIso(d: Date): string {
  return d.toISOString().slice(0, 10);
}

const entries = await getCollection("blog");
const blogPosts = entries
  .map((entry) => {
    const publishDate: Date = entry.data.publishDate ? new Date(entry.data.publishDate) : new Date();
    const rawCat = (entry.data.category || "research") as string;
    const category = CATEGORY_LABEL[rawCat] || rawCat;
    const wordCount = (entry.body || "").split(/\s+/).filter(Boolean).length;
    const readTime = `${Math.max(1, Math.round(wordCount / 220))} min read`;
    return {
      slug: entry.id,
      title: entry.data.title,
      excerpt: entry.data.description || "",
      category,
      author: entry.data.author || "TMS List Editorial Team",
      tags: entry.data.tags || [],
      publishDate,
      dateLabel: fmtDate(publishDate),
      dateIso: fmtIso(publishDate),
      readTime,
    };
  })
  .sort((a, b) => b.publishDate.getTime() - a.publishDate.getTime());

const categories = [...new Set(blogPosts.map((p) => p.category))];
const categoryColors: Record<string, { bg: string; text: string; tone: string }> = {
  Research:        { bg: "bg-[var(--paper2)]",            text: "text-[var(--accent)]", tone: "accent" },
  Treatment:       { bg: "bg-emerald-50",                 text: "text-emerald-700",     tone: "success" },
  "Patient Guide": { bg: "bg-[rgba(201,101,74,0.10)]",    text: "text-[var(--warm)]",   tone: "warm" },
  FAQ:             { bg: "bg-[rgba(59,46,90,0.10)]",      text: "text-[#3B2E5A]",       tone: "muted" },
  Insurance:       { bg: "bg-amber-50",                   text: "text-amber-700",       tone: "muted" },
};
const defaultColor = { bg: "bg-[var(--paper2)]", text: "text-[var(--muted)]", tone: "muted" };

// Structured data: ItemList of blog posts (helps Google build a richer index card).
const itemListSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "TMS List — Articles",
  itemListOrder: "https://schema.org/ItemListOrderDescending",
  numberOfItems: blogPosts.length,
  itemListElement: blogPosts.slice(0, 30).map((post, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `${SITE_URL}/blog/${post.slug}/`,
    name: post.title,
  })),
});

// Per-post BlogPosting summaries — kept compact, top 12 only, helps surface freshness signals.
const blogSummariesSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": blogPosts.slice(0, 12).map((post) => ({
    "@type": "BlogPosting",
    headline: post.title,
    description: post.excerpt,
    datePublished: post.dateIso,
    author: { "@type": "Organization", name: post.author },
    url: `${SITE_URL}/blog/${post.slug}/`,
    articleSection: post.category,
  })),
});

const combinedSchema = `${itemListSchema}</script><script type="application/ld+json">${blogSummariesSchema}`;
---

<Layout
  title="TMS Therapy Blog — Evidence-Based Guides, Research & Patient Stories | TMS List"
  description="Expert articles on TMS therapy: depression treatment, deep TMS, theta-burst protocols, insurance coverage, and the latest neuromodulation research. Updated weekly."
  canonical="https://tmslist.com/blog/"
  contentType="blog"
  schema={combinedSchema}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Blog", url: "/blog/" },
  ]}
>
  <main style="background:var(--paper)">
    <EditorialHero
      eyebrow={`${blogPosts.length} Articles`}
      eyebrowDot="#22c55e"
      title="The TMS"
      titleAccent="journal."
      description="Evidence-based articles, patient guides, and the latest research on transcranial magnetic stimulation."
      breadcrumbs={[{ label: "Home", href: "/" }, { label: "Blog" }]}
      ctas={[
        { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
        { label: "Find a TMS Clinic", href: "/us/", variant: "outline" },
      ]}
      stats={[
        { value: blogPosts.length, label: "Articles", color: "ink" },
        { value: categories.length, label: "Categories", color: "accent" },
        { value: "Weekly", label: "New Posts", color: "warm" },
      ]}
    />

    <!-- Category Filters -->
    <section class="bg-[var(--paper)] border-b border-[var(--line)] py-4 sticky top-16 z-40" id="filter-bar">
      <div class="container mx-auto px-4">
        <div class="flex items-center gap-2 overflow-x-auto pb-1 scrollbar-hide" role="tablist" aria-label="Filter articles by category">
          <button data-category="all" class="filter-btn is-active px-4 py-2 text-sm font-semibold rounded-full transition-all shrink-0" role="tab" aria-selected="true">All</button>
          {categories.map((cat) => {
            const c = categoryColors[cat] || defaultColor;
            return (
              <button data-category={cat} class={`filter-btn px-4 py-2 ${c.bg} ${c.text} text-sm font-semibold rounded-full hover:opacity-80 transition-all shrink-0`} role="tab" aria-selected="false">{cat}</button>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="py-12 lg:py-16 bg-[var(--paper)]">
      <div class="container mx-auto px-4 max-w-6xl">

        <!-- Featured Post -->
        {blogPosts.length > 0 && (() => {
          const feat = blogPosts[0];
          const fc = categoryColors[feat.category] || defaultColor;
          return (
          <a href={`/blog/${feat.slug}/`} data-category={feat.category}
             class="blog-card group block mb-14"
             aria-label={`Featured: ${feat.title}`}>
            <article class="grid lg:grid-cols-[1.1fr_1fr] gap-0 bg-[var(--paper2)] rounded-3xl overflow-hidden border border-[var(--line)] hover:shadow-[0_20px_60px_-15px_rgba(10,22,40,0.12)] transition-all duration-300">
              <!-- Cover -->
              <div class="relative lg:min-h-[360px] overflow-hidden">
                <BlogCardCover slug={feat.slug} title={feat.title} excerpt={feat.excerpt} category={feat.category} tall={true} />
              </div>
              <!-- Text -->
              <div class="p-8 lg:p-12 flex flex-col justify-center bg-[var(--paper)]">
                <div class="flex items-center gap-3 mb-5 flex-wrap">
                  <span class={`px-3 py-1 ${fc.bg} ${fc.text} text-[11px] font-bold uppercase tracking-wider rounded-md`}>{feat.category}</span>
                  <span class="text-[var(--muted)] text-xs uppercase tracking-widest">Featured</span>
                </div>
                <h2 class="serif text-3xl lg:text-4xl mb-4 group-hover:text-[var(--warm)] transition-colors leading-[1.1]" style="color:var(--ink);">
                  {feat.title}
                </h2>
                <p class="text-[var(--muted)] leading-relaxed mb-6 line-clamp-3">{feat.excerpt}</p>
                <div class="flex items-center gap-4 text-sm flex-wrap">
                  <span class="text-[var(--warm)] font-semibold inline-flex items-center gap-2 group-hover:gap-3 transition-all">
                    Read Article
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                  </span>
                  <span class="text-[var(--muted)] inline-flex items-center gap-2">
                    <time datetime={feat.dateIso}>{feat.dateLabel}</time>
                    <span aria-hidden="true">·</span>
                    <span>{feat.readTime}</span>
                  </span>
                </div>
              </div>
            </article>
          </a>
        )})()}

        <!-- Posts Grid -->
        <div id="blog-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {blogPosts.slice(1).map((post) => {
            const c = categoryColors[post.category] || defaultColor;
            return (
            <a href={`/blog/${post.slug}/`} data-category={post.category}
               class="blog-card group bg-[var(--paper)] rounded-2xl border border-[var(--line)] overflow-hidden hover:shadow-[0_20px_60px_-15px_rgba(10,22,40,0.1)] hover:-translate-y-0.5 transition-all duration-300 flex flex-col"
               aria-label={post.title}>
              <article class="flex-1 flex flex-col">
                <!-- Cover -->
                <div class="relative overflow-hidden">
                  <BlogCardCover slug={post.slug} title={post.title} excerpt={post.excerpt} category={post.category} />
                </div>
                <!-- Body -->
                <div class="p-5 flex-1 flex flex-col">
                  <h2 class="serif text-xl mb-3 group-hover:text-[var(--warm)] transition-colors leading-snug line-clamp-2" style="color:var(--ink);">{post.title}</h2>
                  <p class="text-sm text-[var(--muted)] leading-relaxed mb-4 line-clamp-2 flex-1">{post.excerpt}</p>
                  <div class="flex items-center justify-between pt-3 border-t border-[var(--line)] text-xs text-[var(--muted)]">
                    <time datetime={post.dateIso}>{post.dateLabel}</time>
                    <span class="font-medium">{post.readTime}</span>
                  </div>
                </div>
              </article>
            </a>
          )})}
        </div>

        <!-- Related Reading -->
        <div class="mt-16 bg-[var(--paper2)] rounded-2xl border border-[var(--line)] p-8">
          <h3 class="text-lg font-semibold text-[var(--ink)] mb-4">Related Reading</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <a href="/blog/tms-cost-insurance-guide-2026/" class="group flex items-start gap-3 p-4 rounded-xl hover:bg-[var(--paper)] transition-colors">
              <div class="w-10 h-10 rounded-lg bg-[var(--warm)]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[var(--warm)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-[var(--ink)] group-hover:text-[var(--accent)] transition-colors">TMS Cost & Insurance Guide</p>
                <p class="text-xs text-[var(--muted)] mt-0.5">Coverage, out-of-pocket costs, and appeals</p>
              </div>
            </a>
            <a href="/blog/how-to-find-tms-clinic-guide/" class="group flex items-start gap-3 p-4 rounded-xl hover:bg-[var(--paper)] transition-colors">
              <div class="w-10 h-10 rounded-lg bg-[var(--ink)]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[var(--ink)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-[var(--ink)] group-hover:text-[var(--accent)] transition-colors">How to Find a TMS Clinic</p>
                <p class="text-xs text-[var(--muted)] mt-0.5">What to look for, questions to ask</p>
              </div>
            </a>
            <a href="/blog/tms-for-depression/" class="group flex items-start gap-3 p-4 rounded-xl hover:bg-[var(--paper)] transition-colors">
              <div class="w-10 h-10 rounded-lg bg-[var(--accent)]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[var(--accent)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-[var(--ink)] group-hover:text-[var(--accent)] transition-colors">TMS for Depression</p>
                <p class="text-xs text-[var(--muted)] mt-0.5">The primary cleared indication for TMS</p>
              </div>
            </a>
            <a href="/blog/questions-to-ask-tms-clinic/" class="group flex items-start gap-3 p-4 rounded-xl hover:bg-[var(--paper)] transition-colors">
              <div class="w-10 h-10 rounded-lg bg-[var(--warm)]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[var(--warm)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-[var(--ink)] group-hover:text-[var(--accent)] transition-colors">18 Questions to Ask Your Clinic</p>
                <p class="text-xs text-[var(--muted)] mt-0.5">Device, protocols, outcomes, and costs</p>
              </div>
            </a>
            <a href="/blog/preparing-for-first-tms-session/" class="group flex items-start gap-3 p-4 rounded-xl hover:bg-[var(--paper)] transition-colors">
              <div class="w-10 h-10 rounded-lg bg-[var(--ink)]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[var(--ink)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-[var(--ink)] group-hover:text-[var(--accent)] transition-colors">Preparing for Your First Session</p>
                <p class="text-xs text-[var(--muted)] mt-0.5">What to bring, what to expect on day one</p>
              </div>
            </a>
            <a href="/blog/maintenance-tms-guide/" class="group flex items-start gap-3 p-4 rounded-xl hover:bg-[var(--paper)] transition-colors">
              <div class="w-10 h-10 rounded-lg bg-[var(--accent)]/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-[var(--accent)]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-[var(--ink)] group-hover:text-[var(--accent)] transition-colors">Maintenance TMS Guide</p>
                <p class="text-xs text-[var(--muted)] mt-0.5">Booster sessions and long-term planning</p>
              </div>
            </a>
          </div>
        </div>

        <!-- Newsletter -->
        <div class="mt-20 relative bg-[var(--ink)] rounded-3xl p-10 lg:p-14 overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-r from-[#0A1628]/10 via-transparent to-[rgba(10,22,40,0.10)]"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-[rgba(10,22,40,0.5)] rounded-full blur-[100px]"></div>
          <div class="relative z-10" id="newsletter-content">
            <div class="text-center max-w-lg mx-auto">
              <p class="text-sm font-semibold text-[var(--warm-light)] tracking-wider uppercase mb-3">Stay informed</p>
              <h3 class="serif text-3xl lg:text-4xl text-white mb-3 tracking-tight">Get TMS research in your inbox</h3>
              <p class="text-white/70 mb-8">New articles, clinical trial updates, and patient resources. No spam.</p>
              <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
                <label class="sr-only" for="newsletter-email">Email address</label>
                <input id="newsletter-email" type="email" name="email" required placeholder="you@email.com" class="flex-1 px-5 py-3.5 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/50 focus:ring-2 focus:ring-[var(--warm)] focus:border-transparent" />
                <button type="submit" class="px-7 py-3.5 bg-[var(--warm)] hover:bg-[var(--warm-light)] text-white font-semibold rounded-xl transition-colors shadow-lg shadow-[rgba(201,101,74,0.3)]">Subscribe</button>
              </form>
            </div>
          </div>
          <div id="newsletter-success" class="hidden relative z-10 text-center py-8">
            <div class="w-14 h-14 bg-emerald-500/20 backdrop-blur rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">You're subscribed!</h3>
            <p class="text-white/70">Check your inbox for a welcome email.</p>
          </div>
        </div>

        <!-- End-of-page CTA -->
        <div class="mt-12 bg-[var(--ink)] rounded-2xl p-8 text-center">
          <h3 class="serif text-2xl text-white mb-2">Ready to take the next step?</h3>
          <p class="text-white/70 text-sm mb-6 leading-relaxed">Browse our complete TMS clinic directory or take our free eligibility quiz to see if TMS is right for you.</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/quiz/am-i-a-candidate/" class="px-6 py-3 bg-[var(--warm)] text-white font-semibold rounded-xl hover:bg-[var(--warm-light)] transition-colors shadow-md">
              Take the Eligibility Quiz
            </a>
            <a href="/us/" class="px-6 py-3 bg-white/10 border border-white/30 text-white font-semibold rounded-xl hover:bg-white/20 transition-all">
              Browse TMS Clinics
            </a>
          </div>
          <p class="text-xs text-white/60 mt-4">Also: <a href="/tms-cost-guide/" class="underline hover:text-white">download the free TMS Buyer's Guide</a>.</p>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .filter-btn.is-active {
    background: var(--ink) !important;
    color: #fff !important;
  }
</style>

<script>
  function initBlogIndex() {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const cards = document.querySelectorAll<HTMLElement>(".blog-card");
    if (!buttons.length) return;

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const category = btn.getAttribute("data-category");
        buttons.forEach((b) => {
          b.classList.remove("is-active");
          b.setAttribute("aria-selected", "false");
        });
        btn.classList.add("is-active");
        btn.setAttribute("aria-selected", "true");
        cards.forEach((card) => {
          const cardCat = card.getAttribute("data-category");
          card.style.display = (category === "all" || cardCat === category) ? "" : "none";
        });
      });
    });

    const form = document.getElementById("newsletter-form") as HTMLFormElement | null;
    const content = document.getElementById("newsletter-content");
    const success = document.getElementById("newsletter-success");
    if (form && !form.dataset.bound) {
      form.dataset.bound = "1";
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        btn.disabled = true;
        const original = btn.textContent;
        btn.textContent = "Joining...";
        try {
          const res = await fetch("/api/leads", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ type: "newsletter", email: new FormData(form).get("email"), sourceUrl: location.href }),
          });
          if (res.ok) { content?.classList.add("hidden"); success?.classList.remove("hidden"); }
          else throw new Error();
        } catch {
          btn.disabled = false;
          btn.textContent = original;
          alert("Something went wrong. Please try again.");
        }
      });
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBlogIndex);
  } else {
    initBlogIndex();
  }
  // Re-init if Astro view-transitions are added later.
  document.addEventListener("astro:page-load", initBlogIndex);
</script>
