    },
    {
        slug: "theta-burst-vs-standard-tms",
        title: "Theta Burst vs Standard TMS: 3-Minute Sessions vs 20-Minute Sessions",
        excerpt: "Theta burst stimulation (TBS) cuts session time from 20 minutes to 3 minutes. We compare outcomes, side effects, and availability across 1,100+ clinics.",
        category: "Treatment",
        date: "March 2026",
        readTime: "8 min read",
        image: "/images/tms_chair_luxury_1769446442231.jpg",
