        title: "TMS + Ketamine: Why Clinics Are Combining Both Treatments",
        excerpt: "A growing number of clinics now offer TMS and ketamine together. The science behind combination therapy and whether it's worth the extra cost.",
        category: "Treatment",
        date: "March 2026",
        readTime: "9 min read",
        image: "/images/tms_chair_luxury_1769446442231.jpg",
    },
    {
        slug: "tms-at-home-devices-2026",
        title: "At-Home TMS Devices in 2026: Do They Actually Work?",
        excerpt: "Consumer TMS devices are flooding the market. We separate FDA-cleared options from wellness gadgets and explain what the clinical evidence really says.",
        category: "FAQ",
        date: "March 2026",
        readTime: "7 min read",
        image: "/images/brain_stimulation_art_1769446474392.jpg",
    },
    // — February 2026 —
    {
        slug: "choosing-tms-clinic-red-flags",
        title: "Red Flags When Choosing a TMS Clinic: What to Watch Out For",
        excerpt: "Not all TMS clinics are equal. Board certification, machine type, protocol adherence, and 7 other things you should verify before committing.",
        category: "Patient Guide",
        date: "February 2026",
        readTime: "8 min read",
        image: "/images/tms_chair_luxury_1769446442231.jpg",
    },
    {
        slug: "tms-for-ocd-deep-tms-results",
        title: "Deep TMS for OCD: 2-Year Follow-Up Data Shows Lasting Results",
        excerpt: "BrainsWay's deep TMS for OCD now has long-term data. 58% of responders maintained improvement at 2 years without additional treatment.",
        category: "Research",
        date: "February 2026",
        readTime: "7 min read",
        image: "/images/brain_stimulation_art_1769446474392.jpg",
