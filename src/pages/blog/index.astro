        image: "/images/tms_chair_luxury_1769446442231.jpg",
    },
    {
        slug: "tms-for-veterans-va-coverage",
        title: "TMS for Veterans: VA Coverage, Eligibility, and Where to Find Treatment",
        excerpt: "The VA now covers TMS at over 100 facilities. Complete guide to eligibility requirements, referral process, and community care options.",
        category: "Insurance",
        date: "February 2026",
        readTime: "8 min read",
        image: "/images/brain_stimulation_art_1769446474392.jpg",
    },
    {
        slug: "tms-during-pregnancy-safety-data",
        title: "TMS During Pregnancy: Updated Safety Data and Clinical Guidelines",
        excerpt: "New meta-analysis covering 400+ pregnant patients confirms TMS safety profile. Current guidelines from ACOG and the APA on when to consider it.",
        category: "Research",
        date: "February 2026",
        readTime: "7 min read",
        image: "/images/tms_chair_luxury_1769446442231.jpg",
    },
    // — January 2026 (existing) —
    {
        slug: "tms-success-rates-2026",
        title: "TMS Success Rates in 2026: What the Latest Research Shows",
        excerpt: "A comprehensive look at the latest clinical data on TMS therapy outcomes for depression, OCD, and other conditions.",
        category: "Research",
        date: "January 2026",
        readTime: "8 min read",
        image: "/images/tms_chair_luxury_1769446442231.jpg",
    },
    {
        slug: "tms-vs-medication",
        title: "TMS vs Medication: A Complete Comparison Guide",
        excerpt: "How does TMS compare to antidepressants? We break down efficacy, side effects, and long-term outcomes.",
        category: "Treatment",
        date: "January 2026",
        readTime: "10 min read",
        image: "/images/brain_stimulation_art_1769446474392.jpg",
    },
