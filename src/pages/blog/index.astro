        slug: "how-to-prepare-for-tms",
        title: "How to Prepare for Your First TMS Session",
        excerpt: "Everything you need to know before starting TMS therapy, from what to wear to what to expect.",
        category: "Patient Guide",
        date: "January 2026",
        readTime: "5 min read",
        image: "/images/tms_chair_luxury_1769446442231.jpg",
    },
    {
        slug: "does-tms-cause-memory-loss",
        title: "Does TMS Cause Memory Loss? Separating Fact from Fiction",
        excerpt: "Addressing common concerns about cognitive side effects of transcranial magnetic stimulation.",
        category: "FAQ",
        date: "January 2026",
        readTime: "6 min read",
        image: "/images/brain_stimulation_art_1769446474392.jpg",
    },
    {
        slug: "can-i-drive-after-tms",
        title: "Can I Drive After TMS? Activity Guidelines Explained",
        excerpt: "Understanding what activities are safe immediately after a TMS session.",
        category: "Patient Guide",
        date: "January 2026",
        readTime: "4 min read",
        image: "/images/tms_chair_luxury_1769446442231.jpg",
    },
    {
        slug: "how-long-does-tms-last",
        title: "How Long Do TMS Results Last? Durability of Treatment",
        excerpt: "Exploring long-term outcomes and maintenance protocols for sustaining TMS benefits.",
        category: "Research",
        date: "January 2026",
        readTime: "7 min read",
        image: "/images/brain_stimulation_art_1769446474392.jpg",
    },
];

const categories = [...new Set(blogPosts.map((p) => p.category))];
---

<Layout title="TMS Therapy Blog - Expert Guides & Research | TMS List" description="Expert articles on TMS therapy, depression treatment, insurance coverage, and the latest research in brain stimulation.">
    <!-- Hero -->
    <section class="relative bg-white border-b border-slate-100 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
        <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
        <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
            <nav class="flex items-center gap-2 text-sm text-slate-400 mb-6 justify-center">
                <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <span class="text-slate-600 font-medium">Blog</span>
            </nav>
            <div class="text-center">
                <span
                    class="inline-block px-4 py-1.5 bg-violet-50 text-violet-700 rounded-full text-sm font-semibold uppercase tracking-wider mb-6"
                    >TMS List Blog</span
                >
                <h1 class="text-4xl md:text-6xl font-semibold tracking-tight text-slate-900 mb-6">
                    Expert <span class="text-violet-600">Insights</span> on TMS Therapy
                </h1>
                <p class="text-xl text-slate-500 max-w-2xl mx-auto">
                    Evidence-based articles, patient guides, and the latest research
                    on transcranial magnetic stimulation.
                </p>
            </div>
        </div>
    </section>

    <!-- Category Filters -->
    <section class="bg-white/95 backdrop-blur-sm border-b border-gray-100 py-4 sticky top-16 z-40 transition-shadow duration-300" id="filter-bar">
        <div class="container mx-auto px-6">
            <div class="flex items-center gap-4 overflow-x-auto pb-2">
                <span class="text-sm font-semibold text-gray-500 shrink-0"
                    >Filter:</span
                >
                <button
                    data-category="all"
                    class="filter-btn px-4 py-2 bg-violet-600 text-white text-sm font-semibold rounded-full transition-colors"
                    >All</button
                >
                {
                    categories.map((cat) => (
                        <button
                            data-category={cat}
                            class="filter-btn px-4 py-2 bg-gray-100 text-gray-600 text-sm font-semibold rounded-full hover:bg-gray-200 transition-colors shrink-0"
                        >
                            {cat}
                        </button>
                    ))
                }
            </div>
        </div>
    </section>

    <main class="container mx-auto px-6 py-16">
        <!-- Featured Post -->
        {blogPosts.length > 0 && (
            <a
                href={`/blog/${blogPosts[0].slug}/`}
                data-category={blogPosts[0].category}
                class="blog-card group block bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden mb-14 hover:shadow-md transition-all duration-300"
            >
                <div class="flex flex-col lg:flex-row">
                    <div class="lg:w-1/2 relative">
                        <div class="aspect-[16/9] lg:aspect-auto lg:h-full bg-gradient-to-br from-violet-100 to-cyan-100 overflow-hidden">
                            <img
                                src={blogPosts[0].image}
                                alt={blogPosts[0].title}
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                            />
                        </div>
                    </div>
                    <div class="lg:w-1/2 p-8 lg:p-10 flex flex-col justify-center">
                        <span class="inline-block self-start px-3 py-1 bg-violet-50 text-violet-600 text-xs font-semibold rounded-full mb-4">
                            {blogPosts[0].category}
                        </span>
                        <h2 class="text-2xl lg:text-3xl font-semibold text-gray-900 mb-4 group-hover:text-violet-600 transition-colors">
                            {blogPosts[0].title}
                        </h2>
                        <p class="text-gray-600 mb-6 text-base leading-relaxed line-clamp-3">
                            {blogPosts[0].excerpt}
                        </p>
                        <div class="flex items-center gap-4 text-sm text-gray-400 mb-6">
                            <span>{blogPosts[0].date}</span>
                            <span class="w-1 h-1 rounded-full bg-gray-300"></span>
                            <span>{blogPosts[0].readTime}</span>
                        </div>
                        <span class="inline-flex items-center gap-2 text-violet-600 font-semibold text-sm group-hover:gap-3 transition-all">
                            Read Article
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                        </span>
                    </div>
                </div>
            </a>
        )}

        <!-- Remaining Posts Grid -->
        <div
            id="blog-grid"
            class="grid grid-cols-1 md:grid-cols-2 gap-8"
        >
            {
                blogPosts.slice(1).map((post) => (
                    <a
                        href={`/blog/${post.slug}/`}
                        data-category={post.category}
                        class="blog-card group block bg-white rounded-2xl overflow-hidden border border-slate-100 shadow-sm hover:shadow-md transition-all duration-300"
                    >
                        <div class="relative h-52 bg-gradient-to-br from-violet-100 to-cyan-100 overflow-hidden">
                            <img
                                src={post.image}
                                alt={post.title}
                                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                loading="lazy"
                            />
                            <span class="absolute top-4 left-4 px-3 py-1 bg-white/90 backdrop-blur text-xs font-semibold text-violet-600 rounded-full">
                                {post.category}
                            </span>
                        </div>
                        <div class="p-7">
                            <h2 class="text-xl font-semibold text-gray-900 mb-3 group-hover:text-violet-600 transition-colors line-clamp-2">
                                {post.title}
                            </h2>
                            <p class="text-gray-600 mb-5 line-clamp-2 leading-relaxed">
                                {post.excerpt}
                            </p>
                            <div class="border-t border-slate-100 pt-4 flex items-center justify-between text-sm text-gray-400">
                                <span>{post.date}</span>
                                <span>{post.readTime}</span>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>

        <!-- Newsletter CTA -->
        <div
            class="mt-16 bg-gradient-to-r from-violet-600 to-blue-600 rounded-3xl p-10 text-center"
        >
            <div id="newsletter-content">
                <h3 class="text-3xl font-semibold text-white mb-4">
                    Stay Updated on TMS Research
                </h3>
                <p class="text-violet-100 mb-8 max-w-xl mx-auto">
                    Get the latest articles, research updates, and patient
                    resources delivered to your inbox.
                </p>
                <form
                    id="newsletter-form"
                    class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto"
                >
                    <input
                        type="email"
                        name="email"
                        required
                        placeholder="Enter your email"
                        class="flex-1 px-5 py-4 rounded-xl text-gray-900 font-medium"
                    />
                    <button
                        type="submit"
                        class="px-8 py-4 bg-white text-violet-600 font-semibold rounded-xl hover:bg-gray-100 transition-colors"
                        >Subscribe</button
                    >
                </form>
            </div>
            <div
                id="newsletter-success"
                class="hidden h-[232px] flex flex-col items-center justify-center"
            >
                <div
                    class="w-16 h-16 bg-white/20 backdrop-blur rounded-full flex items-center justify-center mb-4"
                >
                    <svg
                        class="w-8 h-8 text-white"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M5 13l4 4L19 7"></path>
                    </svg>
                </div>
                <h3 class="text-2xl font-semibold text-white mb-2">
                    You're Subscribed!
                </h3>
                <p class="text-violet-100">
                    Thank you for joining our community.
                </p>
            </div>
        </div>
    </main>
</Layout>

<script>
    document.addEventListener("astro:page-load", () => {
        // Filter Logic
        const buttons = document.querySelectorAll(".filter-btn");
        const cards = document.querySelectorAll(".blog-card");

        buttons.forEach((btn) => {
            btn.addEventListener("click", () => {
                const category = btn.getAttribute("data-category");

                // Update active state
                buttons.forEach((b) => {
                    b.classList.remove("bg-violet-600", "text-white");
                    b.classList.add("bg-gray-100", "text-gray-600");
                });
                btn.classList.remove("bg-gray-100", "text-gray-600");
                btn.classList.add("bg-violet-600", "text-white");

                // Filter cards
                cards.forEach((card) => {
                    const cardCategory = card.getAttribute("data-category");
                    if (category === "all" || cardCategory === category) {
                        (card as HTMLElement).style.display = "block";
                    } else {
                        (card as HTMLElement).style.display = "none";
                    }
                });
            });
        });

        // Newsletter Form Logic
        const newsletterForm = document.getElementById(
            "newsletter-form",
        ) as HTMLFormElement;
        const newsletterContent = document.getElementById("newsletter-content");
        const newsletterSuccess = document.getElementById("newsletter-success");

        if (newsletterForm) {
            newsletterForm.addEventListener("submit", async (e) => {
                e.preventDefault();

                const submitBtn = newsletterForm.querySelector(
                    'button[type="submit"]',
                ) as HTMLButtonElement;
                const originalText = submitBtn.innerText;
                submitBtn.disabled = true;
                submitBtn.innerText = "Joining...";

                const formData = new FormData(newsletterForm);
                const data = {
                    type: "newsletter",
                    email: formData.get("email"),
                    source: window.location.href,
                    timestamp: new Date().toISOString(),
                };

                try {
                    const res = await fetch('/api/leads', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            type: 'newsletter',
                            email: data.email,
                            sourceUrl: data.source,
                        }),
                    });

                    if (res.ok) {
                        newsletterContent?.classList.add("hidden");
                        newsletterSuccess?.classList.remove("hidden");
                        const input = newsletterForm.querySelector(
                            'input[name="email"]',
                        ) as HTMLInputElement;
                        if (input) input.value = "";
                    } else {
                        throw new Error("Submission failed");
                    }
                } catch (error) {
                    showToast("Something went wrong. Please try again.");
                    submitBtn.disabled = false;
                    submitBtn.innerText = originalText;
                }
            });
        }
    });
</script>
