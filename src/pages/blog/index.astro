        readTime: "6 min read",
        image: "/images/tms_chair_luxury_1769446442231.jpg",
    },
    // — March 2026 —
    {
        slug: "tms-for-anxiety-fda-breakthrough",
        title: "TMS for Anxiety: Why the FDA Breakthrough Therapy Designation Matters",
        excerpt: "The FDA granted Breakthrough Therapy designation for TMS in generalized anxiety disorder. What this means for patients and the timeline for formal clearance.",
        category: "Research",
        date: "March 2026",
        readTime: "7 min read",
