---
import Layout from "../../layouts/Layout.astro";
import EditorialHero from "../../components/editorial/EditorialHero.astro";
import { getAllClinics } from "../../utils/clinicData";
import { getClinicRating, getClinicReviewCount, COUNTRY_NAMES } from "../../utils/dataHelpers";
import { getVisitorCountry } from "../../utils/visitorCountry";
import ComparisonTool from "../../components/react/ComparisonTool";

export const prerender = false;

const VISITOR_COUNTRY = getVisitorCountry(Astro.cookies, Astro.url);
const countryName = COUNTRY_NAMES[VISITOR_COUNTRY] || 'United States';

const allClinics = await getAllClinics();
const filtered = allClinics.filter(c => {
  const cc = (c.country || 'US').toUpperCase();
  return cc === VISITOR_COUNTRY;
});
// If selected country has no clinics, fall back to US so the comparison tool isn't empty
const scopedClinics = filtered.length > 0 ? filtered : allClinics.filter(c => !c.country || c.country === 'US');

const clinicList = scopedClinics.map(c => ({
  id: c.id,
  slug: c.slug,
  name: c.name,
  city: c.city || '',
  state: c.state || '',
  country: c.country || 'US',
  ratingAvg: String(getClinicRating(c) || '0'),
  reviewCount: getClinicReviewCount(c),
  machines: c.machines || [],
  specialties: (c.specialties || []).slice(0, 8),
  insurances: (c.insurances || []).slice(0, 10),
  phone: c.phone || '',
  website: c.website || '',
  verified: c.verified || false,
  isFeatured: c.is_featured || false,
  pricing: c.pricing || null,
  availability: c.availability || null,
}));

const title = VISITOR_COUNTRY === 'US'
  ? "Compare TMS Clinics Side-by-Side | TMS List"
  : `Compare TMS Clinics in ${countryName} | TMS List`;
const description = VISITOR_COUNTRY === 'US'
  ? "Compare up to 3 TMS therapy clinics side-by-side. Evaluate technology, insurance coverage, ratings, specialties, and more to find your best match."
  : `Compare up to 3 TMS therapy clinics in ${countryName} side-by-side — technology, insurance coverage, ratings, specialties, and more.`;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Compare TMS Clinics",
  description,
  url: "https://tmslist.com/compare-clinics/",
  isPartOf: { "@type": "WebSite", name: "TMS List", url: "https://tmslist.com" },
});

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Compare Clinics", url: "/compare-clinics/" },
];
---

<Layout title={title} description={description} schema={schema} breadcrumbs={breadcrumbs}>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow="TMS Clinic Finder"
    eyebrowDot="#22c55e"
    title="Compare TMS Clinics"
    titleAccent="Side-by-Side"
    description="Compare up to three TMS clinics on technology, insurance, ratings, specialties, pricing, and availability — all in one view."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Compare Clinics" }]}
    ctas={[
      { label: "Browse All Clinics", href: "/us/" },
      { label: "Best TMS Clinics", href: "/best-tms-clinics/", variant: "outline" },
    ]}
    stats={[
      { value: clinicList.length, label: "Clinics", color: "ink" },
      { value: "3", label: "Compare at Once", color: "accent" },
      { value: "Free", label: "Always", color: "warm" },
    ]}
  />

  <section style="background:var(--paper); padding:4rem 0;">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-8">
      <ComparisonTool client:load allClinics={clinicList} />
    </div>
  </section>
</main>

</Layout>
