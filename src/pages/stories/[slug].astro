---
export const prerender = true;

import ContentPage from '../../layouts/ContentPage.astro';
import { getCollection, render } from 'astro:content';
import { STORIES_SLUGS } from '../../utils/seo_slugs';

export async function getStaticPaths() {
  let contentPaths: any[] = [];
  try {
    const entries = await getCollection('stories');
    contentPaths = entries.map((entry) => ({
      params: { slug: entry.id },
      props: { title: entry.data.title, description: entry.data.description || '', hasContent: true, entry },
    }));
  } catch { /* collection may not exist yet */ }

  const contentSlugsSet = new Set(contentPaths.map(p => p.params.slug));
  const fallbackPaths = STORIES_SLUGS
    .filter(({ slug }) => !contentSlugsSet.has(slug))
    .map(({ slug, title }) => ({
      params: { slug },
      props: { title, description: '', hasContent: false, entry: null },
    }));

  return [...contentPaths, ...fallbackPaths];
}

const { title, description, hasContent, entry } = Astro.props;
const slug = Astro.params.slug!;
let Content: any = null;
if (hasContent && entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description || `TMS patient story: ${title}.`,
  "url": `${siteUrl}/stories/${slug}/`,
  "author": { "@type": "Organization", "name": "TMS List Editorial Team", "url": siteUrl },
  "publisher": { "@type": "Organization", "name": "TMS List", "url": siteUrl, "logo": { "@type": "ImageObject", "url": `${siteUrl}/favicon.svg` } },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `${siteUrl}/stories/${slug}/` },
});
---

<ContentPage
  title={title}
  subtitle={description || "Real stories from TMS therapy patients."}
  description={description}
  schema={articleSchema}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Patient Stories", url: "/stories/" },
    { name: title, url: `/stories/${slug}/` },
  ]}
>
  {Content ? <Content /> : null}
</ContentPage>
