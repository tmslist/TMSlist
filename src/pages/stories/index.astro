---
import Layout from '../../layouts/Layout.astro';
import { STORIES_SLUGS } from '../../utils/seo_slugs';

const title = "Patient Stories | Real TMS Therapy Experiences";
const description = "Read real stories from TMS therapy patients. Hear about their journeys, treatment experiences, and outcomes in their own words.";
---

<Layout title={title} description={description}>
    <main class="bg-gray-50 min-h-screen">
        <section class="dark-section bg-gradient-to-br from-slate-900 via-indigo-900 to-blue-900 py-16 md:py-24">
            <div class="container mx-auto px-6">
                <nav class="flex text-sm text-blue-200 mb-8">
                    <a href="/" class="hover:text-white">Home</a>
                    <span class="mx-2">/</span>
                    <span>Patient Stories</span>
                </nav>
                <div class="max-w-3xl">
                    <h1 class="text-3xl md:text-5xl font-semibold tracking-tight mb-4">
                        Patient Stories
                    </h1>
                    <p class="text-lg text-blue-100 leading-relaxed">
                        Real experiences from people who have undergone TMS therapy. These stories can help you understand what to expect and make informed decisions about your treatment.
                    </p>
                </div>
            </div>
        </section>

        <section class="py-16">
            <div class="container mx-auto px-6 max-w-4xl">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    {STORIES_SLUGS.map(item => (
                        <a href={`/stories/${item.slug}/`} class="group bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-lg hover:border-indigo-200 transition-all">
                            <div class="w-12 h-12 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center mb-5">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            </div>
                            <h2 class="text-xl font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors mb-3">
                                {item.title}
                            </h2>
                            <p class="text-gray-500 text-sm mb-4">
                                Hear directly from patients about their TMS therapy journey.
                            </p>
                            <span class="text-indigo-600 font-semibold text-sm">Read Stories</span>
                        </a>
                    ))}
                </div>

                <div class="mt-16 bg-indigo-50 rounded-2xl p-8 text-center border border-indigo-100">
                    <h3 class="text-xl font-semibold text-gray-900 mb-3">Share Your Story</h3>
                    <p class="text-gray-600 mb-6 max-w-lg mx-auto">
                        Have you undergone TMS therapy? Your experience could help someone else make an important decision about their mental health treatment.
                    </p>
                    <a href="/contact/" class="inline-flex items-center px-6 py-3 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition-colors">
                        Submit Your Story
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>
