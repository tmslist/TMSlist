---
import Layout from '../../layouts/Layout.astro';
import { STORIES_SLUGS } from '../../utils/seo_slugs';

const title = "Patient Stories | Real TMS Therapy Experiences";
const description = "Read real stories from TMS therapy patients. Hear about their journeys, treatment experiences, and outcomes in their own words.";
---

<Layout title={title} description={description}>
    <main>
        <!-- Hero -->
        <section class="relative bg-white border-b border-slate-100 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
            <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-slate-700 font-medium">Patient Stories</span>
                </nav>
                <div class="max-w-3xl">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-violet-50 border border-violet-100 rounded-full mb-6">
                        <span class="flex h-2 w-2 rounded-full bg-violet-500"></span>
                        <span class="text-xs font-semibold text-violet-700 tracking-wide">{STORIES_SLUGS.length} Patient Stories</span>
                    </div>
                    <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 mb-4 leading-tight">
                        Real Patient <span class="text-violet-600">Stories</span>
                    </h1>
                    <p class="text-lg text-slate-500 leading-relaxed">
                        Hear directly from patients who've been through TMS therapy. Their journeys, challenges, and outcomes — in their own words.
                    </p>
                </div>
            </div>
        </section>

        <section class="py-16 lg:py-24 bg-white">
            <div class="container mx-auto px-4 max-w-5xl">
                <!-- Featured Story -->
                {STORIES_SLUGS.length > 0 && (
                    <a href={`/stories/${STORIES_SLUGS[0].slug}/`} class="group block mb-10">
                        <div class="relative bg-gradient-to-br from-slate-50 to-white rounded-3xl border border-slate-100 p-10 lg:p-14 hover:border-violet-200 hover:shadow-[0_20px_60px_-15px_rgba(0,0,0,0.08)] transition-all duration-300 overflow-hidden">
                            <div class="absolute top-0 right-0 w-40 h-40 bg-gradient-to-bl from-rose-50 to-transparent rounded-bl-[100px] opacity-60"></div>
                            <div class="relative z-10 flex flex-col md:flex-row items-start gap-8">
                                <div class="w-16 h-16 rounded-2xl bg-rose-50 text-rose-500 flex items-center justify-center shrink-0">
                                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                                </div>
                                <div class="flex-1">
                                    <span class="px-3 py-1 bg-rose-500 text-white text-[10px] font-bold uppercase tracking-widest rounded-md mb-4 inline-block">Featured Story</span>
                                    <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 group-hover:text-violet-600 transition-colors mb-3 tracking-tight">{STORIES_SLUGS[0].title}</h2>
                                    <p class="text-slate-500 leading-relaxed mb-6">Hear directly from patients about their TMS therapy journey, what to expect, and the outcomes they experienced.</p>
                                    <span class="text-violet-600 font-semibold text-sm inline-flex items-center gap-2 group-hover:gap-3 transition-all">
                                        Read Full Story <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                )}

                <!-- Other Stories -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {STORIES_SLUGS.slice(1).map((item) => (
                        <a href={`/stories/${item.slug}/`} class="group bg-white rounded-2xl border border-slate-100 p-8 hover:border-violet-200 hover:shadow-[0_8px_30px_-10px_rgba(0,0,0,0.06)] transition-all duration-300">
                            <div class="w-12 h-12 rounded-xl bg-violet-50 text-violet-500 flex items-center justify-center mb-5">
                                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                            </div>
                            <h2 class="text-xl font-bold text-slate-900 group-hover:text-violet-600 transition-colors mb-3 tracking-tight">{item.title}</h2>
                            <p class="text-sm text-slate-500 leading-relaxed mb-5">Hear directly from patients about their TMS therapy journey.</p>
                            <span class="text-violet-600 font-semibold text-sm inline-flex items-center gap-2 group-hover:gap-3 transition-all">
                                Read Story <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                            </span>
                        </a>
                    ))}
                </div>

                <!-- Share Your Story CTA -->
                <div class="mt-16 bg-gradient-to-br from-violet-50 to-blue-50 border border-violet-100 rounded-2xl p-10 lg:p-14 text-center">
                    <div class="w-14 h-14 rounded-2xl bg-violet-100 text-violet-600 flex items-center justify-center mx-auto mb-5">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                    </div>
                    <h3 class="text-2xl font-bold text-slate-900 mb-3">Share Your TMS Story</h3>
                    <p class="text-slate-500 max-w-md mx-auto mb-8">Your experience could help someone else make an important decision about their mental health treatment.</p>
                    <a href="/contact/" class="inline-flex items-center px-8 py-3.5 bg-violet-600 hover:bg-violet-700 text-white font-semibold rounded-xl transition-colors shadow-lg shadow-violet-600/20">
                        Submit Your Story
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>
