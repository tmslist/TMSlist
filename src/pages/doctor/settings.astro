---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import DoctorSidebar from "../../components/react/DoctorSidebar";
import DoctorSettings from "../../components/react/DoctorSettings";
import { getSessionFromRequest } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!session) return Astro.redirect("/portal/login/");
---
<Layout title="Settings | Doctor Portal | TMS List" description="Manage your account settings." noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <DoctorSidebar client:load currentPage="settings" userEmail={session.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="mb-6">
          <a href="/doctor/dashboard/" class="text-sm text-blue-600 hover:text-blue-700 font-medium mb-2 inline-block">
            &larr; Back to Dashboard
          </a>
          <h1 class="text-2xl font-semibold text-gray-900">Settings</h1>
          <p class="text-gray-500 text-sm mt-1">Manage your account and preferences</p>
        </div>
        <DoctorSettings client:load userEmail={session.email} userId={session.userId} />
      </div>
    </main>
  </div>
</Layout>
