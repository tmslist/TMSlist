---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import DoctorSidebar from "../../components/react/DoctorSidebar";
import DoctorAvailability from "../../components/react/DoctorAvailability";
import { getSessionFromRequest } from "../../utils/auth";
import { db } from "../../db";
import { doctors, doctorAvailability } from "../../db/schema";
import { eq } from "drizzle-orm";

const session = getSessionFromRequest(Astro.request);
if (!session) return Astro.redirect("/portal/login/");

const doctorRows = await db.select().from(doctors).where(eq(doctors.clinicId, session.clinicId ?? '')).limit(1);
const doctor = doctorRows[0] ?? null;

const slots = doctor
  ? await db.select().from(doctorAvailability).where(eq(doctorAvailability.doctorId, doctor.id))
  : [];
---
<Layout title="Availability | Doctor Portal | TMS List" description="Manage your appointment availability." noindex={true}>
  <div class="flex min-h-screen bg-[var(--paper2)]">
    <DoctorSidebar client:load currentPage="availability" userEmail={session.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="mb-6">
          <a href="/doctor/dashboard/" class="text-sm text-[var(--ink)] hover:text-[var(--ink)] font-medium mb-2 inline-block">
            &larr; Back to Dashboard
          </a>
          <h1 class="text-2xl font-semibold text-[var(--ink)]">Availability</h1>
          <p class="text-[var(--muted)] text-sm mt-1">Set your weekly appointment slots</p>
        </div>
        <DoctorAvailability client:load doctorId={doctor?.id} initialSlots={slots} />
      </div>
    </main>
  </div>
</Layout>
