---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import DoctorSidebar from "../../components/react/DoctorSidebar";
import DoctorNotifications from "../../components/react/DoctorNotifications";
import { getSessionFromRequest } from "../../utils/auth";
import { db } from "../../db";
import { doctors } from "../../db/schema";
import { eq } from "drizzle-orm";

const session = getSessionFromRequest(Astro.request);
if (!session) return Astro.redirect("/portal/login/");

const doctorRows = session.clinicId
  ? await db.select().from(doctors).where(eq(doctors.clinicId, session.clinicId)).limit(1)
  : [];
const doctor = doctorRows[0] ?? null;
---
<Layout title="Notifications | Doctor Portal | TMS List" description="Your doctor notifications." noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <DoctorSidebar client:load currentPage="notifications" userEmail={session.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="mb-6">
          <a href="/doctor/dashboard/" class="text-sm text-blue-600 hover:text-blue-700 font-medium mb-2 inline-block">
            &larr; Back to Dashboard
          </a>
        </div>
        <DoctorNotifications client:load doctorId={doctor?.id} showBadge={true} />
      </div>
    </main>
  </div>
</Layout>
