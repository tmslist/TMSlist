---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import DoctorSidebar from "../../components/react/DoctorSidebar";
import DoctorCmeCredits from "../../components/react/DoctorCmeCredits";
import { getSessionFromRequest } from "../../utils/auth";
import { db } from "../../db";
import { doctors, doctorCmeCredits } from "../../db/schema";
import { eq } from "drizzle-orm";

const session = getSessionFromRequest(Astro.request);
if (!session) return Astro.redirect("/portal/login/");

// Note: 'doctor' is not a DB role — clinic_owners with a clinicId are doctors
const isDoctor = session.clinicId != null;
const isAdmin = ['admin', 'editor'].includes(session.role);
if (!isDoctor && !isAdmin) return Astro.redirect("/portal/login/");

const doctorRows = session.clinicId
  ? await db.select().from(doctors).where(eq(doctors.clinicId, session.clinicId)).limit(1)
  : [];
const doctor = doctorRows[0] ?? null;

const cmeEntries = doctor
  ? await db.select().from(doctorCmeCredits).where(eq(doctorCmeCredits.doctorId, doctor.id))
  : [];
---

<Layout title="CME Credits | TMS List Doctor" noindex={true}>
  <div class="flex min-h-screen bg-[var(--paper2)]">
    <DoctorSidebar client:load currentPage="cme-credits" userEmail={session.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-5xl">
        {!doctor ? (
          <div class="max-w-lg mx-auto text-center py-16">
            <div class="bg-[var(--paper)] rounded-2xl shadow-sm border border-[var(--line)] p-8">
              <p class="text-[var(--muted)]">No doctor profile linked to your account.</p>
              <a href="/doctor/dashboard/" class="mt-4 inline-block text-sm text-[var(--ink)] hover:text-[var(--ink)]">Back to Dashboard</a>
            </div>
          </div>
        ) : (
          <DoctorCmeCredits client:load initialCredits={cmeEntries} doctorId={doctor.id} />
        )}
      </div>
    </main>
  </div>
</Layout>