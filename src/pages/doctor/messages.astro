---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import DoctorSidebar from "../../components/react/DoctorSidebar";
import DoctorMessages from "../../components/react/DoctorMessages";
import { getSessionFromRequest } from "../../utils/auth";
import { db } from "../../db";
import { doctors } from "../../db/schema";
import { eq } from "drizzle-orm";

const session = getSessionFromRequest(Astro.request);
if (!session) return Astro.redirect("/portal/login/");

const doctorRows = session.clinicId
  ? await db.select().from(doctors).where(eq(doctors.clinicId, session.clinicId)).limit(1)
  : [];
const doctor = doctorRows[0] ?? null;
---
<Layout title="Messages | Doctor Portal | TMS List" description="Communicate with your patients." noindex={true}>
  <div class="flex min-h-screen bg-[var(--paper2)]">
    <DoctorSidebar client:load currentPage="messages" userEmail={session.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="mb-6">
          <a href="/doctor/dashboard/" class="text-sm text-[var(--ink)] hover:text-[var(--ink)] font-medium mb-2 inline-block">
            &larr; Back to Dashboard
          </a>
          <h1 class="text-2xl font-semibold text-[var(--ink)]">Messages</h1>
          <p class="text-[var(--muted)] text-sm mt-1">Communicate with your patients</p>
        </div>
        <DoctorMessages client:load doctorId={doctor?.id} clinicId={doctor?.clinicId} />
      </div>
    </main>
  </div>
</Layout>
