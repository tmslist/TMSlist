---
import Layout from "../../layouts/Layout.astro";
import { getAllClinics } from "../../utils/clinicData";
import { getDoctorPhoto } from "../../utils/dataHelpers";

export async function getStaticPaths() {
    const allClinics = await getAllClinics();
    const paths: { params: { slug: string } }[] = [];
    const seenSlugs = new Set<string>();

    allClinics.forEach((clinic: any) => {
        if (clinic.verified && clinic.doctors_data && Array.isArray(clinic.doctors_data)) {
            clinic.doctors_data.forEach((doc: any) => {
                if (doc.slug && !seenSlugs.has(doc.slug)) {
                    seenSlugs.add(doc.slug);
                    paths.push({ params: { slug: doc.slug } });
                }
            });
        }
    });

    return paths;
}

const { slug } = Astro.params;

const allClinicsData = await getAllClinics();
let doctor: any = null;
let clinic: any = null;

for (const c of allClinicsData) {
    if (c.doctors_data && Array.isArray(c.doctors_data)) {
        const found = c.doctors_data.find((d: any) => d.slug === slug);
        if (found) {
            doctor = found;
            clinic = c;
            break;
        }
    }
}

if (!doctor) {
    return Astro.redirect("/specialists/");
}

const fullName = doctor.name || "Unknown Doctor";
const title = doctor.title || "TMS Specialist";
const school = doctor.school || "";
const yearsExperience = doctor.years_experience || 0;
const specialties = doctor.specialties || [];
const bioFocus = doctor.bio_focus || "TMS Therapy";
const imageUrl = getDoctorPhoto(doctor);
const bio = doctor.bio || `${fullName} is a ${title} specializing in TMS therapy at ${clinic?.name} in ${clinic?.city}, ${clinic?.state}.`;
const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Physician",
    name: fullName,
    image: imageUrl.startsWith("/") ? `https://tmslist.com${imageUrl}` : imageUrl,
    jobTitle: title,
    medicalSpecialty: specialties.length > 0 ? specialties[0] : "Transcranial Magnetic Stimulation",
    knowsAbout: specialties,
    description: bio.substring(0, 200),
    ...(school ? { alumniOf: { "@type": "EducationalOrganization", name: school } } : {}),
    ...(yearsExperience > 0 ? { yearsInPractice: yearsExperience } : {}),
    worksFor: {
        "@type": "MedicalClinic",
        name: clinic?.name,
        url: `https://tmslist.com/clinic/${clinic?.slug}`,
    },
    address: {
        "@type": "PostalAddress",
        streetAddress: clinic?.address,
        addressLocality: clinic?.city,
        addressRegion: clinic?.state,
        postalCode: clinic?.zip,
        addressCountry: clinic?.country || "US",
    },
    telephone: clinic?.contact?.phone || clinic?.phone,
});
---

<Layout
    title={`${fullName} - TMS Specialist | TMS List`}
    description={`${fullName} is a ${title} specializing in TMS therapy at ${clinic?.name || "TMS Clinic"}. Book a consultation today.`}
    schema={schema}
    breadcrumbs={[
        { name: "Home", url: "/" },
        { name: "Specialists", url: "/specialists/" },
        { name: fullName, url: `/doctor/${slug}/` },
    ]}
>
    <!-- Hero Section — Light Theme -->
    <section class="relative bg-white border-b border-slate-100 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-cyan-50/30 pointer-events-none"></div>
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-violet-500/5 rounded-full blur-[120px]"></div>

        <div class="container mx-auto px-4 py-12 lg:py-16 relative z-10">
            <!-- Breadcrumb -->
            <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
                <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <a href="/specialists/" class="hover:text-violet-600 transition-colors">Specialists</a>
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <span class="text-slate-700 font-medium">{fullName}</span>
            </nav>

            <div class="max-w-5xl mx-auto">
                <div class="flex flex-col md:flex-row gap-8 items-center md:items-start">
                    <!-- Doctor Image -->
                    <div class="relative shrink-0">
                        <div class="w-40 h-40 md:w-52 md:h-52 rounded-2xl overflow-hidden border-2 border-slate-100 shadow-[0_8px_30px_rgb(0,0,0,0.06)]">
                            <img
                                src={imageUrl}
                                alt={`${fullName} - ${title}`}
                                width="208"
                                height="208"
                                class="w-full h-full object-cover"
                                loading="eager"
                            />
                        </div>
                        {yearsExperience > 0 && (
                            <div class="absolute -bottom-3 -right-3 px-3 py-1.5 bg-violet-600 text-white text-xs font-bold rounded-xl shadow-lg shadow-violet-600/30">
                                {yearsExperience}+ Years
                            </div>
                        )}
                    </div>

                    <!-- Doctor Info -->
                    <div class="text-center md:text-left flex-1">
                        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 mb-2">
                            {fullName}
                        </h1>
                        <p class="text-lg text-violet-600 font-semibold mb-4">{title}</p>

                        {school && (
                            <div class="flex items-center justify-center md:justify-start gap-2 text-sm text-slate-500 mb-4">
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>
                                {school}
                            </div>
                        )}

                        <div class="flex flex-wrap justify-center md:justify-start gap-2 mb-6">
                            {specialties.map((spec: string) => (
                                <span class="px-3 py-1 bg-violet-50 border border-violet-100 rounded-lg text-violet-700 text-sm font-medium">
                                    {spec}
                                </span>
                            ))}
                        </div>

                        {clinic && (
                            <a href={`/clinic/${clinic.slug}/`} class="inline-flex items-center gap-2.5 px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm text-slate-600 hover:border-violet-200 hover:text-violet-600 transition-all shadow-sm group">
                                <svg class="w-4 h-4 text-slate-400 group-hover:text-violet-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                                <span class="font-medium">{clinic.name}</span>
                                <span class="text-slate-400">·</span>
                                <span>{clinic.city}, {clinic.state}</span>
                            </a>
                        )}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <section class="py-12 lg:py-16">
        <div class="container mx-auto px-4">
            <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Left Column -->
                <div class="lg:col-span-2 space-y-6">
                    <!-- About -->
                    <div class="bg-white rounded-2xl p-6 lg:p-8 border border-slate-100 shadow-sm">
                        <h2 class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-2">
                            <div class="w-8 h-8 rounded-lg bg-violet-50 flex items-center justify-center text-violet-600">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            </div>
                            About {doctor.first_name || fullName.split(" ")[0]}
                        </h2>
                        <div class="text-slate-600 leading-relaxed space-y-4">
                            <p>{bio}</p>
                            {bio === `${fullName} is a ${title} specializing in TMS therapy at ${clinic?.name} in ${clinic?.city}, ${clinic?.state}.` && (
                                <p>With over {yearsExperience} years of experience, {doctor.first_name || "they"} provides compassionate care and cutting-edge TMS treatment for patients seeking relief from treatment-resistant conditions.</p>
                            )}
                        </div>
                    </div>

                    <!-- Specialties -->
                    {specialties.length > 0 && (
                        <div class="bg-white rounded-2xl p-6 lg:p-8 border border-slate-100 shadow-sm">
                            <h2 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
                                <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                                </div>
                                Areas of Expertise
                            </h2>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                {specialties.map((spec: string) => (
                                    <div class="flex items-center gap-3 p-3.5 bg-slate-50 rounded-xl border border-slate-100">
                                        <div class="w-8 h-8 bg-violet-100 rounded-lg flex items-center justify-center text-violet-600 shrink-0">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                                        </div>
                                        <span class="font-medium text-slate-700 text-sm">{spec}</span>
                                    </div>
                                ))}
                            </div>
                        </div>
                    )}

                    <!-- Clinic Info -->
                    {clinic && (
                        <div class="bg-white rounded-2xl p-6 lg:p-8 border border-slate-100 shadow-sm">
                            <h2 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2">
                                <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center text-emerald-600">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                </div>
                                Practice Location
                            </h2>
                            <a href={`/clinic/${clinic.slug}/`} class="block group">
                                <div class="flex items-start gap-4 p-5 bg-gradient-to-br from-violet-50/50 to-cyan-50/50 rounded-xl border border-violet-100/50 group-hover:shadow-md group-hover:border-violet-200 transition-all">
                                    <div class="w-14 h-14 bg-violet-600 rounded-xl flex items-center justify-center text-white shrink-0">
                                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                                    </div>
                                    <div>
                                        <h3 class="text-lg font-semibold text-slate-800 group-hover:text-violet-600 transition-colors mb-1">{clinic.name}</h3>
                                        <p class="text-slate-500 text-sm mb-1">{clinic.address}, {clinic.city}, {clinic.state} {clinic.zip}</p>
                                        {(clinic.contact?.phone || clinic.phone) && (
                                            <p class="text-violet-600 font-medium text-sm">{clinic.contact?.phone || clinic.phone}</p>
                                        )}
                                    </div>
                                </div>
                            </a>
                        </div>
                    )}
                </div>

                <!-- Right Column — Contact -->
                <div class="lg:col-span-1">
                    <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm sticky top-20">
                        <div class="text-center mb-5">
                            <div class="w-12 h-12 rounded-xl bg-violet-50 flex items-center justify-center text-violet-600 mx-auto mb-3">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                            </div>
                            <h3 class="text-lg font-bold text-slate-900">Request a Consultation</h3>
                            <p class="text-xs text-slate-400 mt-1">Free, no-obligation inquiry</p>
                        </div>

                        <form id="contact-form" class="space-y-3">
                            <input type="hidden" name="source" value={`doctor-${slug}`} />
                            <input type="hidden" name="doctorName" value={fullName} />
                            <input type="hidden" name="clinicName" value={clinic?.name || ""} />

                            <div>
                                <label for="contact-name" class="sr-only">Your Name</label>
                                <input type="text" id="contact-name" name="name" placeholder="Your Name" required
                                    class="w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-500/20 transition-all" />
                            </div>
                            <div>
                                <label for="contact-email" class="sr-only">Email Address</label>
                                <input type="email" id="contact-email" name="email" placeholder="Email Address" required
                                    class="w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-500/20 transition-all" />
                            </div>
                            <div>
                                <label for="contact-phone" class="sr-only">Phone Number</label>
                                <input type="tel" id="contact-phone" name="phone" placeholder="Phone Number"
                                    class="w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-500/20 transition-all" />
                            </div>
                            <div>
                                <label for="contact-message" class="sr-only">Message</label>
                                <textarea id="contact-message" name="message" placeholder="Tell us about your needs..." rows="3"
                                    class="w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-violet-500 focus:ring-2 focus:ring-violet-500/20 resize-none transition-all"></textarea>
                            </div>
                            <button type="submit"
                                class="dark-section w-full py-3 bg-gradient-to-r from-violet-600 to-violet-700 hover:from-violet-500 hover:to-violet-600 font-semibold rounded-xl transition-all shadow-lg shadow-violet-500/20 text-sm">
                                Send Request
                            </button>
                        </form>
                        <p class="text-[11px] text-slate-400 mt-3 text-center">By submitting, you agree to our privacy policy.</p>

                        <div id="success-message" class="hidden mt-4 p-4 bg-emerald-50 border border-emerald-200 rounded-xl text-center">
                            <svg class="w-6 h-6 text-emerald-500 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            <p class="text-emerald-700 font-medium text-sm">Request sent successfully!</p>
                            <p class="text-emerald-600 text-xs mt-0.5">We'll get back to you shortly.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Medical Disclaimer -->
    <div class="container mx-auto px-6 lg:px-12 py-8">
        <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 max-w-4xl mx-auto">
            <p class="text-sm text-amber-800 leading-relaxed">
                <strong>Medical Disclaimer:</strong> The information on this page is for informational purposes only.
                Always consult directly with a healthcare provider before starting any treatment.
                Provider credentials and availability should be verified directly.
                <a href="/legal/medical-disclaimer/" class="underline hover:text-amber-900 font-medium">Read full disclaimer</a>.
            </p>
        </div>
    </div>
</Layout>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const form = document.getElementById("contact-form") as HTMLFormElement;
        const successMsg = document.getElementById("success-message");

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();

            const formData = new FormData(form);

            try {
                const res = await fetch('/api/leads', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        type: 'specialist_enquiry',
                        name: formData.get('name'),
                        email: formData.get('email'),
                        phone: formData.get('phone'),
                        message: formData.get('message'),
                        doctorName: formData.get('doctorName'),
                        clinicName: formData.get('clinicName'),
                        sourceUrl: window.location.href,
                    }),
                });

                if (res.ok) {
                    form.style.display = "none";
                    successMsg?.classList.remove("hidden");
                } else {
                    (window as any).showToast?.("Something went wrong. Please try again.");
                }
            } catch {
                (window as any).showToast?.("Something went wrong. Please try again.");
            }
        });
    });
</script>
