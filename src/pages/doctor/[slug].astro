---
import { getAllClinics } from "../../utils/clinicData";

const { slug } = Astro.params;

// /doctor/[slug] is a legacy route — 301 redirect to canonical /specialist/[slug]
const allClinicsData = await getAllClinics();
let found = false;

for (const c of allClinicsData) {
    if (c.doctors_data && Array.isArray(c.doctors_data)) {
        if (c.doctors_data.find((d: any) => d.slug === slug)) {
            found = true;
            break;
        }
    }
}

if (!found) {
    return Astro.redirect("/specialists/");
}

return Astro.redirect(`/specialist/${slug}/`, 301);
---
