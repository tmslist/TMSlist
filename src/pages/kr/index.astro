---
import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import LocationSEOContent from '../../components/LocationSEOContent.astro';
import { getClinicsByCountry, COUNTRY_NAMES } from '../../utils/dataHelpers';
import { COUNTRY_META } from '../../utils/countryData';
import { t } from '../../utils/i18n';
const locale = 'ko' as const;

const countryCode = 'KR';
const meta = COUNTRY_META[countryCode];
const clinics = await getClinicsByCountry(countryCode);
const totalClinics = clinics.length;

const regionMap = new Map<string, number>();
clinics.forEach(c => {
    if (!c.state) return;
    regionMap.set(c.state, (regionMap.get(c.state) || 0) + 1);
});

const regions = [...regionMap.entries()]
    .map(([name, count]) => ({
        name,
        slug: name.toLowerCase().replace(/\s+/g, '-'),
        count,
    }))
    .sort((a, b) => a.name.localeCompare(b.name));

const title = `TMS Therapy Clinics in South Korea | ${totalClinics} Verified Providers`;
const description = `Browse ${totalClinics} TMS therapy clinics across ${regions.length} regions in South Korea. ${meta.seoDescription}`;

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "TMS Therapy Clinics in South Korea",
    "description": description,
    "url": "https://tmslist.com/kr/",
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": regions.length,
        "itemListElement": regions.map((r, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "name": `TMS Clinics in ${r.name}, South Korea`,
            "url": `https://tmslist.com/kr/${r.slug}/`
        }))
    }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "South Korea", url: "/kr/" },
]}>
    <main>
        <!-- Hero Section -->
        <EditorialHero
            eyebrow={`${totalClinics}+ Verified Clinics · ${regions.length} Regions`}
            eyebrowDot="#22c55e"
            title="TMS therapy in"
            titleAccent="South Korea."
            description={`Browse ${totalClinics}+ ${meta.tmsStatus} TMS providers across ${regions.length} regions. Find top-rated clinics for depression, anxiety, OCD, and more.`}
            breadcrumbs={[
                { label: "Home", href: "/" },
                { label: "South Korea" },
            ]}
            ctas={[
                { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
                { label: "Browse All Clinics", href: "/kr/", variant: "outline" },
            ]}
            stats={[
                { value: `${totalClinics}+`, label: "Clinics", color: "ink" },
                { value: regions.length, label: "Regions", color: "accent" },
                { value: meta.tmsStatus.length > 12 ? "FDA-Like" : meta.tmsStatus, label: "Status", color: "warm" },
            ]}
        />

        <!-- Content -->
        <div class="container mx-auto px-4 py-8">

        <!-- Key Facts -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
            <div class="bg-[var(--paper)] rounded-xl border border-[var(--line)] p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-[var(--accent)]">{totalClinics}</div>
                <div class="text-sm text-[var(--muted)] font-medium">Clinics</div>
            </div>
            <div class="bg-[var(--paper)] rounded-xl border border-[var(--line)] p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-[var(--accent)]">{regions.length}</div>
                <div class="text-sm text-[var(--muted)] font-medium">Regions</div>
            </div>
            <div class="bg-[var(--paper)] rounded-xl border border-[var(--line)] p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-[var(--accent)]">{meta.publicHealthSystem}</div>
                <div class="text-sm text-[var(--muted)] font-medium">Public Health</div>
            </div>
            <div class="bg-[var(--paper)] rounded-xl border border-[var(--line)] p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-[var(--accent)]">{meta.sessionCostRange}</div>
                <div class="text-sm text-[var(--muted)] font-medium">Per Session</div>
            </div>
        </div>

        <div class="flex items-center mb-8">
            <h2 class="text-2xl font-semibold text-[var(--ink)]">지역별 검색</h2>
            <div class="ml-4 h-px flex-1 bg-[var(--paper2)]"></div>
            <span class="ml-4 text-sm font-medium text-[var(--muted)]">{regions.length} regions</span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {regions.map((region) => (
                <a href={`/kr/${region.slug}/`} class="block p-4 bg-[var(--paper)] rounded-lg border border-[var(--line)] hover:border-[var(--ink2)] hover:shadow-md transition-all group">
                    <span class="text-lg font-medium text-[var(--ink2)] group-hover:text-[var(--accent)]">{region.name}</span>
                    <span class="block text-sm text-[var(--muted)] mt-1">{region.count} {region.count === 1 ? 'clinic' : 'clinics'}</span>
                </a>
            ))}
        </div>

        <!-- SEO Content -->
        <LocationSEOContent type="country" locationName="South Korea" clinicCount={totalClinics} countryCode="KR" />
        </div>
    </main>
</Layout>

<script>
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;
    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }
    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });
</script>
