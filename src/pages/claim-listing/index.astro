---
import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';

const title = "Claim Your TMS Clinic Listing | Manage Your Profile | TMS List";
const description = "Claim your TMS clinic listing on TMS List. Manage your profile, respond to patient reviews, track leads, and get verified badge. Free for all providers.";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Claim Your Clinic Listing",
    "description": description,
    "publisher": {
        "@type": "Organization",
        "name": "TMS List",
        "url": "https://tmslist.com"
    }
});

const benefits = [
    { title: "Verified Badge", desc: "Stand out with a verified checkmark that tells patients your information is confirmed and up to date.", icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", color: "emerald" },
    { title: "Lead Notifications", desc: "Get real-time email and SMS alerts when patients request appointments or submit inquiries through your listing.", icon: "M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9", color: "violet" },
    { title: "Performance Analytics", desc: "Track profile views, search impressions, inquiry volume, and how you compare to nearby competitors.", icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z", color: "blue" },
    { title: "Edit Your Profile", desc: "Update contact info, services offered, insurance accepted, hours, photos, and doctor bios at any time.", icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z", color: "amber" },
    { title: "Review Management", desc: "Respond to patient reviews publicly, flag inappropriate content, and showcase your commitment to patient care.", icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z", color: "cyan" },
    { title: "Priority Placement", desc: "Verified clinics with complete profiles rank higher in search results, increasing your visibility to patients.", icon: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6", color: "rose" },
];

const colorMap: Record<string, { bg: string; text: string }> = {
    emerald: { bg: 'bg-emerald-50', text: 'text-emerald-600' },
    violet: { bg: 'bg-[rgba(10,22,40,0.08)]', text: 'text-[var(--accent)]' },
    blue: { bg: 'bg-[var(--paper2)]', text: 'text-[var(--accent)]' },
    amber: { bg: 'bg-amber-50', text: 'text-amber-600' },
    cyan: { bg: 'bg-[var(--paper2)]', text: 'text-[var(--accent)]' },
    rose: { bg: 'bg-[rgba(201,101,74,0.06)]', text: 'text-[var(--warm)]' },
    default: { bg: 'bg-[var(--paper2)]', text: 'text-[var(--muted)]' },
};
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Claim Listing", url: "/claim-listing/" },
]}>
    <main style="background:var(--paper)">
        <EditorialHero
            eyebrow="Free for Providers"
            eyebrowDot="#22c55e"
            title="Claim your"
            titleAccent="clinic listing."
            description="Take control of your TMS List profile. Manage your information, respond to reviews, track patient inquiries, and grow your practice with verified status."
            breadcrumbs={[{ label: "Home", href: "/" }, { label: "Claim Listing" }]}
            ctas={[
                { label: "Start Claim", href: "#claim-form" },
                { label: "Add New Listing", href: "/add-listing/", variant: "outline" },
            ]}
            stats={[
                { value: "1,250+", label: "Clinics Listed", color: "ink" },
                { value: "Free", label: "To Claim", color: "accent" },
                { value: "Verified", label: "Trust Badge", color: "warm" },
            ]}
        />

        <!-- 3-Step Process -->
        <section class="py-16 lg:py-24 bg-[var(--paper)]">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="text-center mb-16">
                    <h2 class="text-3xl lg:text-4xl font-bold text-[var(--ink)] tracking-tight mb-4">Three Simple Steps</h2>
                    <p class="text-[var(--muted)] max-w-2xl mx-auto">Claiming your listing takes less than 5 minutes. Here is how it works.</p>
                </div>

                <div class="grid md:grid-cols-3 gap-8">
                    <div class="relative text-center">
                        <div class="w-16 h-16 rounded-2xl bg-[var(--ink)] text-white flex items-center justify-center mx-auto mb-6">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <div class="absolute top-8 left-[60%] right-[-40%] h-0.5 bg-gradient-to-r from-[rgba(10,22,40,0.15)] to-transparent hidden md:block"></div>
                        <span class="inline-block px-3 py-1 bg-[rgba(10,22,40,0.08)] text-[var(--accent)] text-xs font-bold rounded-full mb-3">Step 1</span>
                        <h3 class="text-xl font-bold text-[var(--ink)] mb-2">Search</h3>
                        <p class="text-[var(--muted)] text-sm leading-relaxed">Find your clinic in our directory by name, address, or phone number. If your clinic is not listed, you can add it for free.</p>
                    </div>

                    <div class="relative text-center">
                        <div class="w-16 h-16 rounded-2xl bg-emerald-600 text-white flex items-center justify-center mx-auto mb-6">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                        </div>
                        <div class="absolute top-8 left-[60%] right-[-40%] h-0.5 bg-gradient-to-r from-emerald-200 to-transparent hidden md:block"></div>
                        <span class="inline-block px-3 py-1 bg-emerald-50 text-emerald-600 text-xs font-bold rounded-full mb-3">Step 2</span>
                        <h3 class="text-xl font-bold text-[var(--ink)] mb-2">Verify</h3>
                        <p class="text-[var(--muted)] text-sm leading-relaxed">Confirm ownership via phone verification, email domain match, or documentation upload. Verification usually completes within 24 hours.</p>
                    </div>

                    <div class="text-center">
                        <div class="w-16 h-16 rounded-2xl bg-[var(--accent)] text-white flex items-center justify-center mx-auto mb-6">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        </div>
                        <span class="inline-block px-3 py-1 bg-[var(--paper2)] text-[var(--accent)] text-xs font-bold rounded-full mb-3">Step 3</span>
                        <h3 class="text-xl font-bold text-[var(--ink)] mb-2">Manage</h3>
                        <p class="text-[var(--muted)] text-sm leading-relaxed">Access your dashboard to update your profile, respond to reviews, view analytics, and manage your listing at any time.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Benefits Grid -->
        <section class="py-16 lg:py-24 bg-[var(--paper2)]">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-bold text-[var(--ink)] tracking-tight mb-4">Why Claim Your Listing?</h2>
                    <p class="text-[var(--muted)] max-w-2xl mx-auto">Verified clinics see significantly more patient inquiries. Here is what you get when you claim your profile.</p>
                </div>

                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {benefits.map((b) => (
                        <div class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] p-6 hover:shadow-md hover:border-[var(--line)] transition-all">
                            <div class={`w-12 h-12 rounded-xl ${(colorMap[b.color] ?? colorMap.default).bg} ${(colorMap[b.color] ?? colorMap.default).text} flex items-center justify-center mb-4`}>
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={b.icon}/></svg>
                            </div>
                            <h3 class="text-lg font-bold text-[var(--ink)] mb-2">{b.title}</h3>
                            <p class="text-[var(--muted)] text-sm leading-relaxed">{b.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="relative py-20 bg-[var(--ink)] overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-emerald-600/10 via-transparent to-[#0A1628]/10"></div>
            <div class="container mx-auto px-4 text-center relative z-10">
                <p class="text-sm font-semibold text-emerald-400 tracking-wider uppercase mb-4">Ready to Get Started?</p>
                <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4 tracking-tight">Claim your listing today</h2>
                <p class="text-[var(--muted)] max-w-lg mx-auto mb-10">Search for your clinic in our directory or add a new listing. It is free and takes less than 5 minutes.</p>
                <div class="flex items-center justify-center gap-4 flex-wrap">
                    <a href="/us/" class="px-8 py-4 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold rounded-xl transition-colors shadow-lg shadow-emerald-600/25">
                        Search for Your Clinic
                    </a>
                    <a href="/add-listing/" class="px-8 py-4 bg-[var(--paper)]/5 border border-white/10 hover:border-white/25 text-white font-semibold rounded-xl transition-all backdrop-blur">
                        Add New Listing
                    </a>
                </div>
            </div>
        </section>

        <!-- Learn More -->
        <section class="py-8 bg-[var(--paper)] border-t border-[var(--line)]">
            <div class="container mx-auto px-4 text-center">
                <p class="text-sm text-[var(--muted)] mb-4">Learn more about TMS therapy:</p>
                <div class="flex flex-wrap justify-center gap-2">
                    <a href="/blog/tms-for-depression/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">TMS for Depression</a>
                    <a href="/blog/tms-cost-insurance-guide-2026/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Cost &amp; Insurance</a>
                    <a href="/blog/questions-to-ask-tms-clinic/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Questions to Ask</a>
                    <a href="/blog/preparing-for-first-tms-session/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">First Session Guide</a>
                    <a href="/blog/maintenance-tms-guide/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Maintenance TMS</a>
                    <a href="/blog/" class="px-3 py-1.5 text-xs font-medium text-[var(--accent)] hover:underline">View all articles →</a>
                </div>
            </div>
        </section>
    </main>
</Layout>
