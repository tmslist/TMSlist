---
import Layout from "../../layouts/Layout.astro";

const resources = [
    {
        title: "TMS Patient Guide",
        description:
            "Everything you need to know about TMS therapy in one comprehensive guide. From your first consultation to your final session.",
        type: "PDF Guide",
        icon: "guide",
        cta: "Download Free Guide",
        featured: true,
    },
    {
        title: "Insurance Authorization Checklist",
        description:
            "Step-by-step checklist to help you navigate the insurance pre-authorization process for TMS therapy.",
        type: "Checklist",
        icon: "checklist",
        cta: "Get Checklist",
    },
    {
        title: "Questions to Ask Your Doctor",
        description:
            "25 essential questions to ask during your TMS consultation to ensure you find the right provider.",
        type: "Printable",
        icon: "questions",
        cta: "Download Questions",
    },
    {
        title: "TMS Session Tracker",
        description:
            "Track your mood, side effects, and progress throughout your TMS treatment course.",
        type: "Tracker",
        icon: "tracker",
        cta: "Get Tracker",
    },
    {
        title: "Cost Comparison Calculator",
        description:
            "Estimate your out-of-pocket costs for TMS therapy based on your insurance and location.",
        type: "Tool",
        icon: "calculator",
        cta: "Calculate Costs",
    },
    {
        title: "Provider Research Template",
        description:
            "Organize your research on different TMS clinics with this comparison spreadsheet.",
        type: "Template",
        icon: "template",
        cta: "Download Template",
    },
];

const featuredResource = resources.find((r) => r.featured);
const otherResources = resources.filter((r) => !r.featured);
---

<Layout title="Free TMS Resources & Guides | TMS List" description="TMS therapy resources, guides, and educational materials for patients and providers.">
    <!-- Hero -->
    <section class="relative bg-white border-b border-slate-100 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
        <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
        <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
            <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8" aria-label="Breadcrumb">
                <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                <span class="text-slate-700 font-medium">Resources</span>
            </nav>
            <div class="max-w-3xl">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-50 border border-emerald-100 rounded-full mb-6">
                    <span class="flex h-2 w-2 rounded-full bg-emerald-500"></span>
                    <span class="text-xs font-semibold text-emerald-700 tracking-wide">Free Resources</span>
                </div>
                <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 mb-4 leading-tight">
                    Patient <span class="text-violet-600">Resources</span> & Tools
                </h1>
                <p class="text-lg text-slate-500 leading-relaxed max-w-2xl">
                    Free guides, checklists, and tools to help you navigate your TMS therapy journey with confidence.
                </p>
            </div>
        </div>
    </section>

    <main class="container mx-auto px-6 py-16">
        <!-- Featured Resource -->
        {
            featuredResource && (
                <div class="dark-section bg-gradient-to-r from-violet-700 to-violet-500 rounded-3xl p-8 md:p-12 mb-16 relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-1/2 h-full bg-[url('/images/brain_stimulation_art_1769446474392.jpg')] bg-cover bg-center opacity-20" />
                    <div class="relative z-10 max-w-2xl">
                        <span class="inline-block px-3 py-1 bg-white/20 rounded-full text-sm font-semibold mb-4">
                            Featured Resource
                        </span>
                        <h2 class="text-3xl md:text-4xl font-semibold mb-4">
                            {featuredResource.title}
                        </h2>
                        <p class="text-violet-100 text-lg mb-8">
                            {featuredResource.description}
                        </p>
                        <button class="px-8 py-4 bg-white text-violet-600 font-semibold rounded-xl hover:bg-gray-100 transition-colors shadow-[0_4px_20px_rgb(0,0,0,0.03)]">
                            {featuredResource.cta}
                        </button>
                    </div>
                </div>
            )
        }

        <!-- Resource Grid -->
        <h2 class="text-2xl font-semibold text-gray-900 mb-8">All Resources</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {
                otherResources.map((resource) => (
                    <div class="bg-white rounded-2xl border border-gray-100 p-6 hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all duration-300 group">
                        <div class="flex items-start gap-4 mb-4">
                            <div class="w-12 h-12 rounded-xl bg-violet-50 flex items-center justify-center text-violet-600 shrink-0">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                            </div>
                            <div>
                                <span class="text-xs font-semibold text-violet-600 uppercase tracking-wider">
                                    {resource.type}
                                </span>
                                <h3 class="text-xl font-semibold text-gray-900 group-hover:text-violet-600 transition-colors">
                                    {resource.title}
                                </h3>
                            </div>
                        </div>
                        <p class="text-gray-600 mb-6">{resource.description}</p>
                        <button class="w-full py-3 bg-gray-100 text-gray-700 font-semibold rounded-xl hover:bg-violet-600 hover:text-white transition-colors">
                            {resource.cta}
                        </button>
                    </div>
                ))
            }
        </div>

        <!-- Lead Capture CTA -->
        <div
            class="mt-20 bg-gray-50 rounded-3xl p-10 text-center border border-gray-100"
        >
            <h3 class="text-3xl font-semibold text-gray-900 mb-4">
                Need Personalized Help?
            </h3>
            <p class="text-gray-600 mb-8 max-w-xl mx-auto">
                Take our eligibility quiz to find out if TMS is right for you,
                or browse our directory to find verified clinics near you.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a
                    href="/quiz/am-i-a-candidate/"
                    class="px-8 py-4 bg-violet-600 text-white font-semibold rounded-xl hover:bg-violet-700 transition-colors"
                    >Take Eligibility Quiz</a
                >
                <a
                    href="/us/"
                    class="px-8 py-4 bg-white border-2 border-gray-200 text-gray-700 font-semibold rounded-xl hover:border-violet-600 hover:text-violet-600 transition-colors"
                    >Find a Clinic</a
                >
            </div>
        </div>
    </main>
</Layout>
