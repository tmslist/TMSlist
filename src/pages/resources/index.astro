---
import Layout from "../../layouts/Layout.astro";
import { LEAD_MAGNETS } from "../../utils/leadMagnets";

const patientGuides = [
    {
        title: "The Complete TMS Buyer's Guide",
        description: "Everything you need to know about TMS therapy — choosing a provider, what to expect, insurance coverage, and real patient outcomes.",
        type: "PDF Guide",
        format: "24 pages",
        cta: "Download Free Guide",
        url: "/downloads/tms-buyers-guide.pdf",
        icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
        featured: true,
        accent: "#4f46e5",
        slug: "tms-buyers-guide",
    },
    {
        title: "Insurance Coverage Checklist",
        description: "Step-by-step checklist to navigate insurance pre-authorization for TMS therapy — with payer-specific requirements and appeal workflows.",
        type: "Checklist",
        format: "8 pages",
        cta: "Download Checklist",
        url: "/downloads/insurance-checklist.pdf",
        icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
        featured: false,
        accent: "#059669",
        slug: "insurance-checklist",
    },
    {
        title: "TMS vs Medication Comparison",
        description: "Side-by-side comparison of TMS therapy vs antidepressant medications — effectiveness, side effects, cost, and decision framework.",
        type: "Comparison Chart",
        format: "6 pages",
        cta: "Download Comparison",
        url: "/downloads/tms-vs-medication.pdf",
        icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
        featured: false,
        accent: "#0891b2",
        slug: "tms-vs-medication",
    },
    {
        title: "Questions to Ask Your TMS Doctor",
        description: "25 essential questions to ask during your TMS consultation — from device type to expected outcomes to maintenance plans.",
        type: "Printable Checklist",
        format: "25 questions",
        cta: "View Questions",
        url: "/questions/",
        icon: "M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
        featured: false,
        accent: "#7c3aed",
        slug: "questions",
    },
    {
        title: "Am I a Candidate? Assessment",
        description: "Take our 5-question quiz to find out if TMS therapy might be right for you — based on the same criteria psychiatrists use.",
        type: "Interactive Quiz",
        format: "2 minutes",
        cta: "Start Quiz",
        url: "/quiz/am-i-a-candidate/",
        icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
        featured: false,
        accent: "#ea580c",
        slug: "quiz",
    },
    {
        title: "TMS Cost Calculator",
        description: "Estimate your out-of-pocket TMS cost based on your insurance plan, deductible status, and location — with and without coverage.",
        type: "Calculator",
        format: "Interactive",
        cta: "Calculate Cost",
        url: "/tms-cost-calculator/",
        icon: "M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z",
        featured: false,
        accent: "#dc2626",
        slug: "calculator",
    },
];

const featured = patientGuides.find(r => r.featured);
const patientOthers = patientGuides.filter(r => !r.featured);

const categoryMeta: Record<string, {label: string, color: string, bg: string, icon: string}> = {
    billing:      { label: "Billing & Revenue",     color: "#059669", bg: "bg-emerald-50",  icon: "💳" },
    marketing:    { label: "Marketing & Growth",    color: "#2563eb", bg: "bg-blue-50",      icon: "📣" },
    operations:   { label: "Operations",            color: "#ea580c", bg: "bg-orange-50",   icon: "⚙️" },
    clinical:     { label: "Clinical",               color: "#dc2626", bg: "bg-red-50",      icon: "🧠" },
    compliance:   { label: "Compliance",             color: "#0891b2", bg: "bg-cyan-50",     icon: "⚖️" },
    growth:       { label: "Business Growth",         color: "#4f46e5", bg: "bg-violet-50",   icon: "📈" },
};

const formatIcons: Record<string, string> = {
    "Cheat Sheet":    "📋",
    "Playbook":       "🏁",
    "Template Kit":   "📁",
    "Checklist":      "✅",
    "PDF Guide":      "📘",
};
---

<Layout title="Free TMS Resources & Guides | TMS List" description="Free TMS therapy resources for patients and clinic owners — guides, checklists, calculators, and playbooks.">
    <main>
        <!-- Hero -->
        <section class="relative bg-slate-950 overflow-hidden">
            <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.3) 1px, transparent 0); background-size: 32px 32px;"></div>
            <div class="absolute top-[-10%] left-[20%] w-[500px] h-[500px] bg-emerald-600/10 rounded-full blur-[150px]"></div>
            <div class="absolute bottom-[10%] right-[15%] w-[400px] h-[400px] bg-violet-500/8 rounded-full blur-[120px]"></div>

            <div class="container mx-auto px-4 pt-12 pb-24 lg:pt-16 lg:pb-28 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-500 mb-12" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
                    <span class="text-slate-700">/</span>
                    <span class="text-slate-300">Resources</span>
                </nav>
                <div class="max-w-2xl">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-500/10 border border-emerald-500/20 rounded-full mb-6">
                        <div class="w-1.5 h-1.5 rounded-full bg-emerald-400"></div>
                        <span class="text-xs font-semibold text-emerald-400 tracking-wider uppercase">100% Free</span>
                    </div>
                    <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white leading-[0.95] mb-5">
                        TMS<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-400">Resources</span>
                    </h1>
                    <p class="text-lg text-slate-400 leading-relaxed">
                        Free guides, checklists, calculators, and playbooks for patients navigating TMS therapy and clinic owners growing their practice.
                    </p>
                </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-16 bg-white" style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"></div>
        </section>

        <section class="py-16 lg:py-20 bg-white">
            <div class="container mx-auto px-4 max-w-6xl">

                <!-- Featured Patient Guide -->
                {featured && (
                    <div class="relative bg-slate-950 rounded-3xl p-10 lg:p-14 mb-6 overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-r from-violet-600/20 via-transparent to-emerald-600/15"></div>
                        <div class="absolute top-1/2 right-[8%] -translate-y-1/2 w-[280px] h-[280px] rounded-full blur-[80px]" style="background: rgba(79,70,229,0.08);"></div>
                        <div class="relative z-10 flex flex-col lg:flex-row items-start lg:items-center gap-8">
                            <div class="w-16 h-16 rounded-2xl flex items-center justify-center shrink-0" style="background: rgba(79,70,229,0.3);">
                                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={featured.icon}/></svg>
                            </div>
                            <div class="flex-1">
                                <div class="flex items-center gap-3 mb-3">
                                    <span class="px-3 py-1 bg-emerald-500 text-white text-[10px] font-bold uppercase tracking-widest rounded-md">Featured Guide</span>
                                    <span class="text-slate-500 text-sm">{featured.format}</span>
                                </div>
                                <h2 class="text-2xl lg:text-3xl font-bold text-white mb-3 tracking-tight">{featured.title}</h2>
                                <p class="text-slate-400 leading-relaxed mb-6">{featured.description}</p>
                                <a href={featured.url} class="inline-block px-8 py-3.5 bg-white text-slate-900 font-semibold rounded-xl hover:bg-slate-100 transition-colors shadow-lg" download>
                                    {featured.cta} ↓
                                </a>
                            </div>
                        </div>
                    </div>
                )}

                <!-- Patient Resources Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
                    {patientOthers.map(guide => (
                        <a href={guide.url} class="group bg-white rounded-2xl border border-slate-100 p-6 hover:border-slate-200 hover:shadow-[0_16px_48px_-12px_rgba(0,0,0,0.1)] transition-all duration-300 block">
                            <div class="flex items-start justify-between mb-4">
                                <div class="w-11 h-11 rounded-xl flex items-center justify-center text-white" style={`background: ${guide.accent};`}>
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={guide.icon}/></svg>
                                </div>
                                <span class="px-2 py-0.5 bg-slate-100 text-slate-500 text-[10px] font-bold uppercase tracking-wider rounded">{guide.format}</span>
                            </div>
                            <span class="text-[10px] font-bold uppercase tracking-wider" style={`color: ${guide.accent};`}>{guide.type}</span>
                            <h3 class="text-base font-bold text-slate-900 group-hover:text-slate-700 transition-colors mt-1 mb-2">{guide.title}</h3>
                            <p class="text-sm text-slate-500 leading-relaxed mb-4 line-clamp-3">{guide.description}</p>
                            <div class="flex items-center gap-1 text-sm font-semibold" style={`color: ${guide.accent};`}>
                                {guide.cta}
                                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                            </div>
                        </a>
                    ))}
                </div>

                <!-- Divider -->
                <div class="flex items-center gap-4 mb-12">
                    <div class="flex-1 h-px bg-slate-200"></div>
                    <div class="flex items-center gap-2 px-4 py-1.5 bg-slate-100 rounded-full">
                        <span class="text-xs font-bold text-slate-500 uppercase tracking-wider">For TMS Clinic Owners & Providers</span>
                    </div>
                    <div class="flex-1 h-px bg-slate-200"></div>
                </div>

                <!-- Provider Lead Magnets -->
                <div class="mb-12">
                    <div class="flex items-center justify-between mb-6">
                        <div>
                            <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Free Downloads for TMS Professionals</h2>
                            <p class="text-sm text-slate-500 mt-1">Business, billing, and clinical resources for TMS clinic owners and operators.</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {LEAD_MAGNETS.map(magnet => {
                            const meta = categoryMeta[magnet.category];
                            return (
                                <a href={`/resources/${magnet.slug}/`} class="group flex items-start gap-4 bg-white rounded-2xl border border-slate-100 p-6 hover:border-slate-200 hover:shadow-lg transition-all duration-300 block">
                                    <div class="w-12 h-12 rounded-xl flex items-center justify-center text-lg shrink-0 mt-0.5" style={`background: ${magnet.accent}15;`}>
                                        {formatIcons[magnet.format] || "📄"}
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <div class="flex flex-wrap items-center gap-2 mb-1.5">
                                            <span class="text-[10px] font-bold uppercase tracking-wider rounded px-2 py-0.5" style={`background: ${magnet.accent}15; color: ${magnet.accent};`}>
                                                {meta.label}
                                            </span>
                                            <span class="text-[10px] font-semibold text-slate-400">{magnet.format}</span>
                                            <span class="text-[10px] font-semibold text-slate-400">{magnet.pageCount}</span>
                                        </div>
                                        <h3 class="text-sm font-bold text-slate-900 group-hover:text-slate-700 transition-colors leading-snug">{magnet.title}</h3>
                                        <p class="text-xs text-slate-500 mt-1 leading-relaxed line-clamp-2">{magnet.subtitle}</p>
                                        <div class="mt-3 flex items-center gap-1 text-xs font-semibold" style={`color: ${magnet.accent};`}>
                                            Free Download
                                            <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                                        </div>
                                    </div>
                                </a>
                            );
                        })}
                    </div>
                </div>

                <!-- Category Breakdown -->
                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 mb-16">
                    {Object.entries(categoryMeta).map(([cat, meta]) => {
                        const count = LEAD_MAGNETS.filter(m => m.category === cat).length;
                        if (count === 0) return null;
                        return (
                            <div class="rounded-xl p-4 text-center border border-slate-100 hover:border-slate-200 hover:shadow-sm transition-all cursor-pointer">
                                <div class="text-2xl mb-1">{meta.icon}</div>
                                <div class="text-xs font-bold text-slate-700 mb-0.5">{count} {count === 1 ? "Resource" : "Resources"}</div>
                                <div class="text-[10px] text-slate-400">{meta.label}</div>
                            </div>
                        );
                    })}
                </div>

                <!-- CTA -->
                <div class="relative bg-slate-950 rounded-3xl p-10 lg:p-14 overflow-hidden text-center">
                    <div class="absolute inset-0 bg-gradient-to-r from-violet-600/10 via-transparent to-cyan-600/10"></div>
                    <div class="relative z-10">
                        <p class="text-sm font-semibold text-violet-400 tracking-wider uppercase mb-3">Need more help?</p>
                        <h3 class="text-2xl lg:text-3xl font-bold text-white mb-4 tracking-tight">Take the Eligibility Assessment</h3>
                        <p class="text-slate-400 max-w-lg mx-auto mb-8">Find out if TMS therapy is right for you, or browse our directory to find verified clinics near you.</p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <a href="/quiz/am-i-a-candidate/" class="px-8 py-4 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl transition-colors shadow-lg shadow-violet-600/25">Take the Quiz</a>
                            <a href="/us/" class="px-8 py-4 bg-white/5 border border-white/10 hover:border-white/25 text-white font-semibold rounded-xl transition-all backdrop-blur">Find a Clinic</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
