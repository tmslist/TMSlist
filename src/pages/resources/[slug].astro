---
import Layout from "../../layouts/Layout.astro";
import { LEAD_MAGNETS, getLeadMagnetBySlug } from "../../utils/leadMagnets";

export function getStaticPaths() {
  return LEAD_MAGNETS.map(m => ({
    params: { slug: m.slug },
    props: { magnet: m },
  }));
}

const { magnet } = Astro.props;

const pageTitle = `${magnet.title} | Free Download | TMS List`;
const metaDescription = magnet.description.substring(0, 155) + '...';

const categoryLabels: Record<string, string> = {
  billing: 'Billing & Revenue',
  marketing: 'Marketing & Growth',
  operations: 'Operations',
  clinical: 'Clinical',
  compliance: 'Compliance',
  growth: 'Business Growth',
};

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "DigitalDocument",
  "name": magnet.title,
  "description": magnet.description,
  "url": `https://tmslist.com/resources/${magnet.slug}`,
  "encodingFormat": "application/pdf",
  "provider": { "@type": "Organization", "name": "TMS List" },
});
---

<Layout title={pageTitle} description={metaDescription} schema={schema}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-white border-b border-slate-100">
    <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>

    <div class="relative container mx-auto px-6 lg:px-12 py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Left: Content -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <span class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider" style={`background: ${magnet.accent}20; color: ${magnet.accent};`}>
              {categoryLabels[magnet.category]}
            </span>
            <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-full text-xs font-bold uppercase tracking-wider">
              {magnet.format} · {magnet.pageCount}
            </span>
          </div>

          <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 mb-4 leading-tight">
            {magnet.title}
          </h1>
          <p class="text-lg text-slate-500 font-light leading-relaxed mb-8">
            {magnet.description}
          </p>

          <!-- Benefits -->
          <div class="space-y-3 mb-8">
            {magnet.benefits.map(benefit => (
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 shrink-0 mt-0.5" style={`color: ${magnet.accent};`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-sm text-slate-300">{benefit}</span>
              </div>
            ))}
          </div>

          <p class="text-xs text-slate-500 uppercase tracking-wider font-semibold">
            Trusted by 500+ TMS clinics nationwide
          </p>
        </div>

        <!-- Right: Download Form -->
        <div class="bg-white rounded-3xl p-8 shadow-2xl">
          <h2 class="text-xl font-bold text-slate-900 mb-2">Download Free {magnet.format}</h2>
          <p class="text-sm text-slate-500 mb-6">Enter your details below. Instant access — no spam, ever.</p>

          <form id="lead-magnet-form" class="space-y-4">
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">Full Name *</label>
              <input type="text" name="name" required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all"
                placeholder="Dr. Jane Smith" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">Work Email *</label>
              <input type="email" name="email" required
                class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all"
                placeholder="jane@yourclinic.com" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">Clinic Name</label>
              <input type="text" name="clinicName"
                class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all"
                placeholder="Your TMS Clinic" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">Your Role</label>
              <select name="role" class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition-all">
                <option value="">Select...</option>
                <option value="owner">Clinic Owner / Partner</option>
                <option value="psychiatrist">Psychiatrist</option>
                <option value="admin">Practice Manager / Administrator</option>
                <option value="billing">Billing Specialist</option>
                <option value="technician">TMS Technician</option>
                <option value="considering">Considering Starting TMS</option>
              </select>
            </div>

            <div id="form-error" class="hidden px-4 py-3 bg-red-50 border border-red-100 text-red-700 text-sm rounded-xl"></div>

            <button type="submit" class="w-full py-3.5 text-white font-bold rounded-xl text-sm transition-all shadow-lg hover:shadow-xl" style={`background: ${magnet.accent};`}>
              Download Free {magnet.format}
            </button>

            <p class="text-[11px] text-slate-400 text-center leading-relaxed">
              By downloading, you agree to receive occasional emails from TMS List.
              <a href="/legal/privacy-policy/" class="underline">Privacy Policy</a>. Unsubscribe anytime.
            </p>
          </form>

          <!-- Success state (hidden initially) -->
          <div id="form-success" class="hidden text-center py-6">
            <div class="w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-4" style={`background: ${magnet.accent}15;`}>
              <svg class="w-8 h-8" style={`color: ${magnet.accent};`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">Check Your Email!</h3>
            <p class="text-sm text-slate-500 mb-4">
              Your <strong>{magnet.title}</strong> is on its way to your inbox.
            </p>
            <p class="text-xs text-slate-400">Didn't receive it? Check your spam folder or <a href="mailto:support@tmslist.com" class="text-blue-600">contact us</a>.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Table of Contents -->
  <main class="bg-slate-50/50 py-16">
    <div class="container mx-auto px-6 lg:px-12 max-w-4xl">
      <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-8 mb-12">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">What's Inside</h2>
        <div class="space-y-3">
          {magnet.tableOfContents.map((item, i) => (
            <div class="flex items-center gap-4 py-3 border-b border-slate-50 last:border-0">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold text-white shrink-0" style={`background: ${magnet.accent};`}>
                {i + 1}
              </div>
              <span class="text-sm font-medium text-slate-700">{item}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Who is this for -->
      <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-8 mb-12">
        <h2 class="text-xl font-bold text-slate-900 mb-3">Who Is This For?</h2>
        <p class="text-slate-600 leading-relaxed">{magnet.targetAudience}</p>
      </div>

      <!-- Other lead magnets -->
      <h2 class="text-xl font-bold text-slate-900 mb-6">More Free Resources</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {LEAD_MAGNETS.filter(m => m.id !== magnet.id).slice(0, 4).map(m => (
          <a href={`/resources/${m.slug}/`} class="bg-white rounded-2xl border border-slate-100 p-5 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all block">
            <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full" style={`background: ${m.accent}15; color: ${m.accent};`}>
              {m.format}
            </span>
            <h3 class="text-sm font-bold text-slate-900 mt-2 mb-1">{m.title}</h3>
            <p class="text-xs text-slate-500 line-clamp-2">{m.subtitle}</p>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ magnetId: magnet.id, magnetTitle: magnet.title, magnetSlug: magnet.slug }}>
  document.getElementById('lead-magnet-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const errorEl = document.getElementById('form-error');
    errorEl.classList.add('hidden');

    const data = {
      segment: 'lead_magnet',
      name: form.querySelector('[name="name"]').value,
      email: form.querySelector('[name="email"]').value,
      clinicName: form.querySelector('[name="clinicName"]').value,
      guideTitle: magnetTitle,
      source: `lead-magnet-${magnetSlug}`,
    };

    try {
      const res = await fetch('/api/funnel/enter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        // Also track as analytics event
        fetch('/api/analytics/track', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ clinicId: 'lead-magnet', event: 'lead_submit' }),
        }).catch(() => {});

        form.classList.add('hidden');
        document.getElementById('form-success').classList.remove('hidden');
      } else {
        errorEl.textContent = 'Something went wrong. Please try again.';
        errorEl.classList.remove('hidden');
      }
    } catch {
      errorEl.textContent = 'Network error. Please try again.';
      errorEl.classList.remove('hidden');
    }
  });
</script>
