---
import Layout from "../../layouts/Layout.astro";
import EditorialHero from "../../components/editorial/EditorialHero.astro";
import EditorialSection from "../../components/editorial/EditorialSection.astro";
import EditorialCard from "../../components/editorial/EditorialCard.astro";
import EditorialCTA from "../../components/editorial/EditorialCTA.astro";
import {
    getAllClinics,
    getUniqueStates,
    STATE_NAMES,
    getStateSlug,
    getClinicsByCountry,
    getRegionsByCountry,
    COUNTRY_NAMES,
    COUNTRY_URL_PREFIXES,
} from "../../utils/dataHelpers";
import { calculateClinicScore } from "../../utils/ranking";
import { getClinicRating, getClinicReviewCount } from "../../utils/dataHelpers";
import { getVisitorCountry } from "../../utils/visitorCountry";

export const prerender = false;

const VISITOR_COUNTRY = getVisitorCountry(Astro.cookies, Astro.url);

const countryName = COUNTRY_NAMES[VISITOR_COUNTRY] || 'United States';
const countryPrefix = COUNTRY_URL_PREFIXES[VISITOR_COUNTRY] || 'us';

// ── Build location cards (states for US, regions for international) ──
type LocationCard = {
    code: string;
    name: string;
    href: string;
    clinicCount: number;
    topClinic: { name: string; city: string; rating: number; reviews: number } | null;
};

let locationCards: LocationCard[] = [];
let totalClinics = 0;
let locationLabel = 'States';

if (VISITOR_COUNTRY === 'US') {
    const allClinics = await getAllClinics();
    const usClinics = allClinics.filter(c => !c.country || c.country === 'US');
    totalClinics = usClinics.length;
    const uniqueStates = (await getUniqueStates()).sort();
    locationCards = uniqueStates
        .map(stateCode => {
            const stateClinics = usClinics.filter(c => c.state === stateCode);
            const sorted = [...stateClinics].sort((a, b) => calculateClinicScore(b) - calculateClinicScore(a));
            const top = sorted[0];
            return {
                code: stateCode,
                name: STATE_NAMES[stateCode] || stateCode,
                href: `/best-tms-clinics/${getStateSlug(stateCode)}/`,
                clinicCount: stateClinics.length,
                topClinic: top
                    ? { name: top.name, city: top.city, rating: getClinicRating(top), reviews: getClinicReviewCount(top) }
                    : null,
            };
        })
        .filter(s => s.clinicCount > 0);
    locationLabel = 'States';
} else {
    const countryClinics = await getClinicsByCountry(VISITOR_COUNTRY);
    const regions = await getRegionsByCountry(VISITOR_COUNTRY);
    totalClinics = countryClinics.length;
    locationCards = regions
        .map(region => {
            const regionClinics = countryClinics.filter(c => c.state === region);
            const sorted = [...regionClinics].sort((a, b) => calculateClinicScore(b) - calculateClinicScore(a));
            const top = sorted[0];
            const slug = region.toLowerCase().replace(/\s+/g, '-');
            return {
                code: region,
                name: region,
                href: `/${countryPrefix}/${slug}/`,
                clinicCount: regionClinics.length,
                topClinic: top
                    ? { name: top.name, city: top.city, rating: getClinicRating(top), reviews: getClinicReviewCount(top) }
                    : null,
            };
        })
        .filter(r => r.clinicCount > 0)
        .sort((a, b) => b.clinicCount - a.clinicCount);
    locationLabel = 'Regions';
}

const browseAllHref = `/${countryPrefix}/`;
const title = VISITOR_COUNTRY === 'US'
    ? `Best TMS Clinics by State | ${totalClinics}+ Verified Providers | TMS List`
    : `Best TMS Clinics in ${countryName} | ${totalClinics}+ Verified Providers | TMS List`;
const description = VISITOR_COUNTRY === 'US'
    ? `Find the best TMS therapy clinics in every US state. Compare top-rated providers across ${locationCards.length} states with verified reviews, insurance info, and pricing.`
    : `Find the best TMS therapy clinics across ${locationCards.length} regions in ${countryName}. Compare top-rated providers with verified reviews and pricing.`;

const heroTitle = VISITOR_COUNTRY === 'US' ? 'The best TMS clinics' : 'The best TMS clinics in';
const heroAccent = VISITOR_COUNTRY === 'US' ? 'in every state.' : `${countryName}.`;
const heroDescription = VISITOR_COUNTRY === 'US'
    ? 'Top-rated TMS therapy providers ranked by patient reviews, verification status, and clinic quality — across the United States.'
    : `Top-rated TMS therapy providers in ${countryName}, ranked by patient reviews, verification status, and clinic quality.`;

const sectionTitle = VISITOR_COUNTRY === 'US' ? 'Top Clinics by State' : `Top Clinics by Region in ${countryName}`;
const sectionIntro = VISITOR_COUNTRY === 'US'
    ? 'Pick your state to see the highest-ranked TMS providers near you.'
    : 'Pick your region to see the highest-ranked TMS providers near you.';

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": title.split(' |')[0],
    "description": description,
    "url": "https://tmslist.com/best-tms-clinics/",
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": locationCards.length,
        "itemListElement": locationCards.slice(0, 20).map((s, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "name": `Best TMS Clinics in ${s.name}`,
            "url": `https://tmslist.com${s.href}`,
        })),
    },
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Best TMS Clinics", url: "/best-tms-clinics/" },
]}>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow={`${totalClinics}+ Verified Clinics`}
    eyebrowDot="#22c55e"
    title={heroTitle}
    titleAccent={heroAccent}
    description={heroDescription}
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Best TMS Clinics" }]}
    ctas={[
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: "Browse All Clinics", href: browseAllHref, variant: "outline" },
    ]}
    stats={[
      { value: locationCards.length, label: locationLabel, color: "ink" },
      { value: totalClinics, label: "Verified Clinics", color: "accent" },
      { value: "100%", label: "Vetted", color: "warm" },
    ]}
  />

  {locationCards.length > 0 ? (
    <EditorialSection
      title={sectionTitle}
      intro={sectionIntro}
      icon='<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>'
      tone="accent"
      actionLabel={`View all ${locationLabel.toLowerCase()}`}
      actionHref={browseAllHref}
      noBorder
    >
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {locationCards.map(loc => (
          <EditorialCard
            href={loc.href}
            tag={`${loc.clinicCount} Clinics`}
            tagTone="accent"
            title={loc.name}
            description={loc.topClinic ? `Top rated: ${loc.topClinic.name}${loc.topClinic.city ? ` (${loc.topClinic.city})` : ''}` : 'View top-ranked TMS providers in this area.'}
            size="lg"
          />
        ))}
      </div>
    </EditorialSection>
  ) : (
    <EditorialSection
      title={`No clinics listed in ${countryName} yet`}
      intro="We're expanding our directory. In the meantime, browse our full international listings or take the eligibility quiz."
      tone="warm"
      noBorder
    >
      <div class="flex flex-wrap gap-3">
        <a href="/us/" class="inline-block px-5 py-3 rounded-full bg-[var(--accent)] text-white font-medium hover:opacity-90 transition">Browse US Clinics</a>
        <a href="/quiz/am-i-a-candidate/" class="inline-block px-5 py-3 rounded-full border border-[var(--line)] text-[var(--ink)] font-medium hover:bg-[var(--paper2)] transition">Take the Quiz</a>
      </div>
    </EditorialSection>
  )}

  <EditorialCTA
    title="Not sure which clinic is right?"
    description="Take our free 2-minute eligibility assessment to find TMS providers matched to your condition, insurance, and location."
    ctas={[
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: `Browse ${totalClinics}+ Clinics`, href: browseAllHref, variant: "outline" },
    ]}
    stickyMobile
  />
</main>

</Layout>
