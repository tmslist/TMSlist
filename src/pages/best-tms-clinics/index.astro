---
import Layout from "../../layouts/Layout.astro";
import {
  getUniqueStates,
  getClinicsByState,
} from "../../utils/dataHelpers";
import { STATE_NAMES, getStateSlug } from "../../utils/clinicData";

const states = getUniqueStates()
  .map((code) => ({
    code,
    name: STATE_NAMES[code] || code,
    slug: getStateSlug(code),
    count: getClinicsByState(code).length,
  }))
  .sort((a, b) => b.count - a.count);

const totalClinics = states.reduce((sum, s) => sum + s.count, 0);
const year = new Date().getFullYear();

const title = `Best TMS Therapy Clinics in Every State (${year} Rankings) | TMS List`;
const description = `Compare top-rated TMS providers across all 50 states. ${totalClinics}+ verified clinics ranked by patient reviews, technology, and insurance coverage.`;
---

<Layout title={title} description={description} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "Best TMS Clinics", url: "/best-tms-clinics/" },
]}>
  <main class="bg-white">
    <section class="bg-gradient-to-b from-indigo-50 to-white py-16 border-b border-gray-100">
      <div class="container mx-auto px-4 max-w-5xl text-center">
        <h1 class="text-4xl lg:text-5xl font-extrabold text-gray-900 tracking-tight mb-4">
          Best TMS Therapy Clinics by State
        </h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-8">
          {totalClinics}+ verified TMS providers across {states.length} states, ranked by
          patient ratings, technology, and insurance coverage.
        </p>
      </div>
    </section>

    <section class="container mx-auto px-4 max-w-5xl py-12">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {states.map((s) => (
          <a
            href={`/best-tms-clinics/${s.slug}/`}
            class="group flex items-center justify-between p-5 bg-white rounded-xl border border-gray-200 hover:border-indigo-300 hover:shadow-md transition-all"
          >
            <div>
              <h2 class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors">{s.name}</h2>
              <p class="text-sm text-gray-500">{s.count} verified clinics</p>
            </div>
            <svg class="w-5 h-5 text-gray-400 group-hover:text-indigo-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>
