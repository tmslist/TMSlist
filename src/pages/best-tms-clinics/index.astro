---
import Layout from "../../layouts/Layout.astro";
import { getAllClinics, getUniqueStates, STATE_NAMES, getStateSlug } from "../../utils/dataHelpers";
import { calculateClinicScore } from "../../utils/ranking";
import { getClinicRating, getClinicReviewCount } from "../../utils/dataHelpers";

const allClinics = await getAllClinics();
const uniqueStates = (await getUniqueStates()).sort();

// Get top clinics per state
const stateData = uniqueStates.map(stateCode => {
    const stateClinics = allClinics.filter(c => c.state === stateCode);
    const sorted = [...stateClinics].sort((a, b) => calculateClinicScore(b) - calculateClinicScore(a));
    const top = sorted[0];
    return {
        code: stateCode,
        name: STATE_NAMES[stateCode] || stateCode,
        slug: getStateSlug(stateCode),
        clinicCount: stateClinics.length,
        topClinic: top ? { name: top.name, city: top.city, rating: getClinicRating(top), reviews: getClinicReviewCount(top) } : null,
    };
}).filter(s => s.clinicCount > 0);

const totalClinics = allClinics.length;
const title = `Best TMS Clinics by State | ${totalClinics}+ Verified Providers | TMS List`;
const description = `Find the best TMS therapy clinics in every US state. Compare top-rated providers across ${stateData.length} states with verified reviews, insurance info, and pricing.`;

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Best TMS Clinics by State",
    "description": description,
    "url": "https://tmslist.com/best-tms-clinics/",
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": stateData.length,
        "itemListElement": stateData.slice(0, 20).map((s, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "name": `Best TMS Clinics in ${s.name}`,
            "url": `https://tmslist.com/best-tms-clinics/${s.slug}/`,
        })),
    },
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Best TMS Clinics", url: "/best-tms-clinics/" },
]}>
    <!-- Hero -->
    <section class="relative bg-white border-b border-slate-100 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-cyan-50/30 pointer-events-none"></div>
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-violet-500/5 rounded-full blur-[120px]"></div>

        <div class="container mx-auto px-4 py-16 lg:py-20 relative z-10">
            <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
                <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                <span class="text-slate-300">/</span>
                <span class="text-slate-700 font-medium">Best TMS Clinics</span>
            </nav>

            <div class="max-w-4xl">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-50 border border-emerald-100 rounded-full mb-5">
                    <span class="relative flex h-2 w-2"><span class="animate-ping absolute h-full w-full rounded-full bg-emerald-400 opacity-75"></span><span class="relative rounded-full h-2 w-2 bg-emerald-500"></span></span>
                    <span class="text-xs font-semibold text-emerald-700 tracking-wide">{totalClinics}+ Verified Clinics</span>
                </div>
                <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 mb-3 lg:mb-4">Best TMS Clinics by State</h1>
                <p class="text-base lg:text-lg text-slate-500 leading-relaxed">Find top-rated TMS therapy providers in every US state. Ranked by patient reviews, verification status, and clinic quality.</p>
            </div>
        </div>
    </section>

    <!-- State Grid -->
    <main class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {stateData.map(state => (
                <a href={`/best-tms-clinics/${state.slug}/`} class="group bg-white rounded-2xl border border-slate-100 p-5 shadow-sm hover:shadow-md hover:border-violet-200 transition-all hover:-translate-y-0.5">
                    <div class="flex items-start justify-between mb-3">
                        <h2 class="text-lg font-bold text-slate-900 group-hover:text-violet-600 transition-colors">{state.name}</h2>
                        <span class="px-2.5 py-1 bg-violet-50 text-violet-700 text-xs font-bold rounded-full">{state.clinicCount}</span>
                    </div>
                    {state.topClinic && (
                        <div class="text-sm text-slate-500">
                            <span class="font-medium text-slate-700">Top rated:</span> {state.topClinic.name}
                            <svg class="w-4 h-4 text-amber-500 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        </div>
                    )}
                    <div class="mt-3 flex items-center text-violet-600 text-sm font-semibold">
                        View clinics
                        <svg class="w-4 h-4 ml-1 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </div>
                </a>
            ))}
        </div>
    </main>

    <!-- End-of-page CTA -->
    <section class="pb-16 pt-4">
        <div class="container mx-auto px-4 max-w-4xl">
            <div class="bg-gradient-to-br from-violet-50 to-blue-50 rounded-2xl lg:rounded-3xl p-6 lg:p-14 border border-violet-100 text-center">
                <h2 class="text-xl lg:text-2xl font-bold text-slate-900 mb-2 lg:mb-3">Not sure which clinic is right for you?</h2>
                <p class="text-slate-500 mb-6 lg:mb-8 max-w-lg mx-auto leading-relaxed text-sm lg:text-base">Take our free 2-minute eligibility assessment to find TMS providers matched to your condition, insurance, and location.</p>
                <div class="flex flex-col sm:flex-row gap-3 lg:gap-4 justify-center">
                    <a href="/quiz/am-i-a-candidate/" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 lg:px-8 py-3 lg:py-4 bg-violet-600 hover:bg-violet-700 text-white font-semibold rounded-xl shadow-lg shadow-violet-200 transition-all text-sm lg:text-base">
                        Take the Eligibility Quiz
                    </a>
                    <a href="/us/" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 lg:px-8 py-3 lg:py-4 border-2 border-slate-200 hover:border-violet-300 text-slate-700 font-semibold rounded-xl transition-all text-sm lg:text-base">
                        Browse {totalClinics} Clinics Nationwide
                    </a>
                </div>
                <p class="text-xs text-slate-400 mt-4">Also: <a href="/resources/buyers-guide/" class="text-violet-600 hover:underline font-medium">download the free TMS Buyer's Guide</a> to compare your options.</p>
            </div>
        </div>
    </section>

    <!-- Sticky Mobile CTA Bar -->
    <div class="lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-white border-t border-slate-200 shadow-[0_-4px_20px_rgba(0,0,0,0.08)]">
        <div class="flex items-center gap-2 px-3 py-3">
            <a href="/quiz/am-i-a-candidate/" class="flex-1 text-center bg-violet-600 text-white font-bold text-sm py-3 px-4 rounded-xl hover:bg-violet-500 transition-colors shadow-md">
                Take the Quiz
            </a>
            <a href="/us/" class="flex-1 text-center bg-slate-900 text-white font-bold text-sm py-3 px-4 rounded-xl hover:bg-slate-800 transition-colors shadow-md">
                Find a Clinic
            </a>
        </div>
    </div>
</Layout>
