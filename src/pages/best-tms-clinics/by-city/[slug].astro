---
export const prerender = true;

import Layout from "../../../layouts/Layout.astro";
import ClinicCard from "../../../components/ClinicCard.astro";
import {
    getClinicsByCity,
    getStateCodeFromSlug,
    STATE_NAMES,
} from "../../../utils/dataHelpers";
import { TREATMENT_SLUGS } from "../../../utils/seo_slugs";
import { calculateClinicScore } from "../../../utils/ranking";

// Top 20 US metro areas
export async function getStaticPaths() {
    const METRO_AREAS = [
        { city: "new-york", state: "ny", metro: "New York" },
        { city: "los-angeles", state: "ca", metro: "Los Angeles" },
        { city: "chicago", state: "il", metro: "Chicago" },
        { city: "houston", state: "tx", metro: "Houston" },
        { city: "phoenix", state: "az", metro: "Phoenix" },
        { city: "philadelphia", state: "pa", metro: "Philadelphia" },
        { city: "san-antonio", state: "tx", metro: "San Antonio" },
        { city: "san-diego", state: "ca", metro: "San Diego" },
        { city: "dallas", state: "tx", metro: "Dallas" },
        { city: "san-jose", state: "ca", metro: "San Jose" },
        { city: "austin", state: "tx", metro: "Austin" },
        { city: "jacksonville", state: "fl", metro: "Jacksonville" },
        { city: "fort-worth", state: "tx", metro: "Fort Worth" },
        { city: "columbus", state: "oh", metro: "Columbus" },
        { city: "indianapolis", state: "in", metro: "Indianapolis" },
        { city: "charlotte", state: "nc", metro: "Charlotte" },
        { city: "san-francisco", state: "ca", metro: "San Francisco" },
        { city: "seattle", state: "wa", metro: "Seattle" },
        { city: "denver", state: "co", metro: "Denver" },
        { city: "boston", state: "ma", metro: "Boston" },
    ];
    return METRO_AREAS.map(({ city, state, metro }) => ({
        params: { slug: city },
        props: { citySlug: city, stateSlug: state, metroName: metro },
    }));
}

const { citySlug, stateSlug, metroName } = Astro.props;
const stateCode = stateSlug.toUpperCase();
const stateName = STATE_NAMES[stateCode] || stateCode;

const cityName = metroName;
const treatment = "depression"; // Default to depression for ranking

const cityClinics = await getClinicsByCity(stateCode, cityName);
const sortedClinics = [...cityClinics].sort(
    (a, b) => calculateClinicScore(b) - calculateClinicScore(a),
);
const topClinics = sortedClinics.slice(0, 5);

const title = `Best TMS Clinics in ${cityName} ${stateName} 2026 | TMS List`;
const description = `Compare the top 5 best-rated TMS therapy clinics in ${cityName}, ${stateName}. Browse verified providers, check insurance coverage, read patient reviews, and find the right TMS provider for you.`;

const faqSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        { "@type": "Question", "name": `What is the best TMS clinic in ${cityName}?`, "acceptedAnswer": { "@type": "Answer", "text": `The best TMS clinic depends on your specific needs. Our rankings are based on patient ratings, treatment experience, insurance acceptance, and provider credentials. The clinics listed above represent the top-rated TMS providers in ${cityName}, ${stateName}.` }},
        { "@type": "Question", "name": `How much does TMS cost in ${cityName}?`, "acceptedAnswer": { "@type": "Answer", "text": `TMS sessions in ${cityName} typically cost $200-$400 per session. A full treatment course of 20-36 sessions ranges from $6,000-$12,000 before insurance. Most major insurance plans cover TMS for FDA-cleared indications including treatment-resistant depression.` }},
        { "@type": "Question", "name": `Does insurance cover TMS in ${cityName}?`, "acceptedAnswer": { "@type": "Answer", "text": `Yes, Medicare and most major commercial insurance plans cover TMS for FDA-cleared indications. TMS for treatment-resistant depression has been FDA-cleared since 2008. Contact the clinics above to verify your insurance coverage and handle pre-authorization.` }},
    ]
});

const listSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": `Best TMS Clinics in ${cityName}, ${stateName}`,
    "description": description,
    "numberOfItems": topClinics.length,
    "itemListElement": topClinics.map((c, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
            "@type": "MedicalClinic",
            "name": c.name,
            "url": `https://tmslist.com/clinic/${c.slug}`,
            "address": {
                "@type": "PostalAddress",
                "addressLocality": c.city,
                "addressRegion": stateCode,
            }
        }
    }))
});

const combinedSchema = `[${faqSchema}, ${listSchema}]`;
---

<Layout title={title} description={description} schema={combinedSchema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Best TMS Clinics", url: "/best-tms-clinics/" },
    { name: cityName, url: `/best-tms-clinics/by-city/${citySlug}/` },
]}>
    <main>
        <!-- Hero -->
        <section class="relative bg-[var(--paper)] border-b border-[var(--line)] overflow-hidden">
            <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(var(--line) 1px, transparent 0); background-size: 32px 32px; opacity:0.5;"></div>
            <div class="absolute top-[-10%] right-[15%] w-[500px] h-[500px] bg-[rgba(201,101,74,0.06)] rounded-full blur-[150px]"></div>
            <div class="absolute bottom-[5%] left-[10%] w-[400px] h-[400px] bg-amber-500/8 rounded-full blur-[120px]"></div>

            <div class="container mx-auto px-4 pt-10 pb-24 lg:pt-14 lg:pb-28 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-[var(--muted)] mb-10 flex-wrap" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-[var(--accent2)] transition-colors">Home</a>
                    <span class="text-[var(--ink2)]">/</span>
                    <a href="/best-tms-clinics/" class="hover:text-[var(--accent2)] transition-colors">Best TMS Clinics</a>
                    <span class="text-[var(--ink2)]">/</span>
                    <span class="text-[var(--muted)]">{cityName}</span>
                </nav>

                <div class="max-w-3xl">
                    <div class="flex items-center gap-3 mb-4">
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-500/10 border border-amber-500/20 rounded-full">
                            <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                            <span class="text-xs font-semibold text-amber-400 tracking-wider uppercase">2026 Rankings</span>
                        </span>
                    </div>

                    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-[var(--ink)] leading-tight mb-4 lg:mb-5">
                        Best TMS Clinics in<br/>
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--ink2)] to-amber-400">{cityName}, {stateName}</span>
                    </h1>
                    <p class="text-base lg:text-lg text-[var(--muted)] leading-relaxed max-w-2xl">
                        Our ranking of the top 5 best-rated TMS therapy clinics in {cityName}, {stateName}. Each clinic is verified, accepts insurance, and has been rated by real patients.
                    </p>
                </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-12 lg:h-16 bg-[var(--paper)]" style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"></div>
        </section>

        <!-- Why These Clinics Rank -->
        <section class="py-8 lg:py-12 bg-[var(--paper)]">
            <div class="container mx-auto px-4 max-w-4xl">
                <h2 class="text-xl lg:text-2xl font-bold text-[var(--ink)] mb-3 lg:mb-4">Why These Clinics Rank</h2>
                <p class="text-[var(--muted)] leading-relaxed text-sm lg:text-base">
                    Our rankings are based on a comprehensive scoring system that considers patient ratings and reviews, treatment experience and provider credentials, insurance acceptance and payment options, clinic amenities and technology, and overall patient satisfaction. All clinics listed are verified TMS providers with board-certified psychiatrists overseeing treatment.
                </p>
            </div>
        </section>

        <!-- Top 5 Clinics Ranked List -->
        <section class="py-8 lg:py-16 bg-[var(--paper2)]">
            <div class="container mx-auto px-4 max-w-4xl">
                <h2 class="text-xl lg:text-2xl font-bold text-[var(--ink)] mb-6 lg:mb-8">Top 5 Best TMS Clinics in {cityName}</h2>

                {topClinics.length > 0 ? (
                    <div class="space-y-6">
                        {topClinics.map((clinic, index) => (
                            <article class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] overflow-hidden hover:shadow-lg transition-shadow">
                                <div class="flex flex-col md:flex-row">
                                    <div class="w-full md:w-24 bg-[var(--ink)] flex items-center justify-center shrink-0">
                                        <div class="text-center">
                                            <div class="text-3xl font-bold text-[var(--ink)]">#{index + 1}</div>
                                        </div>
                                    </div>
                                    <div class="flex-1 p-6">
                                        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                                            <div class="flex-1">
                                                <h3 class="text-xl font-bold text-[var(--ink)] mb-2">
                                                    <a href={`/clinic/${clinic.slug}/`} class="hover:text-[var(--accent)] transition-colors">{clinic.name}</a>
                                                </h3>
                                                <div class="flex items-center gap-4 text-sm text-[var(--muted)] mb-3">
                                                    <span class="flex items-center gap-1">
                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                                                        {clinic.city}, {clinic.state}
                                                    </span>
                                                    {clinic.phone && (
                                                        <span class="flex items-center gap-1">
                                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                                            {clinic.phone}
                                                        </span>
                                                    )}
                                                </div>
                                                <p class="text-[var(--muted)] text-sm line-clamp-2">
                                                    {clinic.description || `${clinic.name} is a verified TMS therapy provider offering treatment for depression, anxiety, OCD, and other conditions using FDA-cleared TMS technology.`}
                                                </p>
                                            </div>
                                            <div class="flex flex-row md:flex-col items-center gap-3 shrink-0">
                                                {clinic.rating && (
                                                    <div class="flex items-center gap-1 text-amber-500">
                                                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                                        <span class="font-bold text-[var(--ink)]">{typeof clinic.rating === 'number' ? clinic.rating.toFixed(1) : clinic.rating.aggregate?.toFixed(1) || '4.5'}</span>
                                                    </div>
                                                )}
                                                <a href={`/clinic/${clinic.slug}/`} class="px-4 py-2 bg-[var(--ink)] text-white text-sm font-semibold rounded-xl hover:bg-[var(--ink2)] transition-colors whitespace-nowrap">
                                                    View Details
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </article>
                        ))}
                    </div>
                ) : (
                    <div class="text-center py-16 bg-[var(--paper)] rounded-2xl">
                        <p class="text-[var(--muted)] mb-6">No clinics found in {cityName} for this ranking.</p>
                        <a href={`/us/${stateSlug}/${citySlug}/`} class="px-6 py-3 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-colors">
                            Browse All {cityName} TMS Clinics
                        </a>
                    </div>
                )}
            </div>
        </section>

        <!-- Find More Clinics CTA -->
        <section class="py-12 bg-[var(--paper)] border-t border-[var(--line)]">
            <div class="container mx-auto px-4 max-w-4xl text-center">
                <h2 class="text-2xl font-bold text-[var(--ink)] mb-4">Find More TMS Clinics in {cityName}</h2>
                <p class="text-[var(--muted)] mb-8">
                    Browse our complete directory of verified TMS providers in {cityName}, {stateName}.
                </p>
                <a href={`/us/${stateSlug}/${citySlug}/depression/`} class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-colors">
                    View All {cityName} TMS Clinics
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </a>
            </div>
        </section>

        <!-- Related Topics -->
        <section class="py-16 bg-[var(--paper)]">
            <div class="container mx-auto px-4 max-w-5xl">
                <h2 class="text-2xl font-bold text-[var(--ink)] mb-6">Explore Related Topics</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                    <a href="/treatments/depression/" class="group bg-[var(--paper2)] rounded-xl border border-[var(--line)] p-5 hover:border-[rgba(10,22,40,0.2)] hover:shadow-md transition-all">
                        <h4 class="font-semibold text-[var(--ink)] group-hover:text-[var(--accent)] mb-1">TMS for Depression</h4>
                        <p class="text-sm text-[var(--muted)]">Most common TMS indication with strongest evidence base.</p>
                    </a>
                    <a href="/insurance/" class="group bg-[var(--paper2)] rounded-xl border border-[var(--line)] p-5 hover:border-[rgba(10,22,40,0.2)] hover:shadow-md transition-all">
                        <h4 class="font-semibold text-[var(--ink)] group-hover:text-[var(--accent)] mb-1">Insurance Coverage</h4>
                        <p class="text-sm text-[var(--muted)]">Medicare, Blue Cross, Aetna, Cigna and more.</p>
                    </a>
                    <a href="/protocols/" class="group bg-[var(--paper2)] rounded-xl border border-[var(--line)] p-5 hover:border-[rgba(10,22,40,0.2)] hover:shadow-md transition-all">
                        <h4 class="font-semibold text-[var(--ink)] group-hover:text-[var(--accent)] mb-1">TMS Protocols</h4>
                        <p class="text-sm text-[var(--muted)]">Standard, theta burst, accelerated, and deep TMS.</p>
                    </a>
                    <a href="/tms-cost-guide/" class="group bg-[var(--paper2)] rounded-xl border border-[var(--line)] p-5 hover:border-[rgba(10,22,40,0.2)] hover:shadow-md transition-all">
                        <h4 class="font-semibold text-[var(--ink)] group-hover:text-[var(--accent)] mb-1">TMS Cost Guide</h4>
                        <p class="text-sm text-[var(--muted)]">Session costs, insurance coverage, and payment options.</p>
                    </a>
                </div>
                <div class="mt-6 flex flex-wrap gap-3">
                    <a href="/technology/" class="text-sm font-medium text-[var(--accent)] hover:text-[var(--accent)] transition-colors">TMS Technology →</a>
                    <a href="/compare/" class="text-sm font-medium text-[var(--accent)] hover:text-[var(--accent)] transition-colors">Compare Treatments →</a>
                    <a href="/quiz/am-i-a-candidate/" class="text-sm font-medium text-[var(--accent)] hover:text-[var(--accent)] transition-colors">Am I a Candidate? →</a>
                    <a href="/research/" class="text-sm font-medium text-[var(--accent)] hover:text-[var(--accent)] transition-colors">Research & Evidence →</a>
                </div>
            </div>
        </section>

        <!-- FAQ Section -->
        <section class="py-16 bg-[var(--paper2)]">
            <div class="container mx-auto px-4 max-w-4xl">
                <h2 class="text-2xl font-bold text-[var(--ink)] mb-8">Frequently Asked Questions: Best TMS Clinics in {cityName}</h2>
                <div class="space-y-4">
                    <details class="group bg-[var(--paper)] rounded-2xl border border-[var(--line)] overflow-hidden">
                        <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-[var(--ink)] hover:text-[var(--accent)] transition-colors">
                            What is the best TMS clinic in {cityName}?
                            <svg class="w-5 h-5 text-[var(--muted)] group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="px-6 pb-6 text-[var(--muted)]">The best TMS clinic depends on your specific needs. Our rankings are based on patient ratings, treatment experience, insurance acceptance, and provider credentials. The clinics listed above represent the top-rated TMS providers in {cityName}, {stateName}.</div>
                    </details>
                    <details class="group bg-[var(--paper)] rounded-2xl border border-[var(--line)] overflow-hidden">
                        <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-[var(--ink)] hover:text-[var(--accent)] transition-colors">
                            How much does TMS cost in {cityName}?
                            <svg class="w-5 h-5 text-[var(--muted)] group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="px-6 pb-6 text-[var(--muted)]">TMS sessions in {cityName} typically cost $200-$400 per session. A full treatment course of 20-36 sessions ranges from $6,000-$12,000 before insurance. Most major insurance plans cover TMS for FDA-cleared indications including treatment-resistant depression.</div>
                    </details>
                    <details class="group bg-[var(--paper)] rounded-2xl border border-[var(--line)] overflow-hidden">
                        <summary class="flex items-center justify-between p-6 cursor-pointer font-semibold text-[var(--ink)] hover:text-[var(--accent)] transition-colors">
                            Does insurance cover TMS in {cityName}?
                            <svg class="w-5 h-5 text-[var(--muted)] group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="px-6 pb-6 text-[var(--muted)]">Yes, Medicare and most major commercial insurance plans cover TMS for FDA-cleared indications. TMS for treatment-resistant depression has been FDA-cleared since 2008. Contact the clinics above to verify your insurance coverage and handle pre-authorization.</div>
                    </details>
                </div>
            </div>
        </section>

        <!-- End-of-page CTA -->
        <section class="py-12 lg:py-14 bg-gradient-to-br from-[#0A1628] to-[#0A1628] border-t border-[var(--line)]">
            <div class="container mx-auto px-4 max-w-4xl text-center">
                <h2 class="text-xl lg:text-3xl font-bold text-[var(--ink)] mb-3 lg:mb-4 tracking-tight">Ready to Book a Consultation?</h2>
                <p class="text-white/80 mb-6 lg:mb-8 max-w-xl mx-auto leading-relaxed text-sm lg:text-base">Not sure which clinic is right for you? Take our free eligibility quiz to find TMS providers matched to your needs.</p>
                <div class="flex flex-col sm:flex-row gap-3 lg:gap-4 justify-center">
                    <a href="/quiz/am-i-a-candidate/" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 lg:px-8 py-3 lg:py-4 bg-[var(--paper)] text-[var(--accent)] font-semibold rounded-xl shadow-lg hover:bg-[rgba(10,22,40,0.08)] transition-all text-sm lg:text-base">
                        Take the Eligibility Quiz
                    </a>
                    <a href={`/us/${stateSlug}/${citySlug}/`} class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 lg:px-8 py-3 lg:py-4 bg-[var(--paper2)] border border-[var(--line)] hover:bg-[var(--paper2)] text-[var(--ink)] font-semibold rounded-xl transition-all backdrop-blur text-sm lg:text-base">
                        Find More Clinics
                    </a>
                </div>
                <p class="text-xs text-white/60 mt-4">Also: <a href="/tms-cost-guide/" class="underline hover:text-[var(--ink)]">download the free TMS Buyer's Guide</a> for comprehensive answers.</p>
            </div>
        </section>

        <!-- Sticky Mobile CTA Bar -->
        <div class="lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-[var(--paper)] border-t border-[var(--line)] shadow-[0_-4px_20px_rgba(0,0,0,0.08)]">
            <div class="flex items-center gap-2 px-3 py-3">
                <a href="/quiz/am-i-a-candidate/" class="flex-1 text-center bg-[var(--ink)] text-white font-bold text-sm py-3 px-4 rounded-xl hover:bg-[var(--ink2)] transition-colors shadow-md">
                    Take the Quiz
                </a>
                <a href={`/us/${stateSlug}/${citySlug}/`} class="flex-1 text-center bg-[var(--ink)] text-white font-bold text-sm py-3 px-4 rounded-xl hover:bg-[var(--ink2)] transition-colors shadow-md">
                    View Clinics
                </a>
            </div>
        </div>
    </main>
</Layout>
