---
export const prerender = true;

import Layout from "../../../layouts/Layout.astro";
import ClinicCard from "../../../components/ClinicCard.astro";
import {
  getOperationalClinics,
  getClinicRating,
  getClinicReviewCount,
  getClinicPhoto,
} from "../../../utils/dataHelpers";
import { STATE_NAMES, getStateSlug } from "../../../utils/clinicData";
import { calculateClinicScore } from "../../../utils/ranking";
import { CONDITION_MAP } from "../../../utils/conditions";

export async function getStaticPaths() {
  return Object.entries(CONDITION_MAP).map(([key, data]) => ({
    params: { condition: key },
    props: { conditionData: data },
  }));
}

const { condition } = Astro.params;
const conditionData = Astro.props.conditionData || CONDITION_MAP[condition!];
const allClinics = getOperationalClinics();

// Filter clinics that treat this condition
const matchingClinics = allClinics
  .filter(c => {
    const treatments = (c.treatments || []).map(t => t.toLowerCase());
    return conditionData.match.some(m => treatments.includes(m.toLowerCase()));
  })
  .sort((a, b) => calculateClinicScore(b) - calculateClinicScore(a));

const top10 = matchingClinics.slice(0, 10);
const year = new Date().getFullYear();

// Group by state for the directory
const stateGroups: Record<string, number> = {};
matchingClinics.forEach(c => {
  if (c.state && STATE_NAMES[c.state]) {
    stateGroups[c.state] = (stateGroups[c.state] || 0) + 1;
  }
});
const topStates = Object.entries(stateGroups)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12);

const title = `Best TMS Clinics for ${conditionData.label} (${year} Rankings) | TMS List`;
const description = `${matchingClinics.length} verified TMS providers specializing in ${conditionData.label} treatment. ${conditionData.description}`;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Best TMS Clinics for ${conditionData.label}`,
  "description": description,
  "numberOfItems": top10.length,
  "itemListElement": top10.map((clinic, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "MedicalClinic",
      "name": clinic.name,
      "url": `https://tmslist.com/clinic/${clinic.slug}`,
    },
  })),
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "Best TMS Clinics", url: "/best-tms-clinics/" },
  { name: `For ${conditionData.label}`, url: `/best-tms-clinics/for-${condition}/` },
]}>
  <main class="bg-white">
    <!-- Hero -->
    <section class="bg-gradient-to-b from-indigo-50 to-white py-16 border-b border-gray-100">
      <div class="container mx-auto px-4 max-w-5xl">
        <nav class="flex text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
          <ol class="inline-flex items-center space-x-1">
            <li><a href="/" class="hover:text-gray-900">Home</a></li>
            <li><span class="mx-2">/</span></li>
            <li><a href="/best-tms-clinics/" class="hover:text-gray-900">Best TMS Clinics</a></li>
            <li><span class="mx-2">/</span></li>
            <li class="text-gray-900 font-medium">For {conditionData.label}</li>
          </ol>
        </nav>

        <span class="inline-block px-3 py-1 bg-indigo-100 text-indigo-700 text-xs font-bold uppercase tracking-wider rounded-full mb-4">
          Condition-Specific Guide
        </span>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-gray-900 tracking-tight mb-4">
          Best TMS Clinics for {conditionData.label}
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mb-6">
          {matchingClinics.length} verified providers specializing in TMS treatment for {conditionData.label.toLowerCase()}.
          Ranked by patient ratings, technology, and clinical expertise.
        </p>

        <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-500">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-indigo-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            {matchingClinics.length} Verified Providers
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            {conditionData.label}-Specialized Protocols
          </div>
        </div>
      </div>
    </section>

    <!-- About this condition -->
    <section class="container mx-auto px-4 max-w-3xl py-12 border-b border-gray-100">
      <div class="prose prose-lg max-w-none text-gray-600">
        <p>{conditionData.intro}</p>
      </div>
    </section>

    <!-- Ranked List -->
    <section class="container mx-auto px-4 max-w-5xl py-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Top {top10.length} Providers for {conditionData.label}</h2>
      <div class="space-y-6">
        {top10.map((clinic, i) => {
          const rating = getClinicRating(clinic);
          const reviewCount = getClinicReviewCount(clinic);
          const photo = getClinicPhoto(clinic);
          const machines = clinic.machines || [];
          const stateName = STATE_NAMES[clinic.state] || clinic.state;

          return (
            <article class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
              <div class="flex flex-col md:flex-row">
                <div class="relative md:w-72 h-48 md:h-auto shrink-0">
                  <img
                    src={photo}
                    alt={`${clinic.name} - TMS for ${conditionData.label} in ${clinic.city}, ${clinic.state}`}
                    width="400"
                    height="300"
                    loading={i < 3 ? "eager" : "lazy"}
                    class="w-full h-full object-cover"
                  />
                  <div class="absolute top-4 left-4">
                    <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-indigo-600 text-white font-bold text-lg shadow-lg">
                      {i + 1}
                    </span>
                  </div>
                </div>

                <div class="flex-1 p-6">
                  <div class="flex items-start justify-between gap-4 mb-2">
                    <div>
                      <h3 class="text-xl font-bold text-gray-900 mb-1">
                        <a href={`/clinic/${clinic.slug}`} class="hover:text-indigo-600 transition-colors">
                          {clinic.name}
                        </a>
                      </h3>
                      <p class="text-sm text-gray-500">{clinic.city}, {stateName}</p>
                    </div>
                    {rating > 0 && (
                      <div class="flex items-center gap-1.5 bg-amber-50 px-3 py-1.5 rounded-lg border border-amber-100 shrink-0">
                        <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                        <span class="font-bold text-gray-900">{rating.toFixed(1)}</span>
                        <span class="text-gray-400 text-xs">({reviewCount})</span>
                      </div>
                    )}
                  </div>

                  {clinic.description_long && (
                    <p class="text-gray-600 text-sm mb-3 line-clamp-2">{clinic.description_long}</p>
                  )}

                  <div class="flex flex-wrap gap-2 mb-4">
                    {machines.map((m: string) => (
                      <span class="px-2.5 py-1 bg-indigo-50 text-indigo-700 text-xs font-medium rounded-md">{m}</span>
                    ))}
                    <span class="px-2.5 py-1 bg-green-50 text-green-700 text-xs font-medium rounded-md">
                      Treats {conditionData.label}
                    </span>
                  </div>

                  <div class="flex gap-3">
                    <a href={`/clinic/${clinic.slug}`} class="px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-xl hover:bg-indigo-700 transition-colors">
                      View Profile
                    </a>
                    {clinic.phone && (
                      <a href={`tel:${clinic.phone}`} class="px-5 py-2.5 bg-white text-gray-700 text-sm font-semibold rounded-xl border border-gray-200 hover:bg-gray-50 transition-colors">
                        Call Now
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <!-- Browse by State -->
    {topStates.length > 0 && (
      <section class="bg-gray-50 border-t border-gray-200 py-12">
        <div class="container mx-auto px-4 max-w-5xl">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            Find {conditionData.label} TMS Clinics by State
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
            {topStates.map(([code, count]) => (
              <a
                href={`/best-tms-clinics/${getStateSlug(code)}/`}
                class="px-4 py-3 bg-white rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:border-indigo-200 transition-colors flex justify-between"
              >
                <span>{STATE_NAMES[code]}</span>
                <span class="text-gray-400">{count}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- SEO Content -->
    <section class="container mx-auto px-4 max-w-3xl py-16">
      <div class="prose prose-lg max-w-none text-gray-600">
        <h2>Is TMS Effective for {conditionData.label}?</h2>
        <p>{conditionData.description}</p>

        <h2>What to Expect from TMS for {conditionData.label}</h2>
        <p>
          A standard TMS treatment course involves 36 sessions over 6-9 weeks, with each session
          lasting about 19-20 minutes. Most patients begin to notice improvement after 2-3 weeks.
          Side effects are minimal — typically mild scalp discomfort that fades after the first
          few sessions. TMS does not require sedation and you can drive yourself to and from appointments.
        </p>

        <h2>Insurance Coverage for TMS</h2>
        <p>
          Most major insurance plans cover TMS for treatment-resistant depression, including Medicare,
          Aetna, Cigna, UnitedHealthcare, and BlueCross. Coverage for {conditionData.label} specifically
          may vary by plan. The clinics listed here can help verify your coverage and handle prior authorization.
        </p>
      </div>
    </section>
  </main>
</Layout>
