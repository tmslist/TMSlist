---
export const prerender = true;

import Layout from "../../../layouts/Layout.astro";
import ClinicCard from "../../../components/ClinicCard.astro";
import {
  getUniqueStates,
  getClinicsByState,
  getClinicRating,
  getClinicReviewCount,
  getClinicPhoto,
} from "../../../utils/dataHelpers";
import { STATE_NAMES, getStateSlug } from "../../../utils/clinicData";
import { calculateClinicScore } from "../../../utils/ranking";

export async function getStaticPaths() {
  const states = getUniqueStates().filter(s => s && STATE_NAMES[s]);
  return states.map((stateCode) => {
    const stateName = STATE_NAMES[stateCode] || stateCode;
    const clinics = getClinicsByState(stateCode)
      .sort((a, b) => calculateClinicScore(b) - calculateClinicScore(a));
    const stateSlug = getStateSlug(stateCode);

    // Get unique cities for internal linking
    const cities = [...new Set(clinics.map(c => c.city))].sort();

    return {
      params: { state: stateSlug },
      props: { stateCode, stateName, clinics, cities },
    };
  });
}

const { stateCode, stateName, clinics, cities } = Astro.props;
const { state } = Astro.params;
const top10 = clinics.slice(0, 10);
const year = new Date().getFullYear();

const title = `10 Best TMS Therapy Clinics in ${stateName} (${year} Rankings) | TMS List`;
const description = `Compare the top-rated TMS therapy providers in ${stateName}. Verified reviews, insurance coverage, and treatment costs for ${clinics.length}+ clinics.`;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Best TMS Clinics in ${stateName}`,
  "description": description,
  "numberOfItems": top10.length,
  "itemListElement": top10.map((clinic, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "MedicalClinic",
      "name": clinic.name,
      "url": `https://tmslist.com/clinic/${clinic.slug}`,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": clinic.city,
        "addressRegion": stateCode,
        "addressCountry": "US",
      },
      ...(typeof clinic.rating === 'object' ? {
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": clinic.rating.aggregate,
          "reviewCount": clinic.rating.count,
        }
      } : {}),
    },
  })),
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "Best TMS Clinics", url: "/best-tms-clinics/" },
  { name: stateName, url: `/best-tms-clinics/${state}/` },
]}>
  <main class="bg-white">
    <!-- Hero -->
    <section class="bg-gradient-to-b from-indigo-50 to-white py-16 border-b border-gray-100">
      <div class="container mx-auto px-4 max-w-5xl">
        <nav class="flex text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
          <ol class="inline-flex items-center space-x-1">
            <li><a href="/" class="hover:text-gray-900">Home</a></li>
            <li><span class="mx-2">/</span></li>
            <li><a href="/best-tms-clinics/" class="hover:text-gray-900">Best TMS Clinics</a></li>
            <li><span class="mx-2">/</span></li>
            <li class="text-gray-900 font-medium">{stateName}</li>
          </ol>
        </nav>

        <h1 class="text-4xl lg:text-5xl font-extrabold text-gray-900 tracking-tight mb-4">
          10 Best TMS Therapy Clinics in {stateName}
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mb-6">
          We ranked {clinics.length} verified TMS providers across {stateName} based on patient ratings,
          technology, insurance coverage, and data completeness. Updated for {year}.
        </p>

        <div class="flex flex-wrap gap-4 text-sm font-medium text-gray-500">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-indigo-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            {clinics.length} Verified Providers
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-indigo-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            Real Patient Reviews
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Updated {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}
          </div>
        </div>
      </div>
    </section>

    <!-- Ranked List -->
    <section class="container mx-auto px-4 max-w-5xl py-12">
      <div class="space-y-8">
        {top10.map((clinic, i) => {
          const rating = getClinicRating(clinic);
          const reviewCount = getClinicReviewCount(clinic);
          const photo = getClinicPhoto(clinic);
          const machines = clinic.machines || [];
          const insurances = clinic.insurances || [];

          return (
            <article class="bg-white rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden">
              <div class="flex flex-col md:flex-row">
                {/* Rank + Image */}
                <div class="relative md:w-80 h-56 md:h-auto shrink-0">
                  <img
                    src={photo}
                    alt={`${clinic.name} - TMS Clinic in ${clinic.city}, ${stateCode}`}
                    width="400"
                    height="300"
                    loading={i < 3 ? "eager" : "lazy"}
                    class="w-full h-full object-cover"
                  />
                  <div class="absolute top-4 left-4">
                    <span class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-indigo-600 text-white font-bold text-lg shadow-lg">
                      {i + 1}
                    </span>
                  </div>
                  {clinic.verified && (
                    <div class="absolute top-4 right-4">
                      <span class="px-3 py-1 bg-white/95 backdrop-blur text-xs font-semibold text-indigo-700 rounded-full border border-indigo-100">
                        Verified
                      </span>
                    </div>
                  )}
                </div>

                {/* Content */}
                <div class="flex-1 p-6">
                  <div class="flex items-start justify-between mb-3">
                    <div>
                      <h2 class="text-xl font-bold text-gray-900 mb-1">
                        <a href={`/clinic/${clinic.slug}`} class="hover:text-indigo-600 transition-colors">
                          {clinic.name}
                        </a>
                      </h2>
                      <p class="text-sm text-gray-500">{clinic.city}, {stateName}</p>
                    </div>
                    {rating > 0 && (
                      <div class="flex items-center gap-1.5 bg-amber-50 px-3 py-1.5 rounded-lg border border-amber-100">
                        <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                        <span class="font-bold text-gray-900">{rating.toFixed(1)}</span>
                        <span class="text-gray-400 text-xs">({reviewCount})</span>
                      </div>
                    )}
                  </div>

                  {clinic.description_long && (
                    <p class="text-gray-600 text-sm mb-4 line-clamp-2">{clinic.description_long}</p>
                  )}

                  {/* Details */}
                  <div class="flex flex-wrap gap-4 text-xs text-gray-500 mb-4">
                    {machines.length > 0 && (
                      <div class="flex items-center gap-1.5">
                        <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
                        <span>{machines.join(', ')}</span>
                      </div>
                    )}
                    {insurances.length > 0 && (
                      <div class="flex items-center gap-1.5">
                        <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 011.414.586l4 4a1 1 0 01.586 1.414V19a2 2 0 01-2 2z"/></svg>
                        <span>{insurances.slice(0, 3).join(', ')}{insurances.length > 3 ? ` +${insurances.length - 3} more` : ''}</span>
                      </div>
                    )}
                  </div>

                  {/* CTA */}
                  <div class="flex gap-3">
                    <a href={`/clinic/${clinic.slug}`} class="px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-xl hover:bg-indigo-700 transition-colors">
                      View Profile
                    </a>
                    {clinic.phone && (
                      <a href={`tel:${clinic.phone}`} class="px-5 py-2.5 bg-white text-gray-700 text-sm font-semibold rounded-xl border border-gray-200 hover:bg-gray-50 transition-colors">
                        Call Now
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>

      {/* Remaining clinics as grid */}
      {clinics.length > 10 && (
        <div class="mt-16">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            More TMS Clinics in {stateName}
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {clinics.slice(10, 25).map(clinic => (
              <ClinicCard clinic={clinic} />
            ))}
          </div>
        </div>
      )}
    </section>

    <!-- City Links -->
    {cities.length > 1 && (
      <section class="bg-gray-50 border-t border-gray-200 py-12">
        <div class="container mx-auto px-4 max-w-5xl">
          <h2 class="text-2xl font-bold text-gray-900 mb-6">
            Browse TMS Clinics by City in {stateName}
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
            {cities.map(city => {
              const citySlug = city.toLowerCase().replace(/\s+/g, '-');
              return (
                <a
                  href={`/best-tms-clinics/${state}/${citySlug}/`}
                  class="px-4 py-3 bg-white rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:text-indigo-600 hover:border-indigo-200 transition-colors"
                >
                  {city}
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    <!-- SEO Content -->
    <section class="container mx-auto px-4 max-w-3xl py-16">
      <div class="prose prose-lg max-w-none text-gray-600">
        <h2>How We Rank TMS Clinics in {stateName}</h2>
        <p>
          Our rankings are based on a weighted scoring system that considers multiple factors.
          Verified clinics receive priority, followed by patient ratings, technology (NeuroStar,
          BrainsWay, MagVenture), insurance acceptance, and completeness of their profile data.
          We update these rankings regularly as new reviews come in and clinics update their information.
        </p>

        <h2>TMS Therapy Cost in {stateName}</h2>
        <p>
          A typical TMS treatment course involves 36 sessions over 6-9 weeks. In {stateName},
          expect to pay between $300-$500 per session without insurance. Most major insurance
          plans now cover TMS for treatment-resistant depression, including Medicare, Blue Cross,
          Aetna, Cigna, and UnitedHealthcare. Many clinics listed here handle prior authorization
          for you.
        </p>

        <h2>What to Look for in a TMS Provider</h2>
        <p>
          When choosing a TMS clinic in {stateName}, consider: the type of TMS device used
          (newer systems like BrainsWay Deep TMS offer broader stimulation), whether a
          board-certified psychiatrist supervises treatment, patient reviews from verified
          sources, and whether they accept your insurance plan.
        </p>
      </div>
    </section>
  </main>
</Layout>
