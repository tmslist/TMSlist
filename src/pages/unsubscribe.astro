---
import Layout from "../layouts/Layout.astro";

export const prerender = false;

const pageTitle = "Unsubscribe | TMS List";
---

<Layout title={pageTitle} description="Unsubscribe from TMS List emails." noindex={true}>
  <main class="bg-[var(--paper2)]/50 min-h-screen flex items-center justify-center py-12 px-6">
    <div class="w-full max-w-md">
      <div class="bg-[var(--paper)] rounded-3xl border border-[var(--line)] shadow-sm p-8 text-center">
        <div id="form-state">
          <svg class="w-12 h-12 text-[var(--muted)] mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <h1 class="text-2xl font-bold text-[var(--ink)] mb-2">Unsubscribe</h1>
          <p class="text-sm text-[var(--muted)] mb-6">Enter your email to unsubscribe from TMS List emails.</p>

          <form id="unsubscribe-form" class="space-y-4">
            <input type="email" name="email" required placeholder="your@email.com"
              class="w-full px-4 py-3 rounded-xl border border-[var(--line)] text-sm text-center focus:border-[rgba(10,22,40,0.2)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] transition-all" />
            <button type="submit" class="w-full py-3 bg-[var(--ink)] hover:bg-[var(--ink2)] text-white font-semibold rounded-xl text-sm transition-all">
              Unsubscribe
            </button>
          </form>
        </div>

        <div id="success-state" class="hidden">
          <svg class="w-12 h-12 text-emerald-500 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <h2 class="text-xl font-bold text-[var(--ink)] mb-2">You've been unsubscribed</h2>
          <p class="text-sm text-[var(--muted)] mb-6">You won't receive any more emails from us. We're sorry to see you go.</p>
          <a href="/" class="text-sm text-[var(--accent)] font-semibold hover:text-[var(--accent)]">Back to TMS List</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  document.getElementById('unsubscribe-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = ((e.target as HTMLFormElement).querySelector('[name="email"]') as HTMLInputElement).value;

    // In a real implementation, this would call an API to mark the email as unsubscribed
    // For now, we show a confirmation
    document.getElementById('form-state')?.classList.add('hidden');
    document.getElementById('success-state')?.classList.remove('hidden');
  });
</script>
