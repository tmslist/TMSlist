---
import Layout from "../layouts/Layout.astro";
import EditorialHero from "../components/editorial/EditorialHero.astro";
import ClinicMap from "../components/react/ClinicMap";
import { getVisitorCountry } from "../utils/visitorCountry";
import { COUNTRY_URL_PREFIXES } from "../utils/dataHelpers";

const VISITOR_COUNTRY = getVisitorCountry(Astro.cookies, Astro.url);
const visitorCountryUrl = `/${COUNTRY_URL_PREFIXES[VISITOR_COUNTRY] || VISITOR_COUNTRY.toLowerCase()}/`;
const browseLabel = VISITOR_COUNTRY === 'US' ? 'Browse by State' : 'Browse by Region';

const pageTitle = "Find TMS Clinics Near You | Interactive Map | TMS List";
const metaDescription = "Use our interactive map to find TMS therapy clinics near you. Browse verified providers, compare ratings, and book a consultation today.";

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "TMS Clinic Map Search",
  "description": metaDescription,
  "url": "https://tmslist.com/map",
});
---

<Layout title={pageTitle} description={metaDescription} schema={schema}>
  <EditorialHero
    eyebrow="Interactive Map"
    eyebrowDot="#22c55e"
    title="TMS clinics"
    titleAccent="near you."
    description={`Explore our interactive map of verified TMS therapy providers worldwide. Click "Find Near Me" to discover clinics in your area.`}
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Map" }]}
    ctas={[
      { label: "Find Near Me", href: "#map" },
      { label: browseLabel, href: visitorCountryUrl, variant: "outline" },
    ]}
  />

  <main class="bg-[var(--paper2)]/50 py-10">
    <div class="container mx-auto px-6 lg:px-12" role="region" aria-label="Interactive clinic map">
      <ClinicMap client:visible height="600px" />
      <noscript>
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-center mt-4">
          <p class="text-amber-800">The interactive map requires JavaScript. <a href={visitorCountryUrl} class="underline font-medium">Browse clinics by state instead</a>.</p>
        </div>
      </noscript>
    </div>
  </main>
</Layout>
