---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import { getSessionFromRequest } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!session) {
  return Astro.redirect('/login?redirect=/account/connections');
}
---

<Layout title="My Connections | TMS List" noindex={true}>
  <div class="min-h-screen bg-gray-50/50">
    <!-- Header -->
    <div class="bg-white border-b border-gray-200">
      <div class="max-w-4xl mx-auto px-4 py-6">
        <a href="/account" class="inline-flex items-center gap-1.5 text-sm text-gray-400 hover:text-violet-600 mb-4 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" strokeWidth="1.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
          Back to Account
        </a>
        <h1 class="text-2xl font-bold text-gray-900">My Connections</h1>
        <p class="text-sm text-gray-500 mt-1">Track your community interactions, followed users, and bookmarks</p>
      </div>
    </div>

    <!-- Tabs -->
    <div class="max-w-4xl mx-auto px-4 py-6">
      <div class="flex gap-1 bg-gray-100 p-1 rounded-xl w-fit mb-6">
        <button onclick="switchTab('activity')" id="tab-activity" class="px-4 py-2 text-sm font-semibold rounded-lg bg-white text-gray-900 shadow-sm transition-all">Activity Feed</button>
        <button onclick="switchTab('bookmarks')" id="tab-bookmarks" class="px-4 py-2 text-sm font-semibold rounded-lg text-gray-500 hover:text-gray-700 transition-all">Bookmarks</button>
        <button onclick="switchTab('following')" id="tab-following" class="px-4 py-2 text-sm font-semibold rounded-lg text-gray-500 hover:text-gray-700 transition-all">Following</button>
      </div>

      <!-- Activity Feed Tab -->
      <div id="panel-activity" class="space-y-4">
        <div id="activity-list">
          <div class="flex justify-center py-12">
            <div class="w-6 h-6 border-2 border-indigo-200 border-t-indigo-600 rounded-full animate-spin"></div>
          </div>
        </div>
        <div id="activity-empty" class="hidden text-center py-16">
          <div class="w-14 h-14 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gray-400" fill="none" stroke="currentColor" strokeWidth="1.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a11.841 11.841 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>
          </div>
          <h3 class="font-semibold text-gray-900 text-lg">No activity yet</h3>
          <p class="text-gray-500 text-sm mt-1">Participate in the community to see your activity here.</p>
          <a href="/community" class="inline-flex items-center gap-2 mt-6 px-5 py-2.5 bg-violet-600 text-white text-sm font-semibold rounded-xl hover:bg-violet-700 transition-colors">
            Explore Community
          </a>
        </div>
      </div>

      <!-- Bookmarks Tab -->
      <div id="panel-bookmarks" class="hidden space-y-4">
        <div id="bookmarks-list">
          <div class="flex justify-center py-12">
            <div class="w-6 h-6 border-2 border-rose-200 border-t-rose-600 rounded-full animate-spin"></div>
          </div>
        </div>
        <div id="bookmarks-empty" class="hidden text-center py-16">
          <div class="w-14 h-14 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gray-400" fill="none" stroke="currentColor" strokeWidth="1.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" /></svg>
          </div>
          <h3 class="font-semibold text-gray-900 text-lg">No bookmarks yet</h3>
          <p class="text-gray-500 text-sm mt-1">Bookmark community posts to save them for later.</p>
          <a href="/community" class="inline-flex items-center gap-2 mt-6 px-5 py-2.5 bg-violet-600 text-white text-sm font-semibold rounded-xl hover:bg-violet-700 transition-colors">
            Browse Community
          </a>
        </div>
      </div>

      <!-- Following Tab -->
      <div id="panel-following" class="hidden space-y-4">
        <div id="following-list">
          <div class="flex justify-center py-12">
            <div class="w-6 h-6 border-2 border-violet-200 border-t-violet-600 rounded-full animate-spin"></div>
          </div>
        </div>
        <div id="following-empty" class="hidden text-center py-16">
          <div class="w-14 h-14 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-gray-400" fill="none" stroke="currentColor" strokeWidth="1.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="font-semibold text-gray-900 text-lg">Not following anyone</h3>
          <p class="text-gray-500 text-sm mt-1">Follow community members to see their posts in your feed.</p>
          <a href="/community" class="inline-flex items-center gap-2 mt-6 px-5 py-2.5 bg-violet-600 text-white text-sm font-semibold rounded-xl hover:bg-violet-700 transition-colors">
            Find Members
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  function esc(str: string) {
    if (!str) return '';
    const d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  function switchTab(tab: string) {
    ['activity', 'bookmarks', 'following'].forEach(t => {
      document.getElementById(`panel-${t}`)?.classList.add('hidden');
      document.getElementById(`tab-${t}`)?.classList.remove('bg-white', 'text-gray-900', 'shadow-sm');
      document.getElementById(`tab-${t}`)?.classList.add('text-gray-500');
    });
    document.getElementById(`panel-${tab}`)?.classList.remove('hidden');
    document.getElementById(`tab-${tab}`)?.classList.remove('text-gray-500');
    document.getElementById(`tab-${tab}`)?.classList.add('bg-white', 'text-gray-900', 'shadow-sm');
  }

  async function loadActivity() {
    try {
      const res = await fetch('/api/community/user/activity');
      if (!res.ok) throw new Error();
      const data = await res.json();
      const items = data.activity || [];

      const list = document.getElementById('activity-list');
      if (items.length === 0) {
        list.innerHTML = '';
        document.getElementById('activity-empty').classList.remove('hidden');
        return;
      }

      list.innerHTML = items.map((item: any) => `
        <div class="bg-white rounded-2xl border border-gray-200 p-5 flex gap-4">
          <div class="w-10 h-10 rounded-xl bg-indigo-50 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" strokeWidth="1.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a11.841 11.841 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900">${esc(item.title)}</p>
            <p class="text-xs text-gray-500 mt-0.5">${item.action} · ${new Date(item.createdAt).toLocaleDateString()}</p>
          </div>
          ${item.postSlug ? `<a href="/community/${item.category}/${item.postSlug}" class="text-xs text-violet-600 font-semibold hover:text-indigo-700 shrink-0">View →</a>` : ''}
        </div>
      `).join('');
    } catch {
      document.getElementById('activity-list').innerHTML = '<p class="text-center text-gray-500 py-8">Failed to load activity.</p>';
    }
  }

  async function loadBookmarks() {
    try {
      const res = await fetch('/api/community/bookmarks');
      if (!res.ok) throw new Error();
      const data = await res.json();
      const items = data.bookmarks || [];

      const list = document.getElementById('bookmarks-list');
      if (items.length === 0) {
        list.innerHTML = '';
        document.getElementById('bookmarks-empty').classList.remove('hidden');
        return;
      }

      list.innerHTML = items.map((item: any) => `
        <div class="bg-white rounded-2xl border border-gray-200 p-5 flex gap-4">
          <div class="w-10 h-10 rounded-xl bg-rose-50 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-rose-500" fill="currentColor" viewBox="0 0 24 24"><path d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" /></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-gray-900">${esc(item.postTitle)}</p>
            <p class="text-xs text-gray-500 mt-0.5">Bookmarked · ${new Date(item.createdAt).toLocaleDateString()}</p>
          </div>
          ${item.postSlug ? `<a href="/community/${item.category}/${item.postSlug}" class="text-xs text-rose-600 font-semibold hover:text-rose-700 shrink-0">View →</a>` : ''}
        </div>
      `).join('');
    } catch {
      document.getElementById('bookmarks-list').innerHTML = '<p class="text-center text-gray-500 py-8">Failed to load bookmarks.</p>';
    }
  }

  async function loadFollowing() {
    const list = document.getElementById('following-list');
    const empty = document.getElementById('following-empty');
    list.innerHTML = '<p class="text-center text-gray-500 py-8">Following feature is coming soon.</p>';
    if (empty) empty.classList.remove('hidden');
  }

  // Load data on tab switch
  let activityLoaded = false, bookmarksLoaded = false, followingLoaded = false;

  document.getElementById('tab-activity')?.addEventListener('click', () => {
    switchTab('activity');
    if (!activityLoaded) { loadActivity(); activityLoaded = true; }
  });
  document.getElementById('tab-bookmarks')?.addEventListener('click', () => {
    switchTab('bookmarks');
    if (!bookmarksLoaded) { loadBookmarks(); bookmarksLoaded = true; }
  });
  document.getElementById('tab-following')?.addEventListener('click', () => {
    switchTab('following');
    if (!followingLoaded) { loadFollowing(); followingLoaded = true; }
  });

  // Load initial tab
  loadActivity();
  activityLoaded = true;
</script>