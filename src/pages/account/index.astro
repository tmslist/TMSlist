---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import { getSessionFromRequest } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!session) {
  return Astro.redirect('/login?redirect=/account');
}

// Get user data from API
let userName = session.name || session.email?.split('@')[0] || 'User';
let userEmail = session.email || '';
let userRole = session.role || 'patient';
---

<Layout title="My Account | TMS List" noindex={true}>
  <div class="min-h-screen bg-gray-50/50">

    <!-- Profile Header Banner -->
    <div class="bg-gradient-to-r from-violet-600 via-violet-600 to-purple-600">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-5">
          <!-- Avatar -->
          <div class="w-20 h-20 rounded-2xl bg-white/20 backdrop-blur-sm border-2 border-white/40 flex items-center justify-center text-white text-2xl font-bold shadow-lg">
            {userName.split(' ').map((n: string) => n[0]).join('').slice(0, 2).toUpperCase()}
          </div>

          <!-- Info -->
          <div class="flex-1">
            <h1 class="text-2xl sm:text-3xl font-bold text-white">{userName}</h1>
            <p class="text-indigo-200 mt-1 text-sm sm:text-base">{userEmail}</p>
            <div class="flex items-center gap-2 mt-3 flex-wrap">
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/20 text-white text-xs font-semibold rounded-full backdrop-blur-sm border border-white/20">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" strokeWidth="2" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Verified Account
              </span>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-white/10 text-indigo-100 text-xs font-medium rounded-full border border-white/10">
                {userRole === 'admin' ? 'Admin' : userRole === 'clinic_owner' ? 'Clinic Owner' : 'Patient Member'}
              </span>
            </div>
          </div>

          <!-- Edit Profile Button -->
          <a
            href="/account/profile"
            class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 bg-white/20 hover:bg-white/30 text-white text-sm font-semibold rounded-xl backdrop-blur-sm border border-white/20 transition-all"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" strokeWidth="2" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.454.454-2.685A4.5 4.5 0 0110.183 8.205z" /></svg>
            Edit Profile
          </a>
        </div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">

      <!-- Quick Stats -->
      <div>
        <h2 class="text-sm font-bold text-gray-500 uppercase tracking-widest mb-4">Your Activity</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="bg-white rounded-2xl border border-gray-200 p-5 hover:shadow-md transition-all cursor-pointer group" onclick="location.href='/account/reviews'">
            <div class="w-10 h-10 bg-indigo-50 rounded-xl flex items-center justify-center mb-3 group-hover:bg-indigo-100 transition-colors">
              <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" strokeWidth="2" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
            </div>
            <p class="text-2xl font-bold text-gray-900" id="stat-reviews">—</p>
            <p class="text-xs text-gray-500 mt-1 font-medium">Reviews Written</p>
          </div>

          <div class="bg-white rounded-2xl border border-gray-200 p-5 hover:shadow-md transition-all cursor-pointer group" onclick="location.href='/account/saved'">
            <div class="w-10 h-10 bg-rose-50 rounded-xl flex items-center justify-center mb-3 group-hover:bg-rose-100 transition-colors">
              <svg class="w-5 h-5 text-rose-500" fill="none" stroke="currentColor" strokeWidth="2" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" /></svg>
            </div>
            <p class="text-2xl font-bold text-gray-900" id="stat-saved">—</p>
            <p class="text-xs text-gray-500 mt-1 font-medium">Clinics Saved</p>
          </div>

          <div class="bg-white rounded-2xl border border-gray-200 p-5 hover:shadow-md transition-all cursor-pointer group" onclick="location.href='/account/connections'">
            <div class="w-10 h-10 bg-violet-50 rounded-xl flex items-center justify-center mb-3 group-hover:bg-violet-100 transition-colors">
              <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" strokeWidth="2" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <p class="text-2xl font-bold text-gray-900" id="stat-connections">—</p>
            <p class="text-xs text-gray-500 mt-1 font-medium">Connections</p>
          </div>

          <div class="bg-white rounded-2xl border border-gray-200 p-5 hover:shadow-md transition-all cursor-pointer group" onclick="location.href='/community'">
            <div class="w-10 h-10 bg-emerald-50 rounded-xl flex items-center justify-center mb-3 group-hover:bg-emerald-100 transition-colors">
              <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" strokeWidth="2" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a11.841 11.841 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>
            </div>
            <p class="text-2xl font-bold text-gray-900" id="stat-posts">—</p>
            <p class="text-xs text-gray-500 mt-1 font-medium">Community Posts</p>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div>
        <h2 class="text-sm font-bold text-gray-500 uppercase tracking-widest mb-4">Quick Actions</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <a href="/account/profile" class="group bg-white rounded-2xl border border-gray-200 p-5 hover:border-violet-300 hover:shadow-lg transition-all">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-blue-100 transition-colors">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" strokeWidth="1.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 group-hover:text-violet-600 transition-colors">Edit Profile</h3>
                <p class="text-sm text-gray-500 mt-0.5">Update your name, bio, and preferences</p>
              </div>
            </div>
          </a>

          <a href="/account/reviews" class="group bg-white rounded-2xl border border-gray-200 p-5 hover:border-violet-300 hover:shadow-lg transition-all">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-amber-100 transition-colors">
                <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" strokeWidth="1.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 group-hover:text-violet-600 transition-colors">My Reviews</h3>
                <p class="text-sm text-gray-500 mt-0.5">Track and manage your clinic reviews</p>
              </div>
            </div>
          </a>

          <a href="/account/saved" class="group bg-white rounded-2xl border border-gray-200 p-5 hover:border-violet-300 hover:shadow-lg transition-all">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-rose-50 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-rose-100 transition-colors">
                <svg class="w-6 h-6 text-rose-500" fill="none" stroke="currentColor" strokeWidth="1.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 group-hover:text-violet-600 transition-colors">Saved Clinics</h3>
                <p class="text-sm text-gray-500 mt-0.5">View your bookmarked clinics</p>
              </div>
            </div>
          </a>

          <a href="/account/connections" class="group bg-white rounded-2xl border border-gray-200 p-5 hover:border-violet-300 hover:shadow-lg transition-all">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-violet-50 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-violet-100 transition-colors">
                <svg class="w-6 h-6 text-violet-600" fill="none" stroke="currentColor" strokeWidth="1.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 group-hover:text-violet-600 transition-colors">My Connections</h3>
                <p class="text-sm text-gray-500 mt-0.5">Community interactions and follows</p>
              </div>
            </div>
          </a>

          <a href="/community" class="group bg-white rounded-2xl border border-gray-200 p-5 hover:border-violet-300 hover:shadow-lg transition-all">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-emerald-100 transition-colors">
                <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" strokeWidth="1.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a11.841 11.841 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 group-hover:text-violet-600 transition-colors">Community Forum</h3>
                <p class="text-sm text-gray-500 mt-0.5">Ask questions, share experiences</p>
              </div>
            </div>
          </a>

          <a href="/api/auth/logout" class="group bg-white rounded-2xl border border-gray-200 p-5 hover:border-red-300 hover:shadow-lg transition-all">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-red-100 transition-colors">
                <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" strokeWidth="1.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" /></svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 group-hover:text-red-600 transition-colors">Sign Out</h3>
                <p class="text-sm text-gray-500 mt-0.5">Log out of your account</p>
              </div>
            </div>
          </a>
        </div>
      </div>

    </div>
  </div>
</Layout>

<script>
  async function loadStats() {
    // Load reviews count
    try {
      const reviewsRes = await fetch('/api/patient/reviews');
      if (reviewsRes.ok) {
        const data = await reviewsRes.json();
        const count = (data.reviews || []).length;
        document.getElementById('stat-reviews').textContent = String(count);
      }
    } catch {}

    // Load saved clinics count
    try {
      const savedRes = await fetch('/api/patient/saved-clinics');
      if (savedRes.ok) {
        const data = await savedRes.json();
        const count = (data.data || []).length;
        document.getElementById('stat-saved').textContent = String(count);
      }
    } catch {}
  }

  document.addEventListener('DOMContentLoaded', loadStats);
</script>