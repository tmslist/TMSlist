---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import PatientAuthForm from "../../components/react/PatientAuthForm";
import { getSessionFromRequest } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (session) {
  const redirect = Astro.url.searchParams.get('redirect') || '/account';
  return Astro.redirect(redirect);
}

const redirect = Astro.url.searchParams.get('redirect') || '/account';
---

<Layout
  title="Create Account | TMS List"
  description="Create a free account to save clinics, write reviews, and get personalized TMS recommendations."
  noindex={true}
>
  <main class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-violet-50 flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
      <div class="text-center mb-6">
        <a href="/" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-violet-600 mb-6 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
          Back to TMS List
        </a>
      </div>
      <PatientAuthForm client:load mode="register" redirect={redirect} />
    </div>
  </main>
</Layout>