---
import Layout from '../../layouts/Layout.astro';
import { INSURANCE_SLUGS } from '../../utils/seo_slugs';

const title = "TMS Insurance Coverage Guide | Medicare, BCBS, Aetna, Cigna & More";
const description = "Find out if your insurance covers TMS therapy. Detailed guides for Medicare, BlueCross BlueShield, Aetna, Cigna, UnitedHealthcare, Humana, Optum, VA, Tricare and 20+ more providers.";

const siteUrl = import.meta.env.SITE_URL || 'https://tmslist.com';

const insuranceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'TMS Therapy Insurance Coverage',
  description,
  url: `${siteUrl}/insurance/`,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: INSURANCE_SLUGS.length,
    itemListElement: INSURANCE_SLUGS.map((item: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.title,
      url: `${siteUrl}/insurance/${item.slug}/`,
    })),
  },
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Does Medicare cover TMS therapy?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Medicare Part B covers TMS for treatment-resistant major depressive disorder. Coverage requires a diagnosis of MDD and documentation of at least 4 antidepressant trials (or 2 per 2024 expanded criteria). No referral is needed for Part B beneficiaries.',
      },
    },
    {
      '@type': 'Question',
      name: 'What does "treatment-resistant depression" mean for insurance?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most insurers define treatment-resistant depression as failure to respond to at least 2 antidepressant medications at adequate dose and duration during the current episode. Some insurers require 4 trials, especially for initial coverage. Documentation of each trial including medication name, dose, and duration is required.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I get prior authorization for TMS?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Your TMS clinic typically handles the prior authorization process. They submit clinical documentation including your diagnosis, medication history, and treatment plan. The insurer reviews and approves or denies within 5-15 business days. Most clinics have dedicated insurance coordinators.',
      },
    },
    {
      '@type': 'Question',
      name: 'What if my insurance denies TMS coverage?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'You have the right to appeal. Common reasons for denial include incomplete medication documentation or failure to meet trial requirements. A first-level appeal with additional medical records is often successful. If denied again, request an external review by an independent medical reviewer. Many clinics offer free appeals assistance.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does Medicaid cover TMS?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Medicaid coverage for TMS varies significantly by state. Some state Medicaid programs cover TMS for treatment-resistant depression, while others do not yet include it in covered benefits. Check your state-specific Medicaid policy or contact your managed care organization.',
      },
    },
    {
      '@type': 'Question',
      name: 'How many TMS sessions does insurance typically approve?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most insurers approve 30-36 TMS sessions for an initial treatment course. Sessions are typically delivered 5 days per week over 6-7 weeks. Maintenance TMS (typically 6 booster sessions) may also be covered if symptoms recur after initial treatment.',
      },
    },
  ],
});

const majorProviders = [
  { slug: 'medicare', title: 'Medicare', icon: 'M', color: 'emerald', desc: 'Federal program covering Part B beneficiaries. No referral needed. Typically approves 36 sessions.', badge: 'Most Common' },
  { slug: 'bluecross-blueshield', title: 'Blue Cross Blue Shield', icon: 'BCBS', color: 'blue', desc: 'State affiliates vary. Most cover TMS with prior auth. 30-36 sessions standard.', badge: 'Largest Network' },
  { slug: 'aetna', title: 'Aetna', icon: 'A', color: 'violet', desc: 'Covers rTMS for MDD after 2+ failed medication trials. Prior authorization required.', badge: '' },
  { slug: 'cigna', title: 'Cigna', icon: 'C', color: 'amber', desc: 'Covers rTMS for major depression with documented medication failures in current episode.', badge: '' },
  { slug: 'united-healthcare', title: 'UnitedHealthcare', icon: 'U', color: 'sky', desc: 'UHC covers TMS for treatment-resistant MDD. Clinical documentation and prior auth required.', badge: '' },
  { slug: 'humana', title: 'Humana', icon: 'H', color: 'orange', desc: 'Medicare Advantage plans often cover TMS. Prior authorization and medication history needed.', badge: '' },
  { slug: 'optum-uhc', title: 'Optum / UHC Medicaid', icon: 'O', color: 'teal', desc: 'Managed Medicaid plans vary by state. Many now include TMS coverage.', badge: '' },
  { slug: 'tricare', title: 'Tricare', icon: 'T', color: 'rose', desc: 'Covers active duty, retirees, and dependents. PCM referral required. Both rTMS and deep TMS covered.', badge: '' },
];

const colorMap: Record<string, { bg: string; border: string; text: string; icon: string; badge: string }> = {
  emerald: { bg: 'bg-emerald-50', border: 'border-emerald-200 hover:border-emerald-400', text: 'text-emerald-600', icon: 'bg-emerald-100 text-emerald-600', badge: 'bg-emerald-100 text-emerald-700' },
  blue: { bg: 'bg-blue-50', border: 'border-blue-200 hover:border-blue-400', text: 'text-blue-600', icon: 'bg-blue-100 text-blue-600', badge: 'bg-blue-100 text-blue-700' },
  violet: { bg: 'bg-violet-50', border: 'border-violet-200 hover:border-violet-400', text: 'text-violet-600', icon: 'bg-violet-100 text-violet-600', badge: 'bg-violet-100 text-violet-700' },
  amber: { bg: 'bg-amber-50', border: 'border-amber-200 hover:border-amber-400', text: 'text-amber-600', icon: 'bg-amber-100 text-amber-600', badge: 'bg-amber-100 text-amber-700' },
  sky: { bg: 'bg-sky-50', border: 'border-sky-200 hover:border-sky-400', text: 'text-sky-600', icon: 'bg-sky-100 text-sky-600', badge: 'bg-sky-100 text-sky-700' },
  orange: { bg: 'bg-orange-50', border: 'border-orange-200 hover:border-orange-400', text: 'text-orange-600', icon: 'bg-orange-100 text-orange-600', badge: 'bg-orange-100 text-orange-700' },
  teal: { bg: 'bg-teal-50', border: 'border-teal-200 hover:border-teal-400', text: 'text-teal-600', icon: 'bg-teal-100 text-teal-600', badge: 'bg-teal-100 text-teal-700' },
  rose: { bg: 'bg-rose-50', border: 'border-rose-200 hover:border-rose-400', text: 'text-rose-600', icon: 'bg-rose-100 text-rose-600', badge: 'bg-rose-100 text-rose-700' },
};
---

<Layout title={title} description={description} schema={insuranceSchema} canonical="https://tmslist.com/insurance/">
  <main>
    <!-- Hero -->
    <section class="relative bg-slate-950 overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.4) 1px, transparent 0); background-size: 28px 28px;"></div>
      <div class="absolute top-[-20%] right-[10%] w-[600px] h-[600px] bg-emerald-500/10 rounded-full blur-[180px]"></div>
      <div class="absolute bottom-[-10%] left-[15%] w-[400px] h-[400px] bg-violet-500/10 rounded-full blur-[140px]"></div>

      <div class="container mx-auto px-4 pt-12 pb-20 lg:pt-16 lg:pb-28 relative z-10">
        <nav class="flex items-center gap-2 text-sm text-slate-500 mb-12" aria-label="Breadcrumb">
          <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
          <span class="text-slate-700">/</span>
          <span class="text-slate-300">Insurance</span>
        </nav>
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-full mb-6">
            <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></div>
            <span class="text-xs font-semibold text-slate-300 tracking-wider uppercase">{INSURANCE_SLUGS.length} Coverage Guides</span>
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-7xl font-bold tracking-tight text-white leading-[1.1] mb-5">
            TMS <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-violet-400">Insurance</span> Coverage
          </h1>
          <p class="text-lg text-slate-400 leading-relaxed mb-8 max-w-xl">
            Most major insurance providers cover TMS therapy for treatment-resistant depression. Find your plan and learn what's required for approval.
          </p>
          <!-- Stats -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-3 max-w-xl">
            <div class="text-center sm:text-left">
              <div class="text-2xl font-bold text-white">80%</div>
              <div class="text-xs text-slate-500 mt-1">of plans cover TMS</div>
            </div>
            <div class="text-center sm:text-left">
              <div class="text-2xl font-bold text-white">30–36</div>
              <div class="text-xs text-slate-500 mt-1">Sessions Covered</div>
            </div>
            <div class="text-center sm:text-left">
              <div class="text-2xl font-bold text-white">$3–5K</div>
              <div class="text-xs text-slate-500 mt-1">Typical Patient Copay</div>
            </div>
            <div class="text-center sm:text-left">
              <div class="text-2xl font-bold text-white">6–9</div>
              <div class="text-xs text-slate-500 mt-1">Weeks of Treatment</div>
            </div>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-16 bg-white" style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"></div>
    </section>

    <!-- Key Info Cards -->
    <section class="py-12 bg-white border-b border-slate-100">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          <div class="bg-white rounded-2xl p-7 border border-slate-100 shadow-sm flex gap-5 items-start">
            <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-900 mb-1">Most Plans Cover TMS</h3>
              <p class="text-sm text-slate-500 leading-relaxed">Medicare, BCBS, Aetna, Cigna, UnitedHealthcare, Humana, Optum, Tricare, VA, Kaiser, and most state Medicaid programs cover TMS when criteria are met.</p>
            </div>
          </div>
          <div class="bg-white rounded-2xl p-7 border border-slate-100 shadow-sm flex gap-5 items-start">
            <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-900 mb-1">Pre-Authorization Required</h3>
              <p class="text-sm text-slate-500 leading-relaxed">Your clinic submits documentation of your diagnosis and medication history. Most insurers respond within 5-15 business days.</p>
            </div>
          </div>
          <div class="bg-white rounded-2xl p-7 border border-slate-100 shadow-sm flex gap-5 items-start">
            <div class="w-12 h-12 rounded-xl bg-violet-50 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-violet-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-900 mb-1">Medication Trial Documentation</h3>
              <p class="text-sm text-slate-500 leading-relaxed">Most insurers require proof of 2–4 failed antidepressant trials. Your clinic needs the name, dose, and duration of each medication.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Major Providers -->
    <section class="py-16">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex items-end justify-between mb-10">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <div class="w-5 h-5 rounded bg-emerald-100 text-emerald-600 flex items-center justify-center text-[10px] font-bold">1</div>
              <span class="text-xs font-semibold text-emerald-600 uppercase tracking-wider">Coverage by Plan</span>
            </div>
            <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 tracking-tight">Major Insurance Providers</h2>
            <p class="text-slate-500 mt-1">Click your provider to see full coverage details, prior auth requirements, and approved protocols.</p>
          </div>
          <span class="hidden sm:block text-sm text-slate-400 font-medium">{majorProviders.length} Major Carriers</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {majorProviders.map(p => {
            const c = colorMap[p.color];
            return (
              <a href={`/insurance/${p.slug}/`}
                 class={`group bg-white rounded-2xl border ${c.border} p-7 hover:shadow-[0_12px_40px_-12px_rgba(0,0,0,0.10)] transition-all duration-300 relative overflow-hidden`}>
                {p.badge && (
                  <span class={`absolute top-4 right-4 px-2.5 py-0.5 ${c.badge} text-[10px] font-bold uppercase tracking-wider rounded-full`}>{p.badge}</span>
                )}
                <div class="flex items-start gap-4">
                  <div class={`w-12 h-12 rounded-xl ${c.icon} flex items-center justify-center text-sm font-bold shrink-0`}>{p.icon}</div>
                  <div>
                    <h3 class={`text-xl font-bold text-slate-900 ${c.text} group-hover:underline transition-all mb-2`}>{p.title}</h3>
                    <p class="text-sm text-slate-500 leading-relaxed mb-4">{p.desc}</p>
                    <span class={`inline-flex items-center gap-1.5 text-sm font-semibold ${c.text} group-hover:gap-2.5 transition-all`}>
                      View Full Guide
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- All Providers -->
    <section class="py-14 bg-slate-50 border-t border-slate-100">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex items-end justify-between mb-8">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <div class="w-5 h-5 rounded bg-violet-100 text-violet-600 flex items-center justify-center text-[10px] font-bold">2</div>
              <span class="text-xs font-semibold text-violet-600 uppercase tracking-wider">All Plans</span>
            </div>
            <h2 class="text-2xl font-bold text-slate-900 tracking-tight">All Coverage Guides</h2>
            <p class="text-slate-500 mt-1">State-specific policies, government programs, HSA/FSA, and denied coverage appeals.</p>
          </div>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3">
          {INSURANCE_SLUGS.filter(item => !majorProviders.find(m => m.slug === item.slug)).map(item => (
            <a href={`/insurance/${item.slug}/`}
               class="group bg-white rounded-xl p-4 border border-slate-100 hover:border-violet-300 hover:shadow-sm transition-all flex items-center justify-between gap-2">
              <h3 class="text-sm font-semibold text-slate-700 group-hover:text-violet-600 transition-colors leading-snug">{item.title}</h3>
              <svg class="w-3.5 h-3.5 text-slate-300 group-hover:text-violet-400 shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- What Gets Covered: Requirements Table -->
    <section class="py-16 bg-white border-t border-slate-100">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-10">
          <h2 class="text-2xl lg:text-3xl font-bold text-slate-900 tracking-tight mb-3">What's Required for TMS Coverage</h2>
          <p class="text-slate-500 max-w-xl mx-auto">Most insurers follow similar criteria. Here's what documentation you'll need and typical approval timelines.</p>
        </div>

        <div class="overflow-x-auto rounded-2xl border border-slate-100 shadow-sm mb-10">
          <table class="w-full text-sm">
            <thead class="bg-slate-50">
              <tr>
                <th class="text-left px-6 py-4 font-bold text-slate-700">Requirement</th>
                <th class="text-left px-6 py-4 font-bold text-slate-700">Medicare</th>
                <th class="text-left px-6 py-4 font-bold text-slate-700">BCBS / Aetna</th>
                <th class="text-left px-6 py-4 font-bold text-slate-700">Cigna / UHC</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              <tr>
                <td class="px-6 py-4 font-medium text-slate-800">Medication trials required</td>
                <td class="px-6 py-4 text-slate-600">2–4 (varies by plan year)</td>
                <td class="px-6 py-4 text-slate-600">2 failed trials</td>
                <td class="px-6 py-4 text-slate-600">2 failed trials in current episode</td>
              </tr>
              <tr class="bg-slate-30/40">
                <td class="px-6 py-4 font-medium text-slate-800">Prior authorization</td>
                <td class="px-6 py-4 text-slate-600"><span class="px-2 py-1 bg-amber-50 text-amber-600 text-xs rounded-full font-medium">Required</span></td>
                <td class="px-6 py-4 text-slate-600"><span class="px-2 py-1 bg-amber-50 text-amber-600 text-xs rounded-full font-medium">Required</span></td>
                <td class="px-6 py-4 text-slate-600"><span class="px-2 py-1 bg-amber-50 text-amber-600 text-xs rounded-full font-medium">Required</span></td>
              </tr>
              <tr>
                <td class="px-6 py-4 font-medium text-slate-800">Sessions approved</td>
                <td class="px-6 py-4 text-slate-600">Up to 36</td>
                <td class="px-6 py-4 text-slate-600">30–36 sessions</td>
                <td class="px-6 py-4 text-slate-600">30–36 sessions</td>
              </tr>
              <tr class="bg-slate-30/40">
                <td class="px-6 py-4 font-medium text-slate-800">FDA-cleared device required</td>
                <td class="px-6 py-4 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes</span></td>
                <td class="px-6 py-4 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes</span></td>
                <td class="px-6 py-4 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes</span></td>
              </tr>
              <tr>
                <td class="px-6 py-4 font-medium text-slate-800">Deep TMS for OCD covered</td>
                <td class="px-6 py-4 text-slate-600"><span class="px-2 py-1 bg-slate-100 text-slate-500 text-xs rounded-full font-medium">Case by case</span></td>
                <td class="px-6 py-4 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes (BrainsWay)</span></td>
                <td class="px-6 py-4 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes (BrainsWay)</span></td>
              </tr>
              <tr class="bg-slate-30/40">
                <td class="px-6 py-4 font-medium text-slate-800">Maintenance sessions covered</td>
                <td class="px-6 py-4 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes</span></td>
                <td class="px-6 py-4 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes</span></td>
                <td class="px-6 py-4 text-slate-600"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes</span></td>
              </tr>
              <tr>
                <td class="px-6 py-4 font-medium text-slate-800">Typical approval time</td>
                <td class="px-6 py-4 text-slate-600">7–10 business days</td>
                <td class="px-6 py-4 text-slate-600">5–15 business days</td>
                <td class="px-6 py-4 text-slate-600">5–15 business days</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Appeals Guide -->
        <div class="bg-gradient-to-br from-amber-50 to-orange-50 border border-amber-100 rounded-2xl p-8">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-amber-100 text-amber-600 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0 4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/></svg>
            </div>
            <div class="flex-1">
              <h3 class="font-bold text-slate-900 mb-2">What to Do If Coverage Is Denied</h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-4">If your insurer denies TMS coverage, you have the right to appeal. Most denials happen because of incomplete medication history documentation or failure to meet the medication trial requirement.</p>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div class="bg-white/80 rounded-xl p-4">
                  <div class="text-sm font-bold text-slate-800 mb-1">Step 1: First Appeal</div>
                  <p class="text-xs text-slate-500">Submit additional documentation. Most clinics handle this. ~40% succeed at this level.</p>
                </div>
                <div class="bg-white/80 rounded-xl p-4">
                  <div class="text-sm font-bold text-slate-800 mb-1">Step 2: Independent Review</div>
                  <p class="text-xs text-slate-500">Request an external review by an independent physician. ~25% more approvals at this level.</p>
                </div>
                <div class="bg-white/80 rounded-xl p-4">
                  <div class="text-sm font-bold text-slate-800 mb-1">Step 3: State Insurance Dept</div>
                  <p class="text-xs text-slate-500">File a complaint with your state's insurance commissioner. Effective for bad-faith denials.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
