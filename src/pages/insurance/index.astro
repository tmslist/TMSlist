---
import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import BrandLogo from '../../components/BrandLogo.astro';
import { INSURANCE_SLUGS } from '../../utils/seo_slugs';

const title = "TMS Insurance Coverage Guide | Medicare, BCBS, Aetna, Cigna & More";
const description = "Find out if your insurance covers TMS therapy. Detailed guides for Medicare, BlueCross BlueShield, Aetna, Cigna, UnitedHealthcare, Humana, Optum, VA, Tricare and 20+ more providers.";

const siteUrl = import.meta.env.SITE_URL || 'https://tmslist.com';

const insuranceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'TMS Therapy Insurance Coverage',
  description,
  url: `${siteUrl}/insurance/`,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: INSURANCE_SLUGS.length,
    itemListElement: INSURANCE_SLUGS.map((item: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.title,
      url: `${siteUrl}/insurance/${item.slug}/`,
    })),
  },
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Does Medicare cover TMS therapy?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Medicare Part B covers TMS for treatment-resistant major depressive disorder. Coverage requires a diagnosis of MDD and documentation of at least 4 antidepressant trials (or 2 per 2024 expanded criteria). No referral is needed for Part B beneficiaries.',
      },
    },
    {
      '@type': 'Question',
      name: 'What does "treatment-resistant depression" mean for insurance?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most insurers define treatment-resistant depression as failure to respond to at least 2 antidepressant medications at adequate dose and duration during the current episode. Some insurers require 4 trials, especially for initial coverage. Documentation of each trial including medication name, dose, and duration is required.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I get prior authorization for TMS?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Your TMS clinic typically handles the prior authorization process. They submit clinical documentation including your diagnosis, medication history, and treatment plan. The insurer reviews and approves or denies within 5-15 business days. Most clinics have dedicated insurance coordinators.',
      },
    },
    {
      '@type': 'Question',
      name: 'What if my insurance denies TMS coverage?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'You have the right to appeal. Common reasons for denial include incomplete medication documentation or failure to meet trial requirements. A first-level appeal with additional medical records is often successful. If denied again, request an external review by an independent medical reviewer. Many clinics offer free appeals assistance.',
      },
    },
    {
      '@type': 'Question',
      name: 'Does Medicaid cover TMS?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Medicaid coverage for TMS varies significantly by state. Some state Medicaid programs cover TMS for treatment-resistant depression, while others do not yet include it in covered benefits. Check your state-specific Medicaid policy or contact your managed care organization.',
      },
    },
    {
      '@type': 'Question',
      name: 'How many TMS sessions does insurance typically approve?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most insurers approve 30-36 TMS sessions for an initial treatment course. Sessions are typically delivered 5 days per week over 6-7 weeks. Maintenance TMS (typically 6 booster sessions) may also be covered if symptoms recur after initial treatment.',
      },
    },
  ],
});

const majorProviders = [
  { slug: 'medicare', title: 'Medicare', icon: 'M', color: 'emerald', desc: 'Federal program covering Part B beneficiaries. No referral needed. Typically approves 36 sessions.', badge: 'Most Common' },
  { slug: 'bluecross-blueshield', title: 'Blue Cross Blue Shield', icon: 'BCBS', color: 'blue', desc: 'State affiliates vary. Most cover TMS with prior auth. 30-36 sessions standard.', badge: 'Largest Network' },
  { slug: 'aetna', title: 'Aetna', icon: 'A', color: 'violet', desc: 'Covers rTMS for MDD after 2+ failed medication trials. Prior authorization required.', badge: '' },
  { slug: 'cigna', title: 'Cigna', icon: 'C', color: 'amber', desc: 'Covers rTMS for major depression with documented medication failures in current episode.', badge: '' },
  { slug: 'united-healthcare', title: 'UnitedHealthcare', icon: 'U', color: 'sky', desc: 'UHC covers TMS for treatment-resistant MDD. Clinical documentation and prior auth required.', badge: '' },
  { slug: 'humana', title: 'Humana', icon: 'H', color: 'orange', desc: 'Medicare Advantage plans often cover TMS. Prior authorization and medication history needed.', badge: '' },
  { slug: 'optum-uhc', title: 'Optum / UHC Medicaid', icon: 'O', color: 'teal', desc: 'Managed Medicaid plans vary by state. Many now include TMS coverage.', badge: '' },
  { slug: 'tricare', title: 'Tricare', icon: 'T', color: 'rose', desc: 'Covers active duty, retirees, and dependents. PCM referral required. Both rTMS and deep TMS covered.', badge: '' },
];

const colorMap: Record<string, { bg: string; border: string; text: string; icon: string; badge: string }> = {
  emerald: { bg: 'bg-emerald-50', border: 'border-emerald-200 hover:border-emerald-400', text: 'text-emerald-600', icon: 'bg-emerald-100 text-emerald-600', badge: 'bg-emerald-100 text-emerald-700' },
  blue: { bg: 'bg-[var(--paper2)]', border: 'border-[var(--line)] hover:border-[rgba(10,22,40,0.2)]', text: 'text-[var(--accent)]', icon: 'bg-[rgba(10,22,40,0.1)] text-[var(--accent)]', badge: 'bg-[rgba(10,22,40,0.1)] text-[var(--accent)]' },
  violet: { bg: 'bg-[rgba(10,22,40,0.08)]', border: 'border-[rgba(10,22,40,0.15)] hover:border-[var(--ink2)]', text: 'text-[var(--accent)]', icon: 'bg-[rgba(10,22,40,0.08)] text-[var(--accent)]', badge: 'bg-[rgba(10,22,40,0.08)] text-[var(--accent)]' },
  amber: { bg: 'bg-amber-50', border: 'border-amber-200 hover:border-amber-400', text: 'text-amber-600', icon: 'bg-amber-100 text-amber-600', badge: 'bg-amber-100 text-amber-700' },
  sky: { bg: 'bg-[var(--paper2)]', border: 'border-[var(--line)] hover:border-[rgba(10,22,40,0.2)]', text: 'text-[var(--accent)]', icon: 'bg-[rgba(10,22,40,0.1)] text-[var(--accent)]', badge: 'bg-[rgba(10,22,40,0.1)] text-[var(--accent)]' },
  orange: { bg: 'bg-orange-50', border: 'border-orange-200 hover:border-orange-400', text: 'text-orange-600', icon: 'bg-orange-100 text-orange-600', badge: 'bg-orange-100 text-orange-700' },
  teal: { bg: 'bg-teal-50', border: 'border-teal-200 hover:border-teal-400', text: 'text-teal-600', icon: 'bg-teal-100 text-teal-600', badge: 'bg-teal-100 text-teal-700' },
  rose: { bg: 'bg-[rgba(201,101,74,0.06)]', border: 'border-[var(--line)] hover:border-[rgba(201,101,74,0.2)]', text: 'text-[var(--warm)]', icon: 'bg-[rgba(201,101,74,0.1)] text-[var(--warm)]', badge: 'bg-[rgba(201,101,74,0.1)] text-[var(--warm)]' },
};
---

<Layout title={title} description={description} schema={insuranceSchema} canonical="https://tmslist.com/insurance/">
  <main style="background:var(--paper)">
    <EditorialHero
      eyebrow={`${INSURANCE_SLUGS.length} Coverage Guides`}
      eyebrowDot="#22c55e"
      title="Will my insurance"
      titleAccent="cover TMS?"
      description="Most major insurance providers cover TMS therapy for treatment-resistant depression. Find your plan and learn what's required for approval."
      breadcrumbs={[{ label: "Home", href: "/" }, { label: "Insurance" }]}
      ctas={[
        { label: "Check Insurance Eligibility", href: "/quiz/insurance-eligibility-checker/" },
        { label: "Cost Calculator", href: "/tms-cost-calculator/", variant: "outline" },
      ]}
      stats={[
        { value: "80%", label: "Plans Cover TMS", color: "ink" },
        { value: "30–36", label: "Sessions Covered", color: "accent" },
        { value: "$3–5K", label: "Typical Copay", color: "warm" },
      ]}
    />

    <!-- Key Info Cards -->
    <section class="py-12 bg-[var(--paper)] border-b border-[var(--line)]">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
          <div class="bg-[var(--paper)] rounded-2xl p-7 border border-[var(--line)] shadow-sm flex gap-5 items-start">
            <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--ink)] mb-1">Most Plans Cover TMS</h3>
              <p class="text-sm text-[var(--muted)] leading-relaxed">Medicare, BCBS, Aetna, Cigna, UnitedHealthcare, Humana, Optum, Tricare, VA, Kaiser, and most state Medicaid programs cover TMS when criteria are met.</p>
            </div>
          </div>
          <div class="bg-[var(--paper)] rounded-2xl p-7 border border-[var(--line)] shadow-sm flex gap-5 items-start">
            <div class="w-12 h-12 rounded-xl bg-[var(--paper2)] flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-[var(--accent)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--ink)] mb-1">Pre-Authorization Required</h3>
              <p class="text-sm text-[var(--muted)] leading-relaxed">Your clinic submits documentation of your diagnosis and medication history. Most insurers respond within 5-15 business days.</p>
            </div>
          </div>
          <div class="bg-[var(--paper)] rounded-2xl p-7 border border-[var(--line)] shadow-sm flex gap-5 items-start">
            <div class="w-12 h-12 rounded-xl bg-[rgba(10,22,40,0.08)] flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-[var(--accent)]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082"/></svg>
            </div>
            <div>
              <h3 class="font-bold text-[var(--ink)] mb-1">Medication Trial Documentation</h3>
              <p class="text-sm text-[var(--muted)] leading-relaxed">Most insurers require proof of 2–4 failed antidepressant trials. Your clinic needs the name, dose, and duration of each medication.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Major Providers -->
    <section class="py-16">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex items-end justify-between mb-10">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <div class="w-5 h-5 rounded bg-emerald-100 text-emerald-600 flex items-center justify-center text-[10px] font-bold">1</div>
              <span class="text-xs font-semibold text-emerald-600 uppercase tracking-wider">Coverage by Plan</span>
            </div>
            <h2 class="text-2xl lg:text-3xl font-bold text-[var(--ink)] tracking-tight">Major Insurance Providers</h2>
            <p class="text-[var(--muted)] mt-1">Click your provider to see full coverage details, prior auth requirements, and approved protocols.</p>
          </div>
          <span class="hidden sm:block text-sm text-[var(--muted)] font-medium">{majorProviders.length} Major Carriers</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {majorProviders.map(p => {
            const c = colorMap[p.color];
            return (
              <a href={`/insurance/${p.slug}/`}
                 class={`group bg-[var(--paper)] rounded-2xl border ${c.border} p-7 hover:shadow-[0_12px_40px_-12px_rgba(0,0,0,0.10)] transition-all duration-300 relative overflow-hidden`}>
                {p.badge && (
                  <span class={`absolute top-4 right-4 px-2.5 py-0.5 ${c.badge} text-[10px] font-bold uppercase tracking-wider rounded-full`}>{p.badge}</span>
                )}
                <div class="flex items-start gap-4">
                  <BrandLogo slug={p.slug} name={p.title} size={48} />

                  <div>
                    <h3 class={`text-xl font-bold text-[var(--ink)] ${c.text} group-hover:underline transition-all mb-2`}>{p.title}</h3>
                    <p class="text-sm text-[var(--muted)] leading-relaxed mb-4">{p.desc}</p>
                    <span class={`inline-flex items-center gap-1.5 text-sm font-semibold ${c.text} group-hover:gap-2.5 transition-all`}>
                      View Full Guide
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- All Providers -->
    <section class="py-14 bg-[var(--paper2)] border-t border-[var(--line)]">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex items-end justify-between mb-8">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <div class="w-5 h-5 rounded bg-[rgba(10,22,40,0.08)] text-[var(--accent)] flex items-center justify-center text-[10px] font-bold">2</div>
              <span class="text-xs font-semibold text-[var(--accent)] uppercase tracking-wider">All Plans</span>
            </div>
            <h2 class="text-2xl font-bold text-[var(--ink)] tracking-tight">All Coverage Guides</h2>
            <p class="text-[var(--muted)] mt-1">State-specific policies, government programs, HSA/FSA, and denied coverage appeals.</p>
          </div>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3">
          {INSURANCE_SLUGS.filter(item => !majorProviders.find(m => m.slug === item.slug)).map(item => (
            <a href={`/insurance/${item.slug}/`}
               class="group bg-[var(--paper)] rounded-xl p-4 border border-[var(--line)] hover:border-[rgba(10,22,40,0.2)] hover:shadow-sm transition-all flex items-center justify-between gap-2">
              <h3 class="text-sm font-semibold text-[var(--ink2)] group-hover:text-[var(--accent)] transition-colors leading-snug">{item.title}</h3>
              <svg class="w-3.5 h-3.5 text-[var(--muted)] group-hover:text-[var(--accent2)] shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- What Gets Covered: Requirements Table -->
    <section class="py-16 bg-[var(--paper)] border-t border-[var(--line)]">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-10">
          <h2 class="text-2xl lg:text-3xl font-bold text-[var(--ink)] tracking-tight mb-3">What's Required for TMS Coverage</h2>
          <p class="text-[var(--muted)] max-w-xl mx-auto">Most insurers follow similar criteria. Here's what documentation you'll need and typical approval timelines.</p>
        </div>

        <div class="overflow-x-auto rounded-2xl border border-[var(--line)] shadow-sm mb-10">
          <table class="w-full text-sm">
            <thead class="bg-[var(--paper2)]">
              <tr>
                <th class="text-left px-6 py-4 font-bold text-[var(--ink2)]">Requirement</th>
                <th class="text-left px-6 py-4 font-bold text-[var(--ink2)]">Medicare</th>
                <th class="text-left px-6 py-4 font-bold text-[var(--ink2)]">BCBS / Aetna</th>
                <th class="text-left px-6 py-4 font-bold text-[var(--ink2)]">Cigna / UHC</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[var(--line)]">
              <tr>
                <td class="px-6 py-4 font-medium text-[var(--ink2)]">Medication trials required</td>
                <td class="px-6 py-4 text-[var(--muted)]">2–4 (varies by plan year)</td>
                <td class="px-6 py-4 text-[var(--muted)]">2 failed trials</td>
                <td class="px-6 py-4 text-[var(--muted)]">2 failed trials in current episode</td>
              </tr>
              <tr class="bg-[var(--paper2)]">
                <td class="px-6 py-4 font-medium text-[var(--ink2)]">Prior authorization</td>
                <td class="px-6 py-4 text-[var(--muted)]"><span class="px-2 py-1 bg-amber-50 text-amber-600 text-xs rounded-full font-medium">Required</span></td>
                <td class="px-6 py-4 text-[var(--muted)]"><span class="px-2 py-1 bg-amber-50 text-amber-600 text-xs rounded-full font-medium">Required</span></td>
                <td class="px-6 py-4 text-[var(--muted)]"><span class="px-2 py-1 bg-amber-50 text-amber-600 text-xs rounded-full font-medium">Required</span></td>
              </tr>
              <tr>
                <td class="px-6 py-4 font-medium text-[var(--ink2)]">Sessions approved</td>
                <td class="px-6 py-4 text-[var(--muted)]">Up to 36</td>
                <td class="px-6 py-4 text-[var(--muted)]">30–36 sessions</td>
                <td class="px-6 py-4 text-[var(--muted)]">30–36 sessions</td>
              </tr>
              <tr class="bg-[var(--paper2)]">
                <td class="px-6 py-4 font-medium text-[var(--ink2)]">FDA-cleared device required</td>
                <td class="px-6 py-4 text-[var(--muted)]"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes</span></td>
                <td class="px-6 py-4 text-[var(--muted)]"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes</span></td>
                <td class="px-6 py-4 text-[var(--muted)]"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes</span></td>
              </tr>
              <tr>
                <td class="px-6 py-4 font-medium text-[var(--ink2)]">Deep TMS for OCD covered</td>
                <td class="px-6 py-4 text-[var(--muted)]"><span class="px-2 py-1 bg-[var(--paper2)] text-[var(--muted)] text-xs rounded-full font-medium">Case by case</span></td>
                <td class="px-6 py-4 text-[var(--muted)]"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes (BrainsWay)</span></td>
                <td class="px-6 py-4 text-[var(--muted)]"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes (BrainsWay)</span></td>
              </tr>
              <tr class="bg-[var(--paper2)]">
                <td class="px-6 py-4 font-medium text-[var(--ink2)]">Maintenance sessions covered</td>
                <td class="px-6 py-4 text-[var(--muted)]"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes</span></td>
                <td class="px-6 py-4 text-[var(--muted)]"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes</span></td>
                <td class="px-6 py-4 text-[var(--muted)]"><span class="px-2 py-1 bg-emerald-50 text-emerald-600 text-xs rounded-full font-medium">Yes</span></td>
              </tr>
              <tr>
                <td class="px-6 py-4 font-medium text-[var(--ink2)]">Typical approval time</td>
                <td class="px-6 py-4 text-[var(--muted)]">7–10 business days</td>
                <td class="px-6 py-4 text-[var(--muted)]">5–15 business days</td>
                <td class="px-6 py-4 text-[var(--muted)]">5–15 business days</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Appeals Guide -->
        <div class="bg-gradient-to-br from-amber-50 to-orange-50 border border-amber-100 rounded-2xl p-8">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-amber-100 text-amber-600 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0 4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/></svg>
            </div>
            <div class="flex-1">
              <h3 class="font-bold text-[var(--ink)] mb-2">What to Do If Coverage Is Denied</h3>
              <p class="text-sm text-[var(--muted)] leading-relaxed mb-4">If your insurer denies TMS coverage, you have the right to appeal. Most denials happen because of incomplete medication history documentation or failure to meet the medication trial requirement.</p>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div class="bg-[var(--paper)]/80 rounded-xl p-4">
                  <div class="text-sm font-bold text-[var(--ink2)] mb-1">Step 1: First Appeal</div>
                  <p class="text-xs text-[var(--muted)]">Submit additional documentation. Most clinics handle this. ~40% succeed at this level.</p>
                </div>
                <div class="bg-[var(--paper)]/80 rounded-xl p-4">
                  <div class="text-sm font-bold text-[var(--ink2)] mb-1">Step 2: Independent Review</div>
                  <p class="text-xs text-[var(--muted)]">Request an external review by an independent physician. ~25% more approvals at this level.</p>
                </div>
                <div class="bg-[var(--paper)]/80 rounded-xl p-4">
                  <div class="text-sm font-bold text-[var(--ink2)] mb-1">Step 3: State Insurance Dept</div>
                  <p class="text-xs text-[var(--muted)]">File a complaint with your state's insurance commissioner. Effective for bad-faith denials.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- HSA / FSA Section -->
    <section class="py-14 bg-[var(--paper2)] border-t border-[var(--line)]">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div>
            <h2 class="text-2xl font-bold text-[var(--ink)] tracking-tight mb-3">Pay with HSA or FSA</h2>
            <p class="text-[var(--muted)] leading-relaxed mb-5">If insurance doesn't cover your TMS, or if you have a high deductible, you can use pre-tax HSA or FSA funds. TMS is an eligible medical expense under IRS guidelines.</p>
            <a href="/insurance/hsa-fsa-tms/" class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-colors">
              Learn About HSA/FSA Coverage
