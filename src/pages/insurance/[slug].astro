---
export const prerender = true;

import InsurancePage from '../../layouts/InsurancePage.astro';
import { getCollection, render } from 'astro:content';
import { INSURANCE_SLUGS } from '../../utils/seo_slugs';

export async function getStaticPaths() {
  let entries: any[] = [];
  try {
    entries = await getCollection('insurance');
  } catch {}

  const contentPaths = entries.map((entry) => ({
    params: { slug: entry.id },
    props: {
      title: entry.data.title,
      description: entry.data.description,
      insurer: entry.data.insurer,
      provider: entry.data.provider,
      coversTms: entry.data.coversTms,
      priorAuthRequired: entry.data.priorAuthRequired,
      typicalCost: entry.data.typicalCost,
      faqs: entry.data.faqs || [],
      hasContent: true,
      entry,
    },
  }));

  const contentSlugsSet = new Set(contentPaths.map(p => p.params.slug));
  const fallbackPaths = INSURANCE_SLUGS
    .filter(({ slug }) => !contentSlugsSet.has(slug))
    .map(({ slug, title }) => ({
      params: { slug },
      props: { title, description: `Does ${title} cover TMS therapy? Learn about coverage policies, prior authorization, typical costs, and how to get approved.`, hasContent: false, entry: null },
    }));

  return [...contentPaths, ...fallbackPaths];
}

const { title, description, insurer, provider, coversTms, priorAuthRequired, typicalCost, faqs, hasContent, entry } = Astro.props;
const slug = Astro.params.slug!;
let Content: any = null;
if (hasContent && entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description || `TMS insurance coverage guide: ${title}.`,
  "url": `${siteUrl}/insurance/${slug}/`,
  "author": { "@type": "Organization", "name": "TMS List Editorial Team", "url": siteUrl },
  "publisher": { "@type": "Organization", "name": "TMS List", "url": siteUrl, "logo": { "@type": "ImageObject", "url": `${siteUrl}/favicon.svg` } },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `${siteUrl}/insurance/${slug}/` },
  "reviewedBy": { "@type": "Person", "name": "Dr. Karan Narwal", "jobTitle": "Mental Health Specialist & Consultant" },
  ...(insurer || provider ? {
    "about": {
      "@type": "HealthInsurancePlan",
      "name": insurer || provider || title,
      ...(coversTms !== undefined ? { "coverageDescription": coversTms ? "Covers TMS therapy for treatment-resistant depression" : "TMS coverage varies by plan and state" } : {}),
      ...(priorAuthRequired !== undefined ? { "additionalProperty": { "@type": "PropertyValue", "name": "Prior Authorization Required", "value": priorAuthRequired ? "Yes" : "No" } } : {}),
      ...(typicalCost ? { "costPerUnit": typicalCost } : {}),
    },
  } : {}),
});

const faqSchema = faqs && faqs.length > 0 ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq: { question: string; answer: string }) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
  })),
}) : null;
---

<InsurancePage
  title={title}
  insurer={insurer}
  provider={provider}
  description={description}
  coversTms={coversTms}
  priorAuthRequired={priorAuthRequired}
  typicalCost={typicalCost}
  slug={slug}
  faqs={faqs || []}
  schema={articleSchema}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Insurance", url: "/insurance/" },
    { name: title, url: `/insurance/${slug}/` },
  ]}
>
  {Content ? <Content /> : null}
</InsurancePage>

{faqSchema && (
  <script type="application/ld+json" set:html={faqSchema} />
)}
