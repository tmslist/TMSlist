---
import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import { getAllClinics, getStateSlug, STATE_NAMES } from '../../utils/clinicData';
import LocationSEOContent from '../../components/LocationSEOContent.astro';
import { getClinicRating, getClinicReviewCount, getTotalDoctorCount, getStateCodeFromSlug } from '../../utils/dataHelpers';
import ClinicCard from '../../components/ClinicCard.astro';

const allClinics = await getAllClinics();
const clinics = allClinics.filter(c => !c.country || c.country === 'US');
const totalDoctors = await getTotalDoctorCount();

// ── Handle search query param ──────────────────────────────
const rawQuery = Astro.url.searchParams.get('q') || '';
const query = rawQuery.toLowerCase().trim();

if (query && query.length >= 2) {
    // 1. Exact zip code match → redirect to city page
    const zipMatch = clinics.find(c => c.zip === query);
    if (zipMatch && zipMatch.city && zipMatch.state) {
        const citySlug = zipMatch.city.toLowerCase().replace(/\s+/g, '-');
        return Astro.redirect(`/us/${getStateSlug(zipMatch.state)}/${citySlug}/`);
    }

    // 2. City name match (case-insensitive) → redirect to city page
    const cityMatch = clinics.find(c =>
        c.city && c.city.toLowerCase() === query
    );
    if (cityMatch && cityMatch.state) {
        const citySlug = cityMatch.city.toLowerCase().replace(/\s+/g, '-');
        return Astro.redirect(`/us/${getStateSlug(cityMatch.state)}/${citySlug}/`);
    }

    // 3. State name match → redirect to state page
    const stateMatch = Object.entries(STATE_NAMES).find(([, name]) =>
        name.toLowerCase() === query
    );
    if (stateMatch) {
        return Astro.redirect(`/us/${getStateSlug(stateMatch[0])}/`);
    }

    // 4. State code match (e.g. "CA", "ny") → redirect to state page
    const stateCodeMatch = Object.keys(STATE_NAMES).find(
        code => code.toLowerCase() === query
    );
    if (stateCodeMatch) {
        return Astro.redirect(`/us/${getStateSlug(stateCodeMatch)}/`);
    }
}

// Filtered clinics when query doesn't redirect
const filteredClinics = query
    ? clinics.filter(c => {
        const inZip = c.zip?.toLowerCase().includes(query);
        const inCity = c.city?.toLowerCase().includes(query);
        const inState = c.state?.toLowerCase().includes(query);
        const inName = c.name?.toLowerCase().includes(query);
        const inAddress = c.address?.toLowerCase().includes(query);
        return inZip || inCity || inState || inName || inAddress;
    })
    : [];

const states = [...new Set(clinics.map(c => c.state))].map(stateCode => {
    const stateClinics = clinics.filter(c => c.state === stateCode);
    const cities = [...new Set(stateClinics.map(c => c.city).filter(Boolean))];
    const avgRating = stateClinics.reduce((sum, c) => sum + getClinicRating(c), 0) / (stateClinics.length || 1);
    const totalReviews = stateClinics.reduce((sum, c) => sum + getClinicReviewCount(c), 0);
    return {
        name: STATE_NAMES[stateCode] || stateCode,
        code: stateCode,
        slug: getStateSlug(stateCode),
        count: stateClinics.length,
        cityCount: cities.length,
        avgRating: avgRating,
        totalReviews: totalReviews,
        topCities: cities.sort().slice(0, 3),
    };
}).sort((a, b) => b.count - a.count);

const totalClinics = clinics.length;
const title = "Find TMS Therapy Clinics in Every US State | TMS List Directory";
const description = `Browse ${totalClinics}+ TMS therapy clinics across all 50 states. Compare FDA-cleared providers by location, insurance, technology, and patient ratings.`;

const stateListSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "TMS Therapy Clinics by State",
  "description": description,
  "url": "https://tmslist.com/us/",
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": states.length,
    "itemListElement": states.map((s, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": `TMS Clinics in ${s.name}`,
      "url": `https://tmslist.com/us/${s.slug}/`
    }))
  }
});
---

<Layout title={title} description={description} schema={stateListSchema} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "United States", url: "/us/" },
]}>
  <main style="background:var(--paper)">
    {query ? (
      <EditorialHero
        eyebrow={`${filteredClinics.length} ${filteredClinics.length === 1 ? 'Result' : 'Results'} for "${rawQuery}"`}
        eyebrowDot="#22c55e"
        title="Matching"
        titleAccent={`"${rawQuery}".`}
        description={filteredClinics.length > 0
          ? `Found ${filteredClinics.length} FDA-cleared TMS provider${filteredClinics.length !== 1 ? 's' : ''} matching "${rawQuery}".`
          : `No clinics found matching "${rawQuery}". Browse all states below.`}
        breadcrumbs={[{ label: "Home", href: "/" }, { label: "United States" }]}
        ctas={[
          { label: "Browse All States", href: "/us/" },
          { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/", variant: "outline" },
        ]}
      />
    ) : (
      <EditorialHero
        eyebrow={`${states.length} States · ${totalClinics}+ Verified Clinics`}
        eyebrowDot="#22c55e"
        title="TMS clinics across"
        titleAccent="the United States."
        description={`Browse ${totalClinics}+ FDA-cleared TMS providers. Find top-rated clinics near you for depression, anxiety, OCD, and more.`}
        breadcrumbs={[{ label: "Home", href: "/" }, { label: "United States" }]}
        ctas={[
          { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
          { label: "Best TMS Clinics", href: "/best-tms-clinics/", variant: "outline" },
        ]}
        stats={[
          { value: `${totalClinics}+`, label: "Verified Clinics", color: "ink" },
          { value: states.length, label: "States Covered", color: "accent" },
          { value: `${totalDoctors}+`, label: "Specialists", color: "warm" },
        ]}
      />
    )}

    <!-- State Grid / Search Results -->
    <section class="py-12 lg:py-16">
      <div class="container mx-auto px-4">
        {query ? (
          // ── Search Results: Clinic Cards ──────────────────
          <>
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
              <h2 class="text-2xl font-bold text-[var(--ink)]">TMS Clinics matching "{rawQuery}"</h2>
            </div>

            {filteredClinics.length > 0 ? (
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
                {filteredClinics.map((clinic) => (
                  <ClinicCard clinic={clinic} />
                ))}
              </div>
            ) : (
              <div class="text-center py-16">
                <div class="w-16 h-16 rounded-full bg-[var(--paper2)] flex items-center justify-center mx-auto mb-4">
                  <svg class="w-8 h-8 text-[var(--muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <h3 class="text-lg font-semibold text-[var(--ink2)] mb-2">No clinics found</h3>
                <p class="text-[var(--muted)] mb-6">We couldn't find any TMS clinics matching "{rawQuery}".</p>
                <a href="/us/" class="inline-flex items-center gap-2 px-4 py-2 bg-[var(--ink)] text-white rounded-xl text-sm font-medium hover:bg-[var(--ink2)] transition-colors">
                  Browse all US clinics
                </a>
              </div>
            )}
          </>
        ) : (
          // ── Default: State Grid ────────────────────────────
          <>
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
              <h2 class="text-2xl font-bold text-[var(--ink)]">Browse by State</h2>
              <div class="relative w-full sm:w-72">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input
                  type="text"
                  id="state-search"
                  placeholder="Search states..."
                  class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-[var(--line)] text-sm focus:border-[var(--ink2)] focus:ring-2 focus:ring-[rgba(10,22,40,0.1)] transition-all bg-[var(--paper)]"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4" id="state-grid">
              {states.map((state) => {
                const sizeClass = state.count >= 50 ? 'ring-2 ring-[rgba(10,22,40,0.1)]' : '';
                return (
                  <a
                    href={`/us/${state.slug}/`}
                    class={`state-card group block bg-[var(--paper)] rounded-2xl border border-[var(--line)] p-5 hover:border-[rgba(10,22,40,0.15)] hover:shadow-[0_4px_20px_rgb(0,0,0,0.04)] transition-all ${sizeClass}`}
                    data-name={state.name.toLowerCase()}
                  >
                    <div class="flex items-start justify-between mb-3">
                      <div class="flex items-center gap-2.5">
                        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-[var(--paper2)] to-[var(--paper)] flex items-center justify-center text-sm font-bold text-[var(--muted)] group-hover:from-[rgba(10,22,40,0.08)] group-hover:to-[rgba(10,22,40,0.08)] group-hover:text-[var(--accent)] transition-colors">
                          {state.code}
                        </div>
                        <div>
                          <h3 class="font-semibold text-[var(--ink)] group-hover:text-[var(--accent)] transition-colors leading-tight">{state.name}</h3>
                          <p class="text-xs text-[var(--muted)] mt-0.5">{state.cityCount} cities</p>
                        </div>
                      </div>
                      <span class="text-xs font-bold text-[var(--accent)] bg-[rgba(10,22,40,0.08)] px-2.5 py-1 rounded-lg">
                        {state.count}
                      </span>
                    </div>

                    <div class="flex items-center gap-2 mb-3">
                      <div class="flex-1 h-1.5 rounded-full bg-[var(--paper2)] overflow-hidden">
                        <div
                          class="h-full rounded-full bg-gradient-to-r from-[var(--ink2)] to-[var(--ink)]"
                          style={`width: ${Math.min((state.avgRating / 5) * 100, 100)}%`}
                        ></div>
                      </div>
                      <span class="text-xs font-semibold text-[var(--muted)]">{state.avgRating.toFixed(1)}</span>
                      <svg class="w-3 h-3 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                    </div>

                    {state.topCities.length > 0 && (
                      <div class="flex flex-wrap gap-1.5">
                        {state.topCities.map(city => (
                          <span class="text-[10px] font-medium text-[var(--muted)] bg-[var(--paper2)] px-2 py-0.5 rounded-md">{city}</span>
                        ))}
                        {state.cityCount > 3 && (
                          <span class="text-[10px] font-medium text-[var(--accent2)] bg-[rgba(10,22,40,0.08)] px-2 py-0.5 rounded-md">+{state.cityCount - 3} more</span>
                        )}
                      </div>
                    )}
                  </a>
                );
              })}
            </div>

            <p id="no-state-results" class="hidden text-center text-[var(--muted)] py-12 text-sm">No states match your search.</p>
          </>
        )}
      </div>
    </section>

    <!-- Top Cities with Gemini Images -->
    <section class="py-16 bg-gradient-to-b from-[var(--paper2)] to-white border-t border-[var(--line)]">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <span class="inline-block px-3 py-1 bg-[var(--paper2)] text-[var(--accent)] rounded-full text-xs font-semibold uppercase tracking-wider mb-3">Top Locations</span>
          <h2 class="text-3xl font-bold text-[var(--ink)] mb-3">Most Popular TMS States</h2>
          <p class="text-[var(--muted)] max-w-xl mx-auto">These states have the highest concentration of verified TMS providers</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3 sm:gap-4">
          {states.slice(0, 5).map(state => (
            <a href={`/us/${state.slug}/`} class="group relative overflow-hidden rounded-2xl aspect-[3/4] bg-gradient-to-br from-[rgba(10,22,40,0.08)] to-[var(--paper2)]">
              <div class="gemini-city-img absolute inset-0 bg-gradient-to-br from-[rgba(10,22,40,0.15)]/50 to-[rgba(10,22,40,0.50)] transition-transform duration-700 group-hover:scale-110" data-city={state.topCities[0] || state.name} data-state={state.name}></div>
              <div class="absolute inset-0 bg-gradient-to-t from-[var(--ink)]/80 via-[var(--ink)]/20 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-4">
                <h3 class="font-bold text-white text-lg leading-tight">{state.name}</h3>
                <p class="text-white/70 text-sm mt-1">{state.count} clinics</p>
              </div>
              <div class="absolute top-3 right-3 px-2 py-1 bg-[var(--paper)]/90 backdrop-blur rounded-lg text-xs font-bold text-[var(--accent)]">
                <svg class="w-3 h-3 text-amber-400 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <LocationSEOContent
      type="country"
      locationName="United States"
      clinicCount={totalClinics}
    />

    <!-- Learn More -->
    <section class="py-10 bg-[var(--paper)] border-t border-[var(--line)]">
      <div class="container mx-auto px-4 md:px-6">
        <div class="flex flex-wrap justify-center gap-3 max-w-4xl mx-auto">
          <a href="/blog/tms-for-depression/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">TMS for Depression</a>
          <a href="/blog/tms-cost-insurance-guide-2026/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Cost & Insurance Guide</a>
          <a href="/blog/questions-to-ask-tms-clinic/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Questions to Ask</a>
          <a href="/blog/preparing-for-first-tms-session/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">First Session Prep</a>
          <a href="/blog/maintenance-tms-guide/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Maintenance TMS</a>
          <a href="/blog/" class="px-4 py-2 text-sm font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">TMS Research Blog</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  // State search filter
  const searchInput = document.getElementById('state-search') as HTMLInputElement;
  const stateCards = document.querySelectorAll('.state-card');
  const noResults = document.getElementById('no-state-results');

  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase().trim();
    let visible = 0;

    stateCards.forEach(card => {
      const name = card.getAttribute('data-name') || '';
      const show = !q || name.includes(q);
      (card as HTMLElement).style.display = show ? '' : 'none';
      if (show) visible++;
    });

    noResults?.classList.toggle('hidden', visible > 0);
  });

  // AI hero image loader
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;

    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }

    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });

  // Gemini city image loader — loads top 5 city images via API
  document.querySelectorAll('.gemini-city-img').forEach(async (el) => {
    const city = el.getAttribute('data-city');
    const state = el.getAttribute('data-state');
    if (!city || !state) return;

    try {
      const res = await fetch(`/api/ai/generate-image?type=city&subject=${encodeURIComponent(city)}&state=${encodeURIComponent(state)}`);
      if (res.ok) {
        const { image } = await res.json();
        if (image) {
          (el as HTMLElement).style.backgroundImage = `url(${image})`;
          (el as HTMLElement).style.backgroundSize = 'cover';
          (el as HTMLElement).style.backgroundPosition = 'center';
        }
      }
    } catch {
      // Keep gradient fallback
    }
  });
</script>
