---
import Layout from "../../../layouts/Layout.astro";
import EditorialHero from "../../../components/editorial/EditorialHero.astro";
import ClinicCard from "../../../components/ClinicCard.astro";
import {
  getClinicsByState,
  getStateCodeFromSlug,
  STATE_NAMES,
} from "../../../utils/dataHelpers";
import LocationSEOContent from "../../../components/LocationSEOContent.astro";

const stateSlug = Astro.params.state!;
const stateCode = getStateCodeFromSlug(stateSlug);
if (!stateCode) return Astro.redirect('/us/');
const stateName = STATE_NAMES[stateCode] || stateCode;

const stateClinics = await getClinicsByState(stateCode);
if (stateClinics.length === 0) return Astro.redirect('/us/');

const cities = [
  ...new Set(
    stateClinics.map((c) =>
      JSON.stringify({
        name: c.city,
        slug: c.city.toLowerCase().replace(/\s+/g, "-"),
      }),
    ),
  ),
]
  .map((s) => JSON.parse(s))
  .sort((a, b) => a.name.localeCompare(b.name));

const getRatingVal = (c: any) =>
  typeof c.rating === "number" ? c.rating : c.rating?.aggregate || 0;
const topClinics = [...stateClinics]
  .sort((a, b) => getRatingVal(b) - getRatingVal(a))
  .slice(0, 3);

const clinicCount = stateClinics.length;

// strict SEO: "Best TMS Therapy Clinics in [State] | TMS List"
const title = `Best TMS Clinics in ${stateName} | TMS List`;
const description = `Find the best TMS therapy providers in ${stateName}. Compare ${clinicCount} top-rated clinics across ${cities.length} cities, read patient reviews, check insurance coverage, and find affordable treatment options near you.`;

const stateSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `TMS Therapy Clinics in ${stateName}`,
  "description": description,
  "url": `https://tmslist.com/us/${stateSlug}/`,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": clinicCount,
    "itemListElement": topClinics.slice(0, 3).map((c: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "MedicalClinic",
        "name": c.name,
        "url": `https://tmslist.com/clinic/${c.slug}`,
        "address": {
          "@type": "PostalAddress",
          "addressLocality": c.city,
          "addressRegion": stateName,
          "addressCountry": "US"
        },
        ...(getRatingVal(c) > 0 ? {
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": getRatingVal(c),
            "reviewCount": typeof c.rating === 'object' ? c.rating?.count || 0 : 50
          }
        } : {})
      }
    }))
  }
});
---

<Layout title={title} description={description} schema={stateSchema} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "United States", url: "/us/" },
  { name: stateName, url: `/us/${stateSlug}/` },
]}>
  <EditorialHero
    eyebrow={`${clinicCount} Verified Clinics · ${cities.length} Cities`}
    eyebrowDot="#22c55e"
    title="TMS therapy clinics in"
    titleAccent={`${stateName}.`}
    description={`Compare ${clinicCount} top-rated TMS therapy providers across ${cities.length} cities in ${stateName}. Read patient reviews, check insurance coverage, and find treatment near you.`}
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: "United States", href: "/us/" },
      { label: stateName },
    ]}
    ctas={[
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: "Best TMS Clinics", href: "/best-tms-clinics/", variant: "outline" },
    ]}
    stats={[
      { value: clinicCount, label: "Clinics", color: "ink" },
      { value: cities.length, label: "Cities", color: "accent" },
      { value: stateName.length > 12 ? stateName.slice(0,3).toUpperCase() : stateName, label: "State", color: "warm" },
    ]}
  />

  <main class="container mx-auto px-4 py-8">
    <!-- Top Rated Section -->
    <section class="mb-16">
      <div class="flex items-center mb-8">
        <h2 class="text-2xl font-semibold text-[var(--ink)]">
          Top Rated Clinics in {stateName}
        </h2>
        <div class="ml-4 h-px flex-1 bg-[var(--paper2)]"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {topClinics.map((clinic) => <ClinicCard clinic={clinic} />)}
      </div>
    </section>

    <!-- City Directory -->
    <section>
      <div class="flex items-center mb-8">
        <h2 class="text-2xl font-semibold text-[var(--ink)]">
          Browse by City in {stateName}
        </h2>
        <div class="ml-4 h-px flex-1 bg-[var(--paper2)]"></div>
        <span class="ml-4 text-sm font-medium text-[var(--muted)]">{cities.length} cities</span>
      </div>
      <div
        class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4"
      >
        {
          cities.map((city) => (
            <a
              href={`/us/${Astro.params.state}/${city.slug}/`}
              class="group relative bg-[var(--paper)] p-5 rounded-2xl border border-[var(--line)] shadow-[0_2px_8px_rgb(0,0,0,0.02)] hover:shadow-[0_8px_30px_rgb(37,99,235,0.08)] hover:border-[var(--line)] transition-all overflow-hidden"
            >
              <div class="absolute inset-x-0 bottom-0 h-1 bg-[var(--accent2)] transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
              <div class="flex items-center justify-between mb-1">
                <span class="font-bold text-[var(--ink)] group-hover:text-[var(--accent)] transition-colors">
                  {city.name}
                </span>
                <svg class="w-4 h-4 text-[var(--line)] group-hover:text-[var(--accent2)] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </div>
              <span class="text-xs font-medium text-[var(--muted)]">
                View Clinics
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- All Clinics with Sort & Pagination -->
    <section class="mb-16">
      <div class="flex items-center flex-wrap gap-4 mb-8">
        <h2 class="text-2xl font-semibold text-[var(--ink)]">
          All Clinics in {stateName}
        </h2>
        <div class="ml-0 md:ml-4 h-px flex-1 bg-[var(--paper2)] hidden md:block"></div>
        <span class="text-sm font-medium text-[var(--muted)]">{clinicCount} clinics</span>
        <div class="relative">
          <label for="clinic-sort" class="sr-only">Sort clinics</label>
          <select
            id="clinic-sort"
            class="appearance-none bg-[var(--paper)] border border-[var(--line)] rounded-xl px-4 py-2 pr-9 text-sm font-medium text-[var(--ink2)] shadow-sm hover:border-[rgba(10,22,40,0.2)] focus:border-[var(--ink2)] focus:ring-2 focus:ring-[rgba(10,22,40,0.1)] focus:outline-none cursor-pointer transition-colors"
          >
            <option value="rating">Highest Rated</option>
            <option value="name">Name A–Z</option>
            <option value="reviews">Most Reviews</option>
          </select>
          <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-[var(--muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </div>
      </div>

      <div id="all-clinics-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {stateClinics.map((clinic, i) => (
          <div class:list={["clinic-card-wrapper", { "clinic-hidden": i >= 24 }]}>
            <ClinicCard clinic={clinic} />
          </div>
        ))}
      </div>

      {clinicCount > 24 && (
        <div id="show-more-wrap" class="flex justify-center mt-10">
          <button
            id="show-more-btn"
            type="button"
            class="inline-flex items-center gap-2 px-8 py-3 bg-[var(--paper)] border border-[var(--line)] rounded-xl text-sm font-semibold text-[var(--ink2)] shadow-sm hover:border-[rgba(10,22,40,0.2)] hover:text-[var(--accent)] hover:shadow-md transition-all focus-visible:ring-2 focus-visible:ring-[rgba(10,22,40,0.2)] focus-visible:ring-offset-2 cursor-pointer"
          >
            <span id="show-more-label">Show More Clinics</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
        </div>
      )}
    </section>

    <LocationSEOContent
      type="state"
      locationName={stateName}
      clinicCount={clinicCount}
      topCities={cities.slice(0, 3).map((c: any) => c.name)}
    />
  </main>
</Layout>

<style>
  .clinic-hidden { display: none; }
</style>

<script is:inline>
  (function() {
    const PAGE_SIZE = 24;
    const grid = document.getElementById('all-clinics-grid');
    const btn = document.getElementById('show-more-btn');
    const btnWrap = document.getElementById('show-more-wrap');
    const sortSelect = document.getElementById('clinic-sort');
    if (!grid) return;

    let visible = PAGE_SIZE;

    function getCards() {
      return Array.from(grid.querySelectorAll('.clinic-card-wrapper'));
    }

    function updateVisibility() {
      var cards = getCards();
      cards.forEach(function(card, i) {
        if (i < visible) {
          card.classList.remove('clinic-hidden');
        } else {
          card.classList.add('clinic-hidden');
        }
      });
      if (btnWrap) {
        btnWrap.style.display = visible >= cards.length ? 'none' : 'flex';
      }
    }

    function sortCards(mode) {
      var cards = getCards();
      cards.sort(function(a, b) {
        var articleA = a.querySelector('article');
        var articleB = b.querySelector('article');
        if (!articleA || !articleB) return 0;
        if (mode === 'rating') {
          return parseFloat(articleB.dataset.rating || '0') - parseFloat(articleA.dataset.rating || '0');
        } else if (mode === 'name') {
          return (articleA.dataset.name || '').localeCompare(articleB.dataset.name || '');
        } else if (mode === 'reviews') {
          return parseInt(articleB.dataset.reviews || '0', 10) - parseInt(articleA.dataset.reviews || '0', 10);
        }
        return 0;
      });
      // Re-append in sorted order
      cards.forEach(function(card) { grid.appendChild(card); });
      // Reset pagination on sort change
      visible = PAGE_SIZE;
      updateVisibility();
    }

    if (btn) {
      btn.addEventListener('click', function() {
        visible += PAGE_SIZE;
        updateVisibility();
      });
    }

    if (sortSelect) {
      sortSelect.addEventListener('change', function() {
        sortCards(this.value);
      });
    }

    // Initial sort by rating (default)
    sortCards('rating');
  })();
</script>

<script>
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;
    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }
    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });
</script>
