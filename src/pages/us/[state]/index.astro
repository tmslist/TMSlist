---
import Layout from "../../../layouts/Layout.astro";
import ClinicCard from "../../../components/ClinicCard.astro";
import {
  getClinicsByState,
  getStateCodeFromSlug,
  STATE_NAMES,
} from "../../../utils/dataHelpers";

const stateSlug = Astro.params.state!;
const stateCode = getStateCodeFromSlug(stateSlug);
if (!stateCode) return Astro.redirect('/us/');
const stateName = STATE_NAMES[stateCode] || stateCode;

const stateClinics = await getClinicsByState(stateCode);
if (stateClinics.length === 0) return Astro.redirect('/us/');

const cities = [
  ...new Set(
    stateClinics.map((c) =>
      JSON.stringify({
        name: c.city,
        slug: c.city.toLowerCase().replace(/\s+/g, "-"),
      }),
    ),
  ),
]
  .map((s) => JSON.parse(s))
  .sort((a, b) => a.name.localeCompare(b.name));

const getRatingVal = (c: any) =>
  typeof c.rating === "number" ? c.rating : c.rating?.aggregate || 0;
const topClinics = [...stateClinics]
  .sort((a, b) => getRatingVal(b) - getRatingVal(a))
  .slice(0, 3);

const clinicCount = stateClinics.length;

// strict SEO: "Best TMS Therapy Clinics in [State] | TMS List"
const title = `Best TMS Clinics in ${stateName} | TMS List`;
const description = `Find the best TMS therapy providers in ${stateName}. Compare ${clinicCount} top-rated clinics across ${cities.length} cities, read patient reviews, check insurance coverage, and find affordable treatment options near you.`;

const stateSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `TMS Therapy Clinics in ${stateName}`,
  "description": description,
  "url": `https://tmslist.com/us/${stateSlug}/`,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": clinicCount,
    "itemListElement": topClinics.slice(0, 3).map((c: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "MedicalClinic",
        "name": c.name,
        "url": `https://tmslist.com/clinic/${c.slug}`,
        "address": {
          "@type": "PostalAddress",
          "addressLocality": c.city,
          "addressRegion": stateName,
          "addressCountry": "US"
        },
        ...(getRatingVal(c) > 0 ? {
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": getRatingVal(c),
            "reviewCount": typeof c.rating === 'object' ? c.rating?.count || 0 : 50
          }
        } : {})
      }
    }))
  }
});
---

<Layout title={title} description={description} schema={stateSchema} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "United States", url: "/us/" },
  { name: stateName, url: `/us/${stateSlug}/` },
]}>
  <section class="relative bg-white border-b border-slate-100 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
    <div
      class="ai-hero-image absolute inset-0 opacity-20"
      data-subject={stateName}
      data-type="city"
      data-cache-key={`ai-img:city:${stateName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
      data-alt={`Illustration of ${stateName}`}
    >
      <div class="ai-img-placeholder absolute inset-0"></div>
      <img class="ai-img-result hidden w-full h-full object-cover" alt="" loading="lazy" />
      <div class="ai-img-fallback hidden"></div>
    </div>
    <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
      <nav class="flex items-center gap-2 text-sm text-slate-400 mb-6 flex-wrap" aria-label="Breadcrumb">
        <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/us/" class="hover:text-violet-600 transition-colors">United States</a>
        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-slate-700 font-medium">{stateName}</span>
      </nav>
      <div class="max-w-3xl">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">TMS Therapy Clinics in <span class="text-violet-600">{stateName}</span></h1>
        <p class="text-lg text-gray-600">Compare {clinicCount} top-rated TMS therapy providers across {cities.length} cities in {stateName}. Read patient reviews, check insurance coverage, and find treatment near you.</p>
      </div>
    </div>
  </section>

  <main class="container mx-auto px-4 py-8">
    <!-- Top Rated Section -->
    <section class="mb-16">
      <div class="flex items-center mb-8">
        <h2 class="text-2xl font-semibold text-gray-900">
          Top Rated Clinics in {stateName}
        </h2>
        <div class="ml-4 h-px flex-1 bg-gray-200"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {topClinics.map((clinic) => <ClinicCard clinic={clinic} />)}
      </div>
    </section>

    <!-- City Directory -->
    <section>
      <div class="flex items-center mb-8">
        <h2 class="text-2xl font-semibold text-gray-900">
          Browse by City in {stateName}
        </h2>
        <div class="ml-4 h-px flex-1 bg-gray-200"></div>
        <span class="ml-4 text-sm font-medium text-gray-400">{cities.length} cities</span>
      </div>
      <div
        class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4"
      >
        {
          cities.map((city) => (
            <a
              href={`/us/${Astro.params.state}/${city.slug}/`}
              class="group relative bg-white p-5 rounded-2xl border border-gray-100 shadow-[0_2px_8px_rgb(0,0,0,0.02)] hover:shadow-[0_8px_30px_rgb(37,99,235,0.08)] hover:border-blue-200 transition-all overflow-hidden"
            >
              <div class="absolute inset-x-0 bottom-0 h-1 bg-blue-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
              <div class="flex items-center justify-between mb-1">
                <span class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors">
                  {city.name}
                </span>
                <svg class="w-4 h-4 text-gray-300 group-hover:text-blue-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </div>
              <span class="text-xs font-medium text-gray-400">
                View Clinics
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- SEO Content + Internal Links -->
    <section class="mt-16 pt-12 border-t border-gray-100 prose prose-lg max-w-none text-gray-600">
      <h2>TMS Therapy in {stateName}</h2>
      <p>{stateName} has {clinicCount} TMS therapy clinics across {cities.length} cities. Whether you're in {cities.slice(0, 3).map((c: any) => c.name).join(', ')}, or elsewhere in {stateName}, our directory helps you find FDA-cleared TMS providers with verified reviews and insurance information.</p>
      <p>Most clinics in {stateName} accept major insurance plans including Medicare, BlueCross BlueShield, Aetna, Cigna, and UnitedHealthcare. Use our <a href="/quiz/am-i-a-candidate/">eligibility quiz</a> to check if you're a candidate for TMS therapy.</p>
      <h3>Related Resources</h3>
      <ul>
        <li><a href="/treatments/">Conditions Treated with TMS</a> — depression, anxiety, OCD, PTSD and more</li>
        <li><a href="/technology/">TMS Technology Guide</a> — compare NeuroStar, BrainsWay, MagVenture</li>
        <li><a href="/insurance/">Insurance Coverage for TMS</a> — which plans cover treatment</li>
        <li><a href="/specialists/">Find a TMS Specialist</a> — board-certified psychiatrists</li>
      </ul>
    </section>
  </main>
</Layout>

<script>
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;
    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }
    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });
</script>
