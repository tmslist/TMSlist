---
export const prerender = false;

import Layout from "../../../../layouts/Layout.astro";
import EditorialHero from "../../../../components/editorial/EditorialHero.astro";
import ClinicCard from "../../../../components/ClinicCard.astro";
import {
    getClinicsByState,
    getStateCodeFromSlug,
    STATE_NAMES,
} from "../../../../utils/dataHelpers";
import { TREATMENT_SLUGS } from "../../../../utils/seo_slugs";
import { calculateClinicScore } from "../../../../utils/ranking";
import {
    generateBreadcrumbSchema,
    generateMedicalClinicListSchema,
} from "../../../../utils/schema";
import { getTreatmentMeta } from "../../../../utils/treatmentData";

Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=300, s-maxage=86400, stale-while-revalidate=604800",
);

const { state, treatment } = Astro.params;
const stateCode = getStateCodeFromSlug(state || '');
if (!stateCode) return Astro.redirect('/us/');
const stateName = STATE_NAMES[stateCode] || stateCode;

const treatmentEntry = TREATMENT_SLUGS.find(t => t.slug === treatment);
if (!treatmentEntry) return Astro.redirect(`/us/${state}/`);
const treatmentTitle = treatmentEntry.title;
const conditionName = treatmentTitle.replace('TMS for ', '');

const stateClinics = await getClinicsByState(stateCode);
const sortedClinics = [...stateClinics].sort(
    (a, b) => calculateClinicScore(b) - calculateClinicScore(a),
);

// Group by city for the city-roll-up section
const cityGroups = new Map<string, typeof sortedClinics>();
for (const c of sortedClinics) {
    if (!c.city) continue;
    const arr = cityGroups.get(c.city) || [];
    arr.push(c);
    cityGroups.set(c.city, arr);
}
const cities = [...cityGroups.entries()]
    .map(([name, clinics]) => ({
        name,
        slug: name.toLowerCase().replace(/\s+/g, '-'),
        count: clinics.length,
    }))
    .sort((a, b) => b.count - a.count);

const td = getTreatmentMeta(treatment || '', conditionName);

const title = `${conditionName} Treatment with TMS in ${stateName} | Find Top Providers`;
const description = `Compare ${sortedClinics.length} verified TMS clinics treating ${conditionName.toLowerCase()} across ${stateName}. ${cities.length} cities, insurance coverage, pricing & specialist credentials. ${td.fdaCleared ? 'FDA-cleared treatment.' : 'Emerging clinical evidence.'}`;

const breadcrumbSchema = generateBreadcrumbSchema([
    { name: "Home", item: "https://tmslist.com" },
    { name: "U.S.", item: "https://tmslist.com/us/" },
    { name: stateName, item: `https://tmslist.com/us/${state}/` },
    { name: treatmentTitle, item: `https://tmslist.com/us/${state}/${treatment}/` },
]);

const listingSchema = generateMedicalClinicListSchema(
    sortedClinics.slice(0, 25),
    `${conditionName} TMS Clinics in ${stateName}`,
    description,
);

const faqSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        { "@type": "Question", "name": `How much does TMS for ${conditionName.toLowerCase()} cost in ${stateName}?`, "acceptedAnswer": { "@type": "Answer", "text": `TMS sessions in ${stateName} typically cost ${td.costRange}. A full course of ${td.sessions} ranges from $6,000-$12,000. Most major insurance plans operating in ${stateName} cover TMS for FDA-cleared indications.` }},
        { "@type": "Question", "name": `Is TMS for ${conditionName.toLowerCase()} FDA-cleared?`, "acceptedAnswer": { "@type": "Answer", "text": td.fdaCleared ? `Yes, TMS for ${conditionName.toLowerCase()} is FDA-cleared${td.yearCleared ? ` since ${td.yearCleared}` : ''}.` : `TMS for ${conditionName.toLowerCase()} is currently used off-label with growing clinical evidence. Insurance coverage in ${stateName} may be limited.` }},
        { "@type": "Question", "name": `Where can I find TMS treatment for ${conditionName.toLowerCase()} in ${stateName}?`, "acceptedAnswer": { "@type": "Answer", "text": `${stateName} has ${sortedClinics.length} verified TMS clinics offering treatment for ${conditionName.toLowerCase()} across ${cities.length} cities including ${cities.slice(0, 5).map(c => c.name).join(', ')}.` }},
    ]
});

const combinedSchema = `[${breadcrumbSchema}, ${listingSchema}, ${faqSchema}]`;
---

<Layout title={title} description={description} schema={combinedSchema}>
    <main style="background:var(--paper)">
        <EditorialHero
            eyebrow={td.fdaCleared ? `FDA-Cleared${td.yearCleared ? ` since ${td.yearCleared}` : ''}` : 'Emerging Evidence'}
            eyebrowDot={td.fdaCleared ? '#22c55e' : '#C9654A'}
            title={`${conditionName} treatment in`}
            titleAccent={`${stateName}.`}
            description={`Compare ${sortedClinics.length} verified TMS providers treating ${conditionName.toLowerCase()} across ${stateName}. ${cities.length} cities, insurance, ratings.`}
            breadcrumbs={[
                { label: "Home", href: "/" },
                { label: "United States", href: "/us/" },
                { label: stateName, href: `/us/${state}/` },
                { label: conditionName },
            ]}
            ctas={[
                { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
                { label: `Learn about ${conditionName} TMS`, href: `/treatments/${treatment}/`, variant: "outline" },
            ]}
            stats={[
                { value: sortedClinics.length, label: "Clinics", color: "ink" },
                { value: cities.length, label: "Cities", color: "accent" },
                { value: td.sessions.split(' ')[0], label: "Sessions", color: "warm" },
            ]}
        />

        <!-- Cities roll-up -->
        {cities.length > 0 && (
            <section class="py-10 lg:py-14 bg-[var(--paper2)] border-t border-[var(--line)]">
                <div class="container mx-auto px-4 max-w-5xl">
                    <h2 class="text-xl lg:text-2xl font-bold text-[var(--ink)] tracking-tight mb-6">{conditionName} TMS by City in {stateName}</h2>
                    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
                        {cities.slice(0, 40).map(city => (
                            <a href={`/us/${state}/${city.slug}/${treatment}/`}
                               class="px-4 py-3 bg-[var(--paper)] border border-[var(--line)] rounded-xl hover:border-[var(--accent)] transition-all">
                                <div class="text-sm font-semibold text-[var(--ink)]">{city.name}</div>
                                <div class="text-xs text-[var(--muted)]">{city.count} clinic{city.count !== 1 ? 's' : ''}</div>
                            </a>
                        ))}
                    </div>
                </div>
            </section>
        )}

        <!-- Top clinics in state -->
        <section class="py-12 lg:py-16 bg-[var(--paper)]">
            <div class="container mx-auto px-4">
                {sortedClinics.length > 0 ? (
                    <>
                        <div class="flex items-end justify-between mb-8">
                            <h2 class="text-2xl font-bold text-[var(--ink)] tracking-tight">Top {conditionName} TMS Providers in {stateName}</h2>
                            <span class="text-sm text-[var(--muted)] hidden md:block">{sortedClinics.length} clinics</span>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            {sortedClinics.slice(0, 24).map(clinic => (
                                <ClinicCard clinic={clinic} />
                            ))}
                        </div>
                        {sortedClinics.length > 24 && (
                            <div class="text-center mt-8">
                                <a href={`/us/${state}/`} class="inline-block px-6 py-3 border border-[var(--line)] text-[var(--ink2)] font-semibold rounded-xl hover:bg-[var(--paper2)] transition-colors">View all {sortedClinics.length} {stateName} clinics</a>
                            </div>
                        )}
                    </>
                ) : (
                    <div class="text-center py-16">
                        <h2 class="text-xl font-bold text-[var(--ink)] mb-3">No {stateName} clinics found for this treatment</h2>
                        <p class="text-[var(--muted)] mb-6 max-w-md mx-auto">Browse all clinics in {stateName} or explore other treatments.</p>
                        <div class="flex gap-4 justify-center flex-wrap">
                            <a href={`/us/${state}/`} class="px-6 py-3 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-colors">All {stateName} Clinics</a>
                            <a href={`/treatments/${treatment}/`} class="px-6 py-3 border border-[var(--line)] text-[var(--ink2)] font-semibold rounded-xl hover:bg-[var(--paper2)] transition-colors">About {conditionName} TMS</a>
                        </div>
                    </div>
                )}
            </div>
        </section>

        <!-- Educational pSEO content -->
        <section class="py-12 lg:py-20 bg-[var(--paper2)]">
            <div class="container mx-auto px-4 max-w-4xl">
                <div class="prose prose-slate max-w-none prose-headings:tracking-tight prose-headings:font-bold">
                    <h2 class="text-2xl lg:text-3xl font-bold text-[var(--ink)] tracking-tight">Understanding {conditionName} Treatment with TMS in {stateName}</h2>
                    <p>{td.howItWorks}</p>
                    <p>
                        {td.fdaCleared
                            ? `TMS for ${conditionName.toLowerCase()} has been FDA-cleared${td.yearCleared ? ` since ${td.yearCleared}` : ''}. In ${stateName}, ${sortedClinics.length} verified clinics offer this treatment with insurance coverage available through most major plans operating in the state.`
                            : `While TMS for ${conditionName.toLowerCase()} is not yet FDA-cleared for this specific indication, growing clinical evidence supports its effectiveness. Some ${stateName} providers offer this treatment off-label.`
                        }
                    </p>

                    <h3>How TMS Treats {conditionName}</h3>
                    <p>TMS therapy targets the <strong>{td.brainArea}</strong> using {td.protocol}. A magnetic coil placed against the scalp delivers focused pulses that stimulate neurons in this region, promoting neuroplasticity over the course of treatment.</p>

                    <h3>Treatment Protocol</h3>
                    <ul>
                        <li><strong>Sessions:</strong> {td.sessions}</li>
                        <li><strong>Duration:</strong> 19-37 minutes per session</li>
                        <li><strong>Devices commonly used:</strong> {td.devices}</li>
                        <li><strong>Success rate:</strong> {td.successRate}</li>
                    </ul>

                    <h3>Who Qualifies for TMS for {conditionName} in {stateName}?</h3>
                    <p>{td.whoQualifies}</p>
                    <p>Most insurance plans in {stateName} require documentation of prior treatment attempts before authorizing TMS. Medicare and most commercial insurers cover FDA-cleared TMS indications.</p>

                    <h3>Cost of TMS for {conditionName} in {stateName}</h3>
                    <p>TMS sessions in {stateName} typically cost <strong>{td.costRange}</strong>. A full course of {td.sessions} can range from <strong>$6,000 to $12,000</strong> before insurance. <a href="/tms-cost-guide/">View our complete TMS cost guide</a>.</p>
                </div>
            </div>
        </section>

        <!-- Other treatments in this state -->
        <section class="py-8 lg:py-12 bg-[var(--paper)] border-t border-[var(--line)]">
            <div class="container mx-auto px-4 max-w-5xl">
                <h2 class="text-lg lg:text-xl font-bold text-[var(--ink)] mb-4 lg:mb-6">Other TMS Treatments in {stateName}</h2>
                <div class="flex flex-wrap gap-2">
                    {TREATMENT_SLUGS.filter(t => t.slug !== treatment).slice(0, 16).map(t => (
                        <a href={`/us/${state}/${t.slug}/`}
                           class="px-4 py-2 bg-[var(--paper2)] border border-[var(--line)] text-sm font-medium text-[var(--ink2)] rounded-xl hover:border-[var(--accent)] hover:text-[var(--accent)] transition-all">
                            {t.title.replace('TMS for ', '')}
                        </a>
                    ))}
                </div>
            </div>
        </section>

        <section class="relative py-14 lg:py-16 bg-[var(--ink)] overflow-hidden">
            <div class="container mx-auto px-4 text-center relative z-10">
                <h2 class="text-xl lg:text-3xl font-bold text-white mb-3 lg:mb-4 tracking-tight">Ready to explore TMS for {conditionName.toLowerCase()}?</h2>
                <p class="text-[var(--muted)] max-w-lg mx-auto mb-6 lg:mb-8 text-sm lg:text-base">Take our quick assessment, or contact a {stateName} provider directly.</p>
                <div class="flex flex-col sm:flex-row gap-3 justify-center flex-wrap">
                    <a href="/quiz/am-i-a-candidate/" class="px-6 lg:px-8 py-3.5 lg:py-4 bg-[var(--accent)] hover:bg-[var(--accent-dark)] text-white font-semibold rounded-xl transition-colors shadow-lg text-sm lg:text-base">Am I a Candidate?</a>
                    <a href={`/us/${state}/`} class="px-6 lg:px-8 py-3.5 lg:py-4 border border-white/20 hover:border-white/40 text-white font-semibold rounded-xl transition-all text-sm lg:text-base">All {stateName} Clinics</a>
                </div>
            </div>
        </section>
    </main>
</Layout>
