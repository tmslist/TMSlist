---
export const prerender = false;

import Layout from '../../../../../layouts/Layout.astro';
import EditorialHero from '../../../../../components/editorial/EditorialHero.astro';
import { getOperationalClinics, getStateCodeFromSlug, STATE_NAMES, getClinicPhoto } from '../../../../../utils/dataHelpers';

const { state, city } = Astro.params;
const stateCode = getStateCodeFromSlug(state || '');
const stateName = STATE_NAMES[stateCode] || stateCode;
const cityName = (city || '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());

const allClinics = await getOperationalClinics();
const cityClinics = allClinics.filter(c => c.state === stateCode && c.city.toLowerCase() === cityName.toLowerCase());

const title = `TMS Clinics in ${cityName}, ${stateName} | Find Treatment Centers Near You`;
const description = `Compare ${cityClinics.length} TMS therapy clinics in ${cityName}, ${stateName}. View ratings, insurance accepted, and treatment options.`;

const getRating = (clinic: any) => typeof clinic.rating === 'number' ? clinic.rating : clinic.rating?.aggregate || 4.5;
---

<Layout title={title} description={description} schema={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `TMS Clinics in ${cityName}, ${stateName}`,
  "description": description,
  "url": `https://tmslist.com/us/${Astro.params.state}/${Astro.params.city}/clinics/`,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": cityClinics.length,
    "itemListElement": cityClinics.slice(0, 10).map((c: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "MedicalClinic",
        "name": c.name,
        "url": `https://tmslist.com/clinic/${c.slug}`,
        "address": { "@type": "PostalAddress", "streetAddress": c.address, "addressLocality": cityName, "addressRegion": stateName, "addressCountry": "US" },
        "telephone": c.contact?.phone || c.phone,
        ...(getRating(c) > 0 ? { "aggregateRating": { "@type": "AggregateRating", "ratingValue": getRating(c), "reviewCount": typeof c.rating === 'object' ? c.rating?.count || 0 : 50 } } : {})
      }
    }))
  }
})} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "United States", url: "/us/" },
  { name: stateName, url: `/us/${Astro.params.state}/` },
  { name: cityName, url: `/us/${Astro.params.state}/${Astro.params.city}/` },
  { name: "Clinics", url: `/us/${Astro.params.state}/${Astro.params.city}/clinics/` },
]}>
    <main style="background:var(--paper)">
        <EditorialHero
            eyebrow={`${cityClinics.length} Verified Clinics`}
            eyebrowDot="#22c55e"
            title={`TMS clinics in`}
            titleAccent={`${cityName}.`}
            description={`Compare ${cityClinics.length} FDA-cleared TMS therapy clinics in ${cityName}, ${stateName}. View ratings, technology, insurance accepted, and book consultations.`}
            breadcrumbs={[
                { label: "Home", href: "/" },
                { label: "United States", href: "/us/" },
                { label: stateName, href: `/us/${Astro.params.state}/` },
                { label: cityName, href: `/us/${Astro.params.state}/${Astro.params.city}/` },
                { label: "Clinics" },
            ]}
            ctas={[
                { label: "View Psychiatrists", href: `/us/${Astro.params.state}/${Astro.params.city}/psychiatrists/` },
                { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/", variant: "outline" },
            ]}
            stats={[
                { value: cityClinics.length, label: "TMS Clinics", color: "ink" },
                { value: cityClinics.reduce((acc: number, c: any) => acc + (c.doctors_data?.length || 0), 0), label: "Specialists", color: "accent" },
                { value: cityClinics.filter((c: any) => c.verified).length, label: "Verified", color: "warm" },
            ]}
        />

        <!-- Stats Bar -->
        <section class="bg-[var(--paper)] border-b border-[var(--line)] py-6">
            <div class="container mx-auto px-6">
                <div class="flex flex-wrap justify-center gap-8 md:gap-16">
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-[var(--accent)]">{cityClinics.length}</div>
                        <div class="text-sm text-[var(--muted)] font-medium">TMS Clinics</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-[var(--accent)]">{cityClinics.reduce((acc: number, c: any) => acc + (c.doctors_data?.length || 0), 0)}</div>
                        <div class="text-sm text-[var(--muted)] font-medium">Specialists</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-[var(--accent)]">{cityClinics.filter((c: any) => c.verified).length}</div>
                        <div class="text-sm text-[var(--muted)] font-medium">Verified</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Clinics Grid -->
        <section class="py-16">
            <div class="container mx-auto px-6">
                <h2 class="text-3xl font-semibold text-[var(--ink)] mb-10">All TMS Clinics in {cityName}</h2>
                
                <div class="space-y-6">
                    {cityClinics.map((clinic: any, index: number) => (
                        <article class="bg-[var(--paper)] rounded-2xl shadow-sm border border-[var(--line)] overflow-hidden hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all">
                            <div class="p-6 md:p-8">
                                <div class="flex flex-col lg:flex-row lg:items-start gap-6">
                                    <!-- Clinic Image -->
                                    <div class="lg:w-64 lg:shrink-0">
                                        <img 
                                            src={getClinicPhoto(clinic)}
                                            alt={clinic.name}
                                            class="w-full h-48 lg:h-40 object-cover rounded-xl"
                                        />
                                    </div>
                                    
                                    <!-- Clinic Info -->
                                    <div class="flex-1">
                                        <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                                            <div>
                                                <div class="flex items-center gap-2 mb-2">
                                                    {clinic.verified && (
                                                        <span class="px-2 py-1 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full flex items-center gap-1">
                                                            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                                                            Verified
                                                        </span>
                                                    )}
                                                    <span class="px-2 py-1 bg-[rgba(10,22,40,0.08)] text-[var(--accent)] text-xs font-semibold rounded-full">#{index + 1} in {cityName}</span>
                                                </div>
                                                <h3 class="text-2xl font-semibold text-[var(--ink)] hover:text-[var(--accent)] transition-colors">
                                                    <a href={`/clinic/${clinic.slug}`}>{clinic.name}</a>
                                                </h3>
                                                <p class="text-[var(--muted)]">{clinic.address}, {clinic.city}, {clinic.state} {clinic.zip}</p>
                                            </div>
                                            <div class="text-right">
                                                <div class="flex items-center gap-2">
                                                    <span class="text-2xl font-semibold tracking-tight text-[var(--ink)]">{getRating(clinic).toFixed(1)}</span>
                                                    <div class="flex gap-0.5">
                                                        {[1,2,3,4,5].map(() => (
                                                            <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                                        ))}
                                                    </div>
                                                </div>
                                                <p class="text-sm text-[var(--muted)]">{typeof clinic.rating === 'object' ? clinic.rating.count : clinic.review_count || 0} reviews</p>
                                            </div>
                                        </div>
                                        
                                        <p class="text-[var(--muted)] mb-4 line-clamp-2">{clinic.description_long}</p>
                                        
                                        <div class="flex flex-wrap gap-2 mb-4">
                                            {(clinic.machines || []).slice(0, 3).map((m: string) => (
                                                <span class="px-3 py-1 bg-[var(--paper2)] text-[var(--ink2)] rounded-full text-sm font-medium">{m}</span>
                                            ))}
                                        </div>
                                        
                                        <div class="flex flex-wrap items-center gap-4 pt-4 border-t border-[var(--line)]">
                                            <a href={`/clinic/${clinic.slug}`} class="px-6 py-2.5 bg-[var(--ink)] text-white font-semibold rounded-lg hover:bg-[var(--ink2)] transition-colors">
                                                View Clinic
                                            </a>
                                            <button data-request-callback data-clinic-name={clinic.name} data-clinic-id={clinic.slug}
                                                class="px-6 py-2.5 border-2 border-[var(--ink)] text-[var(--accent)] font-semibold rounded-lg hover:bg-[rgba(10,22,40,0.08)] transition-colors cursor-pointer">
                                                Request Callback
                                            </button>
                                            <span class="text-sm text-[var(--muted)]">{(clinic.doctors_data || []).length} specialists on staff</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </section>

        <!-- SEO Content Section -->
        <section class="py-16 bg-[var(--paper)]">
            <div class="container mx-auto px-6 max-w-4xl">
                <h2 class="text-3xl font-semibold text-[var(--ink)] mb-8">TMS Therapy in {cityName}, {stateName}</h2>
                
                <div class="prose prose-lg max-w-none text-[var(--muted)]">
                    <p>
                        {cityName}, {stateName} is home to {cityClinics.length} FDA-cleared TMS (Transcranial Magnetic Stimulation) therapy clinics, offering advanced treatment options for depression, anxiety, OCD, and other mental health conditions.
                        Our comprehensive directory helps you compare facilities, read verified reviews, and find the right clinic for your needs.
                    </p>
                    
                    <h3 class="text-xl font-semibold text-[var(--ink)] mt-8 mb-4">Why Choose TMS Therapy?</h3>
                    <p>
                        TMS therapy offers a non-invasive, FDA-cleared treatment option for those who haven't found relief from medication alone.
                        Unlike ECT (electroconvulsive therapy), TMS requires no anesthesia, has minimal side effects, and allows patients to drive themselves to and from treatment.
                        Clinical studies show remission rates of 50-60% for treatment-resistant depression.
                    </p>
                    
                    <h3 class="text-xl font-semibold text-[var(--ink)] mt-8 mb-4">What to Expect at a {cityName} TMS Clinic</h3>
                    <p>
                        Your TMS journey typically begins with a consultation where a psychiatrist evaluates your medical history and treatment goals.
                        If you're a candidate, you'll undergo a brain mapping session to identify the optimal treatment location.
                        Treatment involves 36 sessions over 6-9 weeks, with each session lasting 19-37 minutes depending on the protocol.
                    </p>
                    
                    <h3 class="text-xl font-semibold text-[var(--ink)] mt-8 mb-4">Insurance Coverage in {stateName}</h3>
                    <p>
                        Most major insurance providers now cover TMS therapy when medical necessity is demonstrated.
                        Clinics in {cityName} commonly accept Medicare, BlueCross BlueShield, Aetna, Cigna, and UnitedHealthcare.
                        Our clinic profiles show exactly which insurances each facility accepts.
                    </p>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="py-16 bg-[var(--ink)]">
            <div class="container mx-auto px-6 text-center">
                <h2 class="text-3xl font-semibold text-[var(--ink)] mb-6">Find Your TMS Clinic in {cityName}</h2>
                <p class="text-xl text-[var(--muted)] mb-8 max-w-2xl mx-auto">
                    Compare {cityClinics.length} verified clinics and start your journey to mental wellness today.
                </p>
                <a href="/quiz/am-i-a-candidate/" class="inline-block px-8 py-4 bg-[var(--paper)] text-[var(--accent)] font-semibold rounded-xl hover:bg-[var(--paper2)] transition-colors shadow-[0_4px_20px_rgb(0,0,0,0.03)]">
                    Am I a Candidate?
                </a>
            </div>
        </section>
    </main>
</Layout>
