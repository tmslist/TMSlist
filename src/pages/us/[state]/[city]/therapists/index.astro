---
export const prerender = false;

import Layout from '../../../../../layouts/Layout.astro';
import { getAllClinics, getStateCodeFromSlug, STATE_NAMES } from '../../../../../utils/clinicData';
import ProviderPageBody from '../../../../../components/providerPage/ProviderPageBody.astro';
import { filterDoctorsByType } from '../../../../../utils/providerFilter';

const { state, city } = Astro.params;
const stateCode = getStateCodeFromSlug(state || '');
const stateName = STATE_NAMES[stateCode] || stateCode;
const cityName = (city || '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());

const clinics = await getAllClinics();
const cityClinics = clinics.filter(
  c => c.state === stateCode && c.city.toLowerCase() === cityName.toLowerCase()
);

const allDoctors = cityClinics.flatMap((c: any) =>
  (c.doctors_data || []).map((d: any) => ({ ...d, clinic: c }))
);
const doctors = filterDoctorsByType(allDoctors, 'therapists');

const title = `Best Therapists in ${cityName}, ${stateName} | TMS Therapy Support`;
const description = doctors.length > 0
  ? `Find ${doctors.length} licensed therapists and counselors offering TMS-compatible mental health care in ${cityName}, ${stateName}. Compare approaches and book consultations.`
  : `Find licensed therapists with TMS therapy support in ${cityName}, ${stateName}. Browse verified providers for depression, anxiety, and trauma treatment.`;
---

<Layout
  title={title}
  description={description}
  schema={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `Therapists in ${cityName}, ${stateName}`,
    "description": description,
    "url": `https://tmslist.com/us/${Astro.params.state}/${Astro.params.city}/therapists/`,
    "mainEntity": doctors.length > 0 ? {
      "@type": "ItemList",
      "numberOfItems": doctors.length,
      "itemListElement": doctors.slice(0, 10).map((d: any, i: number) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "Person",
          "name": d.name,
          "url": d.slug ? `https://tmslist.com/specialist/${d.slug}` : undefined,
          "jobTitle": d.title || "Licensed Therapist",
          "medicalSpecialty": "Mental Health Counseling",
          "knowsAbout": ["TMS Therapy", "Transcranial Magnetic Stimulation"],
          ...(d.school ? { "alumniOf": { "@type": "EducationalOrganization", "name": d.school } } : {}),
          ...(d.clinic?.name ? { "worksFor": { "@type": "MedicalClinic", "name": d.clinic.name } } : {}),
        }
      }))
    } : undefined,
  })}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "United States", url: "/us/" },
    { name: stateName, url: `/us/${Astro.params.state}/` },
    { name: cityName, url: `/us/${Astro.params.state}/${Astro.params.city}/` },
    { name: "Therapists", url: `/us/${Astro.params.state}/${Astro.params.city}/therapists/` },
  ]}
>
  <ProviderPageBody
    providerType="therapists"
    cityName={cityName}
    stateName={stateName}
    stateSlug={Astro.params.state || ''}
    citySlug={Astro.params.city || ''}
    doctors={doctors}
    clinics={cityClinics}
  />
</Layout>