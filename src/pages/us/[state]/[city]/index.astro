---
import Layout from "../../../../layouts/Layout.astro";
import EditorialHero from "../../../../components/editorial/EditorialHero.astro";
import ClinicCard from "../../../../components/ClinicCard.astro";
import {
  getClinicsByState,
  getClinicsByCity,
  getStateCodeFromSlug,
  STATE_NAMES,
} from "../../../../utils/dataHelpers";
import { calculateClinicScore } from "../../../../utils/ranking";
import { ClinicMachine, ClinicInsurance } from "../../../../types/clinic";
import RelatedContent from "../../../../components/RelatedContent.astro";
import { getAllQuestions } from "../../../../db/queries";
import { getClinicRating, getClinicReviewCount } from "../../../../utils/dataHelpers";
import LocationSEOContent from "../../../../components/LocationSEOContent.astro";

const { state, city } = Astro.params;

const stateCode = getStateCodeFromSlug(state!);
if (!stateCode) return Astro.redirect("/us/");

const stateName = STATE_NAMES[stateCode] || stateCode;

// Derive city name from slug by fetching all clinics in the state and matching
const stateClinics = await getClinicsByState(stateCode);
const cityMatch = stateClinics.find(
  (c) => c.city && c.city.toLowerCase().replace(/\s+/g, "-") === city
);
if (!cityMatch) return Astro.redirect(`/us/${state}/`);

const cityName = cityMatch.city;
const cityClinics = await getClinicsByCity(stateCode, cityName);

const sortedClinics = [...cityClinics].sort(
  (a, b) => calculateClinicScore(b) - calculateClinicScore(a),
);

const avgRating = sortedClinics.reduce((sum, c) => sum + getClinicRating(c), 0) / (sortedClinics.length || 1);
const totalReviews = sortedClinics.reduce((sum, c) => sum + getClinicReviewCount(c), 0);
const totalDoctors = sortedClinics.reduce((sum, c) => sum + ((c as any).doctors_data?.length || 0), 0);
const verifiedCount = sortedClinics.filter(c => c.verified).length;

const title = `Best TMS Clinics in ${cityName}, ${stateName} | TMS List`;
const topClinicName = sortedClinics[0]?.name || '';
const description = `Compare ${sortedClinics.length} TMS therapy clinic${sortedClinics.length !== 1 ? 's' : ''} in ${cityName}, ${stateName}${avgRating > 0 ? ` — ${avgRating.toFixed(1)}★ avg rating from ${totalReviews} reviews` : ''}${topClinicName ? `. Top rated: ${topClinicName}` : ''}. Insurance, pricing & verified provider info.`;

const questionsData = await getAllQuestions();
const relatedQuestions = questionsData
  .filter(
    (q) =>
      q.question.toLowerCase().includes(cityName.toLowerCase()) ||
      q.question.toLowerCase().includes(stateName.toLowerCase()) ||
      q.category === "location" ||
      q.category === "cost",
  )
  .slice(0, 8);

const relatedBlogs = [
  {
    title: `Best TMS Clinics in ${stateName}`,
    excerpt: `Compare top-rated TMS providers across ${stateName}. Verified reviews, insurance info, and costs.`,
    url: `/best-tms-clinics/${state}/`,
  },
  {
    title: "TMS for Depression — Clinical Guide",
    excerpt: "Understand the science, success rates, and what to expect from TMS treatment for depression.",
    url: "/treatments/depression/",
  },
  {
    title: "Insurance Coverage for TMS",
    excerpt: "Which insurance plans cover TMS? How to get prior authorization and maximize your benefits.",
    url: "/insurance/",
  },
];

const machines = Object.values(ClinicMachine);
const insurances = Object.values(ClinicInsurance);
---

<Layout title={title} description={description} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "United States", url: "/us/" },
  { name: stateName, url: `/us/${state}/` },
  { name: cityName, url: `/us/${state}/${cityName.toLowerCase().replace(/\s+/g, '-')}/` },
]}>
  <main style="background:var(--paper)">
    <EditorialHero
      eyebrow={`${verifiedCount} Verified Providers`}
      eyebrowDot="#22c55e"
      title="TMS therapy in"
      titleAccent={`${cityName}.`}
      description={`Compare ${cityClinics.length} FDA-cleared TMS providers in ${cityName}, ${stateName}. Real patient ratings, insurance info, and treatment costs.`}
      breadcrumbs={[
        { label: "Home", href: "/" },
        { label: "United States", href: "/us/" },
        { label: stateName, href: `/us/${state}/` },
        { label: cityName },
      ]}
      ctas={[
        { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
        { label: "Compare Clinics", href: "/compare-clinics/", variant: "outline" },
      ]}
      stats={[
        { value: cityClinics.length, label: "Clinics", color: "ink" },
        { value: `${avgRating.toFixed(1)}★`, label: "Avg Rating", color: "warm" },
        { value: totalDoctors, label: "Specialists", color: "accent" },
      ]}
    />

    <!-- Main Content -->
    <section class="py-8 lg:py-12">
      <div class="container mx-auto px-4">
        <div class="flex flex-col lg:flex-row gap-8">
          <!-- Sidebar -->
          <aside class="w-full lg:w-72 shrink-0">
            <button id="filter-toggle" class="lg:hidden w-full flex items-center justify-between px-4 py-3 bg-[var(--paper)] rounded-xl border border-[var(--line)] mb-4 text-sm font-semibold text-[var(--ink2)]">
              <span class="flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
                Filters
              </span>
              <svg class="w-4 h-4 transition-transform" id="filter-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>

            <div id="filter-panel" class="hidden lg:block">
              <div class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] shadow-sm sticky top-20 overflow-hidden">
                <div class="flex items-center justify-between p-5 border-b border-[var(--line)]">
                  <h2 class="text-sm font-bold text-[var(--ink)] uppercase tracking-wider">Filters</h2>
                  <button id="reset-filters" class="text-xs text-[var(--accent)] hover:text-[var(--accent)] font-semibold">Reset All</button>
                </div>
                <div class="p-5 space-y-6 max-h-[calc(100vh-200px)] overflow-y-auto">
                  <div>
                    <h3 class="text-xs font-bold text-[var(--muted)] uppercase tracking-wider mb-3 flex items-center gap-2">
                      <svg class="w-3.5 h-3.5 text-[var(--accent2)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                      TMS Technology
                    </h3>
                    <div class="space-y-2">
                      {machines.map((m) => (
                        <label class="flex items-center gap-2.5 cursor-pointer group py-0.5">
                          <input type="checkbox" data-filter="machine" value={m.toLowerCase()} class="filter-checkbox h-4 w-4 rounded border-[var(--line)] text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]" />
                          <span class="text-sm text-[var(--muted)] group-hover:text-[var(--ink)] transition-colors">{m}</span>
                        </label>
                      ))}
                    </div>
                  </div>
                  <div>
                    <h3 class="text-xs font-bold text-[var(--muted)] uppercase tracking-wider mb-3 flex items-center gap-2">
                      <svg class="w-3.5 h-3.5 text-[var(--accent2)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                      Treatments
                    </h3>
                    <div class="space-y-2">
                      {["Depression", "Anxiety", "OCD", "PTSD", "Ketamine Infusion", "Spravato (Esketamine)"].map((t) => (
                        <label class="flex items-center gap-2.5 cursor-pointer group py-0.5">
                          <input type="checkbox" data-filter="treatment" value={t.toLowerCase()} class="filter-checkbox h-4 w-4 rounded border-[var(--line)] text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]" />
                          <span class="text-sm text-[var(--muted)] group-hover:text-[var(--ink)] transition-colors">{t}</span>
                        </label>
                      ))}
                    </div>
                  </div>
                  <div>
                    <h3 class="text-xs font-bold text-[var(--muted)] uppercase tracking-wider mb-3 flex items-center gap-2">
                      <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                      Insurance
                    </h3>
                    <div class="space-y-2 max-h-[280px] overflow-y-auto pr-1">
                      {insurances.map((i) => (
                        <label class="flex items-center gap-2.5 cursor-pointer group py-0.5">
                          <input type="checkbox" data-filter="insurance" value={i.toLowerCase()} class="filter-checkbox h-4 w-4 rounded border-[var(--line)] text-[var(--accent)] focus:ring-[rgba(10,22,40,0.15)]" />
                          <span class="text-sm text-[var(--muted)] group-hover:text-[var(--ink)] transition-colors">{i}</span>
                        </label>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
              <div class="mt-6">
                <RelatedContent relatedQuestions={relatedQuestions} relatedBlogs={relatedBlogs} currentPage={`${cityName}, ${stateName}`} />
              </div>
            </div>
          </aside>

          <!-- Grid -->
          <div class="flex-1 min-w-0">
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-xl font-bold text-[var(--ink)]">
                {cityName} Clinics
                <span class="text-[var(--muted)] font-medium text-base ml-2" id="clinic-count">{cityClinics.length} Providers</span>
              </h2>
              <label for="sort-select" class="sr-only">Sort clinics</label>
              <select id="sort-select" aria-label="Sort clinics" class="text-sm border border-[var(--line)] rounded-lg px-3 py-1.5 text-[var(--ink2)] focus:border-[var(--ink2)] focus:ring-1 focus:ring-[rgba(10,22,40,0.1)] bg-[var(--paper)]">
                <option value="score">Best Match</option>
                <option value="rating">Highest Rated</option>
                <option value="reviews">Most Reviews</option>
                <option value="name">Name A-Z</option>
              </select>
            </div>

            <div id="active-filters" class="hidden flex-wrap gap-2 mb-4"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5" id="clinic-grid">
              {sortedClinics.map((clinic) => (
                <div class="clinic-item"
                  data-machines={(clinic.machines || []).join(",").toLowerCase()}
                  data-treatments={(clinic.specialties || []).join(",").toLowerCase()}
                  data-insurances={(clinic.insurance_accepted || clinic.insurances || []).join(",").toLowerCase()}
                  data-rating={getClinicRating(clinic)}
                  data-reviews={getClinicReviewCount(clinic)}
                  data-name={clinic.name}
                >
                  <ClinicCard clinic={clinic} />
                </div>
              ))}
            </div>

            <p id="no-results" class="hidden text-center py-16">
              <svg class="w-12 h-12 text-[var(--muted)] mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              <span class="text-[var(--muted)] font-medium block">No clinics match your filters</span>
              <span class="text-[var(--muted)] text-sm mt-1 block">Try adjusting your criteria</span>
            </p>

            <LocationSEOContent
              type="city"
              locationName={cityName}
              stateName={stateName}
              clinicCount={cityClinics.length}
            />

            <!-- Learn More -->
            <div class="mt-10 pt-8 border-t border-[var(--line)]">
              <div class="flex flex-wrap justify-center gap-2">
                <a href="/blog/tms-cost-insurance-guide-2026/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Cost &amp; Insurance</a>
                <a href="/blog/questions-to-ask-tms-clinic/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Questions to Ask</a>
                <a href="/blog/preparing-for-first-tms-session/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">First Session</a>
                <a href="/blog/maintenance-tms-guide/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Maintenance</a>
                <a href="/blog/" class="px-3 py-1.5 text-xs font-medium text-[var(--accent)] hover:underline">View all articles →</a>
              </div>
            </div>

            <div id="clinic-map" class="mt-12 rounded-2xl h-80 shadow-sm border border-[var(--line)] overflow-hidden z-0"></div>
            <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
            <script is:inline define:vars={{ clinicsForMap: sortedClinics.filter((c) => c.geo?.lat && c.geo?.lng).map((c) => ({ name: c.name, lat: c.geo.lat, lng: c.geo.lng, slug: c.slug })) }}>
              window.addEventListener("load", () => {
                if (typeof L === "undefined") { const s = document.createElement("script"); s.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"; s.onload = initMap; document.head.appendChild(s); } else { initMap(); }
                function initMap() {
                  const mapEl = document.getElementById("clinic-map");
                  if (!mapEl || clinicsForMap.length === 0) return;
                  const map = L.map("clinic-map").setView([clinicsForMap[0].lat, clinicsForMap[0].lng], 11);
                  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", { attribution: "&copy; OpenStreetMap contributors" }).addTo(map);
                  clinicsForMap.forEach((c) => { L.marker([c.lat, c.lng]).addTo(map).bindPopup(`<strong>${c.name}</strong><br/><a href="/clinic/${c.slug}/">View Clinic</a>`); });
                  if (clinicsForMap.length > 1) { map.fitBounds(L.latLngBounds(clinicsForMap.map((c) => [c.lat, c.lng])), { padding: [30, 30] }); }
                }
              });
            </script>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.getElementById('filter-toggle')?.addEventListener('click', () => {
    document.getElementById('filter-panel')?.classList.toggle('hidden');
    document.getElementById('filter-chevron')?.classList.toggle('rotate-180');
  });

  const checkboxes = document.querySelectorAll('.filter-checkbox') as NodeListOf<HTMLInputElement>;
  const clinicItems = document.querySelectorAll('.clinic-item') as NodeListOf<HTMLElement>;
  const clinicCount = document.getElementById('clinic-count');
  const noResults = document.getElementById('no-results');
  const activeFiltersEl = document.getElementById('active-filters');

  function filterClinics() {
    const filters: Record<string, string[]> = { machine: [], treatment: [], insurance: [] };
    checkboxes.forEach(cb => { if (cb.checked) { const t = cb.getAttribute('data-filter') || ''; if (filters[t]) filters[t].push(cb.value); } });

    let visible = 0;
    clinicItems.forEach(item => {
      const m = item.dataset.machines || '', t = item.dataset.treatments || '', ins = item.dataset.insurances || '';
      const show = (filters.machine.length === 0 || filters.machine.some(v => m.includes(v)))
        && (filters.treatment.length === 0 || filters.treatment.some(v => t.includes(v)))
        && (filters.insurance.length === 0 || filters.insurance.some(v => ins.includes(v)));
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    if (clinicCount) clinicCount.textContent = `${visible} Provider${visible !== 1 ? 's' : ''}`;
    noResults?.classList.toggle('hidden', visible > 0);

    const all = [...filters.machine, ...filters.treatment, ...filters.insurance];
    if (activeFiltersEl) {
      if (all.length === 0) { activeFiltersEl.classList.add('hidden'); activeFiltersEl.classList.remove('flex'); }
      else {
        activeFiltersEl.classList.remove('hidden'); activeFiltersEl.classList.add('flex');
        activeFiltersEl.innerHTML = all.map(f => `<span class="inline-flex items-center gap-1 px-3 py-1 bg-[rgba(10,22,40,0.08)] text-[var(--accent)] rounded-full text-xs font-semibold"><span>${f}</span><button class="remove-filter hover:text-red-500" data-value="${f}">&times;</button></span>`).join('');
        activeFiltersEl.querySelectorAll('.remove-filter').forEach(btn => {
          btn.addEventListener('click', () => { const val = btn.getAttribute('data-value'); checkboxes.forEach(cb => { if (cb.value === val) cb.checked = false; }); filterClinics(); });
        });
      }
    }
  }

  checkboxes.forEach(cb => cb.addEventListener('change', filterClinics));
  document.getElementById('reset-filters')?.addEventListener('click', () => { checkboxes.forEach(cb => cb.checked = false); filterClinics(); });

  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
  const clinicGrid = document.getElementById('clinic-grid');
  sortSelect?.addEventListener('change', () => {
    if (!clinicGrid) return;
    const items = Array.from(clinicItems);
    items.sort((a, b) => {
      switch (sortSelect.value) {
        case 'rating': return parseFloat(b.dataset.rating || '0') - parseFloat(a.dataset.rating || '0');
        case 'reviews': return parseInt(b.dataset.reviews || '0') - parseInt(a.dataset.reviews || '0');
        case 'name': return (a.dataset.name || '').localeCompare(b.dataset.name || '');
        default: return 0;
      }
    });
    items.forEach(item => clinicGrid.appendChild(item));
  });

  // AI hero image (city skyline) with localStorage cache
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;

    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }

    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });
</script>
