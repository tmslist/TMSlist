---
export const prerender = false;

import Layout from "../../../../../layouts/Layout.astro";
import ClinicCard from "../../../../../components/ClinicCard.astro";
import {
    getClinicsByCity,
    getStateCodeFromSlug,
    STATE_NAMES,
} from "../../../../../utils/dataHelpers";
import { TREATMENT_SLUGS } from "../../../../../utils/seo_slugs";
import { calculateClinicScore } from "../../../../../utils/ranking";
import {
    generateBreadcrumbSchema,
    generateMedicalClinicListSchema,
} from "../../../../../utils/schema";

const { state, city, treatment } = Astro.params;
const stateCode = getStateCodeFromSlug(state || '');
const stateName = STATE_NAMES[stateCode] || stateCode;
const cityName = (city || '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
const treatmentEntry = TREATMENT_SLUGS.find(t => t.slug === treatment);
const treatmentTitle = treatmentEntry?.title || `TMS for ${(treatment || '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}`;

const cityClinics = await getClinicsByCity(stateCode, cityName);
const sortedClinics = [...cityClinics].sort(
    (a, b) => calculateClinicScore(b) - calculateClinicScore(a),
);

const title = `${treatmentTitle} in ${cityName}, ${stateName} | Top Rated Clinics`;
const description = `Find top-rated TMS providers for ${treatmentTitle} in ${cityName}, ${stateName}. Verified patient reviews, insurance acceptance, and availability for ${treatmentTitle}.`;

// Schema Generation
const breadcrumbSchema = generateBreadcrumbSchema([
    { name: "Home", item: "https://tmslist.com" },
    { name: "U.S.", item: "https://tmslist.com/us/" },
    { name: stateName, item: `https://tmslist.com/us/${state}/` },
    { name: cityName, item: `https://tmslist.com/us/${state}/${city}/` },
    {
        name: treatmentTitle,
        item: `https://tmslist.com/us/${state}/${city}/${treatment}/`,
    },
]);

const listingSchema = generateMedicalClinicListSchema(
    sortedClinics,
    `${treatmentTitle} Clinics in ${cityName}, ${stateName}`,
    description,
);

const combinedSchema = `[${breadcrumbSchema}, ${listingSchema}]`;
---

<Layout title={title} description={description} schema={combinedSchema}>
    <main class="container mx-auto px-4 py-8">
        <!-- Breadcrumbs -->
        <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
            <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <a href="/us/" class="hover:text-violet-600 transition-colors">U.S.</a>
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <a href={`/us/${state}/`} class="hover:text-violet-600 transition-colors">{stateName}</a>
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <a href={`/us/${state}/${city}/`} class="hover:text-violet-600 transition-colors">{cityName}</a>
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <span class="text-slate-700 font-medium">{treatmentTitle}</span>
        </nav>

        <div class="max-w-4xl mx-auto mb-12 text-center">
            <h1 class="text-3xl md:text-4xl font-semibold tracking-tight text-gray-900 mb-4">
                {treatmentTitle} in {cityName}, {stateName}
            </h1>
            <p class="text-lg text-gray-600">
                Compare {sortedClinics.length} verified clinics offering Transcranial
                Magnetic Stimulation (TMS) for {
                    treatmentTitle.replace("TMS for ", "")
                }.
            </p>
        </div>

        <!-- Main Content -->
        <div class="flex flex-col lg:flex-row gap-8">
            <!-- Clinic Grid -->
            <div class="w-full">
                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
                >
                    {
                        sortedClinics.map((clinic) => (
                            <div class="clinic-item">
                                <ClinicCard clinic={clinic} />
                            </div>
                        ))
                    }
                </div>

                {
                    sortedClinics.length === 0 && (
                        <div class="text-center py-12 bg-gray-50 rounded-xl border border-gray-200">
                            <p class="text-gray-500 mb-4">
                                No clinics found specifically for this criteria
                                in {cityName}.
                            </p>
                            <a
                                href={`/us/${state}/`}
                                class="inline-block px-6 py-2 bg-violet-600 text-white font-semibold rounded-lg hover:bg-violet-700 transition-colors"
                            >
                                View All {stateName} Clinics
                            </a>
                        </div>
                    )
                }
            </div>
        </div>

        <!-- Educational Content -->
        <section class="mt-20 max-w-3xl mx-auto prose prose-lg prose-violet">
            <h2>About {treatmentTitle.replace("TMS for ", "")} Treatment</h2>
            <p>
                Transcranial Magnetic Stimulation (TMS) is an FDA-cleared,
                non-invasive treatment for various mental health conditions,
                including {treatmentTitle.replace("TMS for ", "")}. It is often
                used when traditional medications have not provided relief.
            </p>
            <h3>Why Choose TMS?</h3>
            <ul>
                <li>Non-invasive outpatient procedure</li>
                <li>
                    No systemic side effects (like weight gain or sexual
                    dysfunction)
                </li>
                <li>High efficacy rates for treatment-resistant cases</li>
                <li>Covered by most major insurance providers</li>
            </ul>
            <p>
                If you live in {cityName} and are struggling with {
                    treatmentTitle.replace("TMS for ", "")
                }, consult with one of the verified specialists listed above to
                allow them to evaluate if TMS is right for you.
            </p>
        </section>
    </main>
</Layout>
