---
export const prerender = false;

import Layout from "../../../../../layouts/Layout.astro";
import EditorialHero from "../../../../../components/editorial/EditorialHero.astro";
import ClinicCard from "../../../../../components/ClinicCard.astro";
import {
    getClinicsByCity,
    getStateCodeFromSlug,
    STATE_NAMES,
} from "../../../../../utils/dataHelpers";
import { TREATMENT_SLUGS } from "../../../../../utils/seo_slugs";
import { calculateClinicScore } from "../../../../../utils/ranking";
import {
    generateBreadcrumbSchema,
    generateMedicalClinicListSchema,
} from "../../../../../utils/schema";
import { getTreatmentMeta } from "../../../../../utils/treatmentData";

Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=300, s-maxage=86400, stale-while-revalidate=604800",
);

const { state, city, treatment } = Astro.params;
const stateCode = getStateCodeFromSlug(state || '');
const stateName = STATE_NAMES[stateCode] || stateCode;
const cityName = (city || '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
const treatmentEntry = TREATMENT_SLUGS.find(t => t.slug === treatment);
const treatmentTitle = treatmentEntry?.title || `TMS for ${(treatment || '').replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}`;
const conditionName = treatmentTitle.replace('TMS for ', '');

const cityClinics = await getClinicsByCity(stateCode, cityName);
const sortedClinics = [...cityClinics].sort(
    (a, b) => calculateClinicScore(b) - calculateClinicScore(a),
);

const td = getTreatmentMeta(treatment || '', conditionName);

const title = `${conditionName} Treatment with TMS in ${cityName}, ${stateName} | Find Top Providers`;
const description = `Find ${sortedClinics.length} verified TMS clinics treating ${conditionName.toLowerCase()} in ${cityName}, ${stateName}. Compare providers, check insurance coverage, and book consultations. ${td.fdaCleared ? 'FDA-cleared treatment.' : 'Emerging clinical evidence.'}`;

const breadcrumbSchema = generateBreadcrumbSchema([
    { name: "Home", item: "https://tmslist.com" },
    { name: "U.S.", item: "https://tmslist.com/us/" },
    { name: stateName, item: `https://tmslist.com/us/${state}/` },
    { name: cityName, item: `https://tmslist.com/us/${state}/${city}/` },
    { name: treatmentTitle, item: `https://tmslist.com/us/${state}/${city}/${treatment}/` },
]);

const listingSchema = generateMedicalClinicListSchema(
    sortedClinics,
    `${conditionName} TMS Clinics in ${cityName}, ${stateName}`,
    description,
);

const faqSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
        { "@type": "Question", "name": `How much does TMS for ${conditionName.toLowerCase()} cost in ${cityName}?`, "acceptedAnswer": { "@type": "Answer", "text": `TMS sessions in ${cityName} typically cost ${td.costRange}. A full treatment course of ${td.sessions} ranges from $6,000-$12,000. Most major insurance plans cover TMS for approved indications. Contact clinics listed above for specific pricing.` }},
        { "@type": "Question", "name": `Is TMS for ${conditionName.toLowerCase()} FDA-cleared?`, "acceptedAnswer": { "@type": "Answer", "text": td.fdaCleared ? `Yes, TMS for ${conditionName.toLowerCase()} is FDA-cleared${td.yearCleared ? ` since ${td.yearCleared}` : ''}. Most insurance providers cover FDA-cleared TMS indications.` : `TMS for ${conditionName.toLowerCase()} is currently used off-label with growing clinical evidence. Insurance coverage may be limited; check with providers listed above.` }},
        { "@type": "Question", "name": `How many TMS sessions are needed for ${conditionName.toLowerCase()}?`, "acceptedAnswer": { "@type": "Answer", "text": `A typical TMS course for ${conditionName.toLowerCase()} involves ${td.sessions}. Each session lasts 19-37 minutes depending on the protocol used. Improvement is usually noticed by weeks 2-3.` }},
    ]
});

const combinedSchema = `[${breadcrumbSchema}, ${listingSchema}, ${faqSchema}]`;
---

<Layout title={title} description={description} schema={combinedSchema}>
    <main style="background:var(--paper)">
        <EditorialHero
            eyebrow={td.fdaCleared ? `FDA-Cleared${td.yearCleared ? ` since ${td.yearCleared}` : ''}` : 'Emerging Evidence'}
            eyebrowDot={td.fdaCleared ? '#22c55e' : '#C9654A'}
            title={`${conditionName} treatment in`}
            titleAccent={`${cityName}.`}
            description={sortedClinics.length > 0
                ? `Compare ${sortedClinics.length} verified TMS providers treating ${conditionName.toLowerCase()} in ${cityName}, ${stateName}. View ratings, insurance coverage, and specialist credentials.`
                : `Find TMS providers for ${conditionName.toLowerCase()} near ${cityName}, ${stateName}. Browse verified clinics across ${stateName}.`}
            breadcrumbs={[
                { label: "Home", href: "/" },
                { label: "United States", href: "/us/" },
                { label: stateName, href: `/us/${state}/` },
                { label: cityName, href: `/us/${state}/${city}/` },
                { label: conditionName },
            ]}
            ctas={[
                { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
                { label: `Learn about ${conditionName} TMS`, href: `/treatments/${treatment}/`, variant: "outline" },
            ]}
            stats={[
                { value: sortedClinics.length, label: "Clinics", color: "ink" },
                { value: td.successRate.split(',')[0].split(' ')[0], label: "Success Rate", color: "accent" },
                { value: td.sessions.split(' ')[0], label: "Sessions", color: "warm" },
            ]}
        />

        <!-- Clinics Grid -->
        <section class="py-12 lg:py-16 bg-[var(--paper)]">
            <div class="container mx-auto px-4">
                {sortedClinics.length > 0 ? (
                    <>
                        <div class="flex items-end justify-between mb-8">
                            <h2 class="text-2xl font-bold text-[var(--ink)] tracking-tight">Top {conditionName} TMS Providers in {cityName}</h2>
                            <span class="text-sm text-[var(--muted)] hidden md:block">{sortedClinics.length} clinics</span>
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            {sortedClinics.map(clinic => (
                                <ClinicCard clinic={clinic} />
                            ))}
                        </div>
                    </>
                ) : (
                    <div class="text-center py-16">
                        <div class="w-16 h-16 rounded-full bg-[var(--paper2)] flex items-center justify-center mx-auto mb-6">
                            <svg class="w-8 h-8 text-[var(--muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                        </div>
                        <h2 class="text-xl font-bold text-[var(--ink)] mb-3">No clinics found in {cityName} for this treatment</h2>
                        <p class="text-[var(--muted)] mb-6 max-w-md mx-auto">Try browsing all clinics in {stateName} or searching for a nearby city.</p>
                        <div class="flex gap-4 justify-center flex-wrap">
                            <a href={`/us/${state}/`} class="px-6 py-3 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-colors">All {stateName} Clinics</a>
                            <a href={`/us/${state}/${city}/`} class="px-6 py-3 border border-[var(--line)] text-[var(--ink2)] font-semibold rounded-xl hover:bg-[var(--paper2)] transition-colors">All TMS in {cityName}</a>
                        </div>
                    </div>
                )}
            </div>
        </section>

        <!-- Rich Educational Content (pSEO) -->
        <section class="py-12 lg:py-20 bg-[var(--paper2)]">
            <div class="container mx-auto px-4 max-w-4xl">
                <div class="prose prose-slate max-w-none prose-headings:tracking-tight prose-headings:font-bold">
                    <h2 class="text-2xl lg:text-3xl font-bold text-[var(--ink)] tracking-tight">Understanding {conditionName} Treatment with TMS in {cityName}</h2>

                    <p>{td.howItWorks}</p>

                    <p>
                        {td.fdaCleared
                            ? `TMS for ${conditionName.toLowerCase()} has been FDA-cleared${td.yearCleared ? ` since ${td.yearCleared}` : ''}, making it a well-established treatment option. In ${cityName}, ${stateName}, ${sortedClinics.length > 0 ? `${sortedClinics.length} verified clinics` : 'providers'} offer this treatment with insurance coverage available through most major plans.`
                            : `While TMS for ${conditionName.toLowerCase()} is not yet FDA-cleared for this specific indication, growing clinical evidence supports its effectiveness. Some ${cityName} providers offer this treatment off-label. Insurance coverage may be limited — check with individual clinics for details.`
                        }
                    </p>

                    <h3>How TMS Treats {conditionName} — The Science</h3>
                    <p>
                        TMS therapy targets the <strong>{td.brainArea}</strong> using {td.protocol}. During each session, a magnetic coil placed against your scalp delivers focused pulses that stimulate neurons in this region. Over the course of treatment, this repeated stimulation promotes neuroplasticity — the brain's ability to form new neural connections and restore healthy patterns of activity.
                    </p>

                    <h3>Treatment Protocol in {cityName}</h3>
                    <p>A typical TMS course for {conditionName.toLowerCase()} in {cityName} involves:</p>
                    <ul>
                        <li><strong>Sessions:</strong> {td.sessions}</li>
                        <li><strong>Duration:</strong> 19-37 minutes per session depending on protocol</li>
                        <li><strong>Location:</strong> Outpatient — no anesthesia, no recovery time</li>
                        <li><strong>Devices commonly used:</strong> {td.devices}</li>
                        <li><strong>Success rate:</strong> {td.successRate}</li>
                    </ul>

                    <h3>Who Qualifies for TMS for {conditionName} in {stateName}?</h3>
                    <p>{td.whoQualifies}</p>
                    <p>
                        Most insurance plans in {stateName} require documentation of prior treatment attempts before authorizing TMS. Your provider's office will typically handle the pre-authorization process. Medicare and most commercial insurers cover FDA-cleared TMS indications.
                    </p>

                    <h3>Cost of TMS for {conditionName} in {cityName}</h3>
                    <p>
                        TMS sessions in {cityName} typically cost <strong>{td.costRange}</strong> per session. A full course of {td.sessions} can range from <strong>$6,000 to $12,000</strong> before insurance. With insurance coverage, out-of-pocket costs may be significantly reduced.
                    </p>
                    <p>
                        Many clinics in {cityName} offer free initial consultations, payment plans, and assistance with insurance pre-authorization. <a href="/tms-cost-guide/">View our complete TMS cost guide</a> for detailed pricing information.
                    </p>

                    <h3>What to Expect at Your First Visit</h3>
                    <p>
                        Your journey begins with a psychiatric evaluation where a {cityName}-area specialist will review your medical history, current symptoms, and prior treatments. If you're a candidate, the clinic will perform brain mapping to identify the optimal stimulation site for your treatment. Sessions are painless — most patients describe a tapping or clicking sensation on the scalp. You can drive yourself to and from appointments and return to normal activities immediately after each session.
                    </p>

                    <h3>Choosing the Right TMS Provider in {cityName}</h3>
                    <p>When selecting a TMS clinic in {cityName}, consider:</p>
                    <ul>
                        <li><strong>Experience:</strong> How many patients has the clinic treated with TMS for {conditionName.toLowerCase()}?</li>
                        <li><strong>Supervision:</strong> Is a board-certified psychiatrist overseeing your treatment?</li>
                        <li><strong>Technology:</strong> Which TMS devices do they use? ({td.devices} are among the leading systems.)</li>
                        <li><strong>Insurance:</strong> Do they handle pre-authorization for your insurance plan?</li>
                        <li><strong>Reviews:</strong> What do verified patients say about their experience?</li>
                    </ul>
                    <p>
                        All clinics listed above are verified by TMS List. <a href="/how-we-rank/">Learn how we rank clinics</a>.
                    </p>
                </div>
            </div>
        </section>

        <!-- FAQ Schema Section -->
        <section class="py-12 lg:py-16 bg-[var(--paper)]">
            <div class="container mx-auto px-4 max-w-4xl">
                <h2 class="text-xl lg:text-2xl font-bold text-[var(--ink)] tracking-tight mb-6 lg:mb-8">Frequently Asked Questions: TMS for {conditionName} in {cityName}</h2>
                <div class="space-y-3 lg:space-y-4">
                    <details class="group bg-[var(--paper2)] rounded-2xl border border-[var(--line)] overflow-hidden">
                        <summary class="flex items-center justify-between gap-3 p-5 lg:p-6 cursor-pointer font-semibold text-[var(--ink)] hover:text-[var(--accent)] transition-colors text-sm lg:text-base">
                            <span class="flex-1">How much does TMS for {conditionName.toLowerCase()} cost in {cityName}?</span>
                            <svg class="w-5 h-5 text-[var(--muted)] group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="px-5 lg:px-6 pb-5 lg:pb-6 text-[var(--muted)] text-sm">Sessions typically cost {td.costRange}. A full course of {td.sessions} ranges from $6,000-$12,000 before insurance. Most major insurance plans cover TMS for FDA-cleared indications.</div>
                    </details>
                    <details class="group bg-[var(--paper2)] rounded-2xl border border-[var(--line)] overflow-hidden">
                        <summary class="flex items-center justify-between gap-3 p-5 lg:p-6 cursor-pointer font-semibold text-[var(--ink)] hover:text-[var(--accent)] transition-colors text-sm lg:text-base">
                            <span class="flex-1">Is TMS for {conditionName.toLowerCase()} FDA-cleared?</span>
                            <svg class="w-5 h-5 text-[var(--muted)] group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="px-5 lg:px-6 pb-5 lg:pb-6 text-[var(--muted)] text-sm">{td.fdaCleared ? `Yes, TMS for ${conditionName.toLowerCase()} is FDA-cleared${td.yearCleared ? ` since ${td.yearCleared}` : ''}. This means most insurance providers cover the treatment.` : `TMS for ${conditionName.toLowerCase()} is currently an off-label application with growing clinical evidence. Insurance coverage may vary — check with providers for details.`}</div>
                    </details>
                    <details class="group bg-[var(--paper2)] rounded-2xl border border-[var(--line)] overflow-hidden">
                        <summary class="flex items-center justify-between gap-3 p-5 lg:p-6 cursor-pointer font-semibold text-[var(--ink)] hover:text-[var(--accent)] transition-colors text-sm lg:text-base">
                            <span class="flex-1">How many TMS sessions will I need for {conditionName.toLowerCase()}?</span>
                            <svg class="w-5 h-5 text-[var(--muted)] group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="px-5 lg:px-6 pb-5 lg:pb-6 text-[var(--muted)] text-sm">A typical course involves {td.sessions}. Each session lasts 19-37 minutes. Most patients begin noticing improvement by weeks 2-3 of treatment.</div>
                    </details>
                    <details class="group bg-[var(--paper2)] rounded-2xl border border-[var(--line)] overflow-hidden">
                        <summary class="flex items-center justify-between gap-3 p-5 lg:p-6 cursor-pointer font-semibold text-[var(--ink)] hover:text-[var(--accent)] transition-colors text-sm lg:text-base">
                            <span class="flex-1">Does TMS have side effects?</span>
                            <svg class="w-5 h-5 text-[var(--muted)] group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="px-5 lg:px-6 pb-5 lg:pb-6 text-[var(--muted)] text-sm">TMS has minimal side effects compared to medication. The most common are mild scalp discomfort at the treatment site and occasional headaches, both of which typically resolve within the first few sessions. Unlike antidepressants, TMS does not cause weight gain, sexual dysfunction, or emotional blunting.</div>
                    </details>
                </div>
            </div>
        </section>

        <!-- Related Treatments in this City -->
        <section class="py-8 lg:py-12 bg-[var(--paper2)] border-t border-[var(--line)]">
            <div class="container mx-auto px-4 max-w-5xl">
                <h2 class="text-lg lg:text-xl font-bold text-[var(--ink)] mb-4 lg:mb-6">Other TMS Treatments in {cityName}</h2>
                <div class="flex flex-wrap gap-2">
                    {TREATMENT_SLUGS.filter(t => t.slug !== treatment).slice(0, 12).map(t => (
                        <a href={`/us/${state}/${city}/${t.slug}/`}
                           class="px-4 py-2 bg-[var(--paper)] border border-[var(--line)] text-sm font-medium text-[var(--ink2)] rounded-xl hover:border-[rgba(10,22,40,0.2)] hover:text-[var(--accent)] transition-all">
                            {t.title.replace('TMS for ', '')}
                        </a>
                    ))}
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="relative py-14 lg:py-16 bg-[var(--ink)] overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-[#0A1628]/10 via-transparent to-[rgba(10,22,40,0.10)]"></div>
            <div class="container mx-auto px-4 text-center relative z-10">
                <h2 class="text-xl lg:text-3xl font-bold text-white mb-3 lg:mb-4 tracking-tight">Ready to explore TMS for {conditionName.toLowerCase()}?</h2>
                <p class="text-[var(--muted)] max-w-lg mx-auto mb-6 lg:mb-8 text-sm lg:text-base">Take our quick assessment to find out if you're a candidate, or contact a provider in {cityName} directly.</p>
                <div class="flex flex-col sm:flex-row gap-3 justify-center flex-wrap">
                    <a href="/quiz/am-i-a-candidate/" class="px-6 lg:px-8 py-3.5 lg:py-4 bg-[var(--ink)] hover:bg-[var(--ink2)] text-white font-semibold rounded-xl transition-colors shadow-lg shadow-[rgba(10,22,40,0.2)] text-sm lg:text-base">Am I a Candidate?</a>
                    <a href={`/us/${state}/${city}/`} class="px-6 lg:px-8 py-3.5 lg:py-4 bg-[var(--paper)]/5 border border-white/10 hover:border-white/25 text-white font-semibold rounded-xl transition-all backdrop-blur text-sm lg:text-base">All {cityName} Clinics</a>
                </div>
            </div>
        </section>

        <!-- Sticky Mobile CTA Bar -->
        <div class="lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-[var(--paper)] border-t border-[var(--line)] shadow-[0_-4px_20px_rgba(0,0,0,0.08)]">
            <div class="flex items-center gap-2 px-3 py-3">
                <a href="/quiz/am-i-a-candidate/" class="flex-1 text-center bg-[var(--ink)] text-white font-bold text-sm py-3 px-4 rounded-xl hover:bg-[var(--ink2)] transition-colors shadow-md">
                    Take the Quiz
                </a>
                <a href={`/us/${state}/${city}/`} class="flex-1 text-center bg-[var(--ink)] text-white font-bold text-sm py-3 px-4 rounded-xl hover:bg-[var(--ink2)] transition-colors shadow-md">
                    View Clinics
                </a>
            </div>
        </div>
    </main>

    <!-- Learn More -->
    <section class="py-8 bg-[var(--paper)] border-t border-[var(--line)]">
      <div class="container mx-auto px-4 text-center">
        <div class="flex flex-wrap justify-center gap-2">
          <a href="/blog/tms-cost-insurance-guide-2026/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Cost &amp; Insurance</a>
          <a href="/blog/questions-to-ask-tms-clinic/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Questions to Ask</a>
          <a href="/blog/preparing-for-first-tms-session/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">First Session</a>
          <a href="/blog/" class="px-3 py-1.5 text-xs font-medium text-[var(--accent)] hover:underline">View all articles →</a>
        </div>
      </div>
    </section>
</Layout>
