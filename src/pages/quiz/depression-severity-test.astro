                        <h3 class="font-semibold text-violet-800 mb-2">Recommended Next Steps</h3>
                        <p id="treatment-text" class="text-sm text-violet-700 leading-relaxed"></p>
                    </div>

                    <div id="self-harm-alert" class="hidden bg-red-50 border border-red-200 rounded-xl p-5 mb-8 text-left">
                        <div class="flex items-start gap-3">
                            <svg class="w-5 h-5 text-red-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                            <div>
                                <p class="text-red-700 font-semibold text-sm mb-1">You indicated thoughts of self-harm</p>
                                <p class="text-red-600 text-sm leading-relaxed">If you are in crisis or need immediate support, call or text <strong>988</strong> (Suicide &amp; Crisis Lifeline, available 24/7). You can also text HOME to <strong>741741</strong> to reach the Crisis Text Line.</p>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
                        <a href="/us/" class="quiz-geo-link w-full sm:w-auto text-center px-8 py-4 bg-violet-600 text-white font-semibold rounded-xl hover:bg-violet-700 transition-all shadow-lg shadow-violet-200">Find a Clinic Near You</a>
                        <a href="/quiz/am-i-a-candidate/" class="w-full sm:w-auto text-center px-8 py-4 text-gray-500 font-medium rounded-xl border border-gray-200 hover:border-gray-300 hover:text-gray-700 transition-all">Am I a Candidate for TMS?</a>
                    </div>
                </div>

            </div>

            <p class="text-center text-xs text-gray-400 mt-6">
                This is a screening tool, not a diagnosis. Only a licensed clinician can evaluate and diagnose depression.
                Scores are not stored and this assessment does not constitute medical advice.
            </p>
        </div>
    </main>
</Layout>

<script is:inline>
    document.getElementById('btn-start').addEventListener('click', function() {
        nextSlide('intro', 'q1');
    });

    var phqAnswers = {};
    var currentQuestion = 1;

    function phqAnswer(qNum, val) {
        phqAnswers[qNum] = val;
        var nextId = qNum >= 9 ? 'results' : 'q' + (qNum + 1);
        nextSlide('q' + qNum, nextId);
    }

    function nextSlide(currentId, nextId) {
        var cur = document.getElementById('slide-' + currentId);
        var nxt = document.getElementById('slide-' + nextId);
        if (cur) cur.classList.add('hidden');
        if (nxt) nxt.classList.remove('hidden');

        var answered = Object.keys(phqAnswers).length;
        var progress = Math.min((answered / 9) * 100, 100);
        var bar = document.getElementById('progress-bar');
        var text = document.getElementById('progress-text');
        if (bar) bar.style.width = progress + '%';
        if (text) text.innerText = Math.round(progress) + '%';

        if (nextId === 'results') showResults();
    }

    function getSeverity(score) {
        if (score <= 4) return { label: "Minimal or None", color: "bg-green-100 text-green-700", interpretation: "Your score suggests minimal or no depression symptoms. Lifestyle changes, regular exercise, and maintaining social connections can support continued well-being.", treatment: "At this level, treatment is typically not needed. Consider monitoring your mood and seeking support if symptoms worsen." };
        if (score <= 9) return { label: "Mild", color: "bg-yellow-100 text-yellow-700", interpretation: "Your score suggests mild depression. This may respond well to lifestyle interventions, therapy (CBT or similar), or a trial of antidepressant medication.", treatment: "Consider talking to a primary care doctor or therapist. Many people improve significantly with a combination of therapy and exercise. Watch for changes and re-assess in 2-4 weeks." };
        if (score <= 14) return { label: "Moderate", color: "bg-orange-100 text-orange-700", interpretation: "Your score suggests moderate depression. A combination of psychotherapy and medication is typically the first-line treatment approach. TMS may be an option if medications haven't helped.", treatment: "Schedule an appointment with a psychiatrist or your primary care doctor to discuss treatment options. Document your medication history — insurance often requires records of failed medication trials." };
        if (score <= 19) return { label: "Moderately Severe", color: "bg-amber-100 text-amber-700", interpretation: "Your score suggests moderately severe depression. This level typically warrants active treatment — either medication, therapy, or both. TMS is often a strong option if you've tried medications without adequate relief.", treatment: "You're likely a good candidate for TMS evaluation. Most insurance requires PHQ-9 of 10 or higher and documented medication failures. Consider scheduling a TMS consultation and gathering your medication history." };
        return { label: "Severe", color: "bg-red-100 text-red-700", interpretation: "Your score suggests severe depression. This level requires prompt evaluation by a mental health professional. TMS is often appropriate for treatment-resistant cases at this severity level, especially with documented medication history.", treatment: "Please seek evaluation from a psychiatrist or TMS clinic as soon as possible. With your severity score, you may be a strong candidate for TMS. Contact a provider and bring any documentation of past treatments." };
    }

    function showResults() {
        var score = 0;
        for (var i = 1; i <= 9; i++) {
            score += (phqAnswers[i] || 0);
        }

        var severity = getSeverity(score);

        var numEl = document.getElementById('score-number');
        if (numEl) numEl.innerText = score;

        var badge = document.getElementById('severity-badge');
        if (badge) {
            badge.innerText = severity.label;
            badge.className = 'inline-block px-4 py-1.5 rounded-full text-sm font-bold mb-4 ' + severity.color;
        }

        var labelEl = document.getElementById('severity-label');
        if (labelEl) labelEl.innerText = severity.label + ' Depression';

        var pct = Math.min((score / 27) * 100, 100);
        var marker = document.getElementById('score-marker');
        if (marker) marker.style.left = 'calc(' + pct + '% - 10px)';

        var interp = document.getElementById('score-interpretation');
        if (interp) interp.innerText = severity.interpretation;

        var treat = document.getElementById('treatment-text');
        if (treat) treat.innerText = severity.treatment;

        if ((phqAnswers[9] || 0) > 0) {
            var alert = document.getElementById('self-harm-alert');
            if (alert) alert.classList.remove('hidden');
        }

        var text = document.getElementById('progress-text');
        if (text) text.innerText = '100%';
        var bar = document.getElementById('progress-bar');
        if (bar) bar.style.width = '100%';
    }

    // Geo-route CTA links
    try {
        if (window.TMS_GEO && window.TMS_GEO.url) {
            document.querySelectorAll('.quiz-geo-link').forEach(function(el) {
                el.href = window.TMS_GEO.url;
            });
        }
    } catch (e) {}
</script>