---
import Layout from "../../layouts/Layout.astro";

const title = "Depression Severity Self-Assessment | PHQ-9 Quiz";
const description = "Take the free PHQ-9 questionnaire to measure your depression severity and find out what treatment options — including TMS — may be right for you.";

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const quizSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Quiz",
    "name": "PHQ-9 Depression Severity Assessment",
    "description": description,
    "url": `${siteUrl}/quiz/depression-severity-test/`,
    "educationalLevel": "patient",
    "about": {
        "@type": "MedicalCondition",
        "name": "Major Depressive Disorder",
        "code": { "@type": "MedicalCode", "code": "F33.1", "codingSystem": "ICD-10" }
    },
    "provider": {
        "@type": "Organization",
        "name": "TMS List",
        "url": siteUrl,
    },
});

const questions = [
    { id: 1, question: "Little interest or pleasure in doing things" },
    { id: 2, question: "Feeling down, depressed, or hopeless" },
    { id: 3, question: "Trouble falling or staying asleep, or sleeping too much" },
    { id: 4, question: "Feeling tired or having little energy" },
    { id: 5, question: "Poor appetite or overeating" },
    { id: 6, question: "Feeling bad about yourself — or that you are a failure or have let yourself or your family down" },
    { id: 7, question: "Trouble concentrating on things, such as reading the newspaper or watching television" },
    { id: 8, question: "Moving or speaking so slowly that other people could have noticed — or the opposite, being so fidgety or restless that you have been moving around a lot more than usual" },
    { id: 9, question: "Thoughts that you would be better off dead, or of hurting yourself in some way" },
];
---

<Layout title={title} description={description} noindex={true} schema={quizSchema}>
    <main class="min-h-screen bg-gradient-to-b from-slate-50 to-white py-12">
        <div class="container mx-auto px-4 max-w-2xl">

            <div class="mb-6 flex items-center justify-center">
                <div class="flex items-center gap-2 text-sm text-slate-500">
                    <svg class="w-4 h-4 text-violet-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    Over the last 2 weeks
                    <span class="text-slate-300">•</span>
                    9 questions
                    <span class="text-slate-300">•</span>
                    ~3 minutes
                </div>
            </div>

            <div class="mb-8">
                <div class="flex justify-between text-xs font-semibold text-gray-500 mb-2 uppercase tracking-wide">
                    <span>Your Progress</span>
                    <span id="progress-text">0%</span>
                </div>
                <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div id="progress-bar" class="h-full bg-violet-600 transition-all duration-500 ease-out" style="width: 0%"></div>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-[0_4px_20px_rgb(0,0,0,0.03)] border border-gray-100 overflow-hidden">

                <!-- Intro Slide -->
                <div id="slide-intro" class="quiz-slide p-8 md:p-12 text-center">
                    <div class="w-16 h-16 bg-violet-100 text-violet-600 rounded-full flex items-center justify-center mx-auto mb-6">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    </div>
                    <h1 class="text-3xl font-semibold tracking-tight text-gray-900 mb-4">Depression Severity Assessment</h1>
                    <p class="text-lg text-gray-600 mb-4 leading-relaxed">
                        The PHQ-9 is the standard screening tool for depression severity, used by psychiatrists, primary care doctors, and TMS clinics worldwide.
                    </p>
                    <p class="text-base text-gray-500 mb-8 leading-relaxed">
                        Rate how often each problem has bothered you over the <strong>past 2 weeks</strong>. Your score helps identify severity and appropriate next steps — including whether TMS might be an option.
                    </p>
                    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-6">
                        <button id="btn-start" class="w-full sm:w-auto px-8 py-4 bg-violet-600 text-white font-semibold rounded-xl hover:bg-violet-700 transition-all transform hover:-translate-y-1 shadow-lg shadow-violet-200">
                            Start Assessment
