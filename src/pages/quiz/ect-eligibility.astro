---
import Layout from "../../layouts/Layout.astro";

const title = "Am I a Candidate for ECT? | 2-Minute Eligibility Quiz";
const description =
    "Free confidential eligibility quiz for Electroconvulsive Therapy (ECT) — see if you may be a candidate for severe, treatment-resistant, or life-threatening depression.";

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const quizSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Quiz",
    "name": "ECT Eligibility Assessment",
    "description": description,
    "url": `${siteUrl}/quiz/ect-eligibility/`,
    "educationalLevel": "patient",
    "about": {
        "@type": "MedicalTherapy",
        "name": "Electroconvulsive Therapy (ECT)",
        "medicalSpecialty": "Psychiatry",
    },
    "provider": { "@type": "Organization", "name": "TMS List", "url": siteUrl },
});
---

<Layout title={title} description={description} noindex={true} schema={quizSchema}>
    <main class="min-h-screen bg-gradient-to-b from-[var(--paper2)] to-white py-12">
        <div class="container mx-auto px-4 max-w-2xl">
            <section class="mb-10 bg-[var(--paper)] border border-[var(--line)] rounded-2xl p-8">
                <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">About the Treatment</span>
                <h1 class="text-3xl font-semibold tracking-tight text-[var(--ink)] mb-4">What is ECT?</h1>
                <p class="text-[var(--muted)] leading-relaxed mb-4">
                    Electroconvulsive Therapy is the oldest and, for severe depression, still the <strong>most effective</strong> psychiatric treatment we have.
                    Modern ECT has very little in common with the procedure shown in old movies — it's done under brief general anesthesia, with muscle relaxants
                    so your body doesn't move, and the electrical dose is highly individualized. Response rates of <strong>70-90%</strong> for severe and
                    treatment-resistant depression are typical, often within 1-3 weeks.
                </p>
                <p class="text-[var(--muted)] leading-relaxed mb-4">
                    ECT is the first-line treatment when depression is <strong>life-threatening, psychotic, catatonic,</strong> or has failed multiple medication
                    trials. It's also used for severe mania, bipolar depression, and Parkinson's-related depression. Sessions take about 5-10 minutes of actual treatment
                    plus 30-60 minutes of recovery. A typical course is 6-12 sessions over 2-4 weeks.
                </p>
                <ul class="text-sm text-[var(--muted)] space-y-1 list-disc list-inside">
                    <li><strong>Insurance:</strong> Universally covered by Medicare, Medicaid, and commercial insurance for severe depression.</li>
                    <li><strong>Cost:</strong> ~$300-$1,000 per session retail; copays often $0-$100 with insurance.</li>
                    <li><strong>Side effects:</strong> Temporary memory loss is the main concern — typically resolves over weeks to months. Brief confusion post-procedure. Headache.</li>
                </ul>
            </section>

            <div class="mb-8">
                <div class="flex justify-between text-xs font-semibold text-[var(--muted)] mb-2 uppercase tracking-wide">
                    <span>Eligibility Quiz</span>
                    <span id="progress-text">0%</span>
                </div>
                <div class="h-2 bg-[var(--paper2)] rounded-full overflow-hidden">
                    <div id="progress-bar" class="h-full bg-[var(--ink)] transition-all duration-500 ease-out" style="width: 0%"></div>
                </div>
            </div>

            <div class="bg-[var(--paper)] rounded-2xl shadow-[0_4px_20px_rgb(0,0,0,0.03)] border border-[var(--line)] overflow-hidden">
                <div id="slide-intro" class="p-8 md:p-12 text-center">
                    <h2 class="text-2xl font-semibold tracking-tight text-[var(--ink)] mb-4">Should You Consider ECT?</h2>
                    <p class="text-[var(--muted)] mb-8">Six quick questions to see if ECT may be appropriate for your situation. ECT is generally considered when other treatments have failed or when symptoms are too severe to wait for them to work.</p>
                    <button onclick="next('intro','q1')" class="px-8 py-4 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] shadow-lg">Start Quiz</button>
                    <div class="bg-amber-50 border border-amber-100 rounded-xl p-4 text-left mt-6">
                        <p class="text-amber-700 text-sm">If you are in crisis: call or text <strong>988</strong> for the Suicide &amp; Crisis Lifeline, available 24/7.</p>
                    </div>
                </div>

                <!-- Q1 Diagnosis -->
                <div id="slide-q1" class="hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 1 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">What's the primary condition you're seeking treatment for?</h2>
                    <div class="space-y-3">
                        <button onclick="rec('dx','severe_dep'); next('q1','q2')" class="opt">Severe major depressive disorder</button>
                        <button onclick="rec('dx','psychotic'); next('q1','q2')" class="opt">Depression with psychotic features (hallucinations, delusions)</button>
                        <button onclick="rec('dx','catatonia'); next('q1','q2')" class="opt">Catatonia (severe immobility, mutism, or unresponsiveness)</button>
                        <button onclick="rec('dx','bipolar'); next('q1','q2')" class="opt">Severe bipolar depression or mania</button>
                        <button onclick="rec('dx','parkinsons'); next('q1','q2')" class="opt">Parkinson's-related depression</button>
                        <button onclick="rec('dx','mild'); next('q1','q2')" class="opt">Mild or moderate depression</button>
                    </div>
                </div>

                <!-- Q2 Severity -->
                <div id="slide-q2" class="hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 2 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Are you currently experiencing any of the following?</h2>
                    <div class="space-y-3">
                        <button onclick="rec('crisis','si'); next('q2','q3')" class="opt">Active suicidal thoughts or recent attempts</button>
                        <button onclick="rec('crisis','noteat'); next('q2','q3')" class="opt">Not eating, drinking, or caring for myself</button>
                        <button onclick="rec('crisis','psychosis'); next('q2','q3')" class="opt">Psychotic symptoms or severe agitation</button>
                        <button onclick="rec('crisis','functioning'); next('q2','q3')" class="opt">Severe but not immediately life-threatening symptoms</button>
                        <button onclick="rec('crisis','none'); next('q2','q3')" class="opt">None of the above</button>
                    </div>
                </div>

                <!-- Q3 Failed Treatments -->
                <div id="slide-q3" class="hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 3 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">How many treatments have you tried in your current episode without enough relief?</h2>
                    <div class="space-y-3">
                        <button onclick="rec('failed',0); next('q3','q4')" class="opt">None — this would be my first treatment</button>
                        <button onclick="rec('failed',1); next('q3','q4')" class="opt">1 medication</button>
                        <button onclick="rec('failed',2); next('q3','q4')" class="opt">2-3 medications</button>
                        <button onclick="rec('failed',4); next('q3','q4')" class="opt">4+ medications, including augmentation</button>
                        <button onclick="rec('failed','tms'); next('q3','q4')" class="opt">Multiple medications + TMS or Spravato</button>
                    </div>
                </div>

                <!-- Q4 Anesthesia / Health -->
                <div id="slide-q4" class="hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 4 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Do you have any of the following medical conditions?</h2>
                    <div class="space-y-3">
                        <button onclick="rec('health','severe_cardiac'); next('q4','q5')" class="opt">Recent heart attack, severe heart disease, or uncontrolled hypertension</button>
                        <button onclick="rec('health','aneurysm'); next('q4','q5')" class="opt">Brain aneurysm, recent stroke, or raised intracranial pressure</button>
                        <button onclick="rec('health','anesthesia'); next('q4','q5')" class="opt">Significant anesthesia risk (severe lung disease, etc.)</button>
                        <button onclick="rec('health','none'); next('q4','q5')" class="opt">None of the above — I'm relatively healthy</button>
                    </div>
                </div>

                <!-- Q5 Memory -->
                <div id="slide-q5" class="hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 5 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">How do you feel about ECT's main side effect — temporary memory issues that usually resolve over weeks to months?</h2>
                    <div class="space-y-3">
                        <button onclick="rec('memory','accept'); next('q5','q6')" class="opt">I can accept temporary memory effects given the severity of my depression</button>
                        <button onclick="rec('memory','concern'); next('q5','q6')" class="opt">It concerns me but I'd want to learn more</button>
                        <button onclick="rec('memory','dealbreak'); next('q5','q6')" class="opt">Memory side effects are a deal-breaker for me</button>
                    </div>
                </div>

                <!-- Q6 Logistics -->
                <div id="slide-q6" class="hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Last Question</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Can you arrange transportation, time off work, and someone to be with you on treatment days for 2-4 weeks?</h2>
                    <div class="space-y-3">
                        <button onclick="rec('logistics',true); show()" class="opt">Yes, I can arrange that</button>
                        <button onclick="rec('logistics','partial'); show()" class="opt">Possibly — would need to figure it out</button>
                        <button onclick="rec('logistics',false); show()" class="opt">No, that's not feasible right now</button>
                    </div>
                </div>

                <!-- Result: Strong -->
                <div id="result-high" class="hidden p-8 md:p-12 text-center">
                    <div class="w-20 h-20 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-6">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <h2 class="text-3xl font-semibold tracking-tight text-[var(--ink)] mb-4">ECT Is Likely Appropriate to Discuss</h2>
                    <p class="text-[var(--muted)] mb-8">Based on your answers, ECT fits the standard clinical profile — severe symptoms or treatment-resistance, no major safety contraindications, willing to accept the temporary memory side effects. ECT has the highest response rate of any psychiatric treatment for severe depression. The right next step is an evaluation with a psychiatrist who can refer to an ECT program.</p>
                    <a href="/alternatives/electroconvulsive-therapy-ect/" class="block w-full px-8 py-4 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] shadow-lg mb-4">Read the Full ECT Guide</a>
                    <a href="/specialists/" class="text-[var(--accent)] font-semibold hover:underline">Find a Psychiatrist for Referral</a>
                </div>

                <!-- Result: Maybe -->
                <div id="result-maybe" class="hidden p-8 md:p-12 text-center">
                    <div class="w-20 h-20 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center mx-auto mb-6">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    </div>
                    <h2 class="text-3xl font-semibold tracking-tight text-[var(--ink)] mb-4">ECT Could Be an Option, But Probably Not First</h2>
                    <p class="text-[var(--muted)] mb-8">ECT is typically reserved for severe, life-threatening, or repeatedly treatment-resistant cases. Based on your answers, less invasive options like TMS or Spravato may be worth trying first — they have meaningful efficacy with far fewer logistical and cognitive trade-offs. If those have failed, ECT remains the most powerful option available.</p>
                    <a href="/quiz/which-treatment-is-right/" class="block w-full px-8 py-4 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] shadow-lg mb-4">Try the Treatment Decision Tree</a>
                    <a href="/quiz/am-i-a-candidate/" class="text-[var(--accent)] font-semibold hover:underline">Check TMS Eligibility First</a>
                </div>

                <!-- Result: Not Suitable -->
                <div id="result-low" class="hidden p-8 md:p-12 text-center">
                    <div class="w-20 h-20 bg-rose-100 text-rose-600 rounded-full flex items-center justify-center mx-auto mb-6">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </div>
                    <h2 class="text-3xl font-semibold tracking-tight text-[var(--ink)] mb-4">ECT May Not Be the Right Path</h2>
                    <p class="text-[var(--muted)] mb-8">Based on your answers, ECT carries risks (cardiac/anesthesia concerns, contraindicated medical conditions, or memory side effects you can't accept) that outweigh likely benefit at your current severity. TMS is a strong alternative — same effectiveness category for many patients, no anesthesia, no memory effects.</p>
                    <a href="/treatments/depression/" class="block w-full px-8 py-4 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] shadow-lg mb-4">Explore TMS for Depression</a>
                    <a href="/quiz/which-treatment-is-right/" class="text-[var(--accent)] font-semibold hover:underline">Compare All Treatment Options</a>
                </div>
            </div>

            <p class="text-xs text-[var(--muted)] text-center mt-8 max-w-lg mx-auto">
                This quiz is for educational purposes and does not replace medical advice. Only a licensed psychiatrist can determine if ECT is appropriate for you.
            </p>
        </div>
    </main>
</Layout>

<style>
    .opt { width: 100%; padding: 1rem; text-align: left; border: 2px solid var(--line); border-radius: 0.75rem; font-weight: 500; color: var(--ink2); transition: all 0.15s ease; }
    .opt:hover { border-color: var(--ink); background: rgba(10,22,40,0.04); }
</style>

<script is:inline>
    const ans = {};
    let answered = 0;
    const total = 6;

    function rec(k, v) { ans[k] = v; }
    function next(curr, n) {
        document.getElementById("slide-" + curr).classList.add("hidden");
        document.getElementById("slide-" + n).classList.remove("hidden");
        answered++;
        const pct = Math.min((answered / total) * 100, 100);
        document.getElementById("progress-bar").style.width = pct + "%";
        document.getElementById("progress-text").innerText = Math.round(pct) + "%";
    }

    function show() {
        document.getElementById("slide-q6").classList.add("hidden");
        document.getElementById("progress-bar").style.width = "100%";
        document.getElementById("progress-text").innerText = "100%";

        const hardStop = ans.health === "severe_cardiac" || ans.health === "aneurysm" || ans.health === "anesthesia" || ans.memory === "dealbreak" || ans.logistics === false;
        const strongFit = (ans.dx === "severe_dep" || ans.dx === "psychotic" || ans.dx === "catatonia" || ans.dx === "bipolar" || ans.dx === "parkinsons") &&
            (ans.crisis === "si" || ans.crisis === "noteat" || ans.crisis === "psychosis" || ans.failed === "tms" || ans.failed >= 4) &&
            ans.health === "none" && ans.memory !== "dealbreak" && ans.logistics !== false;

        if (hardStop) {
            document.getElementById("result-low").classList.remove("hidden");
        } else if (strongFit) {
            document.getElementById("result-high").classList.remove("hidden");
        } else {
            document.getElementById("result-maybe").classList.remove("hidden");
        }
    }
</script>
