---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import EditorialSection from '../../components/editorial/EditorialSection.astro';
import EditorialCard from '../../components/editorial/EditorialCard.astro';
import EditorialCTA from '../../components/editorial/EditorialCTA.astro';
import { UTILITY_SLUGS } from '../../utils/seo_slugs';

const title = "TMS Assessment Tools | Am I a Candidate? Depression Test & Insurance Check";
const description = "Free self-assessment tools — check if you're a TMS candidate, measure your depression severity, and verify your insurance coverage.";

const TOOL_META: Record<string, { description: string; time: string; tone: 'success' | 'accent' | 'warm' }> = {
  'am-i-a-candidate': { description: 'Quick self-assessment based on your diagnosis, treatment history, and medical profile to determine TMS candidacy.', time: '2 min', tone: 'success' },
  'depression-severity-test': { description: 'PHQ-9 questionnaire to measure your depression severity and understand what treatment options may be appropriate.', time: '3 min', tone: 'accent' },
  'insurance-eligibility-checker': { description: 'Check if your insurance covers TMS therapy, understand prior auth requirements, and estimate your out-of-pocket costs.', time: '5 min', tone: 'warm' },
  'spravato-eligibility': { description: 'Find out if you meet FDA and insurance criteria for Spravato (esketamine) nasal spray for treatment-resistant depression.', time: '2 min', tone: 'accent' },
  'ketamine-eligibility': { description: 'See if you may be a candidate for IV ketamine or ketamine-assisted therapy for depression, PTSD, or chronic pain.', time: '2 min', tone: 'success' },
  'anxiety-severity-test': { description: 'GAD-7 questionnaire to measure your anxiety severity over the past 2 weeks and what next steps may help.', time: '2 min', tone: 'warm' },
  'ptsd-severity-test': { description: 'PCL-5 self-report scale to measure PTSD symptoms over the past month — used by the VA and trauma clinics worldwide.', time: '5 min', tone: 'accent' },
  'ocd-severity-test': { description: 'Yale-Brown Obsessive Compulsive Scale (Y-BOCS) style self-rating to gauge OCD severity and explore deep-TMS eligibility.', time: '5 min', tone: 'success' },
  'which-treatment-is-right': { description: 'Decision tree comparing TMS, Spravato, IV ketamine, and ECT based on your diagnosis, prior treatments, urgency, and insurance.', time: '3 min', tone: 'warm' },
  'ect-eligibility': { description: 'Find out if ECT is appropriate for your situation — typically considered for severe, life-threatening, or repeatedly treatment-resistant depression.', time: '2 min', tone: 'accent' },
  'bipolar-screener': { description: 'MDQ-based screen for bipolar disorder — important if antidepressants haven\'t worked as expected or if you\'ve had unusual periods of high energy.', time: '3 min', tone: 'warm' },
};

const enrichedTools = UTILITY_SLUGS.map(item => ({
  ...item,
  ...(TOOL_META[item.slug] || { description: 'Assessment tool for TMS therapy.', time: '3 min', tone: 'accent' as const }),
}));

const schema = JSON.stringify({
  "@context": "https://schema.org", "@type": "CollectionPage",
  "name": "TMS Assessment Tools", "description": description, "url": "https://tmslist.com/quiz/",
  "mainEntity": { "@type": "ItemList", "numberOfItems": UTILITY_SLUGS.length,
    "itemListElement": UTILITY_SLUGS.map((item, i) => ({ "@type": "ListItem", "position": i + 1, "name": item.title, "url": `https://tmslist.com/quiz/${item.slug}/` }))
  }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[{ name: "Home", url: "/" }, { name: "Tools", url: "/quiz/" }]}>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow={`${UTILITY_SLUGS.length} Free Self-Assessments`}
    eyebrowDot="#22c55e"
    title="Find out in"
    titleAccent="under 5 minutes."
    description="Free, evidence-based self-assessments to understand if TMS is right for you, how severe your symptoms are, and what your insurance covers."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Tools" }]}
    ctas={[
      { label: "Start the Candidate Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: "Find a Clinic", href: "/us/", variant: "outline" },
    ]}
  />

  <EditorialSection
    title="Self-Assessment Tools"
    intro="Confidential, no sign-up required. Each tool gives an instant score and next-step recommendations."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>'
    tone="success"
    noBorder
  >
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {enrichedTools.map((tool) => (
        <EditorialCard
          href={`/quiz/${tool.slug}/`}
          tag={tool.time}
          tagTone={tool.tone}
          title={tool.title}
          description={tool.description}
          size="lg"
        />
      ))}
    </div>
  </EditorialSection>

  <EditorialCTA
    title="Ready for the next step?"
    description="Once you've checked your candidacy, find a verified TMS clinic that accepts your insurance."
    ctas={[
      { label: "Browse Clinics", href: "/us/" },
      { label: "Compare Treatments", href: "/compare/", variant: "outline" },
    ]}
    stickyMobile
  />
</main>

</Layout>
