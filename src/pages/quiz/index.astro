---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import { UTILITY_SLUGS } from '../../utils/seo_slugs';

const title = "TMS Assessment Tools | Am I a Candidate? Depression Test & Insurance Check";
const description = "Free self-assessment tools — check if you're a TMS candidate, measure your depression severity, and verify your insurance coverage.";

const TOOL_META: Record<string, { description: string; icon: string; color: string; time: string }> = {
  'am-i-a-candidate': { description: 'Quick self-assessment based on your diagnosis, treatment history, and medical profile to determine TMS candidacy.', icon: 'check', color: 'emerald', time: '2 min' },
  'depression-severity-test': { description: 'PHQ-9 questionnaire to measure your depression severity and understand what treatment options may be appropriate.', icon: 'chart', color: 'violet', time: '3 min' },
  'insurance-eligibility-checker': { description: 'Check if your insurance covers TMS therapy, understand prior auth requirements, and estimate your out-of-pocket costs.', icon: 'shield', color: 'amber', time: '5 min' },
};

const enrichedTools = UTILITY_SLUGS.map(item => ({
  ...item,
  ...(TOOL_META[item.slug] || { description: 'Assessment tool for TMS therapy.', icon: 'check', color: 'violet', time: '3 min' }),
}));

const colorMap: Record<string, { bg: string; border: string; text: string; iconBg: string }> = {
  emerald: { bg: 'bg-emerald-50', border: 'border-emerald-200', text: 'text-emerald-700', iconBg: 'bg-emerald-100' },
  violet: { bg: 'bg-violet-50', border: 'border-violet-200', text: 'text-violet-700', iconBg: 'bg-violet-100' },
  amber: { bg: 'bg-amber-50', border: 'border-amber-200', text: 'text-amber-700', iconBg: 'bg-amber-100' },
};

const schema = JSON.stringify({
  "@context": "https://schema.org", "@type": "CollectionPage",
  "name": "TMS Assessment Tools", "description": description, "url": "https://tmslist.com/quiz/",
  "mainEntity": { "@type": "ItemList", "numberOfItems": UTILITY_SLUGS.length,
    "itemListElement": UTILITY_SLUGS.map((item, i) => ({ "@type": "ListItem", "position": i + 1, "name": item.title, "url": `https://tmslist.com/quiz/${item.slug}/` }))
  }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[{ name: "Home", url: "/" }, { name: "Tools", url: "/quiz/" }]}>
  <section class="relative bg-slate-950 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-600 to-slate-900 opacity-90"></div>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.4) 1px, transparent 0); background-size: 28px 28px;"></div>
    <div class="relative z-10 container mx-auto px-4 pt-20 pb-16 lg:pt-28 lg:pb-20">
      <nav class="flex items-center gap-2 text-sm text-white/40 mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white/70 transition-colors">Home</a><span class="text-white/20">/</span><span class="text-white/60">Tools</span>
      </nav>
      <div class="max-w-3xl">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white tracking-tight leading-[1.1] mb-5 font-display">TMS Assessment Tools</h1>
        <p class="text-lg text-white/60 leading-relaxed max-w-2xl">Free self-assessments to help you understand if TMS is right for you, how severe your symptoms are, and what your insurance covers.</p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-12 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <main class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {enrichedTools.map((tool) => {
        const colors = colorMap[tool.color] || colorMap.violet;
        return (
          <a href={`/quiz/${tool.slug}/`} class={`group ${colors.bg} border ${colors.border} rounded-2xl p-8 hover:shadow-lg transition-all text-center`}>
            <div class={`w-14 h-14 ${colors.iconBg} rounded-2xl flex items-center justify-center mx-auto mb-4`}>
              <svg class={`w-7 h-7 ${colors.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <span class={`text-xs font-bold ${colors.text} uppercase tracking-wider`}>{tool.time}</span>
            <h2 class="text-lg font-display font-bold text-slate-900 group-hover:text-violet-600 transition-colors my-3">{tool.title}</h2>
            <p class="text-sm text-slate-600 leading-relaxed">{tool.description}</p>
          </a>
        );
      })}
    </div>
  </main>
</Layout>
