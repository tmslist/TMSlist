---
import Layout from "../../layouts/Layout.astro";

const title = "Am I Eligible for Ketamine Therapy? | 2-Minute Quiz";
const description =
    "Free confidential eligibility quiz for IV ketamine and ketamine-assisted therapy — see if you're a candidate for treatment-resistant depression, PTSD, or chronic pain.";

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const quizSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Quiz",
    "name": "Ketamine Therapy Eligibility Assessment",
    "description": description,
    "url": `${siteUrl}/quiz/ketamine-eligibility/`,
    "educationalLevel": "patient",
    "about": {
        "@type": "MedicalTherapy",
        "name": "Ketamine Infusion Therapy",
        "medicalSpecialty": "Psychiatry",
    },
    "provider": {
        "@type": "Organization",
        "name": "TMS List",
        "url": siteUrl,
    },
});
---

<Layout title={title} description={description} noindex={true} schema={quizSchema}>
    <main class="min-h-screen bg-gradient-to-b from-[var(--paper2)] to-white py-12">
        <div class="container mx-auto px-4 max-w-2xl">
            <!-- About Ketamine -->
            <section class="mb-10 bg-[var(--paper)] border border-[var(--line)] rounded-2xl p-8">
                <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">About the Treatment</span>
                <h1 class="text-3xl font-semibold tracking-tight text-[var(--ink)] mb-4">What is Ketamine Therapy?</h1>
                <p class="text-[var(--muted)] leading-relaxed mb-4">
                    Ketamine is a decades-old anesthetic that, at sub-anesthetic doses, has shown rapid antidepressant effects.
                    It is used <strong>off-label</strong> in psychiatry for <strong>treatment-resistant depression, PTSD, severe anxiety,
                    suicidal ideation, OCD, and certain chronic pain conditions</strong>. Ketamine works on the NMDA glutamate receptor
                    and triggers synaptic regrowth — many patients report relief within 24–72 hours of their first session.
                </p>
                <p class="text-[var(--muted)] leading-relaxed mb-4">
                    The most common forms are <strong>IV infusions</strong> (40–60 minutes, the most studied route), <strong>IM injections</strong>,
                    and <strong>sublingual lozenges</strong> for at-home protocols. A typical induction course is 6 infusions over 2–3 weeks,
                    followed by booster sessions as needed. Sessions occur in a clinic with vital sign monitoring; you'll need a ride home.
                </p>
                <ul class="text-sm text-[var(--muted)] space-y-1 list-disc list-inside">
                    <li><strong>FDA status:</strong> Off-label for mood disorders (only the esketamine nasal spray, Spravato, is FDA-approved).</li>
                    <li><strong>Insurance:</strong> Rarely covered — most clinics are cash-pay, $400–$800 per IV session.</li>
                    <li><strong>Onset:</strong> Hours to days, vs. 4–6 weeks for SSRIs.</li>
                </ul>
            </section>

            <!-- Progress Bar -->
            <div class="mb-8">
                <div class="flex justify-between text-xs font-semibold text-[var(--muted)] mb-2 uppercase tracking-wide">
                    <span>Eligibility Quiz</span>
                    <span id="progress-text">0%</span>
                </div>
                <div class="h-2 bg-[var(--paper2)] rounded-full overflow-hidden">
                    <div id="progress-bar" class="h-full bg-[var(--ink)] transition-all duration-500 ease-out" style="width: 0%"></div>
                </div>
            </div>

            <!-- Quiz Card -->
            <div class="bg-[var(--paper)] rounded-2xl shadow-[0_4px_20px_rgb(0,0,0,0.03)] border border-[var(--line)] overflow-hidden">
                <!-- Intro -->
                <div id="slide-intro" class="quiz-slide p-8 md:p-12 text-center">
                    <h2 class="text-2xl font-semibold tracking-tight text-[var(--ink)] mb-4">Are You a Candidate for Ketamine?</h2>
                    <p class="text-[var(--muted)] mb-8">Answer 6 quick questions to check whether ketamine therapy may be appropriate and safe for you.</p>
                    <button onclick="nextSlide('intro', 'q1')" class="w-full sm:w-auto px-8 py-4 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-all shadow-lg">Start Quiz</button>
                    <p class="text-xs text-[var(--muted)] mt-6">Confidential. No personal info required to take the quiz.</p>
                </div>

                <!-- Q1: Age -->
                <div id="slide-q1" class="quiz-slide hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 1 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Are you 18 or older?</h2>
                    <div class="space-y-3">
                        <button onclick="recordAnswer('age', true); nextSlide('q1', 'q2')" class="quiz-opt">Yes</button>
                        <button onclick="recordAnswer('age', false); nextSlide('q1', 'q2')" class="quiz-opt">No (under 18)</button>
                    </div>
                </div>

                <!-- Q2: Condition -->
                <div id="slide-q2" class="quiz-slide hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 2 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Which best describes what you're seeking treatment for?</h2>
                    <div class="space-y-3">
                        <button onclick="recordAnswer('condition', 'depression'); nextSlide('q2', 'q3')" class="quiz-opt">Treatment-resistant depression</button>
                        <button onclick="recordAnswer('condition', 'ptsd'); nextSlide('q2', 'q3')" class="quiz-opt">PTSD or severe anxiety</button>
                        <button onclick="recordAnswer('condition', 'pain'); nextSlide('q2', 'q3')" class="quiz-opt">Chronic pain (CRPS, fibromyalgia)</button>
                        <button onclick="recordAnswer('condition', 'si'); nextSlide('q2', 'q3')" class="quiz-opt">Suicidal thoughts or acute crisis</button>
                        <button onclick="recordAnswer('condition', 'other'); nextSlide('q2', 'q3')" class="quiz-opt">Something else / exploring</button>
                    </div>
                </div>

                <!-- Q3: Failed Treatments -->
                <div id="slide-q3" class="quiz-slide hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 3 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Have you tried at least one standard treatment (medication or therapy) without enough relief?</h2>
                    <div class="space-y-3">
                        <button onclick="recordAnswer('triedFirstLine', true); nextSlide('q3', 'q4')" class="quiz-opt">Yes</button>
                        <button onclick="recordAnswer('triedFirstLine', false); nextSlide('q3', 'q4')" class="quiz-opt">No, this would be my first treatment</button>
                    </div>
                </div>

                <!-- Q4: Cardio / BP -->
                <div id="slide-q4" class="quiz-slide hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 4 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Do you have uncontrolled high blood pressure, recent heart attack, severe heart disease, or active intracranial pressure issues?</h2>
                    <div class="space-y-3">
                        <button onclick="recordAnswer('cardio', true); nextSlide('q4', 'q5')" class="quiz-opt">Yes, one or more</button>
                        <button onclick="recordAnswer('cardio', false); nextSlide('q4', 'q5')" class="quiz-opt">No</button>
                    </div>
                </div>

                <!-- Q5: Psychosis / Substance -->
                <div id="slide-q5" class="quiz-slide hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 5 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Do you have active psychosis, untreated bipolar mania, or active ketamine/substance use disorder?</h2>
                    <div class="space-y-3">
                        <button onclick="recordAnswer('exclusion', true); nextSlide('q5', 'q6')" class="quiz-opt">Yes</button>
                        <button onclick="recordAnswer('exclusion', false); nextSlide('q5', 'q6')" class="quiz-opt">No</button>
                    </div>
                </div>

                <!-- Q6: Logistics -->
                <div id="slide-q6" class="quiz-slide hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Last Question</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Can you arrange transportation home after each session and budget for cash-pay treatment (typically not covered by insurance)?</h2>
                    <div class="space-y-3">
                        <button onclick="recordAnswer('logistics', true); showResults()" class="quiz-opt">Yes, both</button>
                        <button onclick="recordAnswer('logistics', 'partial'); showResults()" class="quiz-opt">Transport yes, cost is a concern</button>
                        <button onclick="recordAnswer('logistics', false); showResults()" class="quiz-opt">No / unsure</button>
                    </div>
                </div>

                <!-- Result: Strong -->
                <div id="result-high" class="hidden p-8 md:p-12 text-center">
                    <div class="w-20 h-20 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-6">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <h2 class="text-3xl font-semibold tracking-tight text-[var(--ink)] mb-4">You Look Like a Good Candidate</h2>
                    <p class="text-[var(--muted)] mb-8">Your profile is consistent with the kind of patient most ketamine clinics treat. A consultation will involve a full medical screen, blood pressure check, and a treatment plan. Most clinics offer a free 15-minute phone consult.</p>
                    <a href="/alternatives/ketamine-infusion-therapy/" class="block w-full px-8 py-4 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-all shadow-lg mb-4">Read the Full Ketamine Guide</a>
                    <a href="/specialists/" class="text-[var(--accent)] font-semibold hover:underline">Find a Ketamine Provider</a>
                </div>

                <!-- Result: Maybe -->
                <div id="result-maybe" class="hidden p-8 md:p-12 text-center">
                    <div class="w-20 h-20 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center mx-auto mb-6">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    </div>
                    <h2 class="text-3xl font-semibold tracking-tight text-[var(--ink)] mb-4">You May Be a Candidate — Worth a Consult</h2>
                    <p class="text-[var(--muted)] mb-8">Most providers prefer patients try at least one first-line treatment first, and cost can be a barrier since insurance rarely covers IV ketamine. A psychiatrist can help you decide whether ketamine, Spravato (insurance-covered), or TMS makes more sense for your situation.</p>
                    <a href="/alternatives/ketamine-infusion-therapy/" class="block w-full px-8 py-4 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-all shadow-lg mb-4">Learn More About Ketamine</a>
                    <a href="/quiz/spravato-eligibility/" class="text-[var(--accent)] font-semibold hover:underline">Check Spravato Eligibility (Insurance-Covered)</a>
                </div>

                <!-- Result: Not Suitable -->
                <div id="result-low" class="hidden p-8 md:p-12 text-center">
                    <div class="w-20 h-20 bg-rose-100 text-rose-600 rounded-full flex items-center justify-center mx-auto mb-6">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </div>
                    <h2 class="text-3xl font-semibold tracking-tight text-[var(--ink)] mb-4">Ketamine May Not Be Safe Right Now</h2>
                    <p class="text-[var(--muted)] mb-8">Active psychosis, uncontrolled mania, severe cardiovascular disease, or active substance use disorder are typical exclusions for ketamine therapy. That doesn't mean you have no options — TMS has a much friendlier safety profile, and a psychiatrist can map a safer path.</p>
                    <a href="/alternatives/" class="block w-full px-8 py-4 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-all shadow-lg mb-4">Compare Other Treatments</a>
                    <a href="/quiz/am-i-a-candidate/" class="text-[var(--accent)] font-semibold hover:underline">Try the TMS Eligibility Quiz</a>
                </div>
            </div>

            <p class="text-xs text-[var(--muted)] text-center mt-8 max-w-lg mx-auto">
                This quiz is for educational purposes and does not replace medical advice. Only a licensed clinician can determine if ketamine therapy is appropriate for you.
            </p>
        </div>
    </main>
</Layout>

<style>
    .quiz-opt {
        width: 100%;
        padding: 1rem;
        text-align: left;
        border: 2px solid var(--line);
        border-radius: 0.75rem;
        font-weight: 500;
        color: var(--ink2);
        transition: all 0.15s ease;
    }
    .quiz-opt:hover {
        border-color: var(--ink);
        background: rgba(10,22,40,0.04);
    }
</style>

<script is:inline>
    const answers = { age: false, condition: 'other', triedFirstLine: false, cardio: false, exclusion: false, logistics: false };
    const totalQ = 6;
    let idx = 0;

    function nextSlide(curr, next) {
        document.getElementById(`slide-${curr}`).classList.add("hidden");
        document.getElementById(`slide-${next}`).classList.remove("hidden");
        idx++;
        const pct = Math.min((idx / totalQ) * 100, 100);
        document.getElementById("progress-bar").style.width = `${pct}%`;
        document.getElementById("progress-text").innerText = `${Math.round(pct)}%`;
    }

    function recordAnswer(key, val) { answers[key] = val; }

    function showResults() {
        document.getElementById("slide-q6").classList.add("hidden");
        document.getElementById("progress-bar").style.width = "100%";
        document.getElementById("progress-text").innerText = "100%";

        const hardExclusion = !answers.age || answers.cardio || answers.exclusion;
        const goodFit = answers.age && !answers.cardio && !answers.exclusion && answers.triedFirstLine && answers.logistics === true;

        if (hardExclusion) {
            document.getElementById("result-low").classList.remove("hidden");
        } else if (goodFit) {
            document.getElementById("result-high").classList.remove("hidden");
        } else {
            document.getElementById("result-maybe").classList.remove("hidden");
        }
    }
</script>
