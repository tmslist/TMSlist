---
export const prerender = true;

import ContentPage from '../../layouts/ContentPage.astro';
import { getCollection, render } from 'astro:content';
import { UTILITY_SLUGS } from '../../utils/seo_slugs';

export async function getStaticPaths() {
  let entries: any[] = [];
  try {
    entries = await getCollection('quiz');
  } catch {}

  const contentPaths = entries.map((entry) => ({
    params: { slug: entry.id },
    props: { title: entry.data.title, description: entry.data.description, hasContent: true, entry },
  }));

  const contentSlugsSet = new Set(contentPaths.map(p => p.params.slug));
  const fallbackPaths = UTILITY_SLUGS
    .filter(({ slug }) => !contentSlugsSet.has(slug))
    .map(({ slug, title }) => ({
      params: { slug },
      props: { title, description: '', hasContent: false, entry: null },
    }));

  return [...contentPaths, ...fallbackPaths];
}

const { title, description, hasContent, entry } = Astro.props;
const slug = Astro.params.slug!;

// depression-severity-test has a dedicated interactive page, skip static content rendering
const SKIP_STATIC_RENDER = ['depression-severity-test'];
const isInteractive = SKIP_STATIC_RENDER.includes(slug);

let Content: any = null;
if (hasContent && entry && !isInteractive) {
  const rendered = await render(entry);
  Content = rendered.Content;
}
---

<ContentPage
  title={title}
  subtitle={description || "Interactive tools and assessments."}
  description={description}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Tools", url: "/quiz/" },
    { name: title, url: `/quiz/${slug}/` },
  ]}
>
  {Content ? <Content /> : null}
</ContentPage>
