---
import Layout from "../../layouts/Layout.astro";

const title = "Am I Eligible for Spravato? | 2-Minute Esketamine Quiz";
const description =
    "Free confidential eligibility quiz for Spravato (esketamine) nasal spray — see if you meet the FDA and insurance criteria for treatment-resistant depression.";

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const quizSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Quiz",
    "name": "Spravato (Esketamine) Eligibility Assessment",
    "description": description,
    "url": `${siteUrl}/quiz/spravato-eligibility/`,
    "educationalLevel": "patient",
    "about": {
        "@type": "MedicalTherapy",
        "name": "Spravato (Esketamine Nasal Spray)",
        "medicalSpecialty": "Psychiatry",
    },
    "provider": {
        "@type": "Organization",
        "name": "TMS List",
        "url": siteUrl,
    },
});
---

<Layout title={title} description={description} noindex={true} schema={quizSchema}>
    <main class="min-h-screen bg-gradient-to-b from-[var(--paper2)] to-white py-12">
        <div class="container mx-auto px-4 max-w-2xl">
            <!-- About Spravato -->
            <section class="mb-10 bg-[var(--paper)] border border-[var(--line)] rounded-2xl p-8">
                <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">About the Treatment</span>
                <h1 class="text-3xl font-semibold tracking-tight text-[var(--ink)] mb-4">What is Spravato (Esketamine)?</h1>
                <p class="text-[var(--muted)] leading-relaxed mb-4">
                    Spravato is an <strong>FDA-approved nasal spray</strong> derived from ketamine. It was approved in 2019 for adults with
                    <strong> treatment-resistant depression (TRD)</strong> and in 2020 for major depressive disorder with active suicidal ideation.
                    Unlike traditional antidepressants that target serotonin, esketamine acts rapidly on the brain's NMDA glutamate system —
                    many patients feel relief within hours to days rather than weeks.
                </p>
                <p class="text-[var(--muted)] leading-relaxed mb-4">
                    Spravato must be administered in a <strong>REMS-certified clinic</strong> under medical supervision. After self-administering
                    the nasal spray, you remain at the clinic for at least <strong>2 hours of monitoring</strong> for blood pressure changes,
                    sedation, and dissociation. It is taken alongside an oral antidepressant.
                </p>
                <ul class="text-sm text-[var(--muted)] space-y-1 list-disc list-inside">
                    <li><strong>Schedule:</strong> Twice weekly for 4 weeks (induction), then weekly or every other week (maintenance).</li>
                    <li><strong>Insurance:</strong> Covered by most major insurers and Medicare for TRD when criteria are met.</li>
                    <li><strong>Cost:</strong> ~$590–$885 per dose retail; copays often $10–$75 with insurance.</li>
                </ul>
            </section>

            <!-- Progress Bar -->
            <div class="mb-8">
                <div class="flex justify-between text-xs font-semibold text-[var(--muted)] mb-2 uppercase tracking-wide">
                    <span>Eligibility Quiz</span>
                    <span id="progress-text">0%</span>
                </div>
                <div class="h-2 bg-[var(--paper2)] rounded-full overflow-hidden">
                    <div id="progress-bar" class="h-full bg-[var(--ink)] transition-all duration-500 ease-out" style="width: 0%"></div>
                </div>
            </div>

            <!-- Quiz Card -->
            <div class="bg-[var(--paper)] rounded-2xl shadow-[0_4px_20px_rgb(0,0,0,0.03)] border border-[var(--line)] overflow-hidden">
                <!-- Intro -->
                <div id="slide-intro" class="quiz-slide p-8 md:p-12 text-center">
                    <h2 class="text-2xl font-semibold tracking-tight text-[var(--ink)] mb-4">Are You a Candidate for Spravato?</h2>
                    <p class="text-[var(--muted)] mb-8">Answer 6 quick questions to see if you meet the FDA criteria for esketamine therapy.</p>
                    <button onclick="nextSlide('intro', 'q1')" class="w-full sm:w-auto px-8 py-4 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-all shadow-lg">Start Quiz</button>
                    <p class="text-xs text-[var(--muted)] mt-6">Confidential. No personal info required to take the quiz.</p>
                </div>

                <!-- Q1: Age -->
                <div id="slide-q1" class="quiz-slide hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 1 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Are you 18 or older?</h2>
                    <div class="space-y-3">
                        <button onclick="recordAnswer('age', true); nextSlide('q1', 'q2')" class="quiz-opt">Yes</button>
                        <button onclick="recordAnswer('age', false); nextSlide('q1', 'q2')" class="quiz-opt">No (under 18)</button>
                    </div>
                </div>

                <!-- Q2: Diagnosis -->
                <div id="slide-q2" class="quiz-slide hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 2 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Do you have a diagnosis of Major Depressive Disorder?</h2>
                    <div class="space-y-3">
                        <button onclick="recordAnswer('diagnosis', 'mdd'); nextSlide('q2', 'q3')" class="quiz-opt">Yes, MDD</button>
                        <button onclick="recordAnswer('diagnosis', 'mdd_si'); nextSlide('q2', 'q3')" class="quiz-opt">Yes, with suicidal thoughts</button>
                        <button onclick="recordAnswer('diagnosis', 'no'); nextSlide('q2', 'q3')" class="quiz-opt">No / not sure</button>
                    </div>
                </div>

                <!-- Q3: Failed Meds -->
                <div id="slide-q3" class="quiz-slide hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 3 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">In your current depressive episode, how many oral antidepressants have failed to help?</h2>
                    <div class="space-y-3">
                        <button onclick="recordAnswer('failedMeds', 0); nextSlide('q3', 'q4')" class="quiz-opt">None</button>
                        <button onclick="recordAnswer('failedMeds', 1); nextSlide('q3', 'q4')" class="quiz-opt">1 medication</button>
                        <button onclick="recordAnswer('failedMeds', 2); nextSlide('q3', 'q4')" class="quiz-opt">2 medications</button>
                        <button onclick="recordAnswer('failedMeds', 3); nextSlide('q3', 'q4')" class="quiz-opt">3 or more</button>
                    </div>
                </div>

                <!-- Q4: Cardiovascular -->
                <div id="slide-q4" class="quiz-slide hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 4 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Do you have any history of aneurysm, brain hemorrhage, recent heart attack, or uncontrolled high blood pressure?</h2>
                    <div class="space-y-3">
                        <button onclick="recordAnswer('cardio', true); nextSlide('q4', 'q5')" class="quiz-opt">Yes, one or more</button>
                        <button onclick="recordAnswer('cardio', false); nextSlide('q4', 'q5')" class="quiz-opt">No</button>
                    </div>
                </div>

                <!-- Q5: Pregnancy -->
                <div id="slide-q5" class="quiz-slide hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Question 5 of 6</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Are you currently pregnant or breastfeeding?</h2>
                    <div class="space-y-3">
                        <button onclick="recordAnswer('pregnant', true); nextSlide('q5', 'q6')" class="quiz-opt">Yes</button>
                        <button onclick="recordAnswer('pregnant', false); nextSlide('q5', 'q6')" class="quiz-opt">No / not applicable</button>
                    </div>
                </div>

                <!-- Q6: Logistics -->
                <div id="slide-q6" class="quiz-slide hidden p-8 md:p-12">
                    <span class="text-[var(--accent)] font-semibold text-sm tracking-wider uppercase mb-2 block">Last Question</span>
                    <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">Can you attend a clinic for 2-hour monitoring sessions twice weekly, with someone to drive you home?</h2>
                    <div class="space-y-3">
                        <button onclick="recordAnswer('logistics', true); showResults()" class="quiz-opt">Yes, I can arrange that</button>
                        <button onclick="recordAnswer('logistics', false); showResults()" class="quiz-opt">No / unsure</button>
                    </div>
                </div>

                <!-- Result: Strong -->
                <div id="result-high" class="hidden p-8 md:p-12 text-center">
                    <div class="w-20 h-20 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto mb-6">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <h2 class="text-3xl font-semibold tracking-tight text-[var(--ink)] mb-4">You Likely Qualify for Spravato</h2>
                    <p class="text-[var(--muted)] mb-8">Your answers align with the FDA label and typical insurance requirements for esketamine. A REMS-certified provider can confirm eligibility, run a medical screen, and start prior authorization.</p>
                    <a href="/alternatives/spravato-esketamine/" class="block w-full px-8 py-4 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-all shadow-lg mb-4">Read the Full Spravato Guide</a>
                    <a href="/specialists/" class="text-[var(--accent)] font-semibold hover:underline">Find a Spravato-Certified Provider</a>
                </div>

                <!-- Result: Maybe -->
                <div id="result-maybe" class="hidden p-8 md:p-12 text-center">
                    <div class="w-20 h-20 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center mx-auto mb-6">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    </div>
                    <h2 class="text-3xl font-semibold tracking-tight text-[var(--ink)] mb-4">You May Qualify — With Caveats</h2>
                    <p class="text-[var(--muted)] mb-8">Spravato's FDA label requires <strong>2+ failed antidepressants</strong> in your current episode. If you haven't tried that many, your insurer may deny coverage even though Spravato could help. A psychiatrist can review your history and discuss next steps — including TMS, which has different criteria.</p>
                    <a href="/alternatives/spravato-esketamine/" class="block w-full px-8 py-4 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-all shadow-lg mb-4">Learn More About Spravato</a>
                    <a href="/quiz/am-i-a-candidate/" class="text-[var(--accent)] font-semibold hover:underline">Try the TMS Eligibility Quiz</a>
                </div>

                <!-- Result: Not Suitable -->
                <div id="result-low" class="hidden p-8 md:p-12 text-center">
                    <div class="w-20 h-20 bg-rose-100 text-rose-600 rounded-full flex items-center justify-center mx-auto mb-6">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </div>
                    <h2 class="text-3xl font-semibold tracking-tight text-[var(--ink)] mb-4">Spravato May Not Be Right Right Now</h2>
                    <p class="text-[var(--muted)] mb-8">Based on your answers, Spravato may carry meaningful safety or eligibility concerns for you (e.g., cardiovascular history, pregnancy, or no MDD diagnosis). That doesn't mean you're out of options — TMS, ECT, or oral medication adjustments may be safer paths.</p>
                    <a href="/alternatives/" class="block w-full px-8 py-4 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-all shadow-lg mb-4">Compare Other Treatments</a>
                    <a href="/specialists/" class="text-[var(--accent)] font-semibold hover:underline">Talk to a Specialist</a>
                </div>
            </div>

            <p class="text-xs text-[var(--muted)] text-center mt-8 max-w-lg mx-auto">
                This quiz is for educational purposes and does not replace medical advice. Only a licensed psychiatrist can determine if Spravato is appropriate for you.
            </p>
        </div>
    </main>
</Layout>

<style>
    .quiz-opt {
        width: 100%;
        padding: 1rem;
        text-align: left;
        border: 2px solid var(--line);
        border-radius: 0.75rem;
        font-weight: 500;
        color: var(--ink2);
        transition: all 0.15s ease;
    }
    .quiz-opt:hover {
        border-color: var(--ink);
        background: rgba(10,22,40,0.04);
    }
</style>

<script is:inline>
    const answers = { age: false, diagnosis: 'no', failedMeds: 0, cardio: false, pregnant: false, logistics: false };
    const totalQ = 6;
    let idx = 0;

    function nextSlide(curr, next) {
        document.getElementById(`slide-${curr}`).classList.add("hidden");
        document.getElementById(`slide-${next}`).classList.remove("hidden");
        idx++;
        const pct = Math.min((idx / totalQ) * 100, 100);
        document.getElementById("progress-bar").style.width = `${pct}%`;
        document.getElementById("progress-text").innerText = `${Math.round(pct)}%`;
    }

    function recordAnswer(key, val) { answers[key] = val; }

    function showResults() {
        document.getElementById("slide-q6").classList.add("hidden");
        document.getElementById("progress-bar").style.width = "100%";
        document.getElementById("progress-text").innerText = "100%";

        const safetyFlag = answers.cardio || answers.pregnant || !answers.age || answers.diagnosis === 'no';
        const meetsFDA = answers.age && answers.diagnosis !== 'no' && answers.failedMeds >= 2 && !answers.cardio && !answers.pregnant && answers.logistics;

        if (safetyFlag) {
            document.getElementById("result-low").classList.remove("hidden");
        } else if (meetsFDA) {
            document.getElementById("result-high").classList.remove("hidden");
        } else {
            document.getElementById("result-maybe").classList.remove("hidden");
        }
    }
</script>
