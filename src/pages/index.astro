---
import Layout from "../layouts/Layout.astro";

import {
    getOperationalClinics,
    getClinicPhoto,
    getClinicRating,
    getClinicReviewCount,
    getTotalDoctorCount,
    getStateSlug,
    buildInternationalDirectory,
    COUNTRY_NAMES,
    COUNTRY_URL_PREFIXES,
    STATE_NAMES,
} from "../utils/dataHelpers";
import type { Clinic } from "../types/clinic";
import {
    TREATMENT_SLUGS,
    TECHNOLOGY_SLUGS,
    INSURANCE_SLUGS,
} from "../utils/seo_slugs";

// Use ONLY verified real clinics from the main DB
const clinics = await getOperationalClinics();

// Group clinics by state for the location grid
const stateGroups = clinics.reduce(
    (acc, clinic) => {
        const stateCode = clinic.state;
        if (!acc[stateCode]) acc[stateCode] = [];
        acc[stateCode].push(clinic);
        return acc;
    },
    {} as Record<string, Clinic[]>,
);

const locationMap = Object.entries(stateGroups)
    .map(([stateCode, stateClinics]) => {
        const cities = [...new Set(stateClinics.map((c) => c.city))].sort();
        return {
            code: stateCode,
            name: STATE_NAMES[stateCode] || stateCode,
            slug: getStateSlug(stateCode),
            cities: cities,
            clinicCount: stateClinics.length,
        };
    })
    .sort((a, b) => b.clinicCount - a.clinicCount);

const uniqueStates = Object.keys(stateGroups);

// LOGIC: Get top rated VERIFIED clinics, ensuring geographic diversity (1 per city)
// 1. Filter for Verified + High Rating
const qualifiedClinics = clinics.filter(
    (c) =>
        (c.verified || getClinicRating(c) >= 4.9) &&
        getClinicReviewCount(c) > 10 &&
        c.city,
);

// 2. Group by City
const cityGroups = qualifiedClinics.reduce(
    (acc, clinic) => {
        if (!acc[clinic.city]) acc[clinic.city] = [];
        acc[clinic.city].push(clinic);
        return acc;
    },
    {} as Record<string, Clinic[]>,
);

// 3. Pick best clinic from each city
const bestInCity = Object.values(cityGroups).map((cityClinics) => {
    return cityClinics.sort(
        (a, b) => getClinicRating(b) - getClinicRating(a),
    )[0];
});

// 4. Sort by overall rating/verified status and take top 6
const topClinics = bestInCity
    .sort((a, b) => {
        // Prioritize verified
        if (a.verified && !b.verified) return -1;
        if (!a.verified && b.verified) return 1;
        // Then rating
        return getClinicRating(b) - getClinicRating(a);
    });

// 5. Get Featured Specialists grouped by country (4 per country)
// Helper: check if a doctor has a real photo (not a placeholder)
function hasRealDoctorPhoto(img: string | undefined): boolean {
    if (!img) return false;
    return !img.includes('ui-avatars.com') && !img.includes('dicebear') && !img.includes('data:image');
}

const allDoctorsWithCountry = clinics
    .flatMap((clinic) =>
        (clinic.doctors_data || []).map((doc: any) => ({
            ...doc,
            image: doc.image_url || doc.image,
            hasRealPhoto: hasRealDoctorPhoto(doc.image_url || doc.image),
            clinicName: clinic.name,
            clinicCity: clinic.city,
            clinicState: clinic.state,
            clinicCountry: (clinic as any).country || 'US',
        }))
    )
    .filter((d: any) => d.image && d.slug);

// Group by country, prioritize doctors with real photos, then pick 4 from each
const countryCodes = ['US', 'GB', 'CA', 'AU', 'DE', 'IN'];
const featuredDoctorsByCountry: Record<string, any[]> = {};
for (const code of countryCodes) {
    const countryDocs = allDoctorsWithCountry
        .filter((d: any) => d.clinicCountry === code)
        .sort((a: any, b: any) => {
            // Prioritize real photos over placeholders
            if (a.hasRealPhoto && !b.hasRealPhoto) return -1;
            if (!a.hasRealPhoto && b.hasRealPhoto) return 1;
            // Then deterministic shuffle
            const ha = (a.name || '').charCodeAt(0);
            const hb = (b.name || '').charCodeAt(0);
            return ((ha * 9301 + 49297) % 233280) - ((hb * 9301 + 49297) % 233280);
        })
        .slice(0, 4);
    if (countryDocs.length > 0) {
        featuredDoctorsByCountry[code] = countryDocs;
    }
}
// Default fallback for template rendering
const featuredDoctors = featuredDoctorsByCountry['US'] || allDoctorsWithCountry
    .sort((a: any, b: any) => {
        if (a.hasRealPhoto && !b.hasRealPhoto) return -1;
        if (!a.hasRealPhoto && b.hasRealPhoto) return 1;
        return 0;
    })
    .slice(0, 4);

const totalDoctors = await getTotalDoctorCount();
const featuredTech = TECHNOLOGY_SLUGS.slice(0, 4);

// Prepare search data for autocomplete
const searchData = [
    // States
    ...Object.entries(stateGroups).map(([code, _]) => ({
        label: STATE_NAMES[code] || code,
        subLabel: "State",
        value: `/us/${getStateSlug(code)}/`,
        type: "state",
    })),
    // Cities
    ...Object.values(cityGroups)
        .flat()
        .reduce((acc, clinic) => {
            const cityState = `${clinic.city}, ${clinic.state}`;
            if (!acc.find((i) => i.label === cityState)) {
                acc.push({
                    label: cityState,
                    subLabel: "City",
                    value: `/us/${getStateSlug(clinic.state)}/${clinic.city.toLowerCase().replace(/[^a-z0-9]+/g, "-")}/`,
                    type: "city",
                });
            }
            return acc;
        }, [] as any[]),
    // Zip Codes
    ...clinics.reduce((acc, clinic) => {
        if (!acc.find((i) => i.label === clinic.zip)) {
            acc.push({
                label: clinic.zip,
                subLabel: `${clinic.city}, ${clinic.state}`,
                value: `/us/?q=${clinic.zip}`,
                type: "zip",
            });
        }
        return acc;
    }, [] as any[]),
    // International regions and cities
    ...(await buildInternationalDirectory()).flatMap((country) => [
        // Country entry
        {
            label: country.name,
            subLabel: `${country.clinicCount} clinics`,
            value: `/${country.urlPrefix}/`,
            type: "country",
        },
        // Region entries
        ...country.regions.map((region) => ({
            label: `${region.name}, ${country.name}`,
            subLabel: "Region",
            value: `/${country.urlPrefix}/${region.slug}/`,
            type: "region",
        })),
        // City entries
        ...country.regions.flatMap((region) =>
            region.cities.map((city) => ({
                label: `${city.name}, ${country.name}`,
                subLabel: "City",
                value: `/${country.urlPrefix}/${region.slug}/${city.slug}/`,
                type: "city",
            }))
        ),
    ]),
];

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalOrganization",
    "name": "TMS List",
    "url": "https://tmslist.com",
    "logo": "https://tmslist.com/logotmslist.png",
    "description": "The leading directory of FDA-cleared TMS therapy providers. Find verified clinics and specialists near you.",
    "potentialAction": {
        "@type": "SearchAction",
        "target": "https://tmslist.com/us/?q={search_term_string}",
        "query-input": "required name=search_term_string"
    }
});
---

<Layout
    title="TMS List — Find TMS Therapy Clinics Near You | Verified Reviews & Insurance Info"
    description="Find FDA-cleared TMS therapy clinics near you. Compare verified reviews, insurance coverage, pricing, and specialists. The leading directory of TMS providers in the US and worldwide."
    schema={schema}
>
    <!-- HERO SECTION - Revamped -->
    <section class="relative container mx-auto rounded-3xl px-8 bg-white overflow-hidden  pb-8">
        <!-- Background Effects -->
        <div class="absolute inset-0 z-0">
            <!-- New Theme Purple Blob -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] bg-[#7C3AED]/20 rounded-full blur-[120px] animate-pulse"></div>
            <!-- Cyan Contrast -->
            <div class="absolute bottom-0 right-0 w-[800px] h-[600px] bg-cyan-600/10 rounded-full blur-[100px]"></div>
            <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-[0.03]"></div>
        </div>

        <div class="container mx-auto px-4 relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">
                <!-- Left: Content -->
                <div class="text-center lg:text-left max-w-2xl mx-auto lg:mx-0">
                    <!-- Trust Badge -->
                    <div
                        class="inline-flex items-center gap-2.5 bg-white/5 backdrop-blur-md border border-slate-200 rounded-full py-2 px-5 mb-8 shadow-[0_4px_20px_rgb(0,0,0,0.03)] shadow-[#7C3AED]/10 hover:bg-white/10 transition-colors"
                    >
                        <span class="relative flex h-2.5 w-2.5">
                            <span
                                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
                            ></span>
                            <span
                                class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"
                            ></span>
                        </span>
                        <span class="text-sm font-semibold text-slate-900 tracking-wide"
                            >{clinics.length}+ Verified Clinics Added</span
                        >
                    </div>

                    <h1
                        class="text-5xl lg:text-7xl font-semibold tracking-tight text-slate-900 mb-6 tracking-tight leading-[1.1]"
                    >
                        Find <span
                            class="text-violet-500"
                            >TMS Therapy</span
                        >
                        <br />
                        <span class="relative whitespace-nowrap">
                            Near You
                            <!-- Underline using new purple -->
                            <svg class="absolute -bottom-2 left-0 w-full h-3 text-[#7C3AED]/50 -z-10" viewBox="0 0 100 10" preserveAspectRatio="none">
                                <path d="M0 5 Q 50 10 100 5" stroke="currentColor" stroke-width="8" fill="none" />
                            </svg>
                        </span>
                    </h1>

                    <p
                        class="text-lg md:text-xl text-slate-600 mb-2 leading-relaxed font-light"
                    >
                        <span id="hero-subtitle">{clinics.length}+ <strong class="text-slate-900 font-semibold">verified</strong> TMS clinics across 20+ countries. Real patient reviews. Verified providers. <br class="hidden md:block" />Find the right clinic — without the runaround.</span>
                    </p>

                    <!-- Search Box -->
                    <form id="hero-search-form" class="relative max-w-lg mx-auto lg:mx-0 mb-4 z-20" action="/us/">
                        <div class="relative group">
                            <!-- Gradient Border using new purple -->
                            <div class="absolute -inset-1 bg-gradient-to-r from-cyan-500 to-[#7C3AED] rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
                            <div class="relative flex flex-col sm:flex-row bg-white/90 backdrop-blur-xl border border-slate-200 rounded-xl p-2 shadow-[0_8px_30px_rgb(0,0,0,0.04)] ring-1 ring-slate-200/50">
                                <div class="flex-1 relative flex items-center px-4 h-14">
                                    <svg
                                        class="w-6 h-6 text-slate-500 mr-3"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                        ></path>
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                        ></path>
                                    </svg>
                                    <input
                                        type="text"
                                        name="q"
                                        id="hero-search-input"
                                        autocomplete="off"
                                        placeholder="City, state, or zip code..."
                                        class="w-full bg-transparent text-slate-900 placeholder-slate-400 font-medium text-lg outline-none border-none focus:ring-0 p-0"
                                    />
                                    <!-- Autocomplete Dropdown -->
                                    <div
                                        id="search-suggestions"
                                        class="absolute top-16 left-0 right-0 bg-white rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100 overflow-hidden hidden z-50 max-h-[300px] overflow-y-auto"
                                    >
                                    </div>
                                </div>
                                <button
                                    type="submit"
                                    class="dark-section h-14 px-6 bg-gradient-to-r from-[#7C3AED] to-[#8B5CF6] hover:from-[#6D28D9] hover:to-[#7C3AED] font-semibold rounded-lg transition-all shadow-lg hover:shadow-[#7C3AED]/25 flex items-center justify-center gap-2 whitespace-nowrap mt-2 sm:mt-0"
                                >
                                    <span>Search</span>
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </form>

                    <!-- Quick Links -->
                    <div
                        class="flex flex-wrap items-center justify-center lg:justify-start gap-3"
                    >
                        <span class="text-sm font-semibold text-slate-500">Popular:</span>
                        <a
                            href="/us/california/"
                            class="px-4 py-1.5 bg-white/5 hover:bg-white/10 border border-slate-100 hover:border-slate-200 rounded-full text-xs font-medium text-slate-600 hover:text-slate-900 transition-all"
                            >California</a
                        >
                        <a
                            href="/us/texas/"
                            class="px-4 py-1.5 bg-white/5 hover:bg-white/10 border border-slate-100 hover:border-slate-200 rounded-full text-xs font-medium text-slate-600 hover:text-slate-900 transition-all"
                            >Texas</a
                        >
                        <a
                            href="/us/new-york/"
                            class="px-4 py-1.5 bg-white/5 hover:bg-white/10 border border-slate-100 hover:border-slate-200 rounded-full text-xs font-medium text-slate-600 hover:text-slate-900 transition-all"
                            >New York</a
                        >
                        <a
                            href="/treatments/depression/"
                            class="px-4 py-1.5 bg-[#7C3AED]/20 hover:bg-[#7C3AED]/30 border border-[#7C3AED]/30 hover:border-[#7C3AED]/50 rounded-full text-xs font-semibold text-white hover:text-white transition-all flex items-center gap-1.5"
                        >
                            <span class="w-1.5 h-1.5 rounded-full bg-[#8B5CF6]"></span>
                            Depression
                        </a>
                    </div>
                </div>

                <!-- Right: Visual -->
                <div class="relative flex items-center justify-center lg:justify-end perspective-1000">
                    <div class="relative w-full max-w-[600px] aspect-square">
                        <!-- Glow Effect with New Purple -->
                        <div class="absolute inset-0 bg-gradient-to-tr from-violet-500/20 to-purple-500/20 blur-[80px] rounded-full animate-pulse-slow"></div>

                        <!-- Main Image -->
                        <img
                            src="/images/tms_hero.svg"
                            alt="Accurate TMS treatment illustration showing figure-8 coil targeting the left prefrontal cortex"
                            width="600"
                            height="600"
                            class="relative w-full h-full object-contain drop-shadow-[0_10px_30px_rgba(124,58,237,0.15)] z-10 animate-float"
                        />

                        <!-- Floating pulse dots around brain -->
                        <div class="absolute top-[15%] left-[10%] w-3 h-3 rounded-full bg-violet-400 neuron-dot opacity-0" style="animation-delay: 0s;"></div>
                        <div class="absolute top-[25%] right-[15%] w-2.5 h-2.5 rounded-full bg-cyan-400 neuron-dot opacity-0" style="animation-delay: 0.5s;"></div>
                        <div class="absolute bottom-[30%] left-[18%] w-2 h-2 rounded-full bg-blue-400 neuron-dot opacity-0" style="animation-delay: 1s;"></div>
                        <div class="absolute top-[45%] right-[10%] w-3.5 h-3.5 rounded-full bg-purple-400 neuron-dot opacity-0" style="animation-delay: 0.3s;"></div>
                        <div class="absolute bottom-[20%] right-[25%] w-2 h-2 rounded-full bg-emerald-400 neuron-dot opacity-0" style="animation-delay: 0.7s;"></div>
                        <div class="absolute top-[60%] left-[8%] w-2.5 h-2.5 rounded-full bg-amber-400 neuron-dot opacity-0" style="animation-delay: 1.2s;"></div>

                        <!-- Floating live stat cards -->
                        <div class="absolute top-[10%] right-[5%] z-20 hidden lg:block animate-float" style="animation-delay: -1s; animation-duration: 4s;">
                            <div class="bg-white/90 backdrop-blur-md rounded-xl px-4 py-3 shadow-lg border border-white/60">
                                <div class="flex items-center gap-2">
                                    <span class="relative flex h-2 w-2"><span class="animate-ping absolute h-full w-full rounded-full bg-emerald-400 opacity-75"></span><span class="relative rounded-full h-2 w-2 bg-emerald-500"></span></span>
                                    <span class="text-xs font-semibold text-slate-700">FDA Cleared</span>
                                </div>
                            </div>
                        </div>
                        <div class="absolute bottom-[15%] left-[2%] z-20 hidden lg:block animate-float" style="animation-delay: -2s; animation-duration: 5s;">
                            <div class="bg-white/90 backdrop-blur-md rounded-xl px-4 py-3 shadow-lg border border-white/60">
                                <div class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-amber-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                                    <span class="text-xs font-semibold text-slate-700">4.8 avg rating</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- STATS RIBBON - Animated Counters -->
    <div class="relative -mt-16 z-30 container mx-auto px-4">
        <div id="stats-ribbon" class="bg-white rounded-3xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] shadow-violet-900/10 p-8 lg:p-6 border border-slate-100/60">
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-0 divide-y lg:divide-y-0 lg:divide-x divide-slate-100">
                <div class="text-center px-4 pb-4 lg:pb-0 group">
                    <div class="flex items-center justify-center gap-2.5 mb-2">
                        <div class="w-10 h-10 rounded-xl bg-violet-50 flex items-center justify-center text-violet-600 group-hover:scale-110 transition-transform">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                        </div>
                        <span class="stat-counter text-3xl lg:text-4xl font-bold tracking-tight text-slate-900" data-target={clinics.length} data-suffix="+">0</span>
                    </div>
                    <div class="text-xs font-semibold text-slate-400 uppercase tracking-widest">Verified Clinics</div>
                    <div class="mt-2 h-1 rounded-full bg-slate-100 overflow-hidden">
                        <div class="stat-bar h-full bg-gradient-to-r from-violet-500 to-purple-500 rounded-full" style="width: 0%;" data-width="92%"></div>
                    </div>
                </div>

                <div class="text-center px-4 py-4 lg:py-0 group">
                    <div class="flex items-center justify-center gap-2.5 mb-2">
                        <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600 group-hover:scale-110 transition-transform">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <span class="stat-counter text-3xl lg:text-4xl font-bold tracking-tight text-slate-900" data-target={uniqueStates.length}>0</span>
                    </div>
                    <div class="text-xs font-semibold text-slate-400 uppercase tracking-widest">States Covered</div>
                    <div class="mt-2 h-1 rounded-full bg-slate-100 overflow-hidden">
                        <div class="stat-bar h-full bg-gradient-to-r from-blue-500 to-cyan-500 rounded-full" style="width: 0%;" data-width="78%"></div>
                    </div>
                </div>

                <div class="text-center px-4 py-4 lg:py-0 group">
                    <div class="flex items-center justify-center gap-2.5 mb-2">
                        <div class="w-10 h-10 rounded-xl bg-emerald-50 flex items-center justify-center text-emerald-600 group-hover:scale-110 transition-transform">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <span class="stat-counter text-3xl lg:text-4xl font-bold tracking-tight text-slate-900" data-target="62" data-suffix="%">0</span>
                    </div>
                    <div class="text-xs font-semibold text-slate-400 uppercase tracking-widest">Remission Rate</div>
                    <div class="mt-2 h-1 rounded-full bg-slate-100 overflow-hidden">
                        <div class="stat-bar h-full bg-gradient-to-r from-emerald-500 to-teal-500 rounded-full" style="width: 0%;" data-width="62%"></div>
                    </div>
                </div>

                <div class="text-center px-4 pt-4 lg:pt-0 group">
                    <div class="flex items-center justify-center gap-2.5 mb-2">
                        <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center text-amber-600 group-hover:scale-110 transition-transform">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                        </div>
                        <span class="stat-counter text-3xl lg:text-4xl font-bold tracking-tight text-slate-900" data-target={totalDoctors} data-suffix="+">0</span>
                    </div>
                    <div class="text-xs font-semibold text-slate-400 uppercase tracking-widest">TMS Specialists</div>
                    <div class="mt-2 h-1 rounded-full bg-slate-100 overflow-hidden">
                        <div class="stat-bar h-full bg-gradient-to-r from-amber-500 to-orange-500 rounded-full" style="width: 0%;" data-width="85%"></div>
                    </div>
                </div>
            </div>
        </div>
