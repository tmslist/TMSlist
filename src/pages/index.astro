<script>
    // Interactive cost calculator
    (function () {
        const calc = document.getElementById('cost-calc');
        if (!calc) return;
        const pills = calc.querySelectorAll('.cost-pill');
        const perSessionEl = document.getElementById('cost-per-session');
        const fullCourseEl = document.getElementById('cost-full-course');
        const barEl = document.getElementById('cost-bar');
        const coverageEl = document.getElementById('cost-coverage');
        const SESSIONS = 36;
        const fmt = (n) => '$' + n.toLocaleString('en-US');

        function activate(pill) {
            pills.forEach((p) => {
                p.classList.remove('bg-[var(--ink)]', 'text-white');
                p.classList.add('bg-[var(--paper2)]', 'border', 'border-[var(--line)]', 'text-[var(--muted)]');
                p.setAttribute('aria-pressed', 'false');
            });
            pill.classList.add('bg-[var(--ink)]', 'text-white');
            pill.classList.remove('bg-[var(--paper2)]', 'border', 'border-[var(--line)]', 'text-[var(--muted)]');
            pill.setAttribute('aria-pressed', 'true');

            const session = parseInt(pill.dataset.session, 10);
            const coverage = parseInt(pill.dataset.coverage, 10);
            const total = session * SESSIONS;

            [perSessionEl, fullCourseEl].forEach((el) => { el.style.opacity = '0.4'; });
            requestAnimationFrame(() => {
                perSessionEl.textContent = fmt(session);
                fullCourseEl.textContent = fmt(total);
                barEl.style.width = coverage + '%';
                coverageEl.textContent = coverage > 0
                    ? coverage + '% covered by insurance'
                    : 'Self-pay (no insurance applied)';
                setTimeout(() => {
                    perSessionEl.style.opacity = '1';
                    fullCourseEl.style.opacity = '1';
                }, 50);
            });
        }

        pills.forEach((pill) => {
            pill.addEventListener('click', () => activate(pill));
        });
    })();
</script>

