---
import Layout from "../layouts/Layout.astro";

import {
    getOperationalClinics,
    getClinicPhoto,
    getClinicRating,
    getClinicReviewCount,
    getTotalDoctorCount,
    getStateSlug,
    buildInternationalDirectory,
    COUNTRY_NAMES,
    COUNTRY_URL_PREFIXES,
    STATE_NAMES,
    getClinicsByCountry,
    getRegionsByCountry,
} from "../utils/dataHelpers";
import type { Clinic } from "../types/clinic";
import {
    TREATMENT_SLUGS,
    TECHNOLOGY_SLUGS,
    INSURANCE_SLUGS,
} from "../utils/seo_slugs";
import FeaturedClinics from "../components/FeaturedClinics.astro";
import QuizTeaser from "../components/QuizTeaser.astro";
import SpecialistsSection from "../components/SpecialistsSection.astro";
import TrustSignals from "../components/TrustSignals.astro";
import TechnologySection from "../components/TechnologySection.astro";
import TMSSimulationTeaser from "../components/TMSSimulationTeaser.astro";
import LeadMagnetCta from "../components/LeadMagnetCta.astro";

// Read country from x-country cookie (set by middleware via Vercel geo headers)
// Falls back to 'US' if no cookie present
// Also checks ?country= param for local dev override (bypasses cookie timing lag)
const geoCookie = Astro.cookies.get('x-country')?.value as string | undefined;
const urlCountry = Astro.url.searchParams.get('country')?.toUpperCase();
const SUPPORTED = ['US','GB','CA','AU','DE','IN','FR','JP','KR','BR','ES','IT','NL','SG','AE','NZ','ZA','SE','IE','IL','MX'];
const VISITOR_COUNTRY = urlCountry && SUPPORTED.includes(urlCountry)
    ? urlCountry
    : geoCookie && SUPPORTED.includes(geoCookie)
        ? geoCookie
        : 'US';

// Fetch all clinics (global) then filter by visitor's country for geo-personalized sections
const allClinics = await getOperationalClinics();

// Country-specific clinic data for personalized sections
const countryClinics = VISITOR_COUNTRY === 'US' ? allClinics : allClinics.filter(c => (c as any).country === VISITOR_COUNTRY);

// Build location map based on visitor's country
let locationMap: { code: string; name: string; slug: string; cities: string[]; clinicCount: number }[] = [];

if (VISITOR_COUNTRY === 'US') {
    const stateGroups = allClinics.reduce(
        (acc, clinic) => {
            const stateCode = clinic.state;
            if (!acc[stateCode]) acc[stateCode] = [];
            acc[stateCode].push(clinic);
            return acc;
        },
        {} as Record<string, Clinic[]>,
    );
    locationMap = Object.entries(stateGroups)
        .map(([stateCode, stateClinics]) => {
            const cities = [...new Set(stateClinics.map((c) => c.city))].sort();
            return {
                code: stateCode,
                name: STATE_NAMES[stateCode] || stateCode,
                slug: getStateSlug(stateCode),
                cities: cities,
                clinicCount: stateClinics.length,
            };
        })
        .sort((a, b) => b.clinicCount - a.clinicCount);
} else {
    // International: group by region/state for the detected country
    const intlDir = await buildInternationalDirectory();
    const countryData = intlDir.find(c => c.code === VISITOR_COUNTRY);
    if (countryData) {
        locationMap = countryData.regions.map(r => ({
            code: r.slug,
            name: r.name,
            slug: r.slug,
            cities: r.cities.map(c => c.name),
            clinicCount: r.clinicCount,
        }));
    }
}

// For US homepage (default) use all clinics; for others use country-specific
const clinics = VISITOR_COUNTRY === 'US' ? allClinics : countryClinics;

// Build US state groups only when in US mode (used for search autocomplete and stats)
const usStateGroups = allClinics.reduce(
    (acc, clinic) => {
        const stateCode = clinic.state;
        if (!acc[stateCode]) acc[stateCode] = [];
        acc[stateCode].push(clinic);
        return acc;
    },
    {} as Record<string, Clinic[]>,
);
const uniqueStates = Object.keys(usStateGroups);

// LOGIC: Get top rated VERIFIED clinics, ensuring geographic diversity (1 per city)
// 1. Filter for Verified + High Rating
const qualifiedClinics = clinics.filter(
    (c) =>
        (c.verified || getClinicRating(c) >= 4.9) &&
        getClinicReviewCount(c) > 10 &&
        c.city,
);

// 2. Group by City
const cityGroups = qualifiedClinics.reduce(
    (acc, clinic) => {
        if (!acc[clinic.city]) acc[clinic.city] = [];
        acc[clinic.city].push(clinic);
        return acc;
    },
    {} as Record<string, Clinic[]>,
);

// 3. Pick up to 50 best clinics per city (large cap to capture all cities)
const bestInCity = Object.values(cityGroups).map((cityClinics) => {
    return cityClinics.sort(
        (a, b) => getClinicRating(b) - getClinicRating(a),
    )[0];
});

// 4. Sort: featured > verified > rating, no city cap (take top 12)
const topClinics = bestInCity
    .sort((a, b) => {
        // 1. Featured clinics first
        if (a.is_featured && !b.is_featured) return -1;
        if (!a.is_featured && b.is_featured) return 1;
        // 2. Verified clinics second
        if (a.verified && !b.verified) return -1;
        if (!a.verified && b.verified) return 1;
        // 3. Then by rating
        return getClinicRating(b) - getClinicRating(a);
    });

// GUARANTEE: force all is_featured=true clinics into topClinics, capped at 12
// Remove duplicates from topClinics, then prepend featured ones
const featuredIds = new Set(
    clinics.filter((c) => c.is_featured && c.city).map((c) => c.id)
);
const deduped = topClinics.filter((c) => !featuredIds.has(c.id));
const featuredOnes = clinics
    .filter((c) => c.is_featured && c.city)
    .sort((a, b) => {
        if (a.verified && !b.verified) return -1;
        if (!a.verified && b.verified) return 1;
        return getClinicRating(b) - getClinicRating(a);
    });
const finalTopClinics = [...featuredOnes, ...deduped].slice(0, 12);

// 5. Get Featured Specialists grouped by country (4 per country)
// Helper: check if a doctor has a real photo (not a placeholder)
function hasRealDoctorPhoto(img: string | undefined): boolean {
    if (!img) return false;
    return !img.includes('ui-avatars.com') && !img.includes('dicebear') && !img.includes('data:image');
}

const allDoctorsWithCountry = clinics
    .flatMap((clinic) =>
        (clinic.doctors_data || []).map((doc: any) => ({
            ...doc,
            image: doc.image_url || doc.image,
            hasRealPhoto: hasRealDoctorPhoto(doc.image_url || doc.image),
            clinicName: clinic.name,
            clinicCity: clinic.city,
            clinicState: clinic.state,
            clinicCountry: (clinic as any).country || 'US',
        }))
    )
    .filter((d: any) => d.image && d.slug);

// Group by country, prioritize featured/verified doctors, then real photos, then deterministic order
const countryCodes = ['US', 'GB', 'CA', 'AU', 'DE', 'IN'];
const featuredDoctorsByCountry: Record<string, any[]> = {};
for (const code of countryCodes) {
    const countryDocs = allDoctorsWithCountry
        .filter((d: any) => d.clinicCountry === code)
        .sort((a: any, b: any) => {
            // 1. Featured clinics first
            if (a.isFeatured && !b.isFeatured) return -1;
            if (!a.isFeatured && b.isFeatured) return 1;
            // 2. Verified clinics second
            if (a.verified && !b.verified) return -1;
            if (!a.verified && b.verified) return 1;
            // 3. Real photos over placeholders
            if (a.hasRealPhoto && !b.hasRealPhoto) return -1;
            if (!a.hasRealPhoto && b.hasRealPhoto) return 1;
            // 4. Deterministic shuffle by name
            const ha = (a.name || '').charCodeAt(0);
            const hb = (b.name || '').charCodeAt(0);
            return ((ha * 9301 + 49297) % 233280) - ((hb * 9301 + 49297) % 233280);
        })
        .slice(0, 4);
    if (countryDocs.length > 0) {
        featuredDoctorsByCountry[code] = countryDocs;
    }
}
// Default fallback for template rendering
const featuredDoctors = featuredDoctorsByCountry['US'] || allDoctorsWithCountry
    .sort((a: any, b: any) => {
        if (a.isFeatured && !b.isFeatured) return -1;
        if (!a.isFeatured && b.isFeatured) return 1;
        if (a.verified && !b.verified) return -1;
        if (!a.verified && b.verified) return 1;
        if (a.hasRealPhoto && !b.hasRealPhoto) return -1;
        if (!a.hasRealPhoto && b.hasRealPhoto) return 1;
        return 0;
    })
    .slice(0, 4);

// Visitor's country display label
const COUNTRY_DISPLAY_LABELS: Record<string, string> = {
    US: 'United States', GB: 'United Kingdom', CA: 'Canada', AU: 'Australia',
    DE: 'Germany', IN: 'India', FR: 'France', JP: 'Japan', KR: 'South Korea',
    BR: 'Brazil', ES: 'Spain', IT: 'Italy', NL: 'Netherlands', SG: 'Singapore',
    AE: 'United Arab Emirates', NZ: 'New Zealand', ZA: 'South Africa',
    SE: 'Sweden', IE: 'Ireland', IL: 'Israel', MX: 'Mexico',
};
const locationSectionLabel = VISITOR_COUNTRY === 'US'
    ? 'National Network'
    : `${COUNTRY_DISPLAY_LABELS[VISITOR_COUNTRY] || 'International'} Network`;
const locationSectionTitle = VISITOR_COUNTRY === 'US'
    ? 'Find Care <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-[var(--muted)]">Near You</span>'
    : `TMS Clinics in <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-[var(--muted)]">${COUNTRY_DISPLAY_LABELS[VISITOR_COUNTRY] || 'Your Country'}</span>`;
const viewAllUrl = VISITOR_COUNTRY === 'US' ? '/us/' : `/${COUNTRY_URL_PREFIXES[VISITOR_COUNTRY] || 'us'}/`;

const totalDoctors = await getTotalDoctorCount();
const featuredTech = TECHNOLOGY_SLUGS.slice(0, 4);

// Prepare search data for autocomplete
// US state/city/zip entries are only useful for US visitors — surface them only then.
const searchData = [
    // US states (only for US visitors)
    ...(VISITOR_COUNTRY === 'US' ? Object.entries(usStateGroups).map(([code, _]) => ({
        label: STATE_NAMES[code] || code,
        subLabel: "State",
        value: `/us/${getStateSlug(code)}/`,
        type: "state",
    })) : []),
    // US cities (only for US visitors)
    ...(VISITOR_COUNTRY === 'US' ? Object.values(cityGroups)
        .flat()
        .reduce((acc, clinic) => {
            const cityState = `${clinic.city}, ${clinic.state}`;
            if (!acc.find((i) => i.label === cityState)) {
                acc.push({
                    label: cityState,
                    subLabel: "City",
                    value: `/us/${getStateSlug(clinic.state)}/${clinic.city.toLowerCase().replace(/[^a-z0-9]+/g, "-")}/`,
                    type: "city",
                });
            }
            return acc;
        }, [] as any[]) : []),
    // US ZIP codes (only for US visitors — ZIPs are US-specific)
    ...(VISITOR_COUNTRY === 'US' ? clinics.reduce((acc, clinic) => {
        if (!acc.find((i) => i.label === clinic.zip)) {
            acc.push({
                label: clinic.zip,
                subLabel: `${clinic.city}, ${clinic.state}`,
                value: `/us/?q=${clinic.zip}`,
                type: "zip",
            });
        }
        return acc;
    }, [] as any[]) : []),
    // International regions and cities
    ...(await buildInternationalDirectory()).flatMap((country) => [
        // Country entry
        {
            label: country.name,
            subLabel: `${country.clinicCount} clinics`,
            value: `/${country.urlPrefix}/`,
            type: "country",
        },
        // Region entries
        ...country.regions.map((region) => ({
            label: `${region.name}, ${country.name}`,
            subLabel: "Region",
            value: `/${country.urlPrefix}/${region.slug}/`,
            type: "region",
        })),
        // City entries
        ...country.regions.flatMap((region) =>
            region.cities.map((city) => ({
                label: `${city.name}, ${country.name}`,
                subLabel: "City",
                value: `/${country.urlPrefix}/${region.slug}/${city.slug}/`,
                type: "city",
            }))
        ),
    ]),
];

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalOrganization",
    "name": "TMS List",
    "url": "https://tmslist.com",
    "logo": "https://tmslist.com/logotmslist.png",
    "description": "The leading directory of FDA-cleared TMS therapy providers. Find verified clinics and specialists near you.",
    "potentialAction": {
        "@type": "SearchAction",
        "target": `https://tmslist.com${viewAllUrl}?q={search_term_string}`,
        "query-input": "required name=search_term_string"
    }
});
---

<Layout
    title="TMS List — Find TMS Therapy Clinics Near You | Verified Reviews & Insurance Info"
    description="Find FDA-cleared TMS therapy clinics near you. Compare verified reviews, insurance coverage, pricing, and specialists. The leading directory of TMS providers in the US and worldwide."
    schema={schema}
    hreflang={[
        { lang: 'x-default', url: 'https://tmslist.com/' },
        { lang: 'en-US', url: 'https://tmslist.com/us/' },
        { lang: 'en-GB', url: 'https://tmslist.com/uk/' },
        { lang: 'en-CA', url: 'https://tmslist.com/ca/' },
        { lang: 'en-AU', url: 'https://tmslist.com/au/' },
        { lang: 'de-DE', url: 'https://tmslist.com/de/' },
        { lang: 'en-IN', url: 'https://tmslist.com/in/' },
        { lang: 'fr-FR', url: 'https://tmslist.com/fr/' },
        { lang: 'es-ES', url: 'https://tmslist.com/es/' },
        { lang: 'it-IT', url: 'https://tmslist.com/it/' },
        { lang: 'nl-NL', url: 'https://tmslist.com/nl/' },
        { lang: 'pt-BR', url: 'https://tmslist.com/br/' },
        { lang: 'es-MX', url: 'https://tmslist.com/mx/' },
        { lang: 'ja-JP', url: 'https://tmslist.com/jp/' },
        { lang: 'ko-KR', url: 'https://tmslist.com/kr/' },
        { lang: 'sv-SE', url: 'https://tmslist.com/se/' },
        { lang: 'en-NZ', url: 'https://tmslist.com/nz/' },
        { lang: 'en-ZA', url: 'https://tmslist.com/za/' },
        { lang: 'en-IE', url: 'https://tmslist.com/ie/' },
        { lang: 'en-SG', url: 'https://tmslist.com/sg/' },
        { lang: 'en-AE', url: 'https://tmslist.com/ae/' },
        { lang: 'en-IL', url: 'https://tmslist.com/il/' },
    ]}
>
    <!-- HERO — Editorial-warm -->
    <section class="relative overflow-hidden" style="background:var(--paper); padding-top:8rem; padding-bottom:5rem; border-bottom:1px solid var(--line);">
        <!-- Dot grid -->
        <div class="absolute inset-0 pointer-events-none" style="background-image:radial-gradient(var(--line) 1px,transparent 1px); background-size:40px 40px; opacity:.5"></div>
        <!-- Warm accent blob -->
        <div class="absolute top-0 left-[5%] w-[600px] h-[600px] rounded-full blur-[150px] pointer-events-none" style="background:rgba(201,101,74,0.1)"></div>
        <div class="absolute bottom-0 right-[5%] w-[500px] h-[500px] rounded-full blur-[120px] pointer-events-none" style="background:rgba(10,22,40,0.06)"></div>

        <div class="max-w-[1400px] mx-auto px-6 lg:px-8 relative">
            <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-12 lg:gap-16 items-center">
                <!-- Left: Content -->
                <div>
                    <!-- Eyebrow -->
                    <div class="inline-flex items-center gap-2 mb-8" style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:.075em; color:var(--muted);">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                        </span>
                        <span>{clinics.length}+ Verified TMS Clinics</span>
                    </div>

                    <!-- Headline -->
                    <h1 class="serif" style="font-size:clamp(2.75rem,6vw,5.5rem); line-height:.93; color:var(--ink); margin:0 0 1.5rem;">
                        Find TMS therapy<br/>
                        <span class="italic" style="color:var(--warm);">near you.</span>
                    </h1>

                    <!-- Subhead -->
                    <p style="font-size:17px; line-height:1.65; max-width:36rem; color:var(--muted); margin:0 0 2.5rem;">
                        {clinics.length}+ verified TMS clinics across <span>{VISITOR_COUNTRY === 'US' ? '50 US states' : COUNTRY_NAMES[VISITOR_COUNTRY] || 'your region'}</span>. Real patient reviews. Verified providers. Find the right clinic — without the runaround.
                    </p>

                    <!-- Search Box -->
                    <form id="hero-search-form" class="hero-search relative max-w-xl mb-6 z-20" action={viewAllUrl}>
                        <div class="relative flex flex-col sm:flex-row" style="background:var(--paper); border:1px solid var(--line); border-radius:1rem; padding:.375rem; box-shadow:0 4px 20px rgba(10,22,40,0.06); overflow:hidden;">
                            <div class="flex-1 relative flex items-center px-4" style="height:3.25rem;">
                                <svg class="search-icon w-5 h-5 mr-3" style="color:var(--muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                                <input type="text" name="q" id="hero-search-input" autocomplete="off" role="combobox" aria-expanded="false" aria-controls="search-suggestions" aria-autocomplete="list" aria-haspopup="listbox" placeholder="City, state, or zip code..." style="width:100%; background:transparent; color:var(--ink); font-weight:500; font-size:16px; outline:none; border:none; padding:0;" />
                            </div>
                            <button type="submit" class="search-btn group/btn flex items-center justify-center gap-2 whitespace-nowrap mt-2 sm:mt-0" style="height:3.25rem; padding:0 1.75rem; background:var(--ink); color:white; font-weight:600; font-size:14px; border-radius:.625rem; transition:opacity .15s;">
                                <span>Search</span>
                                <svg class="w-4 h-4 transition-transform duration-300 group-hover/btn:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                </svg>
                            </button>
                        </div>
                        <div id="search-suggestions" class="absolute top-full left-0 right-0 mt-2 hidden z-[60] max-h-[300px] overflow-y-auto" style="background:var(--paper); border:1px solid var(--line); border-radius:.75rem; box-shadow:0 8px 30px rgba(10,22,40,0.12);"></div>
                    </form>

                    <!-- Quick Links — render only the visitor's country block -->
                    {VISITOR_COUNTRY === 'US' ? (
                        <div class="hero-links flex flex-wrap items-center gap-2" data-quick-links-country="US">
                            <span style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:.075em; color:var(--muted); margin-right:.25rem;">Popular:</span>
                            {['California', 'Texas', 'New York'].map((state) => (
                                <a href={`/us/${state.toLowerCase().replace(' ', '-')}/`} class="quick-link" style="padding:.5rem 1rem; background:var(--paper2); border:1px solid var(--line); border-radius:9999px; font-size:13px; font-weight:500; color:var(--ink2); text-decoration:none; transition:background .15s, border-color .15s;">
                                    {state}
                                </a>
                            ))}
                            <a href="/treatments/depression/" class="quick-link" style="padding:.5rem 1rem; background:var(--ink); border:1px solid var(--ink); border-radius:9999px; font-size:13px; font-weight:600; color:white; text-decoration:none; display:inline-flex; align-items:center; gap:.5rem;">
                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                                Depression
                            </a>
                        </div>
                    ) : (
                        <div class="hero-links flex flex-wrap items-center gap-2" data-quick-links-country={VISITOR_COUNTRY}>
                            <span style="font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:.075em; color:var(--muted); margin-right:.25rem;">Popular:</span>
                            <a href={`/${COUNTRY_URL_PREFIXES[VISITOR_COUNTRY] || VISITOR_COUNTRY.toLowerCase()}/`} data-country-landing class="quick-link" style="padding:.5rem 1rem; background:var(--paper2); border:1px solid var(--line); border-radius:9999px; font-size:13px; font-weight:500; color:var(--ink2); text-decoration:none;">View All {COUNTRY_NAMES[VISITOR_COUNTRY]} Clinics</a>
                            <a href={`/${COUNTRY_URL_PREFIXES[VISITOR_COUNTRY] || VISITOR_COUNTRY.toLowerCase()}/`} class="quick-link" style="padding:.5rem 1rem; background:var(--ink); border:1px solid var(--ink); border-radius:9999px; font-size:13px; font-weight:600; color:white; text-decoration:none; display:inline-flex; align-items:center; gap:.5rem;">
                                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                                Find a Clinic
                            </a>
                        </div>
                    )}
                </div>

                <!-- Right: Brain Image with editorial stat cards -->
                <div class="relative flex items-center justify-center lg:justify-end">
                    <div class="relative w-full max-w-[520px] aspect-square">
                        <!-- Soft warm glow -->
                        <div class="absolute inset-0 rounded-full blur-[80px] pointer-events-none" style="background:radial-gradient(circle, rgba(201,101,74,0.12) 0%, rgba(10,22,40,0.06) 60%, transparent 100%);"></div>

                        <!-- Brain Image -->
                        <div class="relative z-10">
                            <img src="/images/tms_hero.svg" alt="TMS treatment illustration showing figure-8 coil targeting the left prefrontal cortex" width="520" height="520" class="w-full h-full object-contain" style="filter:drop-shadow(0 20px 50px rgba(10,22,40,0.18));" />
                        </div>

                        <!-- Editorial stat cards -->
                        <div class="absolute top-[5%] right-[2%] z-40 hidden lg:block">
                            <div style="background:var(--paper); border:1px solid var(--line); border-radius:1rem; padding:.875rem 1.125rem; box-shadow:0 12px 30px rgba(10,22,40,0.08);">
                                <div style="font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:.075em; color:var(--muted); margin-bottom:.25rem;">Status</div>
                                <div class="flex items-center gap-1.5" style="font-size:14px; font-weight:600; color:var(--ink);">
                                    FDA Cleared
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                                </div>
                            </div>
                        </div>

                        <div class="absolute bottom-[10%] left-[-2%] z-40 hidden lg:block">
                            <div style="background:var(--paper); border:1px solid var(--line); border-radius:1rem; padding:.875rem 1.125rem; box-shadow:0 12px 30px rgba(10,22,40,0.08);">
                                <div style="font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:.075em; color:var(--muted); margin-bottom:.25rem;">Avg Rating</div>
                                <div class="serif" style="font-size:1.5rem; line-height:1; color:var(--warm);">4.8<span style="font-size:14px; color:var(--muted);">/5</span></div>
                            </div>
                        </div>

                        <div class="absolute top-[55%] left-[3%] z-40 hidden lg:block">
                            <div style="background:var(--paper); border:1px solid var(--line); border-radius:1rem; padding:.875rem 1.125rem; box-shadow:0 12px 30px rgba(10,22,40,0.08);">
                                <div style="font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:.075em; color:var(--muted); margin-bottom:.25rem;">Sessions</div>
