---
export const prerender = true;

import ContentPage from '../../layouts/ContentPage.astro';
import { getCollection, render } from 'astro:content';
import { ALTERNATIVE_SLUGS } from '../../utils/seo_slugs';

export async function getStaticPaths() {
  let entries: any[] = [];
  try {
    entries = await getCollection('alternatives');
  } catch {}

  const contentPaths = entries.map((entry) => ({
    params: { slug: entry.id },
    props: { title: entry.data.title, description: entry.data.description, hasContent: true, entry },
  }));

  const contentSlugsSet = new Set(contentPaths.map(p => p.params.slug));
  const fallbackPaths = ALTERNATIVE_SLUGS
    .filter(({ slug }) => !contentSlugsSet.has(slug))
    .map(({ slug, title }) => ({
      params: { slug },
      props: { title, description: title ? `${title} as a treatment alternative to TMS. Compare mechanisms, efficacy, and who each approach suits best.` : '', hasContent: false, entry: null },
    }));

  return [...contentPaths, ...fallbackPaths];
}

const { title, description, hasContent, entry } = Astro.props;
const slug = Astro.params.slug!;
let Content: any = null;
if (hasContent && entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": title,
  "description": description || `Alternative treatment guide: ${title}.`,
  "url": `${siteUrl}/alternatives/${slug}/`,
  "about": { "@type": "MedicalTherapy", "name": title },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `${siteUrl}/alternatives/${slug}/` },
  "reviewedBy": { "@type": "Person", "name": "Dr. Karan Narwal", "jobTitle": "Mental Health Specialist & Consultant" },
  "publisher": { "@type": "Organization", "name": "TMS List", "url": siteUrl },
});
---

<ContentPage
  title={title}
  subtitle={description || "Alternative treatment options for mental health conditions."}
  description={description}
  schema={schema}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Alternatives", url: "/alternatives/" },
    { name: title, url: `/alternatives/${slug}/` },
  ]}
>
  {Content ? <Content /> : null}
</ContentPage>
