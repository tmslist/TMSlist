---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import { ALTERNATIVE_SLUGS } from '../../utils/seo_slugs';

const title = "TMS Alternatives | Spravato, Ketamine, ECT & Other Treatments";
const description = "Compare TMS therapy alternatives — Spravato (esketamine), ketamine infusions, ECT, VNS, neurofeedback, psilocybin therapy, and more.";

const ALT_META: Record<string, { description: string; fdaStatus: string; speed: string; color: string }> = {
  'spravato-esketamine': { description: 'FDA-cleared nasal spray for treatment-resistant depression. Administered in-office with 2-hour monitoring.', fdaStatus: 'FDA Cleared', speed: 'Hours-Days', color: 'emerald' },
  'ketamine-infusion-therapy': { description: 'IV ketamine for rapid depression relief. Off-label but growing rapidly. Works within hours.', fdaStatus: 'Off-label', speed: 'Hours', color: 'blue' },
  'electroconvulsive-therapy-ect': { description: 'Gold standard for severe, life-threatening depression. Requires anesthesia. Highest remission rates of any treatment.', fdaStatus: 'FDA Cleared', speed: 'Days-Weeks', color: 'violet' },
  'vagus-nerve-stimulation': { description: 'Surgically implanted device stimulating the vagus nerve. For severe treatment-resistant depression.', fdaStatus: 'FDA Cleared', speed: 'Months', color: 'cyan' },
  'neurofeedback': { description: 'Brain training using real-time EEG. Teaches self-regulation of brain activity. Non-invasive.', fdaStatus: 'Not FDA Cleared', speed: 'Weeks-Months', color: 'amber' },
  'psilocybin-assisted-therapy': { description: 'Psychedelic-assisted therapy showing breakthrough results in clinical trials. Not yet FDA-approved.', fdaStatus: 'Investigational', speed: '1-2 Sessions', color: 'rose' },
  'deep-brain-stimulation': { description: 'Surgically implanted electrodes in specific brain regions. Last-resort for the most severe cases.', fdaStatus: 'Investigational', speed: 'Weeks-Months', color: 'slate' },
  'stellate-ganglion-block': { description: 'Anesthetic injection near the neck targeting PTSD symptoms. Rapid relief, growing evidence base.', fdaStatus: 'Off-label', speed: 'Hours-Days', color: 'amber' },
};

const enrichedAlts = ALTERNATIVE_SLUGS.map(item => ({
  ...item,
  ...(ALT_META[item.slug] || { description: 'Alternative treatment option.', fdaStatus: 'Varies', speed: 'Varies', color: 'violet' }),
}));

const statusColors: Record<string, string> = {
  'FDA Cleared': 'bg-emerald-100 text-emerald-700',
  'Off-label': 'bg-blue-100 text-blue-700',
  'Investigational': 'bg-amber-100 text-amber-700',
  'Not FDA Cleared': 'bg-slate-100 text-slate-600',
};

const schema = JSON.stringify({
  "@context": "https://schema.org", "@type": "CollectionPage",
  "name": "TMS Alternatives", "description": description, "url": "https://tmslist.com/alternatives/",
  "mainEntity": { "@type": "ItemList", "numberOfItems": ALTERNATIVE_SLUGS.length,
    "itemListElement": ALTERNATIVE_SLUGS.map((item, i) => ({ "@type": "ListItem", "position": i + 1, "name": item.title, "url": `https://tmslist.com/alternatives/${item.slug}/` }))
  }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[{ name: "Home", url: "/" }, { name: "Alternatives", url: "/alternatives/" }]}>
  <section class="relative bg-slate-950 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-violet-600 to-slate-900 opacity-90"></div>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.4) 1px, transparent 0); background-size: 28px 28px;"></div>
    <div class="absolute top-[-20%] right-[-10%] w-[600px] h-[600px] bg-white/[0.04] rounded-full blur-[100px]"></div>
    <div class="relative z-10 container mx-auto px-4 pt-20 pb-16 lg:pt-28 lg:pb-20">
      <nav class="flex items-center gap-2 text-sm text-white/40 mb-8" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white/70 transition-colors">Home</a><span class="text-white/20">/</span><span class="text-white/60">Alternatives</span>
      </nav>
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-violet-500/20 text-violet-300 border border-violet-400/20 rounded-full text-xs font-bold uppercase tracking-wider mb-6">{ALTERNATIVE_SLUGS.length} Treatments</span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white tracking-tight leading-[1.1] mb-5 font-display">Alternatives to TMS Therapy</h1>
        <p class="text-lg text-white/60 leading-relaxed max-w-2xl">TMS isn't the only option. Compare other evidence-based treatments for depression, PTSD, OCD, and other conditions.</p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-12 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <main class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {enrichedAlts.map((alt) => (
        <a href={`/alternatives/${alt.slug}/`} class="group bg-white border border-slate-200 rounded-2xl p-6 hover:shadow-lg hover:border-violet-200 transition-all">
          <div class="flex items-center gap-3 mb-3">
            <span class={`px-2.5 py-1 ${statusColors[alt.fdaStatus] || 'bg-slate-100 text-slate-600'} text-xs font-semibold rounded-lg`}>{alt.fdaStatus}</span>
            <span class="text-xs text-slate-400">Onset: {alt.speed}</span>
          </div>
          <h2 class="text-lg font-display font-bold text-slate-900 group-hover:text-violet-600 transition-colors mb-2">{alt.title}</h2>
          <p class="text-sm text-slate-600 leading-relaxed mb-3">{alt.description}</p>
          <span class="text-xs text-violet-600 font-semibold group-hover:underline">Compare with TMS →</span>
        </a>
      ))}
    </div>

    <div class="mt-16 bg-violet-50 border border-violet-200 rounded-2xl p-8 text-center">
      <h2 class="text-2xl font-display font-bold text-slate-900 mb-3">Not Sure Which Treatment Is Right?</h2>
      <p class="text-slate-600 max-w-lg mx-auto mb-6">Take our quick candidacy quiz or find a specialist who can evaluate your options.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/quiz/am-i-a-candidate/" class="px-6 py-3 bg-violet-600 text-white font-semibold rounded-xl hover:bg-violet-700 transition-colors">Take the Quiz</a>
        <a href="/us/" class="px-6 py-3 border border-violet-200 text-violet-700 font-semibold rounded-xl hover:bg-violet-100 transition-colors">Find a Specialist</a>
      </div>
    </div>
  </main>
</Layout>
