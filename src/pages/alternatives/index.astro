---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import EditorialSection from '../../components/editorial/EditorialSection.astro';
import EditorialCard from '../../components/editorial/EditorialCard.astro';
import EditorialCTA from '../../components/editorial/EditorialCTA.astro';
import { ALTERNATIVE_SLUGS } from '../../utils/seo_slugs';

const title = "TMS Alternatives | Spravato, Ketamine, ECT & Other Treatments";
const description = "Compare TMS vs ECT, ketamine, Spravato, and other alternatives for treatment-resistant depression. Side-by-side analysis of efficacy, side effects, and cost.";

const ALT_META: Record<string, { description: string; fdaStatus: string; speed: string; conditionLink?: string }> = {
  'spravato-esketamine': { description: 'FDA-cleared nasal spray for treatment-resistant depression. Administered in-office with 2-hour monitoring.', fdaStatus: 'FDA Cleared', speed: 'Hours-Days', conditionLink: '/treatments/depression/' },
  'ketamine-infusion-therapy': { description: 'IV ketamine for rapid depression relief. Off-label but growing rapidly. Works within hours.', fdaStatus: 'Off-label', speed: 'Hours', conditionLink: '/treatments/depression/' },
  'electroconvulsive-therapy-ect': { description: 'Gold standard for severe, life-threatening depression. Requires anesthesia. Highest remission rates of any treatment.', fdaStatus: 'FDA Cleared', speed: 'Days-Weeks', conditionLink: '/treatments/depression/' },
  'vagus-nerve-stimulation': { description: 'Surgically implanted device stimulating the vagus nerve. For severe treatment-resistant depression.', fdaStatus: 'FDA Cleared', speed: 'Months', conditionLink: '/treatments/depression/' },
  'neurofeedback': { description: 'Brain training using real-time EEG. Teaches self-regulation of brain activity. Non-invasive.', fdaStatus: 'Not FDA Cleared', speed: 'Weeks-Months', conditionLink: '/treatments/depression/' },
  'psilocybin-assisted-therapy': { description: 'Psychedelic-assisted therapy showing breakthrough results in clinical trials. Not yet FDA-approved.', fdaStatus: 'Investigational', speed: '1-2 Sessions', conditionLink: '/treatments/depression/' },
  'deep-brain-stimulation': { description: 'Surgically implanted electrodes in specific brain regions. Last-resort for the most severe cases.', fdaStatus: 'Investigational', speed: 'Weeks-Months', conditionLink: '/treatments/depression/' },
  'stellate-ganglion-block': { description: 'Anesthetic injection near the neck targeting PTSD symptoms. Rapid relief, growing evidence base.', fdaStatus: 'Off-label', speed: 'Hours-Days', conditionLink: '/treatments/ptsd/' },
};

const enrichedAlts = ALTERNATIVE_SLUGS.map(item => ({
  ...item,
  ...(ALT_META[item.slug] || { description: 'Alternative treatment option.', fdaStatus: 'Varies', speed: 'Varies' }),
}));

const fdaCleared = enrichedAlts.filter(a => a.fdaStatus === 'FDA Cleared');
const otherAlts = enrichedAlts.filter(a => a.fdaStatus !== 'FDA Cleared');

const tagToneFor = (status: string) =>
  status === 'FDA Cleared' ? 'success' :
  status === 'Investigational' ? 'warm' :
  status === 'Off-label' ? 'accent' : 'muted';

const schema = JSON.stringify({
  "@context": "https://schema.org", "@type": "CollectionPage",
  "name": "TMS Alternatives", "description": description, "url": "https://tmslist.com/alternatives/",
  "mainEntity": { "@type": "ItemList", "numberOfItems": ALTERNATIVE_SLUGS.length,
    "itemListElement": ALTERNATIVE_SLUGS.map((item, i) => ({ "@type": "ListItem", "position": i + 1, "name": item.title, "url": `https://tmslist.com/alternatives/${item.slug}/` }))
  }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[{ name: "Home", url: "/" }, { name: "Alternatives", url: "/alternatives/" }]}>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow={`${ALTERNATIVE_SLUGS.length} Alternatives Compared`}
    eyebrowDot="#C9654A"
    title="When TMS isn't"
    titleAccent="the answer."
    description="TMS isn't the only option. Compare other evidence-based treatments for depression, PTSD, OCD, and treatment-resistant conditions."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Alternatives" }]}
    ctas={[
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: "Compare Treatments", href: "/compare/", variant: "outline" },
    ]}
    stats={[
      { value: ALTERNATIVE_SLUGS.length, label: "Treatments", color: "ink" },
      { value: fdaCleared.length, label: "FDA-Cleared", color: "accent" },
      { value: otherAlts.length, label: "Emerging", color: "warm" },
    ]}
  />
  <div style="text-align:center; padding:1.5rem 0 2rem;">
    <p style="font-size:14px; color:var(--muted);">See <a href="/treatments/" style="color:var(--accent); text-decoration:underline; font-weight:500;">how TMS therapy works</a> for your condition.</p>
  </div>

  <EditorialSection
    title="FDA-Cleared Alternatives"
    intro="Treatments with regulatory approval and broad insurance coverage."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>'
    tone="success"
  >
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {fdaCleared.map((a) => (
        <EditorialCard
          href={`/alternatives/${a.slug}/`}
          tag={a.fdaStatus}
          tagTone="success"
          title={a.title}
          description={a.description + (a.conditionLink ? ` <a href="${a.conditionLink}" style="color:var(--accent); text-decoration:underline;">Learn how TMS compares</a>.` : '')}
          size="lg"
          stats={[
            { label: "Onset", value: a.speed, color: "accent" },
          ]}
        />
      ))}
    </div>
  </EditorialSection>

  <EditorialSection
    title="Emerging & Off-Label"
    intro="Active research and off-label applications with growing evidence."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>'
    tone="warm"
    noBorder
  >
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {otherAlts.map((a) => (
        <EditorialCard
          href={`/alternatives/${a.slug}/`}
          tag={a.fdaStatus}
          tagTone={tagToneFor(a.fdaStatus)}
          title={a.title}
          description={a.description + (a.conditionLink ? ` <a href="${a.conditionLink}" style="color:var(--accent); text-decoration:underline;">Learn how TMS compares</a>.` : '')}
          size="sm"
          stats={[{ label: "Onset", value: a.speed, color: "accent" }]}
        />
      ))}
    </div>
  </EditorialSection>

  <EditorialCTA
    title="Not sure which treatment fits?"
    description="Our assessment evaluates symptoms and treatment history to point you to the best-fit option — TMS or otherwise."
    ctas={[
      { label: "Take the Assessment", href: "/quiz/am-i-a-candidate/" },
      { label: "Find a Specialist", href: "/specialists/", variant: "outline" },
      { label: "View TMS Treatment Options", href: "/treatments/", variant: "outline" },
    ]}
    stickyMobile
  />
</main>

</Layout>
