---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import EditorialHero from "../../components/editorial/EditorialHero.astro";
import EditorialSection from "../../components/editorial/EditorialSection.astro";
import EditorialCTA from "../../components/editorial/EditorialCTA.astro";
import CommunityPostList from "../../components/react/CommunityPostList";
import CommunityTrending from "../../components/react/CommunityTrending";
import CommunityCategoryHeat from "../../components/react/CommunityCategoryHeat";
import CommunityActivityFeed from "../../components/react/CommunityActivityFeed";
import CommunityNotificationBell from "../../components/react/CommunityNotificationBell";
import CategoryIcon from "../../components/react/CommunityCategoryIcon";
import { getForumCategories, getForumPosts, getTrendingPosts, getCategoryActivity, getRecentActivityFeed } from "../../db/forumQueries";
import { getSessionFromRequest } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
const categories = await getForumCategories();

let posts: any[] = [];
let trendingPosts: any[] = [];
let categoryActivity: any[] = [];
let recentActivity: any[] = [];

try {
  posts = await getForumPosts({ sort: 'hot', limit: 20 });
} catch { /* skip if DB not ready */ }

try {
  trendingPosts = await getTrendingPosts(5, 24);
} catch { /* skip if DB not ready */ }

try {
  categoryActivity = await getCategoryActivity(24);
} catch { /* skip if DB not ready */ }

try {
  recentActivity = await getRecentActivityFeed(10);
} catch { /* skip if DB not ready */ }

const totalPosts = categories.reduce((sum, c) => sum + (c.postCount || 0), 0);

const newPostHref = session ? "/community/new" : "/login?redirect=/community/new";
const storyHref = session ? "/community/new?category=patient-stories" : "/login?redirect=/community/new?category=patient-stories";
---

<Layout
  title="TMS Community Forum | Share Experiences & Ask Specialists"
  description="Join the TMS therapy community. Share treatment experiences, ask verified specialists, discuss insurance, and connect with others on their TMS journey."
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "Community", url: "/community" }]}
>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow="Real Patients · Verified Specialists"
    eyebrowDot="#22c55e"
    title="The TMS"
    titleAccent="community."
    description="Share treatment experiences, ask verified specialists, and connect with others on their TMS journey."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Community" }]}
    ctas={[
      { label: session ? "New Post" : "Join the Community", href: newPostHref },
      { label: "Browse Topics", href: "#topics", variant: "outline" },
    ]}
    stats={[
      { value: categories.length, label: "Topics", color: "ink" },
      { value: totalPosts, label: "Posts", color: "accent" },
      { value: "$10", label: "Story Reward", color: "warm" },
    ]}
  />

  <EditorialSection
    title="Browse Topics"
    intro="Pick a category to read what others are discussing — or jump in and start your own."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-4 4z"/>'
    tone="warm"
  >
    <div id="topics" class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {categories.map((cat) => (
        <a
          href={`/community/${cat.slug}`}
          style="background:var(--paper2); border:1px solid var(--line); border-radius:1rem; padding:1rem; transition:box-shadow 0.2s, transform 0.2s;"
          class="block hover:shadow-lg hover:-translate-y-0.5"
        >
          <div class="mb-2"><CategoryIcon icon={cat.icon} color={cat.color} /></div>
          <h3 style="font-size:14px; font-weight:700; color:var(--ink); margin:0 0 0.25rem;">{cat.name}</h3>
          <p style="font-size:12px; color:var(--muted); margin:0;" class="line-clamp-2">{cat.description}</p>
          <p style="font-size:11px; color:var(--muted); margin-top:0.5rem; font-weight:500;">{cat.postCount} posts</p>
        </a>
      ))}
    </div>
  </EditorialSection>

  <EditorialSection
    title="Recent Discussions"
    intro="The hottest TMS conversations happening right now."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>'
    tone="accent"
    actionLabel={session ? "+ New Post" : undefined}
    actionHref={session ? "/community/new" : undefined}
    background="paper2"
    noBorder
  >
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <div class="lg:col-span-2">
        <CommunityPostList
          client:load
          initialPosts={posts}
          isAuthenticated={!!session}
          showCategory={true}
        />
      </div>
      <div class="space-y-6">
        {session && (
          <div class="bg-white rounded-xl border border-[var(--line)] p-4">
            <CommunityNotificationBell client:load userId={session.userId} />
            <p class="text-xs text-[var(--muted)] mt-2">Get notified when someone replies to your posts</p>
          </div>
        )}
        <div class="bg-white rounded-xl border border-[var(--line)] p-4">
          <CommunityTrending client:load initialPosts={trendingPosts} />
        </div>
        <div class="bg-white rounded-xl border border-[var(--line)] p-4">
          <CommunityCategoryHeat client:load initialData={categoryActivity} />
        </div>
      </div>
    </div>
  </EditorialSection>

  <EditorialSection
    title="Community Activity"
    intro="See what others are discussing in real-time."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>'
    tone="warm"
  >
    <div class="max-w-2xl">
      <CommunityActivityFeed client:load initialActivities={recentActivity} />
    </div>
  </EditorialSection>

  <EditorialCTA
    title="Share your TMS story."
    description="The top 10 most helpful stories each month earn a $10 gift card. It takes just 5 minutes to write."
    ctas={[
      { label: "Write Your Story", href: storyHref },
      { label: "Browse Stories", href: "/stories/", variant: "outline" },
    ]}
    stickyMobile
  />
</main>

</Layout>
