---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import { getSessionFromRequest } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
const redirect = Astro.url.searchParams.get('redirect') || '/community';
const error = Astro.url.searchParams.get('error');

// Already logged in
if (session) {
  return Astro.redirect(redirect);
}

const ERROR_MESSAGES: Record<string, string> = {
  'missing-token': 'Invalid login link. Please request a new one.',
  'invalid-or-expired': 'This link has expired. Please request a new one.',
  'server-error': 'Something went wrong. Please try again.',
};
---

<Layout
  title="Join the Community | TMS List"
  description="Sign in to join the TMS therapy community forum."
  noindex={true}
>
  <div class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
    <div class="max-w-md w-full">
      <div class="text-center mb-8">
        <a href="/community" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-violet-600 mb-4 transition-colors">&larr; Back to Community</a>
        <h1 class="text-2xl font-bold text-gray-900">Join the TMS Community</h1>
        <p class="text-sm text-gray-500 mt-2">Enter your email to get a magic link. No password needed.</p>
      </div>

      {error && (
        <div class="bg-red-50 border border-red-200 rounded-lg p-3 mb-4">
          <p class="text-sm text-red-700">{ERROR_MESSAGES[error] || 'Something went wrong.'}</p>
        </div>
      )}

      <div class="bg-white rounded-xl border border-gray-200 p-6" id="login-card">
        <form id="community-login-form" class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="you@example.com"
              class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent"
            />
          </div>
          <button
            type="submit"
            id="submit-btn"
            class="w-full py-2.5 bg-violet-600 text-white font-semibold rounded-lg hover:bg-violet-700 transition-colors text-sm disabled:opacity-50"
          >
            Send Magic Link
          </button>
        </form>

        <div id="success-message" class="hidden text-center py-4">
          <svg class="w-8 h-8 text-violet-500 mx-auto mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          <p class="text-sm text-gray-600">Check your email for a login link. It expires in 15 minutes.</p>
        </div>

        <div id="error-message" class="hidden mt-3">
          <p class="text-sm text-red-600" id="error-text"></p>
        </div>
      </div>

      <div class="text-center mt-6">
        <p class="text-xs text-gray-400">
          Already have a doctor portal account? <a href="/portal/login" class="text-violet-600 hover:text-violet-700">Sign in here</a>
        </p>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ redirect }}>
  const form = document.getElementById('community-login-form');
  const submitBtn = document.getElementById('submit-btn');
  const successMsg = document.getElementById('success-message');
  const errorMsg = document.getElementById('error-message');
  const errorText = document.getElementById('error-text');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = form.querySelector('#email')?.value?.trim();
    if (!email) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    errorMsg?.classList.add('hidden');

    try {
      const res = await fetch('/api/auth/community-login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, redirectTo: redirect }),
      });

      const data = await res.json();

      if (res.ok && data.success) {
        form.classList.add('hidden');
        successMsg?.classList.remove('hidden');
      } else {
        throw new Error(data.error || 'Failed to send login link');
      }
    } catch (err) {
      errorText.textContent = err.message || 'Something went wrong. Please try again.';
      errorMsg?.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Magic Link';
    }
  });
</script>
