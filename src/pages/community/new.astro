---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import CommunityNewPost from "../../components/react/CommunityNewPost";
import { getForumCategories } from "../../db/forumQueries";
import { getSessionFromRequest } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!session) {
  return Astro.redirect(`/community/login?redirect=${encodeURIComponent('/community/new')}`);
}

const categories = await getForumCategories();
const defaultCategoryId = Astro.url.searchParams.get('category') || undefined;
---

<Layout
  title="New Post | TMS Community"
  description="Start a new discussion in the TMS therapy community."
  noindex={true}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Community", url: "/community" },
    { name: "New Post", url: "/community/new" },
  ]}
>
  <div class="min-h-screen bg-gray-50">
    <div class="container mx-auto px-4 lg:px-8 py-8 max-w-2xl">
      <div class="mb-6">
        <a href="/community" class="text-sm text-gray-400 hover:text-violet-600 transition-colors">&larr; Back to Community</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-2">Start a Discussion</h1>
        <p class="text-sm text-gray-500 mt-1">Share your experience, ask a question, or start a conversation.</p>
      </div>

      <CommunityNewPost
        client:load
        categories={categories.map(c => ({ id: c.id, slug: c.slug, name: c.name, icon: c.icon }))}
        defaultCategoryId={defaultCategoryId}
      />
    </div>
  </div>
</Layout>
