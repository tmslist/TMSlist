---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import CommunityNewPost from "../../components/react/CommunityNewPost";
import { getForumCategories } from "../../db/forumQueries";
import { getSessionFromRequest } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!session) {
  return Astro.redirect(`/community/login?redirect=${encodeURIComponent('/community/new')}`);
}

const categories = await getForumCategories();
const defaultCategoryId = Astro.url.searchParams.get('category') || undefined;
---

<Layout
  title="New Post | TMS Community"
  description="Start a new discussion in the TMS therapy community."
  noindex={true}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Community", url: "/community" },
    { name: "New Post", url: "/community/new" },
  ]}
>
  <div class="min-h-screen bg-gray-50">
    <div class="container mx-auto px-4 lg:px-8 py-8 max-w-2xl">
      <div class="mb-6">
        <a href="/community" class="text-sm text-gray-400 hover:text-violet-600 transition-colors">&larr; Back to Community</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-2">Start a Discussion</h1>
        <p class="text-sm text-gray-500 mt-1">Share your experience, ask a question, or start a conversation.</p>
      </div>

      <!-- Story Contest CTA -->
      <div class="mb-6 bg-gradient-to-r from-amber-50 to-orange-50 rounded-2xl border border-amber-200 p-5">
        <div class="flex items-start gap-4">
          <div class="w-12 h-12 bg-amber-400 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-amber-900" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
            </svg>
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-bold text-gray-900 text-base">Write a TMS Story</h3>
              <span class="px-2 py-0.5 bg-amber-400 text-amber-900 text-xs font-bold rounded-full">$10 Gift Card</span>
            </div>
            <p class="text-gray-600 text-sm leading-relaxed">
              Your experience can help others on their TMS journey. The top 10 most helpful stories each month receive a <strong>$10 gift card</strong>. It's simple and takes just a few minutes.
            </p>
          </div>
        </div>
      </div>

      <CommunityNewPost
        client:load
        categories={categories.map(c => ({ id: c.id, slug: c.slug, name: c.name, icon: c.icon }))}
        defaultCategoryId={defaultCategoryId}
      />
    </div>
  </div>
</Layout>
