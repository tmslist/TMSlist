---
import Layout from '../../../layouts/Layout.astro';
import ClinicCard from '../../../components/ClinicCard.astro';
import { getClinicsByCountry, getClinicRating } from '../../../utils/dataHelpers';
import { COUNTRY_META } from '../../../utils/countryData';
import { t, getLocaleFromPath } from '../../../utils/i18n';
import LocationSEOContent from '../../../components/LocationSEOContent.astro';

export async function getStaticPaths() {
    const clinics = await getClinicsByCountry('NL');
    const regionMap = new Map<string, typeof clinics>();
    clinics.forEach(c => {
        if (!c.state) return;
        if (!regionMap.has(c.state)) regionMap.set(c.state, []);
        regionMap.get(c.state)!.push(c);
    });

    return [...regionMap.entries()].map(([regionName, regionClinics]) => {
        const regionSlug = regionName.toLowerCase().replace(/\s+/g, '-');
        const cities = [...new Set(regionClinics.map(c => c.city).filter(Boolean))]
            .map(city => ({
                name: city,
                slug: city.toLowerCase().replace(/\s+/g, '-').replace(/\./g, ''),
                count: regionClinics.filter(c => c.city === city).length,
            }))
            .sort((a, b) => a.name.localeCompare(b.name));

        const topClinics = [...regionClinics]
            .sort((a, b) => getClinicRating(b) - getClinicRating(a))
            .slice(0, 3);

        return {
            params: { region: regionSlug },
            props: { regionName, regionSlug, cities, topClinics, clinicCount: regionClinics.length },
        };
    });
}

const { regionName, regionSlug, cities, topClinics, clinicCount } = Astro.props;
const meta = COUNTRY_META['NL'];

const title = `Best TMS Therapy Clinics in ${regionName}, Netherlands (Top Rated Providers)`;
const description = `Find the best TMS therapy providers in ${regionName}, Netherlands. Compare ${clinicCount} clinics across ${cities.length} cities and find treatment near you.`;

const regionSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `TMS Therapy Clinics in ${regionName}, Netherlands`,
    "description": description,
    "url": `https://tmslist.com/nl/${regionSlug}/`,
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": clinicCount,
        "itemListElement": topClinics.slice(0, 3).map((c: any, i: number) => ({
            "@type": "ListItem",
            "position": i + 1,
            "item": {
                "@type": "MedicalClinic",
                "name": c.name,
                "url": `https://tmslist.com/clinic/${c.slug}`,
                "address": {
                    "@type": "PostalAddress",
                    "addressLocality": c.city,
                    "addressRegion": regionName,
                    "addressCountry": "NL"
                }
            }
        }))
    }
});
---

<Layout title={title} description={description} schema={regionSchema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Netherlands", url: "/nl/" },
    { name: regionName, url: `/nl/${regionSlug}/` },
]}>
    <section class="relative bg-white border-b border-slate-100 overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
        <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
        <div
          class="ai-hero-image absolute inset-0 opacity-20"
          data-subject={regionName}
          data-type="city"
          data-cache-key={`ai-img:city:${regionName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
          data-alt={`Illustration of ${regionName}`}
        >
          <div class="ai-img-placeholder absolute inset-0"></div>
          <img class="ai-img-result hidden w-full h-full object-cover" alt="TMS clinic illustration" />
          <div class="ai-img-fallback hidden"></div>
        </div>
        <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
            <nav class="flex items-center gap-2 text-sm text-slate-400 mb-6 flex-wrap" aria-label="Breadcrumb">
                <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                <span class="text-slate-300">/</span>
                <a href="/nl/" class="hover:text-violet-600 transition-colors">Netherlands</a>
                <span class="text-slate-300">/</span>
                <span class="text-slate-700 font-medium">{regionName}</span>
            </nav>
            <div class="max-w-3xl">
                <h1 class="text-4xl font-bold text-gray-900 mb-4">Top Rated TMS Clinics in <span class="text-violet-600">{regionName}</span></h1>
                <p class="text-lg text-gray-600">Compare {clinicCount} TMS therapy clinics across {cities.length} cities in {regionName}. Find verified providers with patient reviews.</p>
            </div>
        </div>
    </section>

    <div class="container mx-auto px-4 py-8">
        <!-- Top Rated Section -->
        <section class="mb-16">

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {topClinics.map((clinic: any) => <ClinicCard clinic={clinic} />)}
            </div>
        </section>

        <section>
            <div class="flex items-center mb-8">
                <h2 class="text-2xl font-semibold text-gray-900">Browse by City in {regionName}</h2>
                <div class="ml-4 h-px flex-1 bg-gray-200"></div>
                <span class="ml-4 text-sm font-medium text-gray-400">{cities.length} cities</span>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
                {cities.map((city: any) => (
                    <a
                        href={`/nl/${regionSlug}/${city.slug}/`}
                        class="group relative bg-white p-5 rounded-2xl border border-gray-100 shadow-[0_2px_8px_rgb(0,0,0,0.02)] hover:shadow-[0_8px_30px_rgb(37,99,235,0.08)] hover:border-blue-200 transition-all overflow-hidden"
                    >
                        <div class="absolute inset-x-0 bottom-0 h-1 bg-blue-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
                        <div class="flex items-center justify-between mb-1">
                            <span class="font-bold text-gray-900 group-hover:text-blue-600 transition-colors">{city.name}</span>
                            <svg class="w-4 h-4 text-gray-300 group-hover:text-blue-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </div>
                        <span class="text-xs font-medium text-gray-400">{city.count} {city.count === 1 ? 'clinic' : 'clinics'}</span>
                    </a>
                ))}
            </div>
        </section>

<LocationSEOContent type="region" locationName={regionName} clinicCount={clinicCount} countryCode="NL" />
    </div>
</Layout>

<script>
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;
    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }
    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });
</script>
