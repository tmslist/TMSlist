---
import Layout from '../../layouts/Layout.astro';
import { getClinicsByCountry, COUNTRY_NAMES } from '../../utils/dataHelpers';
import { COUNTRY_META } from '../../utils/countryData';
import { t } from '../../utils/i18n';
const locale = 'nl' as const;

const countryCode = 'NL';
const meta = COUNTRY_META[countryCode];
const clinics = await getClinicsByCountry(countryCode);
const totalClinics = clinics.length;

const regionMap = new Map<string, number>();
clinics.forEach(c => {
    if (!c.state) return;
    regionMap.set(c.state, (regionMap.get(c.state) || 0) + 1);
});

const regions = [...regionMap.entries()]
    .map(([name, count]) => ({
        name,
        slug: name.toLowerCase().replace(/\s+/g, '-'),
        count,
    }))
    .sort((a, b) => a.name.localeCompare(b.name));

const title = `TMS Therapy Clinics in Netherlands | ${totalClinics} Verified Providers`;
const description = `Browse ${totalClinics} TMS therapy clinics across ${regions.length} regions in Netherlands. ${meta.seoDescription}`;

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "TMS Therapy Clinics in Netherlands",
    "description": description,
    "url": "https://tmslist.com/nl/",
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": regions.length,
        "itemListElement": regions.map((r, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "name": `TMS Clinics in ${r.name}, Netherlands`,
            "url": `https://tmslist.com/nl/${r.slug}/`
        }))
    }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Netherlands", url: "/nl/" },
]}>
    <main class="container mx-auto px-4 py-8">
        <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8" aria-label="Breadcrumb">
            <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <span class="text-slate-700 font-medium">Netherlands</span>
        </nav>

        <h1 class="text-3xl font-semibold mb-2">TMS Therapy Clinics in Netherlands</h1>
        <p class="text-gray-600 mb-8 max-w-3xl">Browse {totalClinics} verified TMS providers across {regions.length} regions in Netherlands. TMS is {meta.tmsStatus}, with sessions costing {meta.sessionCostRange} per session.</p>

        <!-- Key Facts -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-violet-600">{totalClinics}</div>
                <div class="text-sm text-gray-500 font-medium">Clinics</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-violet-600">{regions.length}</div>
                <div class="text-sm text-gray-500 font-medium">Regions</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-violet-600">{meta.publicHealthSystem}</div>
                <div class="text-sm text-gray-500 font-medium">Public Health</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-violet-600">{meta.sessionCostRange}</div>
                <div class="text-sm text-gray-500 font-medium">Per Session</div>
            </div>
        </div>

        <div class="flex items-center mb-8">
            <h2 class="text-2xl font-semibold text-gray-900">Zoek op regio</h2>
            <div class="ml-4 h-px flex-1 bg-gray-200"></div>
            <span class="ml-4 text-sm font-medium text-gray-400">{regions.length} regions</span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {regions.map((region) => (
                <a href={`/nl/${region.slug}/`} class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-violet-500 hover:shadow-md transition-all group">
                    <span class="text-lg font-medium text-gray-800 group-hover:text-violet-600">{region.name}</span>
                    <span class="block text-sm text-gray-500 mt-1">{region.count} {region.count === 1 ? 'clinic' : 'clinics'}</span>
                </a>
            ))}
        </div>

        <!-- SEO Content -->
        <section class="mt-16 pt-12 border-t border-gray-100 prose prose-lg max-w-none text-gray-600">
            <h2>TMS-therapie in Nederland</h2>
            <p>Nederland is een van de meest toegankelijke Europese landen voor TMS-therapie. Nederlandse zorgverzekeraars vergoeden rTMS voor therapieresistente depressie steeds vaker als onderdeel van gespecialiseerde geestelijke gezondheidszorg (SGGZ). Academische medische centra zoals Amsterdam UMC en UMC Utrecht zijn toonaangevende onderzoeksinstellingen. Het brainclinics research institute in Nijmegen levert een belangrijke bijdrage aan gepersonaliseerde TMS-protocollen.</p>
            <p>TMS-therapie is goed ingeburgerd in Nederland, met dekking door de zorgverzekering voor therapieresistente depressie. Amsterdam, Utrecht en Rotterdam hebben toonaangevende TMS-centra.</p>
            <h3>Verzekering en kosten</h3>
            <p>De basisverzekering (Zorgverzekeringswet) kan TMS vergoeden als onderdeel van gespecialiseerde geestelijke gezondheidszorg (SGGZ) na verwijzing door een psychiater. Een verwijsroute via huisarts en psychiater is vereist. Patiënten betalen het standaard eigen risico. Privéklinieken rekenen {meta.sessionCostRange} per sessie voor zelfbetalers.</p>
            <p>De typische kosten van een TMS-sessie in Nederland variëren van {meta.sessionCostRange}. Behandeltrajecten omvatten doorgaans 20-30 sessies gedurende 4-6 weken.</p>
            <h3>Hoe kies je een TMS-kliniek in Nederland</h3>
            <p>Bij het kiezen van een TMS-aanbieder in Nederland, let op de accreditatie van de kliniek, de ervaring van de behandelend psychiater, de gebruikte TMS-technologie en of uw zorgverzekering de behandeling vergoedt. Ons overzicht helpt u klinieken per regio te vergelijken en de juiste aanbieder te vinden.</p>
            <h3>Gerelateerde bronnen</h3>
            <ul>
                <li><a href="/treatments/">Aandoeningen behandeld met TMS</a> — depressie, angst, OCS, PTSS en meer</li>
                <li><a href="/technology/">TMS-technologiegids</a> — vergelijk NeuroStar, BrainsWay, MagVenture</li>
                <li><a href="/research/">TMS-onderzoek</a> — laatste klinische studies en resultaten</li>
            </ul>
        </section>
    </main>
</Layout>
