---
import Layout from "../../layouts/Layout.astro";
import EditorialHero from "../../components/editorial/EditorialHero.astro";

const title = "TMS CPT Codes Guide 2026 | Billing & Reimbursement Reference";
const description = "Complete 2026 reference for TMS therapy CPT codes (90867, 90868, 90869), ICD-10 diagnosis codes, Medicare reimbursement rates, and prior authorization tips.";

const cptCodes = [
    { code: "90867", name: "Therapeutic repetitive TMS treatment; initial, including cortical mapping, motor threshold determination, delivery and management, first session", type: "Initial Treatment", medicareRate: "$263.41", notes: "Billed once per treatment course. Includes motor threshold determination and cortical mapping." },
    { code: "90868", name: "Therapeutic repetitive TMS treatment; subsequent delivery and management, per session", type: "Subsequent Treatment", medicareRate: "$148.73", notes: "Billed for each session after the initial. Typical course is 36 sessions over 6-9 weeks." },
    { code: "90869", name: "Therapeutic repetitive TMS treatment; subsequent motor threshold re-determination with delivery and management", type: "Re-determination", medicareRate: "$195.86", notes: "Used when motor threshold must be re-established mid-course due to clinical need." },
];

const icdCodes = [
    { code: "F32.0", description: "Major depressive disorder, single episode, mild" },
    { code: "F32.1", description: "Major depressive disorder, single episode, moderate" },
    { code: "F32.2", description: "Major depressive disorder, single episode, severe without psychotic features" },
    { code: "F32.9", description: "Major depressive disorder, single episode, unspecified" },
    { code: "F33.0", description: "Major depressive disorder, recurrent, mild" },
    { code: "F33.1", description: "Major depressive disorder, recurrent, moderate" },
    { code: "F33.2", description: "Major depressive disorder, recurrent, severe without psychotic features" },
    { code: "F33.9", description: "Major depressive disorder, recurrent, unspecified" },
    { code: "F42.2", description: "Mixed obsessional thoughts and acts (OCD)" },
    { code: "F42.8", description: "Other obsessive-compulsive disorder" },
    { code: "F42.9", description: "Obsessive-compulsive disorder, unspecified" },
];

const denialReasons = [
    { reason: "Medical necessity not established", strategy: "Document at least two failed adequate antidepressant trials (minimum 8 weeks at therapeutic doses). Include PHQ-9 or HAM-D scores showing persistent moderate-to-severe depression." },
    { reason: "Experimental or investigational", strategy: "Cite FDA clearances (2008 for depression, 2018 for OCD) and APA Clinical Practice Guidelines. Reference the STAR*D trial outcomes for treatment-resistant depression." },
    { reason: "Prior authorization not obtained", strategy: "Always obtain prior auth before starting treatment. Most payers require it. Build in 2-3 weeks lead time. Submit clinical notes, medication history, and rating scale scores." },
    { reason: "Incorrect coding or documentation", strategy: "Ensure the supervising psychiatrist signs off on each treatment note. Use 90867 for the first session only, 90868 for subsequent sessions. Include session duration and pulse count." },
    { reason: "Exceeded session limits", strategy: "Most payers authorize 36 sessions. If additional sessions are needed, submit a request for continuation with updated clinical documentation showing partial but incomplete response." },
];
---

<Layout title={title} description={description} breadcrumbs={[{ name: "Home", url: "/" }, { name: "TMS CPT Codes", url: "/tms-cpt-codes/" }]}>
    <main style="background:var(--paper)">
        <EditorialHero
            eyebrow="Updated for 2026"
            eyebrowDot="#22c55e"
            title="TMS CPT codes"
            titleAccent="& billing guide."
            description="Complete billing and reimbursement reference for TMS therapy providers. CPT codes, ICD-10 diagnoses, Medicare rates, and authorization guidance."
            breadcrumbs={[{ label: "Home", href: "/" }, { label: "TMS CPT Codes" }]}
            ctas={[
                { label: "View Codes", href: "#codes" },
                { label: "All Legal Guides", href: "/legal/", variant: "outline" },
            ]}
            stats={[
                { value: "2026", label: "Codes Updated", color: "ink" },
                { value: "Medicare", label: "Rates Included", color: "accent" },
                { value: "ICD-10", label: "Diagnoses", color: "warm" },
            ]}
        />

        <!-- CPT Codes Table -->
        <section class="py-16 lg:py-24 bg-[var(--paper)]">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-8 h-8 rounded-lg bg-[var(--paper2)] flex items-center justify-center">
                        <svg class="w-4 h-4 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                    </div>
                    <h2 class="text-2xl font-bold text-[var(--ink)]">TMS CPT Codes</h2>
                </div>

                <div class="space-y-5">
                    {cptCodes.map(c => (
                        <div class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] p-7 hover:border-[var(--line)] hover:shadow-md transition-all">
                            <div class="flex flex-col lg:flex-row lg:items-start gap-5">
                                <div class="shrink-0">
                                    <div class="inline-flex items-center gap-2 px-4 py-2 bg-[var(--paper2)] rounded-xl">
                                        <span class="text-2xl font-bold text-[var(--accent)] font-mono">{c.code}</span>
                                    </div>
                                </div>
                                <div class="flex-1">
                                    <div class="flex flex-wrap items-center gap-3 mb-2">
                                        <span class="px-2.5 py-0.5 bg-[var(--paper2)] text-[var(--muted)] text-[10px] font-bold uppercase tracking-wider rounded">{c.type}</span>
                                        <span class="text-sm font-semibold text-emerald-600">Medicare: {c.medicareRate}</span>
                                    </div>
                                    <p class="text-sm text-[var(--ink2)] leading-relaxed mb-2">{c.name}</p>
                                    <p class="text-sm text-[var(--muted)] leading-relaxed">{c.notes}</p>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>

                <!-- ICD-10 Codes -->
                <div class="mt-16">
                    <div class="flex items-center gap-3 mb-8">
                        <div class="w-8 h-8 rounded-lg bg-[rgba(10,22,40,0.08)] flex items-center justify-center">
                            <svg class="w-4 h-4 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                        </div>
                        <h2 class="text-2xl font-bold text-[var(--ink)]">ICD-10 Diagnosis Codes</h2>
                    </div>

                    <div class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] overflow-hidden">
                        <div class="grid grid-cols-[100px_1fr] lg:grid-cols-[120px_1fr] bg-[var(--paper2)] border-b border-[var(--line)] px-6 py-3">
                            <span class="text-xs font-bold text-[var(--muted)] uppercase tracking-wider">Code</span>
                            <span class="text-xs font-bold text-[var(--muted)] uppercase tracking-wider">Description</span>
                        </div>
                        {icdCodes.map((c, i) => (
                            <div class={`grid grid-cols-[100px_1fr] lg:grid-cols-[120px_1fr] px-6 py-3.5 ${i < icdCodes.length - 1 ? 'border-b border-[var(--line)]' : ''}`}>
                                <span class="font-mono font-semibold text-[var(--accent)] text-sm">{c.code}</span>
                                <span class="text-sm text-[var(--muted)]">{c.description}</span>
                            </div>
                        ))}
                    </div>
                </div>

                <!-- Prior Authorization Tips -->
                <div class="mt-16">
                    <div class="flex items-center gap-3 mb-8">
                        <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center">
                            <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <h2 class="text-2xl font-bold text-[var(--ink)]">Prior Authorization Tips</h2>
                    </div>

                    <div class="bg-emerald-50/50 border border-emerald-100 rounded-2xl p-7 lg:p-9">
                        <ul class="space-y-4">
                            <li class="flex items-start gap-3">
                                <span class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">1</span>
                                <span class="text-sm text-[var(--ink2)] leading-relaxed"><strong>Start early.</strong> Submit prior authorization at least 2-3 weeks before the planned start date. Some payers take up to 15 business days to respond.</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">2</span>
                                <span class="text-sm text-[var(--ink2)] leading-relaxed"><strong>Document medication failures.</strong> Include dates, dosages, duration, and reason for discontinuation for at least two antidepressant trials at adequate dose and duration.</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">3</span>
                                <span class="text-sm text-[var(--ink2)] leading-relaxed"><strong>Include validated rating scales.</strong> PHQ-9, HAM-D, or BDI scores demonstrating moderate-to-severe depression are essential for approval.</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">4</span>
                                <span class="text-sm text-[var(--ink2)] leading-relaxed"><strong>Specify the protocol.</strong> Include the device, coil type, treatment location (left DLPFC), frequency, pulse count, and number of planned sessions.</span>
                            </li>
                            <li class="flex items-start gap-3">
                                <span class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">5</span>
                                <span class="text-sm text-[var(--ink2)] leading-relaxed"><strong>Know your payer.</strong> Medicare generally covers TMS for treatment-resistant depression. Commercial payers vary — always check the specific medical policy.</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Denial Reasons & Appeals -->
                <div class="mt-16">
                    <div class="flex items-center gap-3 mb-8">
                        <div class="w-8 h-8 rounded-lg bg-red-50 flex items-center justify-center">
                            <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                        </div>
                        <h2 class="text-2xl font-bold text-[var(--ink)]">Common Denials & Appeal Strategies</h2>
                    </div>

                    <div class="space-y-4">
                        {denialReasons.map(d => (
                            <div class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] p-6 hover:border-red-200 transition-colors">
                                <h3 class="text-base font-bold text-[var(--ink)] mb-2 flex items-center gap-2">
                                    <svg class="w-4 h-4 text-red-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                    {d.reason}
                                </h3>
                                <p class="text-sm text-[var(--muted)] leading-relaxed pl-6"><strong class="text-[var(--ink2)]">Appeal strategy:</strong> {d.strategy}</p>
                            </div>
                        ))}
                    </div>
                </div>

                <!-- Disclaimer -->
                <div class="mt-16 p-6 bg-[var(--paper2)]/50 border border-[var(--line)] rounded-2xl">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-xl bg-[rgba(10,22,40,0.1)] flex items-center justify-center shrink-0">
                            <svg class="w-5 h-5 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </div>
                        <div>
                            <h3 class="text-sm font-bold text-[var(--ink)] mb-1">Billing Disclaimer</h3>
                            <p class="text-sm text-[var(--muted)]">This guide is for informational purposes only and does not constitute billing or legal advice. Reimbursement rates and payer policies change frequently. Always verify current rates with your Medicare Administrative Contractor (MAC) or commercial payer. Consult a healthcare billing professional for practice-specific guidance.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="py-16 lg:py-24 bg-[var(--paper2)] border-t border-[var(--line)]">
            <div class="container mx-auto px-4 max-w-4xl">
                <div class="relative bg-[var(--ink)] rounded-3xl p-10 lg:p-14 overflow-hidden text-center">
                    <div class="absolute inset-0 bg-gradient-to-r from-[var(--accent2)]0/10 via-transparent to-[#0A1628]/10"></div>
                    <div class="relative z-10">
                        <p class="text-sm font-semibold text-[var(--accent2)] tracking-wider uppercase mb-3">For TMS Providers</p>
                        <h3 class="text-2xl lg:text-3xl font-bold text-white mb-4 tracking-tight">List Your Clinic on TMS List</h3>
                        <p class="text-[var(--muted)] max-w-lg mx-auto mb-8">Reach patients searching for TMS therapy in your area. Free basic listings available for all verified providers.</p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <a href="/add-listing/" class="px-8 py-4 bg-[var(--accent)] hover:bg-[var(--accent2)] text-white font-semibold rounded-xl transition-colors shadow-lg shadow-[rgba(10,22,40,0.1)]">Add Your Clinic</a>
                            <a href="/providers/" class="px-8 py-4 bg-[var(--paper)]/5 border border-white/10 hover:border-white/25 text-white font-semibold rounded-xl transition-all backdrop-blur">Provider Resources</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
