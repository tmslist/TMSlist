---
import Layout from "../../layouts/Layout.astro";
import EditorialHero from "../../components/editorial/EditorialHero.astro";
import { ClinicMachine, ClinicTreatment, ClinicInsurance } from "../../types/clinic";
import { COUNTRY_NAMES } from "../../utils/dataHelpers";

const US_STATES = [
    { code: "AL", name: "Alabama" }, { code: "AK", name: "Alaska" }, { code: "AZ", name: "Arizona" },
    { code: "AR", name: "Arkansas" }, { code: "CA", name: "California" }, { code: "CO", name: "Colorado" },
    { code: "CT", name: "Connecticut" }, { code: "DE", name: "Delaware" }, { code: "DC", name: "Washington DC" },
    { code: "FL", name: "Florida" }, { code: "GA", name: "Georgia" }, { code: "HI", name: "Hawaii" },
    { code: "ID", name: "Idaho" }, { code: "IL", name: "Illinois" }, { code: "IN", name: "Indiana" },
    { code: "IA", name: "Iowa" }, { code: "KS", name: "Kansas" }, { code: "KY", name: "Kentucky" },
    { code: "LA", name: "Louisiana" }, { code: "ME", name: "Maine" }, { code: "MD", name: "Maryland" },
    { code: "MA", name: "Massachusetts" }, { code: "MI", name: "Michigan" }, { code: "MN", name: "Minnesota" },
    { code: "MS", name: "Mississippi" }, { code: "MO", name: "Missouri" }, { code: "MT", name: "Montana" },
    { code: "NE", name: "Nebraska" }, { code: "NV", name: "Nevada" }, { code: "NH", name: "New Hampshire" },
    { code: "NJ", name: "New Jersey" }, { code: "NM", name: "New Mexico" }, { code: "NY", name: "New York" },
    { code: "NC", name: "North Carolina" }, { code: "ND", name: "North Dakota" }, { code: "OH", name: "Ohio" },
    { code: "OK", name: "Oklahoma" }, { code: "OR", name: "Oregon" }, { code: "PA", name: "Pennsylvania" },
    { code: "RI", name: "Rhode Island" }, { code: "SC", name: "South Carolina" }, { code: "SD", name: "South Dakota" },
    { code: "TN", name: "Tennessee" }, { code: "TX", name: "Texas" }, { code: "UT", name: "Utah" },
    { code: "VT", name: "Vermont" }, { code: "VA", name: "Virginia" }, { code: "WA", name: "Washington" },
    { code: "WV", name: "West Virginia" }, { code: "WI", name: "Wisconsin" }, { code: "WY", name: "Wyoming" },
];

const machines = Object.values(ClinicMachine);
const treatments = Object.values(ClinicTreatment);
const insurances = Object.values(ClinicInsurance);

const countries = Object.entries(COUNTRY_NAMES).map(([code, name]) => ({ code, name }));

const title = "Add Your TMS Clinic | Free Listing on TMS List";
const description = "List your TMS therapy clinic for free. Get discovered by thousands of patients. Multi-step onboarding creates your profile, listing, and provider account.";
---

<Layout title={title} description={description} noindex={true}>
    <main class="min-h-screen" style="background:var(--paper)">

        <EditorialHero
            eyebrow="Free Listing + Provider Account"
            eyebrowDot="#22c55e"
            title="List your"
            titleAccent="TMS clinic."
            description="Join 2,000+ providers worldwide. Your listing goes live instantly and you'll get a provider dashboard to manage leads, reviews, and profile."
            breadcrumbs={[
                { label: "Home", href: "/" },
                { label: "Providers", href: "/providers/" },
                { label: "Add Listing" },
            ]}
            stats={[
                { value: "2,000+", label: "Listed Clinics", color: "ink" },
                { value: "5 min", label: "Setup Time", color: "accent" },
                { value: "$0", label: "To Start", color: "warm" },
            ]}
        />

        <!-- Form area -->
        <div class="container mx-auto px-4 relative z-20 py-12 lg:py-16">
            <div class="grid lg:grid-cols-[1fr_320px] gap-8 max-w-6xl mx-auto">

                <!-- Main Form -->
                <div class="bg-[var(--paper)] rounded-3xl shadow-[0_20px_60px_-15px_rgba(0,0,0,0.08)] border border-[var(--line)] overflow-hidden">

                    <!-- Step Progress Bar -->
                    <div class="px-8 pt-8 pb-0">
                        <div class="flex items-center gap-1 mb-2">
                            {[1,2,3,4,5].map(n => (
                                <div class={`step-indicator h-1.5 flex-1 rounded-full transition-all duration-500 ${n === 1 ? 'bg-[var(--ink2)]' : 'bg-[var(--paper2)]'}`} data-step={n}></div>
                            ))}
                        </div>
                        <div class="flex justify-between text-[11px] text-[var(--muted)] font-medium">
                            <span>Basics</span>
                            <span>Location</span>
                            <span>Services</span>
                            <span>Team</span>
                            <span>Account</span>
                        </div>
                    </div>

                    <form id="add-listing-form" class="p-8 space-y-0" method="POST">
                        <input type="hidden" name="form-name" value="clinic-submission" />
                        <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

                        <!-- STEP 1: Basics -->
                        <div class="form-step" data-step="1">
                            <div class="mb-8">
                                <span class="text-xs font-bold text-[var(--accent)] uppercase tracking-wider">Step 1 of 5</span>
                                <h2 class="text-2xl font-bold text-[var(--ink)] mt-1">Tell us about your clinic</h2>
                                <p class="text-[var(--muted)] text-sm mt-1">Basic information patients see first.</p>
                            </div>

                            <!-- Listing type -->
                            <div class="mb-8">
                                <label class="block text-sm font-semibold text-[var(--ink2)] mb-3">What are you listing?</label>
                                <div class="grid grid-cols-3 gap-3">
                                    <label class="listing-type-option cursor-pointer">
                                        <input type="radio" name="listing_type" value="clinic" class="hidden peer" checked />
                                        <div class="p-4 rounded-xl border-2 border-[var(--line)] bg-[var(--paper)] text-center peer-checked:border-[var(--ink2)] peer-checked:bg-[rgba(10,22,40,0.08)] hover:border-[var(--line)] transition-all">
                                            <div class="text-2xl mb-1">&#127959;</div>
                                            <div class="text-sm font-semibold text-[var(--ink)]">Clinic</div>
                                        </div>
                                    </label>
                                    <label class="listing-type-option cursor-pointer">
                                        <input type="radio" name="listing_type" value="doctor" class="hidden peer" />
                                        <div class="p-4 rounded-xl border-2 border-[var(--line)] bg-[var(--paper)] text-center peer-checked:border-[rgba(10,22,40,0.2)] peer-checked:bg-[var(--paper2)] hover:border-[var(--line)] transition-all">
                                            <div class="text-2xl mb-1">&#129658;</div>
                                            <div class="text-sm font-semibold text-[var(--ink)]">Doctor</div>
                                        </div>
                                    </label>
                                    <label class="listing-type-option cursor-pointer">
                                        <input type="radio" name="listing_type" value="both" class="hidden peer" />
                                        <div class="p-4 rounded-xl border-2 border-[var(--line)] bg-[var(--paper)] text-center peer-checked:border-emerald-500 peer-checked:bg-emerald-50 hover:border-[var(--line)] transition-all">
                                            <div class="text-2xl mb-1">&#11088;</div>
                                            <div class="text-sm font-semibold text-[var(--ink)]">Both</div>
                                        </div>
                                    </label>
                                </div>
                            </div>

                            <div class="space-y-5">
                                <div>
                                    <label for="name" class="block text-sm font-semibold text-[var(--ink2)] mb-1.5">Clinic Name *</label>
                                    <input type="text" id="name" name="name" required class="form-input w-full px-4 py-3 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent transition-shadow" placeholder="e.g., Advanced TMS Wellness Center" />
                                </div>
                                <div>
                                    <label for="description" class="block text-sm font-semibold text-[var(--ink2)] mb-1.5">About Your Clinic *</label>
                                    <textarea id="description" name="description" rows="3" required class="form-input w-full px-4 py-3 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent transition-shadow" placeholder="Tell patients about your approach to TMS, what makes you unique, your philosophy of care..."></textarea>
                                    <p class="text-xs text-[var(--muted)] mt-1">Minimum 50 characters. This appears on your clinic profile.</p>
                                </div>
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label for="phone" class="block text-sm font-semibold text-[var(--ink2)] mb-1.5">Phone *</label>
                                        <input type="tel" id="phone" name="phone" required class="form-input w-full px-4 py-3 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent" placeholder="(555) 123-4567" />
                                    </div>
                                    <div>
                                        <label for="website" class="block text-sm font-semibold text-[var(--ink2)] mb-1.5">Website</label>
                                        <input type="url" id="website" name="website" class="form-input w-full px-4 py-3 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent" placeholder="https://yourclinic.com" />
                                    </div>
                                </div>
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label for="email" class="block text-sm font-semibold text-[var(--ink2)] mb-1.5">Clinic Email</label>
                                        <input type="email" id="email" name="email" class="form-input w-full px-4 py-3 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent" placeholder="info@yourclinic.com" />
                                    </div>
                                    <div>
                                        <label for="provider_type" class="block text-sm font-semibold text-[var(--ink2)] mb-1.5">Provider Type</label>
                                        <select id="provider_type" name="provider_type" class="form-input w-full px-4 py-3 rounded-xl border border-[var(--line)] text-[var(--ink)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent">
                                            <option value="">Select type...</option>
                                            <option value="tms_center">Dedicated TMS Center</option>
                                            <option value="psychiatrist">Psychiatrist (MD/DO)</option>
                                            <option value="hospital">Hospital / Medical Center</option>
                                            <option value="neurologist">Neurologist</option>
                                            <option value="mental_health_clinic">Mental Health Clinic</option>
                                            <option value="primary_care">Primary Care</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="flex justify-end mt-10">
                                <button type="button" class="next-step px-8 py-3 bg-[var(--ink)] hover:bg-[var(--ink2)] text-white font-semibold rounded-xl transition-colors flex items-center gap-2">
                                    Continue <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </button>
                            </div>
                        </div>

                        <!-- STEP 2: Location -->
                        <div class="form-step hidden" data-step="2">
                            <div class="mb-8">
                                <span class="text-xs font-bold text-[var(--accent)] uppercase tracking-wider">Step 2 of 5</span>
                                <h2 class="text-2xl font-bold text-[var(--ink)] mt-1">Where are you located?</h2>
                                <p class="text-[var(--muted)] text-sm mt-1">Help patients find you on the map.</p>
                            </div>

                            <div class="space-y-5">
                                <div>
                                    <label for="country" class="block text-sm font-semibold text-[var(--ink2)] mb-1.5">Country *</label>
                                    <select id="country" name="country" required class="form-input w-full px-4 py-3 rounded-xl border border-[var(--line)] text-[var(--ink)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent">
                                        {countries.map(c => (
                                            <option value={c.code} selected={c.code === 'US'}>{c.name}</option>
                                        ))}
                                    </select>
                                </div>
                                <div>
                                    <label for="address" class="block text-sm font-semibold text-[var(--ink2)] mb-1.5">Street Address *</label>
                                    <input type="text" id="address" name="address" required class="form-input w-full px-4 py-3 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent" placeholder="123 Medical Center Drive, Suite 200" />
                                </div>
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label for="city" class="block text-sm font-semibold text-[var(--ink2)] mb-1.5">City *</label>
                                        <input type="text" id="city" name="city" required class="form-input w-full px-4 py-3 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent" placeholder="Los Angeles" />
                                    </div>
                                    <div>
                                        <label for="state" class="block text-sm font-semibold text-[var(--ink2)] mb-1.5">State / Region *</label>
                                        <div id="state-select-wrapper">
                                            <select id="state" name="state" required class="form-input w-full px-4 py-3 rounded-xl border border-[var(--line)] text-[var(--ink)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent">
                                                <option value="">Select state...</option>
                                                {US_STATES.map(s => (<option value={s.code}>{s.name}</option>))}
                                            </select>
                                        </div>
                                        <input type="text" id="state-text" name="state_text" class="hidden form-input w-full px-4 py-3 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent" placeholder="e.g., Greater London" />
                                    </div>
                                </div>
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label for="zip" class="block text-sm font-semibold text-[var(--ink2)] mb-1.5">Postal Code *</label>
                                        <input type="text" id="zip" name="zip" required class="form-input w-full px-4 py-3 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent" placeholder="90210" />
                                    </div>
                                    <div>
                                        <label for="gbp_embed_url" class="block text-sm font-semibold text-[var(--ink2)] mb-1.5">Google Maps Link</label>
                                        <input type="url" id="gbp_embed_url" name="gbp_embed_url" class="form-input w-full px-4 py-3 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent" placeholder="Google Maps embed URL" />
                                    </div>
                                </div>

                                <!-- Operating hours -->
                                <div>
                                    <label class="block text-sm font-semibold text-[var(--ink2)] mb-1.5">Operating Hours</label>
                                    <div class="grid grid-cols-2 gap-4">
                                        <div>
                                            <label class="text-xs text-[var(--muted)]">Weekdays</label>
                                            <input type="text" name="hours_weekday" class="form-input w-full px-4 py-2.5 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] text-sm focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent" placeholder="9:00 AM - 5:00 PM" />
                                        </div>
                                        <div>
                                            <label class="text-xs text-[var(--muted)]">Weekends</label>
                                            <input type="text" name="hours_weekend" class="form-input w-full px-4 py-2.5 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] text-sm focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent" placeholder="Closed / By appointment" />
                                        </div>
                                    </div>
                                </div>

                                <!-- Accessibility -->
                                <div>
                                    <label class="block text-sm font-semibold text-[var(--ink2)] mb-2">Accessibility & Amenities</label>
                                    <div class="flex flex-wrap gap-2">
                                        {['Wheelchair Accessible', 'Free Parking', 'Telehealth Available', 'Evening Hours', 'Weekend Hours', 'Spanish Speaking', 'Multilingual Staff', 'LGBTQ+ Friendly'].map(item => (
                                            <label class="cursor-pointer">
                                                <input type="checkbox" name="amenities" value={item} class="hidden peer" />
                                                <span class="inline-block px-3 py-1.5 rounded-full border border-[var(--line)] text-sm text-[var(--muted)] peer-checked:bg-[rgba(10,22,40,0.08)] peer-checked:border-[rgba(10,22,40,0.2)] peer-checked:text-[var(--accent)] hover:bg-[var(--paper2)] transition-all">{item}</span>
                                            </label>
                                        ))}
                                    </div>
                                </div>
                            </div>

                            <div class="flex justify-between mt-10">
                                <button type="button" class="prev-step px-6 py-3 text-[var(--muted)] font-semibold rounded-xl hover:bg-[var(--paper2)] transition-colors flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg> Back
                                </button>
                                <button type="button" class="next-step px-8 py-3 bg-[var(--ink)] hover:bg-[var(--ink2)] text-white font-semibold rounded-xl transition-colors flex items-center gap-2">
                                    Continue <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </button>
                            </div>
                        </div>

                        <!-- STEP 3: Services -->
                        <div class="form-step hidden" data-step="3">
                            <div class="mb-8">
                                <span class="text-xs font-bold text-[var(--accent)] uppercase tracking-wider">Step 3 of 5</span>
                                <h2 class="text-2xl font-bold text-[var(--ink)] mt-1">What do you offer?</h2>
                                <p class="text-[var(--muted)] text-sm mt-1">Select your TMS equipment, conditions treated, and insurance accepted.</p>
                            </div>

                            <div class="space-y-8">
                                <div>
                                    <label class="block text-sm font-semibold text-[var(--ink2)] mb-3">TMS Machines *</label>
                                    <div class="flex flex-wrap gap-2">
                                        {machines.map(m => (
                                            <label class="cursor-pointer">
                                                <input type="checkbox" name="machines" value={m} class="hidden peer" />
                                                <span class="inline-block px-3.5 py-2 rounded-xl border border-[var(--line)] text-sm font-medium text-[var(--muted)] peer-checked:bg-[var(--ink)] peer-checked:text-white peer-checked:border-[var(--ink)] hover:bg-[var(--paper2)] transition-all">{m}</span>
                                            </label>
                                        ))}
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-sm font-semibold text-[var(--ink2)] mb-3">Conditions Treated *</label>
                                    <div class="flex flex-wrap gap-2">
                                        {treatments.map(t => (
                                            <label class="cursor-pointer">
                                                <input type="checkbox" name="treatments" value={t} class="hidden peer" />
                                                <span class="inline-block px-3.5 py-2 rounded-xl border border-[var(--line)] text-sm font-medium text-[var(--muted)] peer-checked:bg-emerald-600 peer-checked:text-white peer-checked:border-emerald-600 hover:bg-[var(--paper2)] transition-all">{t}</span>
                                            </label>
                                        ))}
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-sm font-semibold text-[var(--ink2)] mb-3">Insurance Accepted</label>
                                    <div class="flex flex-wrap gap-2 max-h-48 overflow-y-auto pr-2 custom-scrollbar">
                                        {insurances.map(i => (
                                            <label class="cursor-pointer">
                                                <input type="checkbox" name="insurances" value={i} class="hidden peer" />
                                                <span class="inline-block px-3 py-1.5 rounded-lg border border-[var(--line)] text-xs font-medium text-[var(--muted)] peer-checked:bg-[var(--accent)] peer-checked:text-white peer-checked:border-[var(--accent)] hover:bg-[var(--paper2)] transition-all">{i}</span>
                                            </label>
                                        ))}
                                    </div>
                                </div>

                                <!-- Pricing info -->
                                <div>
                                    <label class="block text-sm font-semibold text-[var(--ink2)] mb-3">Pricing Information</label>
                                    <div class="grid grid-cols-2 gap-4">
                                        <div>
                                            <label class="text-xs text-[var(--muted)]">Cost per session (self-pay)</label>
                                            <input type="text" name="session_cost" class="form-input w-full px-4 py-2.5 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] text-sm focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent" placeholder="$250 - $400" />
                                        </div>
                                        <div>
                                            <label class="text-xs text-[var(--muted)]">Free consultation?</label>
                                            <select name="free_consult" class="form-input w-full px-4 py-2.5 rounded-xl border border-[var(--line)] text-[var(--ink)] text-sm focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent">
                                                <option value="">Select...</option>
                                                <option value="yes">Yes, free consultation</option>
                                                <option value="no">No</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="flex justify-between mt-10">
                                <button type="button" class="prev-step px-6 py-3 text-[var(--muted)] font-semibold rounded-xl hover:bg-[var(--paper2)] transition-colors flex items-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg> Back
                                </button>
                                <button type="button" class="next-step px-8 py-3 bg-[var(--ink)] hover:bg-[var(--ink2)] text-white font-semibold rounded-xl transition-colors flex items-center gap-2">
                                    Continue <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </button>
                            </div>
                        </div>

                        <!-- STEP 4: Team & Media -->
                        <div class="form-step hidden" data-step="4">
                            <div class="mb-8">
                                <span class="text-xs font-bold text-[var(--accent)] uppercase tracking-wider">Step 4 of 5</span>
                                <h2 class="text-2xl font-bold text-[var(--ink)] mt-1">Your team & media</h2>
                                <p class="text-[var(--muted)] text-sm mt-1">Add your lead psychiatrist and clinic images. All optional.</p>
                            </div>

                            <div class="space-y-6">
                                <!-- Media -->
                                <div class="p-5 bg-[var(--paper2)] rounded-2xl border border-[var(--line)]">
                                    <h3 class="text-sm font-bold text-[var(--ink2)] mb-4">Clinic Images</h3>
                                    <div class="grid grid-cols-2 gap-4">
                                        <div>
                                            <label class="text-xs text-[var(--muted)] font-medium">Logo URL</label>
                                            <input type="url" name="logo_url" class="form-input w-full px-4 py-2.5 rounded-xl border border-[var(--line)] text-[var(--ink)] placeholder-[var(--muted)] text-sm mt-1 focus:ring-2 focus:ring-[rgba(10,22,40,0.15)] focus:border-transparent" placeholder="https://..." />
                                        </div>
                                        <div>
                                            <label class="text-xs text-[var(--muted)] font-medium">Clinic Photo URL</label>
