<script>
    document.addEventListener("DOMContentLoaded", () => {
        let currentStep = 1;
        const totalSteps = 5;
        const form = document.getElementById("add-listing-form") as HTMLFormElement;
        const successMessage = document.getElementById("success-message");
        const submitBtn = document.getElementById("submit-btn");
        const clinicLink = document.getElementById("clinic-link") as HTMLAnchorElement;
        const viewClinicBtn = document.getElementById("view-clinic-btn") as HTMLAnchorElement;

        function showStep(step: number) {
            document.querySelectorAll('.form-step').forEach(el => el.classList.add('hidden'));
            const target = document.querySelector(`.form-step[data-step="${step}"]`);
            if (target) target.classList.remove('hidden');

            document.querySelectorAll('.step-indicator').forEach(el => {
                const s = parseInt(el.getAttribute('data-step') || '0');
                el.classList.toggle('bg-[var(--ink2)]', s <= step);
                el.classList.toggle('bg-[var(--paper2)]', s > step);
            });

            currentStep = step;
            window.scrollTo({ top: 280, behavior: 'smooth' });
        }

        document.querySelectorAll('.next-step').forEach(btn => {
            btn.addEventListener('click', () => {
                if (currentStep < totalSteps) showStep(currentStep + 1);
            });
        });
        document.querySelectorAll('.prev-step').forEach(btn => {
            btn.addEventListener('click', () => {
                if (currentStep > 1) showStep(currentStep - 1);
            });
        });

        // Country selector toggle
        const countrySelect = document.getElementById("country") as HTMLSelectElement;
        const stateSelectWrapper = document.getElementById("state-select-wrapper");
        const stateSelect = document.getElementById("state") as HTMLSelectElement;
        const stateText = document.getElementById("state-text") as HTMLInputElement;

        if (countrySelect) {
            countrySelect.addEventListener("change", () => {
                const isUS = countrySelect.value === "US";
                if (stateSelectWrapper) stateSelectWrapper.classList.toggle("hidden", !isUS);
                if (stateSelect) stateSelect.required = isUS;
                if (stateText) {
                    stateText.classList.toggle("hidden", isUS);
                    stateText.required = !isUS;
                }
            });
        }

        // Submit
        if (form) {
            form.addEventListener("submit", async (e) => {
                e.preventDefault();
                if (!submitBtn) return;

                const originalText = submitBtn.innerHTML;
                submitBtn.setAttribute("disabled", "true");
                submitBtn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Creating your listing...';

                const formData = new FormData(form);
                const name = formData.get("name") as string || "";
                const city = formData.get("city") as string || "";
                const country = formData.get("country") as string || "US";
                const state = country === "US"
                    ? (formData.get("state") as string || "")
                    : (formData.get("state_text") as string || "");

                try {
                    const res = await fetch("/api/clinics/submit", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            name,
                            address: formData.get("address") || "",
                            city,
                            state,
                            country,
                            zip: formData.get("zip") || "",
                            phone: formData.get("phone") || "",
                            website: formData.get("website") || "",
                            email: formData.get("email") || "",
                            machines: Array.from(formData.getAll("machines")),
                            specialties: Array.from(formData.getAll("treatments")),
                            insurances: Array.from(formData.getAll("insurances")),
                            description: formData.get("description") || "",
                            submitterName: formData.get("submitter_name") || name,
                            submitterEmail: formData.get("submitter_email") || "",
                        }),
                    });

                    if (res.ok) {
                        const data = await res.json();
                        const slug = data.clinic?.slug || `${name}-${city}`.toLowerCase().replace(/[^a-z0-9]+/g, '-');
                        if (clinicLink) { clinicLink.href = `/clinic/${slug}`; clinicLink.textContent = `tmslist.com/clinic/${slug}`; }
                        if (viewClinicBtn) viewClinicBtn.href = `/clinic/${slug}`;
                        form.classList.add("hidden");
                        if (successMessage) successMessage.classList.remove("hidden");
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    } else {
                        const err = await res.json().catch(() => ({ error: 'Something went wrong' }));
                        showToast(err.error || "Something went wrong. Please try again.");
                        submitBtn.removeAttribute("disabled");
                        submitBtn.innerHTML = originalText;
                    }
                } catch {
                    showToast("Network error. Please check your connection and try again.");
                    submitBtn.removeAttribute("disabled");
                    submitBtn.innerHTML = originalText;
                }
            });
        }
    });
</script>

