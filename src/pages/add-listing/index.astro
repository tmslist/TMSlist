<script>
    document.addEventListener("DOMContentLoaded", () => {
        const form = document.getElementById(
            "add-listing-form",
        ) as HTMLFormElement;
        const successMessage = document.getElementById("success-message");
        const submitBtn = document.getElementById("submit-btn");
        const clinicLink = document.getElementById(
            "clinic-link",
        ) as HTMLAnchorElement;
        const viewClinicBtn = document.getElementById(
            "view-clinic-btn",
        ) as HTMLAnchorElement;

        // Generate slug from clinic name and city
        function generateSlug(name: string, city: string): string {
            const combined = `${name}-${city}`;
            return combined
                .toLowerCase()
                .replace(/[^a-z0-9\s-]/g, "")
                .replace(/\s+/g, "-")
                .replace(/-+/g, "-")
                .trim();
        }

        // Generate unique ID
        function generateId(state: string, city: string): string {
            const stateCode = state.toLowerCase();
            const citySlug = city
                .toLowerCase()
                .replace(/\s+/g, "-")
                .substring(0, 10);
            const timestamp = Date.now().toString(36);
            return `user-${stateCode}-${citySlug}-${timestamp}`;
        }

        if (form) {
            form.addEventListener("submit", async (e) => {
                e.preventDefault();
                if (!submitBtn) return;

                const originalText = submitBtn.innerHTML;
                submitBtn.setAttribute("disabled", "true");
                submitBtn.innerHTML = "Submitting...";

                const formData = new FormData(form);
                const name = formData.get("name") as string || "";
                const city = formData.get("city") as string || "";
                const state = formData.get("state") as string || "";

                try {
                    const res = await fetch("/api/clinics/submit", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            name,
                            address: formData.get("address") || "",
                            city,
                            state,
                            zip: formData.get("zip") || "00000",
                            phone: formData.get("phone") || "",
                            website: formData.get("website") || "",
                            email: formData.get("email") || "",
                            machines: Array.from(formData.getAll("machines")),
                            specialties: Array.from(formData.getAll("treatments")),
                            insurances: Array.from(formData.getAll("insurances")),
                            description: formData.get("description") || "",
                            submitterName: formData.get("submitter_name") || name,
                            submitterEmail: formData.get("submitter_email") || "",
                        }),
                    });

                    if (res.ok) {
                        const data = await res.json();
                        const slug = data.clinic?.slug || generateSlug(name, city);
                        if (clinicLink) clinicLink.href = `/clinic/${slug}`;
                        if (viewClinicBtn) viewClinicBtn.href = `/clinic/${slug}`;
                        form.classList.add("hidden");
                        if (successMessage) successMessage.classList.remove("hidden");
                    } else {
                        const err = await res.json();
                        alert(err.error || "Something went wrong. Please try again.");
                        submitBtn.removeAttribute("disabled");
                        submitBtn.innerHTML = originalText;
                    }
                } catch {
                    alert("Network error. Please check your connection and try again.");
                    submitBtn.removeAttribute("disabled");
                    submitBtn.innerHTML = originalText;
                }
            });
        }
    });
</script>

