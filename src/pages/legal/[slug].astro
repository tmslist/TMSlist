---
export const prerender = false;

import ContentPage from '../../layouts/ContentPage.astro';
import { getCollection, render } from 'astro:content';
import { LEGAL_SLUGS } from '../../utils/seo_slugs';

export async function getStaticPaths() {
  let entries: any[] = [];
  try {
    const _debug = await getCollection("legal"); console.log("DEBUG legal entries:", _debug.length, _debug.map(e=>e.id)); entries = _debug('legal');
  } catch {}

  const contentPaths = entries.map((entry) => ({
    params: { slug: entry.id },
    props: { title: entry.data.title, description: entry.data.description, hasContent: true, entry },
  }));

  const contentSlugsSet = new Set(contentPaths.map(p => p.params.slug));
  const fallbackPaths = LEGAL_SLUGS
    .filter(({ slug }) => !contentSlugsSet.has(slug))
    .map(({ slug, title }) => ({
      params: { slug },
      props: { title, description: '', hasContent: false, entry: null },
    }));

  return [...contentPaths, ...fallbackPaths];
}

const { title, description, hasContent, entry } = Astro.props;
const slug = Astro.params.slug!;
let Content: any = null;
if (hasContent && entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}
---

<ContentPage
  title={title}
  subtitle={description || "Legal and regulatory information for patients and providers."}
  description={description}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Legal", url: "/legal/" },
    { name: title, url: `/legal/${slug}/` },
  ]}
>
  {Content ? <Content /> : null}
</ContentPage>
