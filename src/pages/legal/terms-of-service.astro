---
import Layout from "../../layouts/Layout.astro";

const title = "Terms of Service | TMS List";
const description =
    "Terms of Service for using TMS List directory and services.";
const lastUpdated = new Date().toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Terms of Service",
    "description": description,
    "url": `${siteUrl}/legal/terms-of-service/`,
    "isPartOf": { "@type": "WebSite", "name": "TMS List", "url": siteUrl },
    "publisher": { "@type": "Organization", "name": "TMS List", "url": siteUrl },
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Legal", url: "/legal/" },
    { name: "Terms of Service", url: "/legal/terms-of-service/" },
]}>
    <main class="min-h-screen">
        <section class="relative bg-slate-950 overflow-hidden">
            <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.3) 1px, transparent 0); background-size: 32px 32px;"></div>
            <div class="absolute top-[-10%] left-[30%] w-[400px] h-[400px] bg-violet-600/10 rounded-full blur-[120px]"></div>
            <div class="container mx-auto px-4 pt-12 pb-16 lg:pt-16 lg:pb-20 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-500 mb-10" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
                    <span class="text-slate-700">/</span>
                    <a href="/legal/" class="hover:text-violet-400 transition-colors">Legal</a>
                    <span class="text-slate-700">/</span>
                    <span class="text-slate-300">Terms of Service</span>
                </nav>
                <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-white mb-3">Terms of Service</h1>
                <p class="text-slate-400">Last Updated: {lastUpdated}</p>
            </div>
        </section>

        <section class="container mx-auto px-4 py-12 max-w-4xl">

        <div class="prose prose-violet max-w-none">
            <h2>1. Acceptance of Terms</h2>
            <p>
                By accessing or using TMS List (the "Site"), you agree to be
                bound by these Terms of Service. If you do not agree to these
                terms, please do not use the Site.
            </p>

            <h2>2. Description of Service</h2>
            <p>
                TMS List provides a directory of Transcranial Magnetic
                Stimulation (TMS) providers and educational content related to
                mental health treatments. We do not provide medical advice,
                diagnosis, or treatment. The content on this Site is for
                informational purposes only.
            </p>

            <h2>3. No Medical Advice</h2>
            <p>
                THE SITE DOES NOT PROVIDE MEDICAL ADVICE. The contents of the
                Site, such as text, graphics, images, and other material
                contained on the Site ("Content") are for informational purposes
                only. The Content is not intended to be a substitute for
                professional medical advice, diagnosis, or treatment. Always
                seek the advice of your physician or other qualified health
                provider with any questions you may have regarding a medical
                condition.
            </p>

            <h2>4. User Responsibilities</h2>
            <p>
                You agree to use the Site only for lawful purposes. You are
                prohibited from violating or attempting to violate the security
                of the Site, including, without limitation, accessing data not
                intended for you or logging into a server or account which you
                are not authorized to access.
            </p>

            <h2>5. Provider Listings</h2>
            <p>
                We make reasonable efforts to ensure the accuracy of provider
                listings, but we do not warrant that any information is complete
                or error-free. Inclusion of a provider in our directory does not
                imply endorsement by TMS List.
            </p>

            <h2>6. Limitation of Liability</h2>
            <p>
                In no event shall TMS List, its affiliates, or their licensors,
                service providers, employees, agents, officers, or directors be
                liable for damages of any kind, under any legal theory, arising
                out of or in connection with your use, or inability to use, the
                Site.
            </p>

            <h2>7. Changes to Terms</h2>
            <p>
                We may revise and update these Terms of Service from time to
                time in our sole discretion. All changes are effective
                immediately when we post them.
            </p>
        </div>
        </section>
    </main>
</Layout>
