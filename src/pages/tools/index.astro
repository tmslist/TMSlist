---
import Layout from '../../layouts/Layout.astro';
import CostCalculator from '../../components/react/CostCalculator';
import ProtocolExplorer from '../../components/react/ProtocolExplorer';
import SideEffectsTracker from '../../components/react/SideEffectsTracker';
import DeviceComparison from '../../components/react/DeviceComparison';
import TreatmentResponseTracker from '../../components/react/tools/TreatmentResponseTracker';
import PulseCounterSimulator from '../../components/react/tools/PulseCounterSimulator';
import SideEffectsLogger from '../../components/react/tools/SideEffectsLogger';
import SessionReadinessChecklist from '../../components/react/tools/SessionReadinessChecklist';
import MotorThresholdDoseCalculator from '../../components/react/tools/MotorThresholdDoseCalculator';
import ContraindicationChecker from '../../components/react/tools/ContraindicationChecker';
import WhatIfSimulator from '../../components/react/tools/WhatIfSimulator';
import AdverseEventTracker from '../../components/react/tools/AdverseEventTracker';
import InsurancePayerReference from '../../components/react/tools/InsurancePayerReference';
import MTFindingLab from '../../components/react/tools/MTFindingLab';
import TMSECTComparator from '../../components/react/tools/TMSECTComparator';

const title = "TMS Tools Hub | Cost Calculator, Protocol Explorer & All Clinical Tools";
const description = "Free TMS therapy tools — estimate cost, explore protocols, track side effects, motor threshold calculator, what-if simulator, and insurance reference.";

const tools = [
  {
    slug: 'cost-calculator',
    title: 'TMS Cost Calculator',
    description: 'Estimate your total TMS treatment cost with insurance, financing options, and state-by-state pricing data.',
    icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z',
    color: '#4f46e5',
    bg: 'bg-violet-50',
    border: 'border-violet-100',
    badge: 'Most Popular',
    badgeColor: '#4f46e5',
    category: 'patient',
  },
  {
    slug: 'protocol-explorer',
    title: 'Protocol Explorer',
    description: 'Compare TMS treatment protocols — standard rTMS, theta burst, deep TMS, and accelerated schedules.',
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
    color: '#059669',
    bg: 'bg-emerald-50',
    border: 'border-emerald-100',
    badge: 'Clinical',
    badgeColor: '#059669',
    category: 'provider',
  },
  {
    slug: 'side-effects-tracker',
    title: 'Side Effects Tracker',
    description: 'Track common TMS side effects session by session — headache, scalp discomfort, facial twitching, fatigue.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    color: '#dc2626',
    bg: 'bg-red-50',
    border: 'border-red-100',
    badge: 'Free',
    badgeColor: '#dc2626',
    category: 'patient',
  },
  {
    slug: 'device-comparison',
    title: 'Device Comparison',
    description: 'Compare FDA-cleared TMS devices — NeuroStar, BrainsWay, MagVenture, and more.',
    icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
    color: '#0891b2',
    bg: 'bg-cyan-50',
    border: 'border-cyan-100',
    badge: null,
    badgeColor: null,
    category: 'patient',
  },
  {
    slug: 'treatment-response',
    title: 'Response Tracker',
    description: 'Log PHQ-9, HAM-D, and GAD-7 scores week-by-week and compare against clinical benchmarks.',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
    color: '#7c3aed',
    bg: 'bg-violet-50',
    border: 'border-violet-100',
    badge: 'New',
    badgeColor: '#7c3aed',
    category: 'patient',
  },
  {
    slug: 'pulse-counter',
    title: 'Pulse Counter Simulator',
    description: 'Watch iTBS vs rTMS vs Deep TMS deliver pulses in real time. See how session duration changes.',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    color: '#06b6d4',
    bg: 'bg-cyan-50',
    border: 'border-cyan-100',
    badge: 'New',
    badgeColor: '#06b6d4',
    category: 'patient',
  },
  {
    slug: 'readiness-checklist',
    title: 'Session Readiness Checklist',
    description: 'Pre-session checklist for patients — sleep, caffeine, medications, hydration, and mental readiness.',
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
    color: '#f59e0b',
    bg: 'bg-amber-50',
    border: 'border-amber-100',
    badge: null,
    badgeColor: null,
    category: 'patient',
  },
  {
    slug: 'motor-threshold-calculator',
    title: 'Motor Threshold Calculator',
    description: 'Input motor threshold and coil type to get recommended intensity, pulse count, and session time.',
    icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
    color: '#0ea5e9',
    bg: 'bg-sky-50',
    border: 'border-sky-100',
    badge: 'Provider',
    badgeColor: '#0ea5e9',
    category: 'provider',
  },
  {
    slug: 'contraindication-checker',
    title: 'Contraindication Checker',
    description: 'Step-by-step safety checklist — metal implants, medications, seizure history, and protocol recommendations.',
    icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
    color: '#ef4444',
    bg: 'bg-red-50',
    border: 'border-red-100',
    badge: 'Safety',
    badgeColor: '#ef4444',
    category: 'provider',
  },
  {
    slug: 'what-if-simulator',
    title: 'What-If Simulator',
    description: 'Adjust frequency, intensity, pulses, and sessions to see how each parameter changes expected outcomes.',
    icon: 'M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
    color: '#a855f7',
    bg: 'bg-fuchsia-50',
    border: 'border-fuchsia-100',
    badge: 'New',
    badgeColor: '#a855f7',
    category: 'both',
  },
  {
    slug: 'adverse-event-tracker',
    title: 'Adverse Event Tracker',
    description: 'Log and track adverse events during TMS — seizure, syncope, device issues. FDA reporting prompts.',
    icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
    color: '#dc2626',
    bg: 'bg-rose-50',
    border: 'border-rose-100',
    badge: 'Provider',
    badgeColor: '#dc2626',
    category: 'provider',
  },
  {
    slug: 'insurance-reference',
    title: 'Insurance & Payer Reference',
    description: 'CPT codes, payer coverage criteria for Aetna, UHC, BCBS, Medicare, and prior auth templates.',
    icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
    color: '#059669',
    bg: 'bg-emerald-50',
    border: 'border-emerald-100',
    badge: 'Provider',
    badgeColor: '#059669',
    category: 'provider',
  },
  {
    slug: 'mt-finding-lab',
    title: 'Motor Threshold Finding Lab',
    description: 'Interactive simulator teaching how clinicians find motor threshold — coil positioning, EMG waveform, and RMT determination.',
    icon: 'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18',
    color: '#6366f1',
    bg: 'bg-indigo-50',
    border: 'border-indigo-100',
    badge: 'New',
    badgeColor: '#6366f1',
    category: 'provider',
  },
  {
    slug: 'tms-vs-ect',
    title: 'TMS vs ECT vs Medication',
    description: 'Compare efficacy, speed, side effects, cost, and cognitive impact of TMS vs ECT vs antidepressants — with decision framework.',
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
    color: '#f59e0b',
    bg: 'bg-amber-50',
    border: 'border-amber-100',
    badge: 'New',
    badgeColor: '#f59e0b',
    category: 'patient',
  },
];

const stats = [
  { value: '14', label: 'Interactive Tools', color: 'text-violet-600' },
  { value: '50+', label: 'Protocols Covered', color: 'text-emerald-600' },
  { value: '100%', label: 'Free to Use', color: 'text-cyan-600' },
  { value: '0', label: 'Account Required', color: 'text-amber-600' },
];

const schema = JSON.stringify({
  "@context": "https://schema.org", "@type": "CollectionPage",
  "name": "TMS Tools Hub", "description": description,
  "url": "https://tmslist.com/tools/",
  "mainEntity": { "@type": "ItemList", "numberOfItems": tools.length,
    "itemListElement": tools.map((t, i) => ({ "@type": "ListItem", "position": i + 1, "name": t.title, "url": `https://tmslist.com/tools/${t.slug}/` }))
  }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[{ name: "Home", url: "/" }, { name: "Tools", url: "/tools/" }]}>
  <main>
    <!-- Hero -->
    <section class="relative bg-slate-950 overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.35) 1px, transparent 0); background-size: 28px 28px;"></div>
      <div class="absolute top-[-15%] left-[10%] w-[600px] h-[600px] bg-violet-600/10 rounded-full blur-[180px]"></div>
      <div class="absolute bottom-[5%] right-[15%] w-[400px] h-[400px] bg-cyan-500/8 rounded-full blur-[120px]"></div>
      <div class="absolute top-1/2 left-[60%] -translate-y-1/2 w-[300px] h-[300px] bg-fuchsia-600/8 rounded-full blur-[100px]"></div>

      <div class="container mx-auto px-4 pt-14 pb-24 lg:pt-20 lg:pb-32 relative z-10">
        <nav class="flex items-center gap-2 text-sm text-white/40 mb-10" aria-label="Breadcrumb">
          <a href="/" class="hover:text-white/70 transition-colors">Home</a>
          <span class="text-white/20">/</span>
          <span class="text-white/70">Tools</span>
        </nav>
        <div class="max-w-2xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-violet-500/10 border border-violet-500/20 rounded-full mb-6">
            <svg class="w-3.5 h-3.5 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-xs font-semibold text-violet-400 tracking-wider uppercase">Free TMS Tools</span>
          </div>
          <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white leading-[0.95] mb-5">
            TMS<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 to-fuchsia-400">Tools</span> Hub
          </h1>
          <p class="text-lg text-white/50 leading-relaxed max-w-xl">
            Interactive calculators, protocol guides, and trackers to help patients and providers make better TMS decisions — 100% free, no account needed.
          </p>
        </div>

        <!-- Stats -->
        <div class="flex flex-wrap gap-8 mt-14 pt-14 border-t border-white/5">
          {stats.map(stat => (
            <div class="text-left">
              <div class={`text-3xl font-bold ${stat.color} tracking-tight`}>{stat.value}</div>
              <div class="text-sm text-white/40 mt-1">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
      <div class="absolute bottom-0 left-0 right-0 h-20 bg-white" style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"></div>
    </section>

    <!-- Tools Grid -->
    <section class="py-16 lg:py-24 bg-white">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="flex items-center justify-between mb-10">
          <div>
            <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Choose a Tool</h2>
            <p class="text-sm text-slate-500 mt-1">Each tool is interactive and free to use immediately.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {tools.map(tool => (
            <a href={`/tools/${tool.slug}/`} class={`group ${tool.bg} ${tool.border} border rounded-2xl p-8 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 block relative overflow-hidden`}>
              {tool.badge && (
                <div class="absolute top-4 right-4">
                  <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full text-white" style={`background: ${tool.badgeColor};`}>{tool.badge}</span>
                </div>
              )}
              <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6" style={`background: ${tool.color}20;`}>
                <svg class="w-7 h-7" style={`color: ${tool.color};`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={tool.icon}/></svg>
              </div>
              <h3 class="text-xl font-bold text-slate-900 group-hover:text-slate-700 transition-colors mb-3 tracking-tight">{tool.title}</h3>
              <p class="text-sm text-slate-500 leading-relaxed">{tool.description}</p>
              <div class="mt-6 flex items-center gap-1 text-sm font-semibold" style={`color: ${tool.color};`}>
                Open Tool
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </div>
            </a>
          ))}
        </div>

        <!-- Coming Soon Banner -->
        <div class="mt-10 p-6 bg-slate-50 rounded-2xl border border-slate-100 flex flex-col sm:flex-row items-start sm:items-center gap-4">
          <div class="w-10 h-10 rounded-xl bg-slate-100 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          </div>
          <div class="flex-1">
            <p class="text-sm font-bold text-slate-700">More tools coming soon</p>
            <p class="text-xs text-slate-500 mt-0.5">ROI Calculator for clinic owners, Prior Auth Assistant, TMS Session Scheduler, and more.</p>
          </div>
          <a href="mailto:tools@tmslist.com?subject=TMS Tool Request" class="shrink-0 text-xs font-semibold text-violet-600 hover:text-violet-700 transition-colors">Request a Tool →</a>
        </div>
      </div>
    </section>

    <!-- Interactive Tools Section (embedded quick access) -->
    <section class="py-16 lg:py-20 bg-slate-50 border-t border-slate-100">
      <div class="container mx-auto px-4 max-w-6xl">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-slate-900 tracking-tight mb-3">Try a Tool Right Now</h2>
          <p class="text-slate-500">Jump straight into any tool without leaving this page.</p>
        </div>

        <!-- Category filter -->
        <div class="flex items-center gap-2 mb-6 justify-center">
          <button onclick="switchCategory('patient')" id="cat-patient" class="cat-btn px-4 py-2 rounded-xl text-sm font-semibold bg-violet-600 text-white">Patient Tools</button>
          <button onclick="switchCategory('provider')" id="cat-provider" class="cat-btn px-4 py-2 rounded-xl text-sm font-semibold bg-slate-100 text-slate-500 hover:bg-slate-200">Provider Tools</button>
        </div>

        <!-- Patient Tools -->
        <div id="tools-patient" class="tools-category">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
            {[
              { id: 'cost', label: 'Cost Calculator', comp: 'CostCalculator' },
              { id: 'pulse', label: 'Pulse Counter', comp: 'PulseCounterSimulator' },
              { id: 'response', label: 'Response Tracker', comp: 'TreatmentResponseTracker' },
              { id: 'sideeffects2', label: 'Side Effects Logger', comp: 'SideEffectsLogger' },
              { id: 'checklist', label: 'Readiness Checklist', comp: 'SessionReadinessChecklist' },
              { id: 'whatif', label: 'What-If Simulator', comp: 'WhatIfSimulator' },
              { id: 'tmsvsect', label: 'TMS vs ECT', comp: 'TMSECTComparator' },
            ].map(item => (
              <button onclick={`switchTab('${item.id}')`} id={`ttab-${item.id}`} class={`ttab-btn px-4 py-3 rounded-xl text-sm font-semibold transition-all ${item.id === 'cost' ? 'bg-violet-600 text-white' : 'bg-white text-slate-500 hover:bg-slate-100 border border-slate-100'}`}>
                {item.label}
              </button>
            ))}
          </div>
          <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6 lg:p-8">
            <div id="tpanel-cost" class="tab-panel">
              <CostCalculator client:load />
            </div>
            <div id="tpanel-pulse" class="tab-panel hidden">
              <PulseCounterSimulator client:load />
            </div>
            <div id="tpanel-response" class="tab-panel hidden">
              <TreatmentResponseTracker client:load />
            </div>
            <div id="tpanel-sideeffects2" class="tab-panel hidden">
              <SideEffectsLogger client:load />
            </div>
            <div id="tpanel-checklist" class="tab-panel hidden">
              <SessionReadinessChecklist client:load />
            </div>
            <div id="tpanel-whatif" class="tab-panel hidden">
              <WhatIfSimulator client:load />
            </div>
            <div id="tpanel-tmsvsect" class="tab-panel hidden">
              <TMSECTComparator client:load />
            </div>
          </div>
        </div>

        <!-- Provider Tools -->
        <div id="tools-provider" class="tools-category hidden">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
            {[
              { id: 'protocol', label: 'Protocol Explorer', comp: 'ProtocolExplorer' },
              { id: 'calculator', label: 'MT Dose Calculator', comp: 'MotorThresholdDoseCalculator' },
              { id: 'ci', label: 'Contraindication Checker', comp: 'ContraindicationChecker' },
              { id: 'adv', label: 'Adverse Event Tracker', comp: 'AdverseEventTracker' },
              { id: 'insurance', label: 'Insurance Reference', comp: 'InsurancePayerReference' },
              { id: 'mtlab', label: 'MT Finding Lab', comp: 'MTFindingLab' },
            ].map(item => (
              <button onclick={`switchTab('${item.id}')`} id={`ptab-${item.id}`} class={`ptab-btn px-4 py-3 rounded-xl text-sm font-semibold transition-all ${item.id === 'protocol' ? 'bg-emerald-600 text-white' : 'bg-white text-slate-500 hover:bg-slate-100 border border-slate-100'}`}>
                {item.label}
              </button>
            ))}
          </div>
          <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6 lg:p-8">
            <div id="ppanel-protocol" class="tab-panel">
              <ProtocolExplorer client:load />
            </div>
            <div id="ppanel-calculator" class="tab-panel hidden">
              <MotorThresholdDoseCalculator client:load />
            </div>
            <div id="ppanel-ci" class="tab-panel hidden">
              <ContraindicationChecker client:load />
            </div>
            <div id="ppanel-adv" class="tab-panel hidden">
              <AdverseEventTracker client:load />
            </div>
            <div id="ppanel-insurance" class="tab-panel hidden">
              <InsurancePayerReference client:load />
            </div>
            <div id="ppanel-mtlab" class="tab-panel hidden">
              <MTFindingLab client:load />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-white border-t border-slate-100">
      <div class="container mx-auto px-4 max-w-6xl text-center">
        <h2 class="text-3xl font-bold text-slate-900 tracking-tight mb-4">Need a personalized recommendation?</h2>
        <p class="text-slate-500 mb-8 max-w-lg mx-auto">Take our 2-minute eligibility quiz to find out if TMS is right for you, based on clinical criteria used by psychiatrists.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/quiz/am-i-a-candidate/" class="px-8 py-4 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl transition-colors shadow-lg shadow-violet-600/20">Take the Quiz</a>
          <a href="/us/" class="px-8 py-4 bg-white border border-slate-200 hover:border-slate-300 text-slate-700 font-semibold rounded-xl transition-colors">Find a Clinic</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  // Unified tab switcher for both patient and provider tool panels
  function switchTab(tab: string) {
    // Hide all panels
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
    // Reset all tab buttons
    document.querySelectorAll('.ttab-btn').forEach(b => {
      b.classList.remove('bg-violet-600', 'text-white');
      b.classList.add('bg-white', 'text-slate-500', 'border', 'border-slate-100');
    });
    document.querySelectorAll('.ptab-btn').forEach(b => {
      b.classList.remove('bg-emerald-600', 'text-white');
      b.classList.add('bg-white', 'text-slate-500', 'border', 'border-slate-100');
    });
    // Show target panel
    const panels = [
      `tpanel-${tab}`, `ppanel-${tab}`,
    ];
    panels.forEach(id => {
      const p = document.getElementById(id);
      if (p) p.classList.remove('hidden');
    });
    // Activate target button(s)
    const tBtn = document.getElementById(`ttab-${tab}`);
    if (tBtn) {
      tBtn.classList.remove('bg-white', 'text-slate-500', 'border', 'border-slate-100');
      tBtn.classList.add('bg-violet-600', 'text-white');
    }
    const pBtn = document.getElementById(`ptab-${tab}`);
    if (pBtn) {
      pBtn.classList.remove('bg-white', 'text-slate-500', 'border', 'border-slate-100');
      pBtn.classList.add('bg-emerald-600', 'text-white');
    }
  }

  function switchCategory(cat: string) {
    document.querySelectorAll('.tools-category').forEach(c => c.classList.add('hidden'));
    document.querySelectorAll('.cat-btn').forEach(b => {
      b.classList.remove('bg-violet-600', 'bg-emerald-600', 'text-white');
      b.classList.add('bg-slate-100', 'text-slate-500');
    });
    const target = document.getElementById(`tools-${cat}`);
    if (target) target.classList.remove('hidden');
    const btn = document.getElementById(`cat-${cat}`);
    if (btn) {
      btn.classList.remove('bg-slate-100', 'text-slate-500');
      btn.classList.add(cat === 'patient' ? 'bg-violet-600' : 'bg-emerald-600', 'text-white');
    }
    // Switch to first tab in category
    switchTab(cat === 'patient' ? 'cost' : 'protocol');
  }
</script>