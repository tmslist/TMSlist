---
import Layout from '../../layouts/Layout.astro';
import { getClinicsByCountry, COUNTRY_NAMES } from '../../utils/dataHelpers';
import { COUNTRY_META } from '../../utils/countryData';

const countryCode = 'GB';
const clinics = getClinicsByCountry(countryCode);
const meta = COUNTRY_META[countryCode];
const totalClinics = clinics.length;

// Group clinics by region (state field)
const regionMap = new Map<string, number>();
clinics.forEach(c => {
    if (!c.state) return;
    regionMap.set(c.state, (regionMap.get(c.state) || 0) + 1);
});

const regions = [...regionMap.entries()]
    .map(([name, count]) => ({
        name,
        slug: name.toLowerCase().replace(/\s+/g, '-'),
        count,
    }))
    .sort((a, b) => a.name.localeCompare(b.name));

const title = `TMS Therapy UK - Find ${totalClinics}+ Clinics Across the United Kingdom | TMS List`;
const description = `Browse ${totalClinics}+ TMS therapy clinics across ${regions.length} regions in the UK. ${meta.tmsStatus}. Compare NICE-approved providers, read patient reviews, and find treatment near you.`;

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "TMS Therapy Clinics in the United Kingdom",
    "description": description,
    "url": "https://tmslist.com/uk/",
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": regions.length,
        "itemListElement": regions.map((r, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "name": `TMS Clinics in ${r.name}`,
            "url": `https://tmslist.com/uk/${r.slug}/`
        }))
    }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "United Kingdom", url: "/uk/" },
]}>
    <main class="container mx-auto px-4 py-8">
        <nav class="flex text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li class="inline-flex items-center">
                    <a href="/" class="hover:text-gray-900">Home</a>
                </li>
                <li aria-current="page">
                    <div class="flex items-center">
                        <span class="mx-2">/</span>
                        <span class="text-gray-800">United Kingdom</span>
                    </div>
                </li>
            </ol>
        </nav>

        <h1 class="text-3xl font-semibold mb-2">TMS Therapy Clinics Across the United Kingdom</h1>
        <p class="text-gray-600 mb-8 max-w-3xl">Browse {totalClinics}+ {meta.tmsStatus} TMS providers across {regions.length} regions. Find top-rated clinics near you for depression, anxiety, OCD, and more.</p>

        <!-- Key Facts -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-indigo-600">{totalClinics}</div>
                <div class="text-sm text-gray-500 font-medium">UK Clinics</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-indigo-600">{regions.length}</div>
                <div class="text-sm text-gray-500 font-medium">Regions</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-indigo-600">{meta.publicHealthSystem}</div>
                <div class="text-sm text-gray-500 font-medium">Public Health</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-indigo-600">{meta.sessionCostRange}</div>
                <div class="text-sm text-gray-500 font-medium">Per Session</div>
            </div>
        </div>

        <!-- Region Grid -->
        <div class="flex items-center mb-8">
            <h2 class="text-2xl font-semibold text-gray-900">Browse by Region</h2>
            <div class="ml-4 h-px flex-1 bg-gray-200"></div>
            <span class="ml-4 text-sm font-medium text-gray-400">{regions.length} regions</span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {regions.map((region) => (
                <a href={`/uk/${region.slug}/`} class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-indigo-500 hover:shadow-md transition-all group">
                    <span class="text-lg font-medium text-gray-800 group-hover:text-indigo-600">{region.name}</span>
                    <span class="block text-sm text-gray-500 mt-1">{region.count} {region.count === 1 ? 'clinic' : 'clinics'}</span>
                </a>
            ))}
        </div>

        <!-- SEO Content -->
        <section class="mt-16 pt-12 border-t border-gray-100 prose prose-lg max-w-none text-gray-600">
            <h2>About TMS Therapy in the United Kingdom</h2>
            <p>{meta.aboutContent}</p>
            <p>{meta.seoDescription}</p>

            <h3>NHS and Private TMS Treatment</h3>
            <p>{meta.insuranceNote}</p>

            <h3>How to Find the Right TMS Clinic in the UK</h3>
            <p>When choosing a UK TMS clinic, consider whether the clinic uses NICE-approved protocols, the experience of the treating psychiatrist, the TMS technology available (rTMS vs Deep TMS), and patient reviews. Our directory includes verified information about each clinic's technology, specialists, and treatment specialities.</p>

            <h3>Related Resources</h3>
            <ul>
                <li><a href="/treatments/">Conditions Treated with TMS</a> -- depression, anxiety, OCD, PTSD and more</li>
                <li><a href="/technology/">TMS Technology Guide</a> -- compare NeuroStar, BrainsWay, MagVenture</li>
                <li><a href="/insurance/">Insurance Coverage for TMS</a> -- which plans cover treatment</li>
                <li><a href="/specialists/">Find a TMS Specialist</a> -- board-certified psychiatrists</li>
            </ul>
        </section>
    </main>
</Layout>
