---
import Layout from '../../../../layouts/Layout.astro';
import ClinicCard from '../../../../components/ClinicCard.astro';
import { getClinicsByCountry, getClinicRating } from '../../../../utils/dataHelpers';
import { COUNTRY_META } from '../../../../utils/countryData';
import { calculateClinicScore } from '../../../../utils/ranking';

const { region, city } = Astro.params;
const regionSlug = region!;

const allClinics = await getClinicsByCountry('GB');

// Find region name from slug
const regionMatch = allClinics.find(c => c.state && c.state.toLowerCase().replace(/\s+/g, '-') === regionSlug);
if (!regionMatch) return Astro.redirect("/uk/");
const regionName = regionMatch.state;

// Find city name from slug
const cityMatch = allClinics.find(c => c.state === regionName && c.city && c.city.toLowerCase().replace(/\s+/g, '-').replace(/\./g, '') === city);
if (!cityMatch) return Astro.redirect(`/uk/${regionSlug}/`);
const cityName = cityMatch.city;

const cityClinics = allClinics.filter(c => c.state === regionName && c.city === cityName);
const meta = COUNTRY_META['GB'];

// Sort clinics by score
const sortedClinics = [...cityClinics].sort((a: any, b: any) => calculateClinicScore(b) - calculateClinicScore(a));

const title = `TMS Clinics in ${cityName}, ${regionName} UK | TMS List`;
const description = `Compare ${cityClinics.length} TMS therapy clinics in ${cityName}, ${regionName}. View ratings, NHS and private options, treatment technology, and book consultations.`;

const getRating = (clinic: any) => typeof clinic.rating === 'number' ? clinic.rating : clinic.rating?.aggregate || 4.5;

const citySchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `TMS Clinics in ${cityName}, ${regionName}`,
    "description": description,
    "url": `https://tmslist.com/uk/${regionSlug}/${Astro.params.city}/`,
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": cityClinics.length,
        "itemListElement": sortedClinics.slice(0, 10).map((c: any, i: number) => ({
            "@type": "ListItem",
            "position": i + 1,
            "item": {
                "@type": "MedicalClinic",
                "name": c.name,
                "url": `https://tmslist.com/clinic/${c.slug}`,
                "address": {
                    "@type": "PostalAddress",
                    "streetAddress": c.address,
                    "addressLocality": cityName,
                    "addressRegion": regionName,
                    "addressCountry": "GB"
                },
                "telephone": c.contact?.phone || c.phone,
                ...(getRating(c) > 0 ? {
                    "aggregateRating": {
                        "@type": "AggregateRating",
                        "ratingValue": getRating(c),
                        "reviewCount": typeof c.rating === 'object' ? c.rating?.count || 0 : c.review_count || 0
                    }
                } : {})
            }
        }))
    }
});
---

<Layout title={title} description={description} schema={citySchema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "United Kingdom", url: "/uk/" },
    { name: regionName, url: `/uk/${regionSlug}/` },
    { name: cityName, url: `/uk/${regionSlug}/${Astro.params.city}/` },
]}>
    <main class="min-h-screen">
        <!-- Hero Section -->
        <section class="relative bg-white border-b border-slate-100 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
            <div
              class="ai-hero-image absolute inset-0 opacity-20"
              data-subject={`${cityName}, ${regionName}`}
              data-type="city"
              data-cache-key={`ai-img:city:${cityName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}-${regionName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
              data-alt={`Watercolor illustration of ${cityName}, ${regionName}`}
            >
              <div class="ai-img-placeholder absolute inset-0"></div>
              <img class="ai-img-result hidden w-full h-full object-cover" alt="" loading="lazy" />
              <div class="ai-img-fallback hidden"></div>
            </div>
            <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <a href="/uk/" class="hover:text-violet-600 transition-colors">UK</a>
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <a href={`/uk/${regionSlug}/`} class="hover:text-violet-600 transition-colors">{regionName}</a>
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-slate-700 font-medium">{cityName}</span>
                </nav>

                <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-slate-900 mb-6">
                    TMS <span class="text-violet-600">Clinics</span> in {cityName}
                </h1>
                <p class="text-xl text-slate-500 max-w-3xl mb-8">
                    Compare {cityClinics.length} NICE-approved TMS therapy {cityClinics.length === 1 ? 'clinic' : 'clinics'} in {cityName}, {regionName}.
                    View ratings, treatment technology, NHS and private options, and book consultations.
                </p>
            </div>
        </section>

        <!-- Stats Bar -->
        <section class="bg-white border-b border-gray-100 py-6">
            <div class="container mx-auto px-6">
                <div class="flex flex-wrap justify-center gap-8 md:gap-16">
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-violet-600">{cityClinics.length}</div>
                        <div class="text-sm text-gray-500 font-medium">TMS Clinics</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-violet-600">{cityClinics.reduce((acc: number, c: any) => acc + (c.doctors_data?.length || 0), 0)}</div>
                        <div class="text-sm text-gray-500 font-medium">Specialists</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-violet-600">{cityClinics.filter((c: any) => c.verified).length}</div>
                        <div class="text-sm text-gray-500 font-medium">Verified</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Clinics Grid -->
        <section class="py-16">
            <div class="container mx-auto px-6">
                <h2 class="text-3xl font-semibold text-gray-900 mb-10">All TMS Clinics in {cityName}</h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {sortedClinics.map((clinic: any) => (
                        <ClinicCard clinic={clinic} />
                    ))}
                </div>
            </div>
        </section>

        <!-- SEO Content Section -->
        <section class="py-16 bg-white">
            <div class="container mx-auto px-6 max-w-4xl">
                <h2 class="text-3xl font-semibold text-gray-900 mb-8">TMS Therapy in {cityName}, {regionName}</h2>

                <div class="prose prose-lg max-w-none text-gray-600">
                    <p>
                        {cityName}, {regionName} is home to {cityClinics.length} TMS (Transcranial Magnetic Stimulation) therapy {cityClinics.length === 1 ? 'clinic' : 'clinics'}, offering advanced treatment options for depression, anxiety, OCD, and other mental health conditions.
                        Our comprehensive directory helps you compare facilities, read verified reviews, and find the right clinic for your needs.
                    </p>

                    <h3 class="text-xl font-semibold text-gray-900 mt-8 mb-4">Why Choose TMS Therapy?</h3>
                    <p>
                        TMS therapy offers a non-invasive, NICE-approved treatment option for those who haven't found relief from medication alone.
                        Unlike ECT (electroconvulsive therapy), TMS requires no anaesthesia, has minimal side effects, and allows patients to drive themselves to and from treatment.
                        Clinical studies show remission rates of 50-60% for treatment-resistant depression.
                    </p>

                    <h3 class="text-xl font-semibold text-gray-900 mt-8 mb-4">What to Expect at a {cityName} TMS Clinic</h3>
                    <p>
                        Your TMS journey typically begins with a consultation where a psychiatrist evaluates your medical history and treatment goals.
                        If you're a candidate, you'll undergo a brain mapping session to identify the optimal treatment location.
                        Treatment involves sessions over several weeks, with each session lasting 20-40 minutes depending on the protocol used.
                    </p>

                    <h3 class="text-xl font-semibold text-gray-900 mt-8 mb-4">NHS and Private TMS Options in {regionName}</h3>
                    <p>
                        {meta.insuranceNote} Private treatment in {cityName} typically costs between {meta.sessionCostRange} per session.
                        Some clinics offer payment plans to make treatment more accessible.
                    </p>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="py-16 bg-gradient-to-r from-violet-600 to-blue-600">
            <div class="container mx-auto px-6 text-center">
                <h2 class="text-3xl font-semibold text-slate-900 mb-6">Find Your TMS Clinic in {cityName}</h2>
                <p class="text-lg text-slate-500 mb-8 max-w-2xl mx-auto">
                    Compare {cityClinics.length} verified {cityClinics.length === 1 ? 'clinic' : 'clinics'} and start your journey to mental wellness today.
                </p>
                <a href="/quiz/am-i-a-candidate/" class="inline-block px-8 py-4 bg-white text-violet-600 font-semibold rounded-xl hover:bg-gray-100 transition-colors shadow-[0_4px_20px_rgb(0,0,0,0.03)]">
                    Am I a Candidate?
                </a>
            </div>
        </section>
    </main>
</Layout>

<script>
  // AI city hero image with localStorage cache
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;

    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }

    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });
</script>
