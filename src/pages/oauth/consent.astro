---
import Layout from '../../layouts/Layout.astro';
import { getSessionFromRequest } from '../../utils/auth';

const session = getSessionFromRequest(Astro.request);
if (!session) {
  return Astro.redirect('/portal/login');
}

const url = new URL(Astro.request.url);
const clientId = url.searchParams.get('client_id');
const redirectUri = url.searchParams.get('redirect_uri');
const responseType = url.searchParams.get('response_type');
const scope = url.searchParams.get('scope') || 'openid email profile';
const state = url.searchParams.get('state');

// Validate required params
if (!clientId || !redirectUri || responseType !== 'code') {
  return new Response('Invalid OAuth request', { status: 400 });
}

// Fetch app details from Supabase OAuth
const appRes = await fetch('https://ynhgxwkpjbhbqqybyvbj.supabase.co/auth/v1/oauth/apps/' + clientId, {
  headers: {
    Authorization: 'Bearer ' + import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
  },
});

let appName = 'Unknown Application';
if (appRes.ok) {
  const appData = await appRes.json();
  appName = appData.name || appName;
}

// Parse requested scopes
const requestedScopes = scope.split(' ').filter(Boolean);
const scopeDescriptions: Record<string, string> = {
  openid: 'Verify your identity',
  email: 'Access your email address',
  profile: 'Access your name and profile picture',
};
---

<Layout title="Authorize Application">
  <main class="max-w-md mx-auto py-12 px-4">
    <div class="bg-white rounded-xl shadow-lg p-8">
      <div class="text-center mb-8">
        <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Authorize Application</h1>
        <p class="text-gray-600 mt-2"><strong>{appName}</strong> is requesting access to your account.</p>
      </div>

      <div class="border rounded-lg p-4 mb-6 bg-gray-50">
        <h3 class="text-sm font-medium text-gray-700 mb-3">This application will be able to:</h3>
        <ul class="space-y-2">
          {requestedScopes.map((s: string) => (
            <li class="flex items-center text-sm text-gray-600">
              <svg class="w-4 h-4 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              {scopeDescriptions[s] || `Use scope: ${s}`}
            </li>
          ))}
        </ul>
      </div>

      <div class="flex gap-3">
        <form method="POST" action="/api/oauth/consent" class="flex-1">
          <input type="hidden" name="action" value="approve" />
          <input type="hidden" name="client_id" value={clientId} />
          <input type="hidden" name="redirect_uri" value={redirectUri} />
          <input type="hidden" name="state" value={state || ''} />
          <input type="hidden" name="scope" value={scope} />
          <button
            type="submit"
            class="w-full bg-blue-600 text-white py-3 px-4 rounded-lg font-medium hover:bg-blue-700 transition"
          >
            Authorize
          </button>
        </form>
        <form method="POST" action="/api/oauth/consent" class="flex-1">
          <input type="hidden" name="action" value="deny" />
          <input type="hidden" name="redirect_uri" value={redirectUri} />
          <input type="hidden" name="state" value={state || ''} />
          <button
            type="submit"
            class="w-full border border-gray-300 text-gray-700 py-3 px-4 rounded-lg font-medium hover:bg-gray-50 transition"
          >
            Cancel
          </button>
        </form>
      </div>

      <p class="text-xs text-gray-500 text-center mt-6">
        You are signing in as <strong>{session.email}</strong>
      </p>
    </div>
  </main>
</Layout>