---
import Layout from "../layouts/Layout.astro";

const pageTitle = "Join as a TMS Specialist | Psychiatrist Directory | TMS List";
const metaDescription = "Join the TMS List specialist directory. Get NPI-verified credentials, receive patient referrals, and grow your practice.";
---

<Layout title={pageTitle} description={metaDescription}>
  <section class="relative bg-slate-50 overflow-hidden pt-24 pb-20 lg:pt-32 lg:pb-28">
    <!-- Ambient Blurs -->
    <div class="absolute top-0 left-0 w-[600px] h-[600px] bg-violet-100/60 rounded-full blur-[120px] -translate-y-1/2 -translate-x-1/3 pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-blue-50/60 rounded-full blur-[100px] translate-y-1/3 translate-x-1/3 pointer-events-none"></div>
    <div class="absolute inset-0 opacity-[0.02] pointer-events-none" style="background-image: radial-gradient(circle at center, #000 1px, transparent 1px); background-size: 24px 24px;"></div>

    <div class="container mx-auto px-6 lg:px-12 max-w-5xl text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white border border-slate-200/60 rounded-full mb-8 shadow-sm">
        <div class="w-1.5 h-1.5 rounded-full bg-violet-500 animate-pulse"></div>
        <span class="text-[11px] font-bold text-slate-700 tracking-widest uppercase">For Psychiatrists & Specialists</span>
      </div>

      <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tight text-slate-900 leading-[1.05] mb-6">
        Get Found by Patients<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-600 via-fuchsia-500 to-pink-500">Seeking TMS</span>
      </h1>
      <p class="text-lg lg:text-xl text-slate-500 font-light max-w-2xl mx-auto mb-14 leading-relaxed">
        Join our verified specialist directory. We auto-verify your NPI credentials and instantly connect you with patients in your area.
      </p>
    </div>
  </section>

  <main class="bg-white py-16 lg:py-24 relative overflow-hidden">
    <!-- Subtle background accent -->
    <div class="absolute inset-0 bg-slate-50/50 [mask-image:linear-gradient(to_bottom,white,transparent)] z-0"></div>

    <div class="container mx-auto px-6 lg:px-12 max-w-3xl relative z-10">

      <!-- Benefits -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-16">
        <div class="bg-white rounded-3xl border border-slate-200/60 p-6 text-center hover:shadow-xl hover:shadow-slate-200/40 hover:-translate-y-1 transition-all duration-300">
          <div class="w-12 h-12 mx-auto bg-violet-50 rounded-2xl flex items-center justify-center text-violet-600 mb-4 border border-violet-100/50">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          </div>
          <h3 class="text-base font-bold text-slate-900 mb-1">NPI Verified</h3>
          <p class="text-sm text-slate-500 font-light">Auto-verified credentials</p>
        </div>
        <div class="bg-white rounded-3xl border border-slate-200/60 p-6 text-center hover:shadow-xl hover:shadow-slate-200/40 hover:-translate-y-1 transition-all duration-300">
          <div class="w-12 h-12 mx-auto bg-blue-50 rounded-2xl flex items-center justify-center text-blue-600 mb-4 border border-blue-100/50">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <h3 class="text-base font-bold text-slate-900 mb-1">High Intent</h3>
          <p class="text-sm text-slate-500 font-light">Direct patient referrals</p>
        </div>
        <div class="bg-white rounded-3xl border border-slate-200/60 p-6 text-center hover:shadow-xl hover:shadow-slate-200/40 hover:-translate-y-1 transition-all duration-300">
          <div class="w-12 h-12 mx-auto bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600 mb-4 border border-emerald-100/50">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
          </div>
          <h3 class="text-base font-bold text-slate-900 mb-1">Reputation</h3>
          <p class="text-sm text-slate-500 font-light">Verified patient reviews</p>
        </div>
      </div>

      <div class="bg-white rounded-[2rem] border border-slate-200 shadow-xl shadow-slate-200/50 p-8 lg:p-12 relative overflow-hidden">
        <!-- Inner Glow -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-violet-50 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
        
        <div class="relative z-10">
          <h2 class="text-3xl font-extrabold text-slate-900 mb-3 tracking-tight">Join as a Specialist</h2>
          <p class="text-slate-500 mb-8 font-light text-lg">We'll create your profile and verify your credentials automatically.</p>

          <form id="specialist-signup-form" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Full Name (with credentials) <span class="text-red-400">*</span></label>
                <input type="text" name="name" required placeholder="Dr. Jane Smith, MD" class="w-full px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-200 focus:bg-white focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 text-sm text-slate-900 placeholder-slate-400 transition-all" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Email <span class="text-red-400">*</span></label>
                <input type="email" name="email" required placeholder="jane@clinic.com" class="w-full px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-200 focus:bg-white focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 text-sm text-slate-900 placeholder-slate-400 transition-all" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">NPI Number <span class="text-slate-400 font-normal">(optional)</span></label>
                <input type="text" name="npi" maxlength="10" placeholder="10-digit NPI" class="w-full px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-200 focus:bg-white focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 text-sm text-slate-900 placeholder-slate-400 transition-all" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Specialty <span class="text-red-400">*</span></label>
                <select name="specialty" required class="w-full px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-200 focus:bg-white focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 text-sm text-slate-900 transition-all">
                  <option value="">Select...</option>
                  <option value="Psychiatrist">Psychiatrist (MD/DO)</option>
                  <option value="Neurologist">Neurologist</option>
                  <option value="Psychiatric NP">Psychiatric Nurse Practitioner</option>
                  <option value="Psychologist">Psychologist</option>
                  <option value="TMS Technician">TMS Technician</option>
                  <option value="Other">Other</option>
                </select>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Practice/Clinic Name</label>
                <input type="text" name="clinicName" placeholder="TMS Institute" class="w-full px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-200 focus:bg-white focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 text-sm text-slate-900 placeholder-slate-400 transition-all" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">State <span class="text-red-400">*</span></label>
                <input type="text" name="state" required maxlength="2" placeholder="CA" class="w-full px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-200 focus:bg-white focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 text-sm text-slate-900 placeholder-slate-400 transition-all" />
              </div>
            </div>

            <div id="form-message" class="hidden px-5 py-4 rounded-xl text-sm font-medium"></div>

            <button type="submit" class="w-full py-4 bg-gradient-to-r from-violet-600 to-fuchsia-600 hover:from-violet-700 hover:to-fuchsia-700 text-white font-bold rounded-xl text-[15px] transition-all shadow-lg shadow-violet-600/20 hover:shadow-violet-600/30 active:scale-[0.98]">
              Join the Specialist Directory (Free)
            </button>
          </form>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  document.getElementById('specialist-signup-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const msgEl = document.getElementById('form-message')!;

    const data = {
      segment: 'specialist',
      name: (form.querySelector('[name="name"]') as HTMLInputElement).value,
      email: (form.querySelector('[name="email"]') as HTMLInputElement).value,
      specialty: (form.querySelector('[name="specialty"]') as HTMLSelectElement).value,
      clinicName: (form.querySelector('[name="clinicName"]') as HTMLInputElement).value,
      state: (form.querySelector('[name="state"]') as HTMLInputElement).value,
      source: 'for-specialists-page',
    };

    try {
      const res = await fetch('/api/funnel/enter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.classList.add('hidden');
        msgEl.textContent = 'Welcome! Check your email — we\'ll verify your credentials and set up your profile.';
        msgEl.className = 'px-4 py-3 rounded-xl text-sm font-medium bg-emerald-50 text-emerald-700 border border-emerald-100';
        msgEl.classList.remove('hidden');
      } else {
        msgEl.textContent = 'Something went wrong. Please try again.';
        msgEl.className = 'px-4 py-3 rounded-xl text-sm font-medium bg-red-50 text-red-700 border border-red-100';
        msgEl.classList.remove('hidden');
      }
    } catch {
      msgEl.textContent = 'Network error. Please try again.';
      msgEl.className = 'px-4 py-3 rounded-xl text-sm font-medium bg-red-50 text-red-700 border border-red-100';
      msgEl.classList.remove('hidden');
    }
  });
</script>
