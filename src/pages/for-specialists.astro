---
import Layout from "../layouts/Layout.astro";

const pageTitle = "Join as a TMS Specialist | Psychiatrist Directory | TMS List";
const metaDescription = "Join the TMS List specialist directory. Get NPI-verified credentials, receive patient referrals, and grow your practice.";
---

<Layout title={pageTitle} description={metaDescription}>
  <section class="bg-gradient-to-b from-blue-900 to-blue-800 text-white pt-20 pb-24">
    <div class="container mx-auto px-6 lg:px-12 max-w-5xl text-center">
      <span class="inline-block px-4 py-1.5 bg-white/10 text-blue-300 text-xs font-bold rounded-full uppercase tracking-wider mb-6">For Psychiatrists & Specialists</span>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">
        Get Found by Patients Seeking TMS
      </h1>
      <p class="text-lg text-blue-200 font-light max-w-2xl mx-auto mb-10">
        Join our verified specialist directory. We'll auto-verify your NPI credentials and connect you with patients in your area.
      </p>
    </div>
  </section>

  <main class="bg-slate-50/50 py-12">
    <div class="container mx-auto px-6 lg:px-12 max-w-3xl">

      <!-- Benefits -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
        <div class="bg-white rounded-2xl border border-slate-100 p-5 text-center shadow-sm">
          <div class="w-10 h-10 mx-auto bg-blue-50 rounded-xl flex items-center justify-center text-blue-600 mb-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          </div>
          <h3 class="text-sm font-bold text-slate-900 mb-1">NPI Verified</h3>
          <p class="text-xs text-slate-500">Auto-verified credentials via NPI Registry</p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 p-5 text-center shadow-sm">
          <div class="w-10 h-10 mx-auto bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-600 mb-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <h3 class="text-sm font-bold text-slate-900 mb-1">Patient Referrals</h3>
          <p class="text-xs text-slate-500">Patients find you directly</p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 p-5 text-center shadow-sm">
          <div class="w-10 h-10 mx-auto bg-amber-50 rounded-xl flex items-center justify-center text-amber-600 mb-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
          </div>
          <h3 class="text-sm font-bold text-slate-900 mb-1">Build Reputation</h3>
          <p class="text-xs text-slate-500">Collect verified patient reviews</p>
        </div>
      </div>

      <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-8">
        <h2 class="text-2xl font-bold text-slate-900 mb-2">Join as a Specialist</h2>
        <p class="text-slate-500 mb-6">We'll create your profile and verify your credentials automatically.</p>

        <form id="specialist-signup-form" class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">Full Name (with credentials) *</label>
              <input type="text" name="name" required placeholder="Dr. Jane Smith, MD" class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">Email *</label>
              <input type="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">NPI Number (optional)</label>
              <input type="text" name="npi" maxlength="10" placeholder="10-digit NPI" class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">Specialty *</label>
              <select name="specialty" required class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100">
                <option value="">Select...</option>
                <option value="Psychiatrist">Psychiatrist (MD/DO)</option>
                <option value="Neurologist">Neurologist</option>
                <option value="Psychiatric NP">Psychiatric Nurse Practitioner</option>
                <option value="Psychologist">Psychologist</option>
                <option value="TMS Technician">TMS Technician</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">Practice/Clinic Name</label>
              <input type="text" name="clinicName" class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">State *</label>
              <input type="text" name="state" required maxlength="2" placeholder="e.g. CA" class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
            </div>
          </div>

          <div id="form-message" class="hidden px-4 py-3 rounded-xl text-sm font-medium"></div>

          <button type="submit" class="w-full py-3.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl text-sm transition-all shadow-sm">
            Join the Specialist Directory (Free)
          </button>
        </form>
      </div>
    </div>
  </main>
</Layout>

<script>
  document.getElementById('specialist-signup-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const msgEl = document.getElementById('form-message')!;

    const data = {
      segment: 'specialist',
      name: (form.querySelector('[name="name"]') as HTMLInputElement).value,
      email: (form.querySelector('[name="email"]') as HTMLInputElement).value,
      specialty: (form.querySelector('[name="specialty"]') as HTMLSelectElement).value,
      clinicName: (form.querySelector('[name="clinicName"]') as HTMLInputElement).value,
      state: (form.querySelector('[name="state"]') as HTMLInputElement).value,
      source: 'for-specialists-page',
    };

    try {
      const res = await fetch('/api/funnel/enter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.classList.add('hidden');
        msgEl.textContent = 'Welcome! Check your email — we\'ll verify your credentials and set up your profile.';
        msgEl.className = 'px-4 py-3 rounded-xl text-sm font-medium bg-emerald-50 text-emerald-700 border border-emerald-100';
        msgEl.classList.remove('hidden');
      } else {
        msgEl.textContent = 'Something went wrong. Please try again.';
        msgEl.className = 'px-4 py-3 rounded-xl text-sm font-medium bg-red-50 text-red-700 border border-red-100';
        msgEl.classList.remove('hidden');
      }
    } catch {
      msgEl.textContent = 'Network error. Please try again.';
      msgEl.className = 'px-4 py-3 rounded-xl text-sm font-medium bg-red-50 text-red-700 border border-red-100';
      msgEl.classList.remove('hidden');
    }
  });
</script>
