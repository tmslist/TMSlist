---
export const prerender = false;
const title = "Is TMS FDA-Approved? - TMS List FAQ";
const description = "Direct answer: TMS is FDA-cleared for treatment-resistant depression, OCD, and smoking cessation. Other uses are off-label.";

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "Is TMS FDA-approved?",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "TMS is FDA-cleared for treatment-resistant major depressive disorder, obsessive-compulsive disorder, and smoking cessation. The FDA cleared TMS devices from NeuroStar, BrainsWay, and MagVenture for these indications. Other applications such as anxiety and PTSD are used off-label with growing clinical evidence."
    }
  }]
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href="https://tmslist.com/faqs/tms-fda-approval/">
  <script type="application/ld+json" set:html={faqSchema}></script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col">
  <main class="flex-1 container mx-auto px-4 py-8 max-w-2xl">
    <article>
      <header class="mb-6">
        <p class="text-sm text-slate-500 mb-2">TMS List FAQ</p>
        <h1 class="text-2xl font-bold text-slate-900">Is TMS FDA-Approved?</h1>
      </header>

      <div class="bg-white rounded-xl border border-slate-200 p-6">
        <p class="text-slate-700 leading-relaxed">
          TMS is FDA-cleared for <strong>treatment-resistant major depressive disorder (2008)</strong>, <strong>obsessive-compulsive disorder</strong>, and <strong>smoking cessation</strong>. The FDA cleared TMS devices from NeuroStar, BrainsWay, and MagVenture for these indications. Other applications such as anxiety and PTSD are used off-label with growing clinical evidence.
        </p>
      </div>

      <div class="mt-8 text-center">
        <a href="/treatments/" class="text-violet-600 font-medium hover:text-violet-700">View all TMS treatments →</a>
      </div>
    </article>
  </main>

  <footer class="py-4 text-center text-xs text-slate-400">
    <a href="/" class="hover:text-violet-600">TMS List</a>
  </footer>
</body>
</html>
