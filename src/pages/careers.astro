---
export const prerender = true;

import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Careers at TMS List — Join Our Team"
    description="We're building the leading TMS therapy directory. Explore open roles in engineering, content, and sales."
>
    <section class="container mx-auto px-4 lg:px-8 py-20 max-w-4xl">
        <div class="text-center mb-16">
            <span class="inline-flex items-center gap-1.5 bg-violet-100 text-violet-700 text-xs font-semibold px-3 py-1 rounded-full mb-4">
                <span class="w-1.5 h-1.5 bg-violet-400 rounded-full animate-pulse"></span>
                Actively Hiring
            </span>
            <h1 class="text-4xl lg:text-5xl font-extrabold text-slate-900 mb-4">
                Join the TMS List Team
            </h1>
            <p class="text-lg text-slate-600 max-w-2xl mx-auto">
                We're making TMS therapy accessible to millions of people worldwide.
                Help us build the most trusted directory in mental healthcare.
            </p>
        </div>

        <!-- Values -->
        <div class="grid grid-cols-3 gap-6 mb-16">
            {[
                { icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z", title: "Mission-Driven", desc: "Every feature we build helps real patients find treatment." },
                { icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z", title: "Small, Focused Team", desc: "You'll own meaningful work with real impact." },
                { icon: "M13 10V3L4 14h7v7l9-11h-7z", title: "Remote-First", desc: "Work from anywhere. Async by default." },
            ].map((v) => (
                <div class="bg-slate-50 rounded-2xl p-6 text-center">
                    <div class="w-12 h-12 rounded-xl bg-violet-100 flex items-center justify-center mx-auto mb-4">
                        <svg class="w-6 h-6 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={v.icon} />
                        </svg>
                    </div>
                    <h3 class="font-bold text-slate-800 mb-2">{v.title}</h3>
                    <p class="text-sm text-slate-500">{v.desc}</p>
                </div>
            ))}
        </div>

        <!-- Open Roles -->
        <div class="mb-16">
            <h2 class="text-2xl font-bold text-slate-900 mb-6">Open Roles</h2>
            <div class="space-y-4">
                {[
                    { title: "Senior Frontend Engineer", type: "Engineering", location: "Remote", desc: "Build next-gen patient-facing features with React and Astro." },
                    { title: "Content Writer — TMS & Mental Health", type: "Content", location: "Remote", desc: "Write evidence-based articles that help patients understand their options." },
                    { title: "Business Development Manager", type: "Sales", location: "Remote", desc: "Grow our clinic partner network across the US and internationally." },
                    { title: "SEO & Growth Marketer", type: "Marketing", location: "Remote", desc: "Drive organic traffic and improve search rankings for 1,100+ clinic pages." },
                ].map((role) => (
                    <div class="border border-slate-200 rounded-xl p-6 hover:border-violet-200 hover:shadow-sm transition-all">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <h3 class="font-semibold text-slate-800 mb-1">{role.title}</h3>
                                <p class="text-sm text-slate-500 mb-3">{role.desc}</p>
                                <div class="flex items-center gap-2">
                                    <span class="text-xs font-medium bg-slate-100 text-slate-600 px-2.5 py-1 rounded-full">{role.type}</span>
                                    <span class="text-xs font-medium bg-emerald-50 text-emerald-700 px-2.5 py-1 rounded-full">{role.location}</span>
                                </div>
                            </div>
                            <a
                                href="/contact/"
                                class="shrink-0 inline-flex items-center px-5 py-2.5 bg-violet-600 hover:bg-violet-700 text-white text-sm font-semibold rounded-lg transition-colors"
                            >
                                Apply
                            </a>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Speculative Apply CTA -->
        <div class="bg-gradient-to-r from-violet-600 to-purple-700 rounded-2xl p-8 text-center text-white">
            <h2 class="text-2xl font-bold mb-2">Don't see your role?</h2>
            <p class="text-violet-100 mb-6">We're a small team growing quickly. Send us your background and we'll reach out when a fit opens up.</p>
            <a
                href="/contact/"
                class="inline-flex items-center px-6 py-3 bg-white text-violet-700 font-semibold rounded-xl hover:bg-violet-50 transition-colors"
            >
                Get in Touch
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
            </a>
        </div>
    </section>
</Layout>
