---
import Layout from '../../layouts/Layout.astro';
import { tmsNews, categoryLabels, getNewsByCategory } from '../../data/tmsNews';

const title = "TMS News & Industry Updates | Latest Research & FDA Approvals";
const description = "Stay current with TMS therapy news — FDA approvals, clinical trial results, insurance coverage updates, and industry breakthroughs.";
const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";

const sortedNews = [...tmsNews].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const categories = Object.entries(categoryLabels) as [TMSNewsItem['category'], string][];
const recentNews = sortedNews.slice(0, 5);
const featured = sortedNews[0];
---

<Layout title={title} description={description}>
    <main class="min-h-screen">
        <!-- Hero -->
        <section class="relative bg-white border-b border-slate-100 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
            <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                    <span class="text-slate-300">/</span>
                    <span class="text-slate-700 font-medium">News</span>
                </nav>
                <div class="max-w-3xl">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-violet-50 border border-violet-100 rounded-full mb-6">
                        <span class="flex h-2 w-2 rounded-full bg-violet-500"></span>
                        <span class="text-xs font-semibold text-violet-700 tracking-wide">Updated Weekly</span>
                    </div>
                    <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 mb-4 leading-tight">
                        TMS <span class="text-violet-600">News</span> & Industry Updates
                    </h1>
                    <p class="text-lg text-slate-500 leading-relaxed">
                        The latest FDA approvals, clinical trial results, insurance coverage changes, and breakthrough research in transcranial magnetic stimulation.
                    </p>
                </div>
            </div>
        </section>

        <!-- Featured Story -->
        {featured && (
            <section class="bg-slate-50 border-b border-slate-100 py-10">
                <div class="container mx-auto px-4 max-w-6xl">
                    <div class="flex items-center gap-2 mb-5">
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Featured Story</span>
                    </div>
                    <a href={featured.url} class="group block bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md hover:border-violet-200 transition-all overflow-hidden">
                        <div class="grid md:grid-cols-2 gap-0">
                            <div class="p-8 flex flex-col justify-center">
                                <div class="flex items-center gap-3 mb-3">
                                    <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${
                                        featured.category === 'breakthrough' ? 'bg-violet-100 text-violet-700' :
                                        featured.category === 'fda' ? 'bg-emerald-100 text-emerald-700' :
                                        featured.category === 'clinical-trial' ? 'bg-blue-100 text-blue-700' :
                                        featured.category === 'study' ? 'bg-purple-100 text-purple-700' :
                                        featured.category === 'insurance' ? 'bg-amber-100 text-amber-700' :
                                        'bg-slate-100 text-slate-600'
                                    }`}>
                                        {categoryLabels[featured.category]}
                                    </span>
                                    <span class="text-xs text-slate-400">{new Date(featured.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                                </div>
                                <h2 class="text-2xl font-bold text-slate-900 group-hover:text-violet-600 transition-colors mb-3 leading-tight">{featured.headline}</h2>
                                <p class="text-slate-500 leading-relaxed mb-4">{featured.summary}</p>
                                <div class="flex items-center gap-2 text-blue-600 font-semibold text-sm">
                                    <span>Read Full Coverage</span>
                                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                </div>
                            </div>
                            <div class="bg-gradient-to-br from-violet-100 to-blue-100 flex items-center justify-center p-8 min-h-[200px]">
                                <div class="w-16 h-16 rounded-2xl bg-violet-500/20 flex items-center justify-center">
                                    <svg class="w-8 h-8 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 12h10"/></svg>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            </section>
        )}

        <!-- Category Filter + News Grid -->
        <section class="py-12 lg:py-16">
            <div class="container mx-auto px-4 max-w-6xl">
                <div class="flex flex-col lg:flex-row gap-10">
                    <!-- Main Content -->
                    <div class="flex-1">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
                                <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 12h10"/></svg>
                            </div>
                            <h2 class="text-2xl font-bold text-slate-900">Latest Updates</h2>
                        </div>

                        <div class="space-y-4">
                            {sortedNews.map((item, index) => (
                                <article class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6 hover:shadow-md hover:border-violet-200 transition-all">
                                    <div class="flex items-start gap-4">
                                        <div class="flex-1">
                                            <div class="flex flex-wrap items-center gap-2 mb-2">
                                                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${
                                                    item.category === 'breakthrough' ? 'bg-violet-100 text-violet-700' :
                                                    item.category === 'fda' ? 'bg-emerald-100 text-emerald-700' :
                                                    item.category === 'clinical-trial' ? 'bg-blue-100 text-blue-700' :
                                                    item.category === 'study' ? 'bg-purple-100 text-purple-700' :
                                                    item.category === 'insurance' ? 'bg-amber-100 text-amber-700' :
                                                    'bg-slate-100 text-slate-600'
                                                }`}>
                                                    {categoryLabels[item.category]}
                                                </span>
                                                <span class="text-xs text-slate-400">{item.source}</span>
                                                <span class="text-xs text-slate-300">·</span>
                                                <span class="text-xs text-slate-400">{new Date(item.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                                            </div>
                                            <h3 class="text-lg font-bold text-slate-900 mb-2 leading-snug">
                                                <a href={item.url} class="hover:text-violet-600 transition-colors">{item.headline}</a>
                                            </h3>
                                            <p class="text-slate-500 text-sm leading-relaxed mb-3">{item.summary}</p>
                                            <a href={item.url} class="inline-flex items-center gap-1 text-blue-600 font-semibold text-sm hover:text-violet-600 transition-colors">
                                                Read more
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                            </a>
                                        </div>
                                    </div>
                                </article>
                            ))}
                        </div>
                    </div>

                    <!-- Sidebar -->
                    <aside class="lg:w-80 shrink-0">
                        <!-- Categories -->
                        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6 mb-6 sticky top-6">
                            <h3 class="text-sm font-bold text-slate-900 mb-4 uppercase tracking-wider">Categories</h3>
                            <div class="space-y-1">
                                {categories.map(([key, label]) => {
                                    const count = getNewsByCategory(key).length;
                                    return (
                                        <div class="flex items-center justify-between py-2 px-3 rounded-lg hover:bg-slate-50 transition-colors cursor-pointer group">
                                            <span class="text-sm text-slate-600 group-hover:text-slate-900">{label}</span>
                                            <span class="text-xs text-slate-400 font-medium">{count}</span>
                                        </div>
                                    );
                                })}
                            </div>
                        </div>

                        <!-- CTA Box -->
                        <div class="bg-gradient-to-br from-violet-600 to-violet-600 rounded-2xl p-6 text-white">
                            <h3 class="font-bold text-lg mb-2">Stay on Top of TMS</h3>
                            <p class="text-violet-100 text-sm mb-5 leading-relaxed">Get the TMS Buyer's Guide and check your eligibility in minutes.</p>
                            <a href="/quiz/am-i-a-candidate/" class="block w-full text-center px-5 py-3 bg-white text-violet-700 font-semibold rounded-xl hover:bg-violet-50 transition-all text-sm mb-3">
                                Am I a Candidate? →
                            </a>
                            <a href="/resources/buyers-guide/" class="block w-full text-center px-5 py-3 bg-white/10 border border-white/20 text-white font-semibold rounded-xl hover:bg-white/20 transition-all text-sm">
                                Download Buyer's Guide
                            </a>
                            <div class="mt-4 pt-4 border-t border-white/10">
                                <a href="/us/" class="flex items-center justify-center gap-2 text-sm text-violet-200 hover:text-white transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                    Find a TMS Clinic
                                </a>
                            </div>
                        </div>
                    </aside>
                </div>
            </div>
        </section>

        <!-- Disclaimer -->
        <section class="py-6 border-t border-slate-100">
            <div class="container mx-auto px-4 max-w-6xl">
                <div class="p-5 bg-blue-50/50 border border-blue-100 rounded-xl">
                    <p class="text-xs text-slate-500">
                        <strong>Disclaimer:</strong> News items are for informational purposes only and do not constitute medical advice. Always consult a qualified healthcare provider regarding treatment decisions.
                    </p>
                </div>
            </div>
        </section>

        <!-- End-of-page CTA -->
        <section class="py-14 lg:py-20 bg-gradient-to-br from-violet-600 to-violet-600 border-t border-slate-100">
            <div class="container mx-auto px-4 max-w-4xl text-center">
                <p class="text-xs font-semibold text-violet-200 tracking-wider uppercase mb-3">Take the Next Step</p>
                <h2 class="text-2xl lg:text-3xl font-bold text-white mb-4 tracking-tight">Ready to Explore TMS Treatment?</h2>
                <p class="text-violet-100 mb-8 max-w-xl mx-auto leading-relaxed">With all this promising research, see if TMS is right for you.</p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="/quiz/am-i-a-candidate/" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-violet-700 font-semibold rounded-xl shadow-lg hover:bg-violet-50 transition-all">
                        Take the Eligibility Quiz
                    </a>
                    <a href="/us/" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/10 border border-white/30 hover:bg-white/20 text-white font-semibold rounded-xl transition-all backdrop-blur">
                        Find a TMS Clinic
                    </a>
                </div>
                <p class="text-xs text-violet-200 mt-4">Also: <a href="/resources/buyers-guide/" class="underline hover:text-white font-medium">download the free TMS Buyer's Guide</a></p>
            </div>
        </section>
    </main>
</Layout>