---
import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import EditorialSection from '../../components/editorial/EditorialSection.astro';
import EditorialCTA from '../../components/editorial/EditorialCTA.astro';
import { tmsNews, categoryLabels, getNewsByCategory } from '../../data/tmsNews';

const title = "TMS News & Industry Updates | Latest Research & FDA Approvals";
const description = "Stay current with TMS therapy news — FDA approvals, clinical trial results, insurance coverage updates, and industry breakthroughs.";

const sortedNews = [...tmsNews].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const categories = Object.entries(categoryLabels) as [keyof typeof categoryLabels, string][];
const featured = sortedNews[0];

const tagToneFor = (cat: string): 'success' | 'accent' | 'warm' | 'muted' =>
  cat === 'fda' ? 'success' :
  cat === 'breakthrough' || cat === 'clinical-trial' ? 'accent' :
  cat === 'insurance' || cat === 'study' ? 'warm' : 'muted';
---

<Layout title={title} description={description}>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow="Updated Weekly"
    eyebrowDot="#22c55e"
    title="The latest in"
    titleAccent="TMS therapy."
    description="FDA approvals, clinical trial results, insurance coverage changes, and breakthrough research in transcranial magnetic stimulation."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "News" }]}
    ctas={[
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: "Browse Research", href: "/research/", variant: "outline" },
    ]}
    stats={[
      { value: sortedNews.length, label: "Stories", color: "ink" },
      { value: categories.length, label: "Categories", color: "accent" },
      { value: "Weekly", label: "Updates", color: "warm" },
    ]}
  />

  {featured && (
    <EditorialSection
      title="Featured Story"
      intro="Our pick of the latest must-read TMS news."
      icon='<path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.196-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>'
      tone="warm"
    >
      <a
        href={`/news/${featured.id}/`}
        style="background:var(--paper2); border:1px solid var(--line); border-radius:1.5rem; padding:2rem; display:block; transition:box-shadow 0.2s, transform 0.2s; text-decoration:none;"
        class="hover:shadow-lg hover:-translate-y-0.5"
      >
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span style={`font-size:11px; font-weight:600; padding:0.25rem 0.625rem; border-radius:9999px; text-transform:uppercase; letter-spacing:0.075em; background:rgba(34,197,94,0.12); color:#16a34a; border:1px solid rgba(34,197,94,0.2);`}>{categoryLabels[featured.category]}</span>
          <span style="font-size:12px; color:var(--muted);">{new Date(featured.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
        </div>
        <h3 class="serif" style="font-size:2rem; line-height:1.15; color:var(--ink); margin:0 0 0.875rem;">{featured.headline}</h3>
        <p style="font-size:15px; color:var(--muted); line-height:1.65; margin:0 0 1rem;">{featured.summary}</p>
        <span style="display:inline-flex; align-items:center; gap:0.375rem; color:var(--accent); font-size:14px; font-weight:600;">Read full coverage →</span>
      </a>
    </EditorialSection>
  )}

  <EditorialSection
    title="Latest Updates"
    intro={`${sortedNews.length} stories on FDA approvals, clinical trials, and emerging research.`}
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 12h10"/>'
    tone="accent"
    background="paper2"
    noBorder
  >
    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="flex flex-col gap-4">
          {sortedNews.map((item) => {
            const tone = tagToneFor(item.category);
            const tagBg = tone === 'success' ? 'rgba(34,197,94,0.12)' : tone === 'warm' ? 'rgba(201,101,74,0.12)' : tone === 'accent' ? 'rgba(10,22,40,0.1)' : 'rgba(90,107,130,0.12)';
            const tagColor = tone === 'success' ? '#16a34a' : tone === 'warm' ? 'var(--warm)' : tone === 'accent' ? 'var(--accent)' : 'var(--muted)';
            return (
              <article style="background:var(--paper); border:1px solid var(--line); border-radius:1.25rem; padding:1.5rem; transition:box-shadow 0.2s;" class="hover:shadow-lg">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span style={`font-size:11px; font-weight:600; padding:0.25rem 0.625rem; border-radius:9999px; text-transform:uppercase; letter-spacing:0.075em; background:${tagBg}; color:${tagColor};`}>{categoryLabels[item.category]}</span>
                  <span style="font-size:12px; color:var(--muted);">{item.source}</span>
                  <span style="font-size:12px; color:var(--muted);">·</span>
                  <span style="font-size:12px; color:var(--muted);">{new Date(item.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                </div>
                <h3 class="serif" style="font-size:1.25rem; line-height:1.2; margin:0 0 0.5rem;"><a href={`/news/${item.id}/`} style="color:var(--ink); text-decoration:none;">{item.headline}</a></h3>
                <p style="font-size:14px; color:var(--muted); line-height:1.65; margin:0 0 0.75rem;">{item.summary}</p>
                <a href={`/news/${item.id}/`} style="display:inline-flex; align-items:center; gap:0.25rem; color:var(--accent); font-size:13px; font-weight:600; text-decoration:none;">Read more →</a>
              </article>
            );
          })}
        </div>
      </div>

      <aside class="lg:sticky lg:top-24 self-start">
        <div style="background:var(--paper); border:1px solid var(--line); border-radius:1.5rem; padding:1.5rem; margin-bottom:1.25rem;">
          <h3 class="serif" style="font-size:1.125rem; color:var(--ink); margin:0 0 1rem;">Categories</h3>
          <div class="flex flex-col gap-1">
            {categories.map(([key, label]) => {
              const count = getNewsByCategory(key as any).length;
              return (
                <div class="flex items-center justify-between py-2" style="border-top:1px solid var(--line);">
                  <span style="font-size:14px; color:var(--ink2);">{label}</span>
                  <span style="font-size:12px; color:var(--muted); font-weight:500;">{count}</span>
                </div>
              );
            })}
          </div>
        </div>

        <div style="background:var(--ink); border-radius:1.5rem; padding:1.5rem; color:white;">
          <h3 class="serif" style="font-size:1.25rem; margin:0 0 0.5rem;">Stay on top of TMS</h3>
          <p style="font-size:13px; color:rgba(255,255,255,0.6); line-height:1.6; margin:0 0 1.25rem;">Check your eligibility and get matched to verified TMS clinics.</p>
          <a href="/quiz/am-i-a-candidate/" style="display:block; text-align:center; padding:0.75rem 1rem; background:var(--warm); color:white; font-size:13px; font-weight:600; border-radius:0.75rem; text-decoration:none; margin-bottom:0.5rem;">Am I a Candidate?</a>
          <a href="/us/" style="display:block; text-align:center; padding:0.75rem 1rem; border:1px solid rgba(255,255,255,0.2); color:rgba(255,255,255,0.8); font-size:13px; font-weight:500; border-radius:0.75rem; text-decoration:none;">Find a Clinic</a>
        </div>
      </aside>
    </div>

    <div style="margin-top:2rem; padding:1rem 1.25rem; background:var(--paper); border:1px solid var(--line); border-radius:0.75rem;">
      <p style="font-size:12px; color:var(--muted); margin:0;"><strong style="color:var(--ink2);">Disclaimer:</strong> News items are for informational purposes only and do not constitute medical advice. Always consult a qualified healthcare provider regarding treatment decisions.</p>
    </div>
  </EditorialSection>

  <EditorialCTA
    title="Ready to explore TMS treatment?"
    description="With all this promising research, see if TMS therapy is right for you."
    ctas={[
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: "Find a TMS Clinic", href: "/us/", variant: "outline" },
    ]}
    stickyMobile
  />
</main>

</Layout>
