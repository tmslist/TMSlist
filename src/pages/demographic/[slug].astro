---
export const prerender = true;

import ContentPage from '../../layouts/ContentPage.astro';
import { getCollection, render } from 'astro:content';
import { DEMOGRAPHIC_SLUGS } from '../../utils/seo_slugs';

export async function getStaticPaths() {
  let entries: any[] = [];
  try {
    entries = await getCollection('demographics');
  } catch { /* collection may not exist yet */ }

  const contentPaths = entries.map((entry) => ({
    params: { slug: entry.id },
    props: { title: entry.data.title, description: entry.data.description, hasContent: true, entry },
  }));

  const contentSlugsSet = new Set(contentPaths.map(p => p.params.slug));
  const fallbackPaths = DEMOGRAPHIC_SLUGS
    .filter(({ slug }) => !contentSlugsSet.has(slug))
    .map(({ slug, title }) => ({
      params: { slug },
      props: { title, description: title ? `TMS therapy considerations and eligibility for ${title}.` : '', hasContent: false, entry: null },
    }));

  return [...contentPaths, ...fallbackPaths];
}

const { title, description, hasContent, entry } = Astro.props;
const slug = Astro.params.slug!;
let Content: any = null;
if (hasContent && entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "MedicalWebPage",
  "name": title,
  "description": description || `TMS therapy considerations for ${title}.`,
  "url": `${siteUrl}/demographic/${slug}/`,
  "about": { "@type": "MedicalTherapy", "name": "Transcranial Magnetic Stimulation (TMS)", "medicalSpecialty": "Psychiatry" },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `${siteUrl}/demographic/${slug}/` },
  "reviewedBy": { "@type": "Person", "name": "Dr. Karan Narwal", "jobTitle": "Mental Health Specialist & Consultant" },
  "publisher": { "@type": "Organization", "name": "TMS List", "url": siteUrl },
});
---

<ContentPage
  title={title}
  subtitle={description || "Specialized TMS considerations for specific patient groups."}
  description={description}
  schema={articleSchema}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Demographics", url: "/demographic/" },
    { name: title, url: `/demographic/${slug}/` },
  ]}
>
  {Content ? <Content /> : null}
</ContentPage>
