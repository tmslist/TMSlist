---
import Layout from '../../layouts/Layout.astro';
import { DEMOGRAPHIC_SLUGS } from '../../utils/seo_slugs';

const title = "TMS for Different Patient Groups | Seniors, Veterans, Teens & More";
const description = "Find TMS treatment information tailored to your specific needs. Guides for seniors, veterans, teens, pregnant women, and more.";
---

<Layout title={title} description={description}>
    <main class="min-h-screen">
        <!-- Hero -->
        <section class="relative bg-white border-b border-slate-100 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
            <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-slate-700 font-medium">Patient Groups</span>
                </nav>

                <div class="max-w-3xl">
                    <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 mb-4 leading-tight">
                        TMS for <span class="text-violet-600">Different Patients</span>
                    </h1>
                    <p class="text-lg text-slate-500 leading-relaxed">
                        TMS therapy can be tailored for various patient groups. Find information specific to your needs.
                    </p>
                </div>
            </div>
        </section>

        <!-- Grid -->
        <section class="py-16">
            <div class="container mx-auto px-6">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {DEMOGRAPHIC_SLUGS.map(item => (
                        <a href={`/demographic/${item.slug}/`} class="group bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:border-amber-200 transition-all">
                            <h3 class="text-xl font-semibold text-gray-900 group-hover:text-amber-600 mb-3">{item.title}</h3>
                            <p class="text-gray-500 text-sm mb-4">Specialized TMS information</p>
                            <span class="text-amber-600 font-semibold text-sm">Learn More →</span>
                        </a>
                    ))}
                </div>
            </div>
        </section>
    </main>
</Layout>
