---
import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import EditorialSection from '../../components/editorial/EditorialSection.astro';
import EditorialCard from '../../components/editorial/EditorialCard.astro';
import EditorialCTA from '../../components/editorial/EditorialCTA.astro';
import { DEMOGRAPHIC_SLUGS } from '../../utils/seo_slugs';

const title = "TMS for Different Patient Groups | Seniors, Veterans, Teens & More";
const description = "Find TMS treatment information tailored to your specific needs. Guides for seniors, veterans, teens, pregnant women, and more.";
---

<Layout title={title} description={description}>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow={`${DEMOGRAPHIC_SLUGS.length} Patient Group Guides`}
    eyebrowDot="#C9654A"
    title="TMS care, tailored"
    titleAccent="for who you are."
    description="Treatment considerations vary by age, health history, and life stage. Find guidance specific to your group."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Patient Groups" }]}
    ctas={[
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: "Find a TMS Clinic", href: "/us/", variant: "outline" },
    ]}
  />

  <EditorialSection
    title="Patient Groups"
    intro="Tailored TMS guides covering protocols, safety, and considerations for each population."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>'
    tone="warm"
    noBorder
  >
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {DEMOGRAPHIC_SLUGS.map((item) => (
        <EditorialCard
          href={`/demographic/${item.slug}/`}
          tag="Patient Group"
          tagTone="warm"
          title={item.title.replace(/^TMS for /, '')}
          description="Specialized TMS information, protocols, and considerations for this group."
          size="lg"
        />
      ))}
    </div>
  </EditorialSection>

  <EditorialCTA
    title="Get personalized guidance."
    description="Take our short assessment to see if TMS therapy is right for your specific situation."
    ctas={[
      { label: "Take the Assessment", href: "/quiz/am-i-a-candidate/" },
      { label: "Find a Specialist", href: "/specialists/", variant: "outline" },
    ]}
    stickyMobile
  />
</main>

</Layout>
