---
import Layout from '../../../../layouts/Layout.astro';
import ClinicCard from '../../../../components/ClinicCard.astro';
import { getClinicsByCountry } from '../../../../utils/dataHelpers';
import { COUNTRY_META } from '../../../../utils/countryData';
import { calculateClinicScore } from '../../../../utils/ranking';

const { region, city } = Astro.params;

const allClinics = await getClinicsByCountry('DE');

// Find region name from slug
const regionMatch = allClinics.find(c => c.state && c.state.toLowerCase().replace(/\s+/g, '-') === region);
if (!regionMatch) return Astro.redirect("/de/");
const regionName = regionMatch.state;

// Find city name from slug
const cityMatch = allClinics.find(c => c.state === regionName && c.city && c.city.toLowerCase().replace(/\s+/g, '-') === city);
if (!cityMatch) return Astro.redirect(`/de/${region}/`);
const cityName = cityMatch.city;

const clinics = allClinics
  .filter(c => c.state === regionName && c.city === cityName)
  .sort((a, b) => calculateClinicScore(b) - calculateClinicScore(a));
const meta = COUNTRY_META['DE'];
const regionSlug = Astro.params.region;
const citySlug = Astro.params.city;

const title = `TMS Therapy Clinics in ${cityName}, ${regionName} | Germany | TMS List`;
const description = `Find ${clinics.length} TMS therapy ${clinics.length === 1 ? 'clinic' : 'clinics'} in ${cityName}, ${regionName}. Compare providers, read patient reviews, and find affordable TMS treatment in Germany.`;

const citySchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `TMS Therapy Clinics in ${cityName}, Germany`,
  "description": description,
  "url": `https://tmslist.com/de/${regionSlug}/${citySlug}/`,
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": clinics.length,
    "itemListElement": clinics.slice(0, 5).map((c: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "MedicalClinic",
        "name": c.name,
        "url": `https://tmslist.com/clinic/${c.slug}`,
        "address": {
          "@type": "PostalAddress",
          "addressLocality": cityName,
          "addressRegion": regionName,
          "addressCountry": "DE"
        }
      }
    }))
  }
});
---

<Layout title={title} description={description} schema={citySchema} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "Germany", url: "/de/" },
  { name: regionName, url: `/de/${regionSlug}/` },
  { name: cityName, url: `/de/${regionSlug}/${citySlug}/` },
]}>
  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="relative bg-white border-b border-slate-100 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
      <div
        class="ai-hero-image absolute inset-0 opacity-20"
        data-subject={`${cityName}, ${regionName}`}
        data-type="city"
        data-cache-key={`ai-img:city:${cityName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}-${regionName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
        data-alt={`Watercolor illustration of ${cityName}, ${regionName}`}
      >
        <div class="ai-img-placeholder absolute inset-0"></div>
        <img class="ai-img-result hidden w-full h-full object-cover" alt="TMS clinic illustration" />
        <div class="ai-img-fallback hidden"></div>
      </div>
      <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
        <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
          <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
          <span class="text-slate-300">/</span>
          <a href="/de/" class="hover:text-violet-600 transition-colors">Germany</a>
          <span class="text-slate-300">/</span>
          <a href={`/de/${regionSlug}/`} class="hover:text-violet-600 transition-colors">{regionName}</a>
          <span class="text-slate-300">/</span>
          <span class="text-slate-700 font-medium">{cityName}</span>
        </nav>

        <h1 class="text-3xl font-semibold mb-2">TMS Therapy Clinics in {cityName}, Germany</h1>
        <p class="text-gray-600 mb-8 max-w-3xl">
          {clinics.length} verified TMS {clinics.length === 1 ? 'provider' : 'providers'} in {cityName}, {regionName}. Sessions typically cost {meta.sessionCostRange}. Compare clinics below to find the best fit for your treatment needs.
        </p>
      </div>
    </section>

    <div class="container mx-auto px-4 py-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {clinics.map((clinic: any) => <ClinicCard clinic={clinic} />)}
    </div>

    <!-- SEO Content -->
    <section class="mt-16 pt-12 border-t border-gray-100 prose prose-lg max-w-none text-gray-600">
      <h2>Finding TMS Therapy in {cityName}</h2>
      <p>TMS (Transcranial Magnetic Stimulation) therapy in {cityName} is available through {clinics.length} verified {clinics.length === 1 ? 'provider' : 'providers'}. {meta.aboutContent}</p>
      <h3>Cost and Insurance Coverage</h3>
      <p>{meta.insuranceNote} Sessions in {cityName} typically range from {meta.sessionCostRange}, with a full treatment course of 20-30 sessions over 4-6 weeks.</p>
      <h3>Explore More</h3>
      <ul>
        <li><a href={`/de/${regionSlug}/`}>All TMS Clinics in {regionName}</a></li>
        <li><a href="/de/">All TMS Clinics in Germany</a></li>
        <li><a href="/treatments/">Conditions Treated with TMS</a></li>
        <li><a href="/technology/">TMS Technology Guide</a></li>
      </ul>
    </section>
    </div>
  </main>
</Layout>

<script>
  // AI city hero image with localStorage cache
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;

    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }

    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });
</script>
