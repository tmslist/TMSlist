---
import Layout from '../../layouts/Layout.astro';
import { getClinicsByCountry, getRegionsByCountry, COUNTRY_NAMES } from '../../utils/dataHelpers';
import { COUNTRY_META } from '../../utils/countryData';

const countryCode = 'DE';
const meta = COUNTRY_META[countryCode];
const clinics = getClinicsByCountry(countryCode);
const regions = getRegionsByCountry(countryCode);

const regionList = regions.map(region => {
  const count = clinics.filter(c => c.state === region).length;
  const slug = region.toLowerCase().replace(/\s+/g, '-');
  return { name: region, slug, count };
}).sort((a, b) => b.count - a.count);

const totalClinics = clinics.length;
const title = `TMS Therapy Clinics in Germany | ${totalClinics} Verified Providers`;
const description = `Browse ${totalClinics} TMS therapy clinics across Germany. ${meta.seoDescription}`;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "TMS Therapy Clinics in Germany",
  "description": description,
  "url": "https://tmslist.com/de/",
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": regionList.length,
    "itemListElement": regionList.map((r, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": `TMS Clinics in ${r.name}, Germany`,
      "url": `https://tmslist.com/de/${r.slug}/`
    }))
  }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
  { name: "Home", url: "/" },
  { name: "Germany", url: "/de/" },
]}>
  <main class="container mx-auto px-4 py-8">
    <nav class="flex text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-gray-900">Home</a>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <span class="mx-2">/</span>
            <span class="text-gray-800">Germany</span>
          </div>
        </li>
      </ol>
    </nav>

    <h1 class="text-3xl font-semibold mb-2">TMS Therapy Clinics in Germany</h1>
    <p class="text-gray-600 mb-8 max-w-3xl">Browse {totalClinics} verified TMS providers across {regionList.length} regions in Germany. TMS is {meta.tmsStatus}, with sessions costing {meta.sessionCostRange} per session.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
      {regionList.map((region) => (
        <a href={`/de/${region.slug}/`} class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-indigo-500 hover:shadow-md transition-all group">
          <span class="text-lg font-medium text-gray-800 group-hover:text-indigo-600">{region.name}</span>
          <span class="block text-sm text-gray-500 mt-1">{region.count} {region.count === 1 ? 'clinic' : 'clinics'}</span>
        </a>
      ))}
    </div>

    <!-- SEO Content -->
    <section class="mt-16 pt-12 border-t border-gray-100 prose prose-lg max-w-none text-gray-600">
      <h2>About TMS Therapy in Germany</h2>
      <p>{meta.aboutContent}</p>
      <h3>Insurance and Costs</h3>
      <p>{meta.insuranceNote}</p>
      <p>The typical cost of a TMS session in Germany ranges from {meta.sessionCostRange}. Treatment courses usually involve 20-30 sessions over 4-6 weeks.</p>
      <h3>How to Choose a TMS Clinic in Germany</h3>
      <p>When selecting a TMS provider in Germany, consider whether the clinic is affiliated with a university hospital (Universit&auml;tsklinikum), the experience of the treating psychiatrist, the TMS technology used, and whether your insurance plan covers treatment. Our directory helps you compare clinics by region, view available technologies, and find the right provider.</p>
      <h3>Related Resources</h3>
      <ul>
        <li><a href="/treatments/">Conditions Treated with TMS</a> -- depression, anxiety, OCD, PTSD and more</li>
        <li><a href="/technology/">TMS Technology Guide</a> -- compare NeuroStar, BrainsWay, MagVenture</li>
        <li><a href="/research/">TMS Research</a> -- latest clinical studies and outcomes</li>
      </ul>
    </section>
  </main>
</Layout>
