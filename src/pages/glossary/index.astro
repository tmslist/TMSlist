---
import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import EditorialCTA from '../../components/editorial/EditorialCTA.astro';

const title = "TMS Glossary | 50+ Terms Explained | TMS List";
const description = "Comprehensive A-Z glossary of TMS therapy terms. From rTMS and theta burst to DLPFC and motor threshold — understand every term used in transcranial magnetic stimulation.";

const courseSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["Course", "DefinedTermSet"],
    "name": "TMS Therapy Glossary & Educational Guide",
    "description": description,
    "url": "https://tmslist.com/glossary/",
    "provider": { "@type": "Organization", "name": "TMS List", "url": "https://tmslist.com" },
    "educationalLevel": "Professional",
    "occupationalCredentialAwarded": "TMS Therapy Educational Resource",
    "timeRequired": "PT30M",
    "publisher": { "@type": "Organization", "name": "TMS List", "url": "https://tmslist.com" },
});

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "DefinedTermSet",
    "name": "TMS Therapy Glossary",
    "description": description,
    "url": "https://tmslist.com/glossary/",
    "publisher": { "@type": "Organization", "name": "TMS List", "url": "https://tmslist.com" }
});

const glossary: { term: string; definition: string }[] = [
    { term: "Accelerated TMS", definition: "A protocol that delivers multiple TMS sessions per day over a compressed timeframe (typically 1-5 days instead of 6 weeks), based on the Stanford SAINT protocol." },
    { term: "Active Motor Threshold", definition: "The minimum TMS intensity required to produce a motor evoked potential while the target muscle is under voluntary contraction." },
    { term: "Adjunctive Therapy", definition: "A treatment used alongside a primary treatment. TMS is often used as adjunctive therapy with antidepressant medications." },
    { term: "ARIA (Automated Robotic Image-guided Apparatus)", definition: "A robotic positioning system used with some TMS devices to automatically position the coil over the correct brain target using neuronavigation." },
    { term: "Bilateral TMS", definition: "A protocol that stimulates both hemispheres of the brain in a single session — typically high-frequency to the left DLPFC followed by low-frequency to the right DLPFC." },
    { term: "BrainsWay", definition: "An Israeli medical device company that manufactures the BrainsWay Deep TMS System using H-coil technology. FDA-cleared for major depressive disorder (2013), OCD (2018), and smoking cessation (2020)." },
    { term: "Burst Stimulation", definition: "A pattern of TMS delivery where pulses are grouped into short bursts rather than delivered individually. Includes theta burst stimulation (TBS) as the most studied variant." },
    { term: "CareCredit", definition: "A healthcare financing credit card commonly used by patients to pay for TMS therapy when insurance does not cover the full cost." },
    { term: "Coil", definition: "The handheld component of a TMS device that generates the magnetic field. Common types include figure-8 coils (focal stimulation) and H-coils (deeper stimulation)." },
    { term: "Cortical Excitability", definition: "The readiness of neurons in the brain's cortex to fire in response to stimulation. TMS can increase or decrease cortical excitability depending on the protocol used." },
    { term: "Deep TMS (dTMS)", definition: "A form of TMS using H-coil technology (BrainsWay) that can stimulate deeper brain structures (up to 4cm). FDA-cleared for depression, OCD, and smoking cessation." },
    { term: "DLPFC (Dorsolateral Prefrontal Cortex)", definition: "The primary brain target for TMS depression treatment. Underactivity in the left DLPFC is associated with depression." },
    { term: "Double-Blind Study", definition: "A clinical trial design where neither the patient nor the administering clinician knows if active TMS or sham (placebo) stimulation is being delivered." },
    { term: "EEG (Electroencephalography)", definition: "A brain imaging technique that measures electrical activity via scalp electrodes. Sometimes used alongside TMS to monitor brain responses." },
    { term: "Express TMS", definition: "Marketing term used by some clinics for theta burst stimulation (TBS) protocols that deliver a full session in approximately 3 minutes." },
    { term: "FDA Clearance", definition: "Regulatory approval from the FDA allowing a TMS device to be marketed for specific medical conditions. Different from FDA approval — clearance (510(k)) demonstrates substantial equivalence to an existing device." },
    { term: "Figure-8 Coil", definition: "The most common TMS coil design, shaped like a figure-8. Creates a focused magnetic field at the intersection of the two loops." },
    { term: "fMRI (Functional Magnetic Resonance Imaging)", definition: "A neuroimaging technique that measures brain activity by detecting changes in blood flow. Used in TMS research to identify optimal stimulation targets." },
    { term: "H-Coil", definition: "A coil design developed by BrainsWay that uses a complex winding pattern inside a padded helmet. Stimulates deeper and broader brain regions than standard figure-8 coils." },
    { term: "HSA/FSA", definition: "Health Savings Accounts and Flexible Spending Accounts — tax-advantaged accounts that can be used to pay for TMS therapy out-of-pocket costs." },
    { term: "Intermittent Theta Burst Stimulation (iTBS)", definition: "An excitatory TBS pattern where 2-second trains of theta burst pulses are delivered every 10 seconds, typically applied to the left DLPFC for depression." },
    { term: "Long-Term Potentiation (LTP)", definition: "A lasting strengthening of neural connections that is believed to underlie the therapeutic effects of TMS." },
    { term: "Maintenance TMS", definition: "Periodic TMS sessions given after completing an initial treatment course to prevent relapse of symptoms." },
    { term: "MagVenture", definition: "A Danish manufacturer of TMS devices, including the MagPro and MagVita systems." },
    { term: "MBS Item Number", definition: "Medicare Benefits Schedule item number (Australia) that determines if a procedure is eligible for a Medicare rebate. TMS was added to the MBS in 2021 for treatment-resistant depression." },
    { term: "Motor Evoked Potential (MEP)", definition: "A measurable muscle twitch produced when TMS is applied to the motor cortex at sufficient intensity." },
    { term: "Motor Threshold (MT)", definition: "The minimum intensity of TMS required to produce a visible muscle twitch in at least 50% of attempts. Used to personalize treatment intensity." },
    { term: "Neuromodulation", definition: "The alteration of nerve activity through targeted delivery of a stimulus. TMS is a form of non-invasive neuromodulation." },
    { term: "Neuronavigation", definition: "Technology that uses brain imaging (MRI/CT) to guide precise TMS coil placement over the target brain region." },
    { term: "NeuroStar", definition: "A TMS system manufactured by Neuronetics, one of the first FDA-cleared TMS devices for depression (2008)." },
    { term: "Neuroplasticity", definition: "The brain's ability to form new neural connections and reorganize existing ones. TMS is believed to work by promoting neuroplasticity." },
    { term: "NICE Approval", definition: "Guidance from the UK's National Institute for Health and Care Excellence recommending TMS as a treatment option (since 2015)." },
    { term: "OCD (Obsessive-Compulsive Disorder)", definition: "A mental health condition characterized by intrusive thoughts and repetitive behaviors. Deep TMS received FDA clearance for OCD in 2018." },
    { term: "Prior Authorization", definition: "An insurance requirement that a provider obtain approval before delivering TMS treatment. Typically requires documentation of medication trials." },
    { term: "Pulse", definition: "A single magnetic field discharge from the TMS coil. Treatment protocols are defined by the number of pulses per session." },
    { term: "Remission", definition: "A clinical outcome where symptoms have been reduced to below diagnostic thresholds. Remission rates in TMS depression studies typically range from 30-35%." },
    { term: "Response Rate", definition: "The percentage of patients who experience a clinically significant improvement (usually 50%+ reduction). TMS depression studies report response rates of 50-60%." },
    { term: "rTMS (Repetitive Transcranial Magnetic Stimulation)", definition: "The most common form of TMS therapy, delivering repeated magnetic pulses to a specific brain target." },
    { term: "SAINT Protocol", definition: "Stanford Accelerated Intelligent Neuromodulation Therapy — 10 sessions per day over 5 days using fMRI-guided targeting. Showed 79% remission in the initial trial." },
    { term: "Sham Stimulation", definition: "A placebo condition used in TMS clinical trials where the coil is positioned or shielded to mimic the sensation of real TMS without delivering therapeutic stimulation." },
    { term: "Smoking Cessation", definition: "FDA-cleared indication for Deep TMS (BrainsWay, 2020). Targets the bilateral insula and prefrontal cortex to reduce nicotine cravings." },
    { term: "Theta Burst Stimulation (TBS)", definition: "An advanced TMS protocol that delivers triplets of pulses at 50Hz, repeated at 5Hz. A full session can be delivered in about 3 minutes versus 19-37 minutes for standard rTMS." },
    { term: "Treatment Course", definition: "A standard series of TMS sessions, typically 36 sessions delivered 5 days per week over 6-9 weeks." },
    { term: "Treatment-Resistant Depression (TRD)", definition: "Depression that has not responded adequately to at least two different antidepressant medications. Primary FDA-cleared indication for TMS therapy." },
    { term: "Transcranial Magnetic Stimulation (TMS)", definition: "A non-invasive brain stimulation technique that uses magnetic fields to induce small electrical currents in targeted brain regions." },
    { term: "Treatment Protocol", definition: "The specific parameters of a TMS session including coil type, brain target, frequency, intensity, number of pulses, and session duration." },
    { term: "V-coil", definition: "A newer coil design used in some TMS systems that provides a broader but still focal stimulation pattern." },
];

const sortedGlossary = glossary.sort((a, b) => a.term.localeCompare(b.term));
const grouped: Record<string, typeof glossary> = {};
sortedGlossary.forEach(item => {
    const letter = item.term[0].toUpperCase();
    if (!grouped[letter]) grouped[letter] = [];
    grouped[letter].push(item);
});
const letters = Object.keys(grouped).sort();
const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
---

<Layout title={title} description={description} schema={schema} extraSchemas={[courseSchema]} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Glossary", url: "/glossary/" },
]}>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow={`${sortedGlossary.length} Terms Defined`}
    eyebrowDot="#22c55e"
    title="The TMS"
    titleAccent="glossary."
    description="From rTMS and theta burst to DLPFC and motor threshold. Every term you'll encounter in TMS therapy, explained in plain language."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Glossary" }]}
    ctas={[
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: "Find a TMS Clinic", href: "/us/", variant: "outline" },
    ]}
    stats={[
      { value: sortedGlossary.length, label: "Terms", color: "ink" },
      { value: letters.length, label: "Letters", color: "accent" },
      { value: "A–V", label: "Range", color: "warm" },
    ]}
  />

  <section style="background:var(--paper); padding:4rem 0; border-bottom:1px solid var(--line);">
    <div class="max-w-[900px] mx-auto px-6 lg:px-8">
      <nav style="position:sticky; top:64px; z-index:10; background:rgba(251,250,247,0.95); backdrop-filter:blur(8px); margin:-1rem -1.5rem 2rem; padding:1rem 1.5rem; border-bottom:1px solid var(--line);" aria-label="Alphabet navigation">
        <div class="flex flex-wrap justify-center gap-1.5">
          {alphabet.map((letter) => {
            const hasTerms = letters.includes(letter);
            return hasTerms ? (
              <a href={`#letter-${letter}`} style="width:2.25rem; height:2.25rem; border-radius:0.5rem; background:var(--paper2); color:var(--ink2); display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:700; text-decoration:none; transition:background 0.15s, color 0.15s;" class="hover:!bg-[rgba(10,22,40,0.1)] hover:!text-[var(--accent)]">
                {letter}
              </a>
            ) : (
              <span style="width:2.25rem; height:2.25rem; display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:700; color:rgba(90,107,130,0.4);">
                {letter}
              </span>
            );
          })}
        </div>
      </nav>

      <div class="flex flex-col gap-12">
        {letters.map((letter) => (
          <div id={`letter-${letter}`} style="scroll-margin-top:6rem;">
            <div class="flex items-center gap-4 mb-6">
              <div class="serif" style="width:3rem; height:3rem; border-radius:0.75rem; background:var(--gradient-brand, linear-gradient(135deg, var(--accent), var(--accent2))); color:white; display:flex; align-items:center; justify-content:center; font-size:1.5rem;">{letter}</div>
              <div style="flex:1; height:1px; background:var(--line);"></div>
              <span style="font-size:12px; color:var(--muted); font-weight:500;">{grouped[letter].length} {grouped[letter].length === 1 ? 'term' : 'terms'}</span>
            </div>

            <div class="flex flex-col gap-4">
              {grouped[letter].map((item) => (
                <div style="background:var(--paper2); border:1px solid var(--line); border-radius:1rem; padding:1.5rem;" id={item.term.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>
                  <dt class="serif" style="font-size:1.25rem; color:var(--ink); margin:0 0 0.5rem;">{item.term}</dt>
                  <dd style="font-size:14px; color:var(--muted); line-height:1.65; margin:0;">{item.definition}</dd>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <EditorialCTA
    title="Now you know the language."
    description="Ready to take the next step? See if TMS therapy is right for you."
    ctas={[
      { label: "Am I a Candidate?", href: "/quiz/am-i-a-candidate/" },
      { label: "Browse Clinics", href: "/us/", variant: "outline" },
    ]}
    stickyMobile
  />
</main>

</Layout>
