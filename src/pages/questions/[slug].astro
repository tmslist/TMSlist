---
import Layout from "../../layouts/Layout.astro";
import { getAllQuestions } from "../../db/queries";

const { slug } = Astro.params;

const questionsData = await getAllQuestions();
const question = questionsData.find((q) => q.slug === slug);
if (!question) return Astro.redirect("/questions/");
const sameCategory = questionsData
    .filter((q) => q.category === question.category && q.id !== question.id)
    .slice(0, 3);

const otherCategories = questionsData
    .filter((q) => q.category !== question.category && q.id !== question.id)
    .slice(0, 3);

const relatedQs = [...sameCategory, ...otherCategories].slice(0, 6);

const answerText = question.answer || '';
const title = `${question.question} | TMS List Expert Answers`;
const description = answerText.substring(0, 155).replace(/<[^>]*>/g, '');
---

<Layout title={title} description={description}>
    <main class="container mx-auto px-4 py-12 max-w-4xl">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
            <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
            <span class="text-slate-300">/</span>
            <a href="/questions/" class="hover:text-violet-600 transition-colors">Questions</a>
            <span class="text-slate-300">/</span>
            <span class="text-slate-700 font-medium">{question.category}</span>
        </nav>

        <!-- Question Header -->
        <h1
            class="text-4xl md:text-5xl font-semibold text-gray-900 mb-6 leading-tight"
        >
            {question.question}
        </h1>

        <!-- Quick Answer Box -->
        <div
            class="bg-violet-50 border-l-4 border-violet-600 p-6 mb-8 rounded-r-lg"
        >
            <h2 class="text-lg font-semibold text-violet-900 mb-2">Quick Answer</h2>
            <p class="text-gray-800 leading-relaxed">{answerText.replace(/<[^>]*>/g, '').substring(0, 300)}</p>
        </div>

        <!-- Main Content -->
        <article class="prose prose-lg prose-violet max-w-none mb-12">
            {answerText.includes('<') ? (
                <div set:html={answerText} />
            ) : (
                <p>{answerText}</p>
            )}

            {question.citations && question.citations.length > 0 && (
                <div class="mt-8 pt-6 border-t border-gray-200">
                    <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Sources</h3>
                    <ul class="text-sm space-y-1">
                        {question.citations.map((cite: string) => (
                            <li>
                                <a href={cite} target="_blank" rel="noopener noreferrer" class="text-violet-600 hover:underline break-all">{cite}</a>
                            </li>
                        ))}
                    </ul>
                </div>
            )}
        </article>

        <!-- Enhanced CTAs Grid -->
        <section class="my-12 grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Find Clinics CTA -->
            <div
                class="dark-section bg-gradient-to-br from-violet-600 to-violet-700 rounded-2xl p-6"
            >
                <div class="w-10 h-10 mb-3 mx-auto rounded-lg bg-violet-500/20 flex items-center justify-center"><svg class="w-5 h-5 text-violet-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg></div>
                <h3 class="text-xl font-semibold mb-2">
                    Find TMS Clinics Near You
                </h3>
                <p class="text-violet-100 text-sm mb-4">
                    Browse verified providers, compare prices & insurance
                </p>
                <div class="flex gap-2">
                    <a
                        href="/us/"
                        class="px-4 py-2 bg-white text-violet-600 font-semibold rounded-lg hover:bg-gray-100 transition-colors text-sm"
                    >
                        Browse Clinics
                    </a>
                    <button
                        onclick="document.dispatchEvent(new Event('open-enquiry-modal'))"
                        class="px-4 py-2 bg-violet-500 text-white font-semibold rounded-lg hover:bg-violet-400 transition-colors border border-slate-200 text-sm"
                    >
                        Talk to Specialist
                    </button>
                </div>
            </div>

            <!-- Lead Magnet CTA -->
            <div
                class="dark-section bg-gradient-to-br from-blue-600 to-cyan-600 rounded-2xl p-6"
            >
                <div class="w-10 h-10 mb-3 rounded-lg bg-blue-500/20 flex items-center justify-center"><svg class="w-5 h-5 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg></div>
                <h3 class="text-xl font-semibold mb-2">Free TMS Guide</h3>
                <p class="text-blue-100 text-sm mb-4">
                    Download: "TMS vs Medication - Which is Right for You?"
                </p>
                <button
                    onclick="document.dispatchEvent(new Event('open-lead-magnet'))"
                    class="px-4 py-2 bg-white text-blue-600 font-semibold rounded-lg hover:bg-gray-100 transition-colors inline-flex items-center gap-2 text-sm"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                        ></path></svg
                    >
                    Download Free
                </button>
            </div>
        </section>

        <!-- Related Questions -->
        {
            relatedQs.length > 0 && (
                <section class="bg-gray-50 rounded-xl p-8 mb-12">
                    <div class="flex items-center justify-between mb-6">
                        <h2 class="text-2xl font-semibold text-gray-900">
                            People Also Ask
                        </h2>
                        <a
                            href="/questions/"
                            class="text-violet-600 font-semibold hover:underline text-sm"
                        >
                            Browse All →
                        </a>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        {relatedQs.map((rq) => (
                            <a
                                href={`/questions/${rq.slug}/`}
                                class="group block p-4 bg-white rounded-lg border-2 border-gray-200 hover:border-violet-500 hover:shadow-md transition-all"
                            >
                                <h3 class="font-semibold text-gray-900 group-hover:text-violet-600 transition-colors mb-2 text-sm line-clamp-2">
                                    {rq.question}
                                </h3>
                                <p class="text-xs text-gray-600 line-clamp-2 mb-2">
                                    {(rq.quickAnswer || rq.answer || '').slice(0, 80)}...
                                </p>
                                <span class="text-xs text-violet-600 font-medium group-hover:underline">
                                    Read Answer →
                                </span>
                            </a>
                        ))}
                    </div>
                    <div class="mt-6 text-center">
                        <a
                            href={`/questions/category/${question.category}/`}
                            class="inline-block px-5 py-2.5 bg-white text-violet-600 font-semibold rounded-lg hover:bg-gray-100 transition-colors border-2 border-violet-200"
                        >
                            More {question.category} Questions →
                        </a>
                    </div>
                </section>
            )
        }

        <!-- Medical Disclaimer -->
        <div class="border-t border-gray-200 pt-8 text-sm text-gray-600">
            <h3 class="font-semibold text-gray-900 mb-2">Medical Disclaimer</h3>
            <p>
                The information provided on this page is for educational
                purposes only and is not intended as medical advice. TMS List
                does not provide medical advice, diagnosis, or treatment. Always
                consult with a qualified healthcare provider regarding any
                questions you may have about a medical condition or treatment.
            </p>
            <p class="mt-4">
                <strong>Last Updated:</strong>
                {
                    new Date().toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                    })
                }
            </p>
        </div>

        <!-- Schema Markup -->
        <script
            type="application/ld+json"
            set:html={JSON.stringify({
                "@context": "https://schema.org",
                "@type": "FAQPage",
                mainEntity: {
                    "@type": "Question",
                    name: question.question,
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: (question.quickAnswer || question.answer || '').replace(/<[^>]*>/g, ''),
                    },
                },
            })}
        />
    </main>
</Layout>
