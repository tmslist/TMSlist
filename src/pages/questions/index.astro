---
import Layout from "../../layouts/Layout.astro";
import EditorialHero from "../../components/editorial/EditorialHero.astro";
import FAQSchema from "../../components/FAQSchema.astro";
import { getAllQuestions } from "../../db/queries";

const questionsData = await getAllQuestions();

const title = "TMS Therapy Questions & Expert Answers | TMS List";
const description =
    "Find expert answers to all your TMS therapy questions. Browse 100+ topics covering cost, effectiveness, side effects, insurance coverage, and more.";

// Group questions by category
const categories = {
    basics: {
        name: "TMS Basics",
        icon: "basics",
        description: "Understanding TMS therapy fundamentals",
    },
    cost: {
        name: "Cost & Insurance",
        icon: "cost",
        description: "Pricing, coverage, and payment options",
    },
    conditions: {
        name: "Conditions Treated",
        icon: "conditions",
        description: "Effectiveness for different mental health conditions",
    },
    comparisons: {
        name: "Treatment Comparisons",
        icon: "comparisons",
        description: "How TMS compares to other therapies",
    },
};

const groupedQuestions = questionsData.reduce<
    Record<string, (typeof questionsData)[0][]>
>((acc, q) => {
    if (!acc[q.category]) acc[q.category] = [];
    acc[q.category].push(q);
    return acc;
}, {});

// Featured/trending questions
const featured = questionsData.slice(0, 6);
---

<Layout title={title} description={description} canonical="https://tmslist.com/questions/">
    {questionsData.length > 0 && (
        <FAQSchema faqs={questionsData.slice(0, 10).map(q => ({ question: q.question, answer: (q.quickAnswer || q.answer || '').replace(/<[^>]*>/g, '') }))} />
    )}
    <main style="background:var(--paper)">
        <EditorialHero
            eyebrow={`${questionsData.length}+ Expert Answers`}
            eyebrowDot="#22c55e"
            title="Every TMS"
            titleAccent="question, answered."
            description="Evidence-based answers from clinical experts. Cost, effectiveness, side effects, insurance, and more."
            breadcrumbs={[{ label: "Home", href: "/" }, { label: "Questions" }]}
            ctas={[
                { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
                { label: "Find a TMS Clinic", href: "/us/", variant: "outline" },
            ]}
            stats={[
                { value: questionsData.length, label: "Questions Answered", color: "ink" },
                { value: Object.keys(categories).length, label: "Categories", color: "accent" },
                { value: "Expert", label: "Reviewed", color: "warm" },
            ]}
        />

        <section style="background:var(--paper); padding:2rem 0; border-bottom:1px solid var(--line);">
            <div class="container mx-auto px-4 max-w-2xl">
                <div class="relative" id="search-container">
                    <input
                        type="text"
                        id="question-search"
                        placeholder="Ask any question about TMS therapy..."
                        style="width:100%; padding:1rem 3rem 1rem 1.5rem; border-radius:1rem; background:var(--paper2); border:1px solid var(--line); color:var(--ink); font-size:16px; outline:none; box-shadow:0 4px 20px rgba(0,0,0,0.03);"
                        autocomplete="off"
                    />
                    <svg style="position:absolute; right:1rem; top:50%; transform:translateY(-50%); width:1.25rem; height:1.25rem; color:var(--muted); pointer-events:none;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    <div id="autocomplete-results" style="position:absolute; top:100%; left:0; right:0; margin-top:0.5rem; background:var(--paper); border-radius:0.75rem; box-shadow:0 8px 30px rgba(0,0,0,0.05); border:1px solid var(--line); max-height:24rem; overflow-y:auto; z-index:50; display:none;">
                    </div>
                </div>
                <p style="font-size:13px; color:var(--muted); margin-top:0.75rem; text-align:center;">Try: "How much does TMS cost?" or "Is TMS FDA approved?"</p>
            </div>
        </section>

        <div class="container mx-auto px-4 max-w-6xl">
            <!-- Featured Questions -->
            <section class="py-12 lg:py-16">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center">
                        <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    </div>
                    <h2 class="text-2xl font-bold text-[var(--ink)]">Most Asked Questions</h2>
                </div>

                {/* Featured first question — larger card */}
                {featured.length > 0 && (
                    <a href={`/questions/${featured[0].slug}/`} class="group block bg-[var(--paper)] rounded-2xl border border-[var(--line)] shadow-sm hover:shadow-md hover:border-[rgba(10,22,40,0.15)] transition-all mb-6 overflow-hidden">
                        <div class="p-8 lg:flex lg:items-start lg:gap-8">
                            <div class="w-14 h-14 rounded-2xl bg-[rgba(10,22,40,0.08)] flex items-center justify-center text-[var(--accent)] shrink-0 mb-4 lg:mb-0">
                                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            </div>
                            <div class="flex-1">
                                <h3 class="text-xl lg:text-2xl font-bold text-[var(--ink)] group-hover:text-[var(--accent)] transition-colors mb-3">{featured[0].question}</h3>
                                <p class="text-[var(--muted)] leading-relaxed mb-4 line-clamp-3">{(featured[0].quickAnswer || featured[0].answer || '').replace(/<[^>]*>/g, '').substring(0, 200)}</p>
                                <span class="text-[var(--accent)] font-semibold text-sm inline-flex items-center gap-1">Read Full Answer <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
                            </div>
                        </div>
                    </a>
                )}

                {/* Remaining featured questions */}
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                    {featured.slice(1).map((q) => (
                        <a href={`/questions/${q.slug}/`} class="group block bg-[var(--paper)] rounded-2xl p-6 border border-[var(--line)] shadow-sm hover:shadow-md hover:border-[rgba(10,22,40,0.15)] transition-all hover:-translate-y-0.5">
                            <h3 class="font-bold text-[var(--ink)] group-hover:text-[var(--accent)] transition-colors mb-3 leading-snug">{q.question}</h3>
                            <p class="text-[var(--muted)] text-sm line-clamp-2 mb-4 leading-relaxed">{(q.quickAnswer || q.answer || '').replace(/<[^>]*>/g, '').substring(0, 120)}</p>
                            <div class="flex items-center justify-between pt-3 border-t border-[var(--line)]">
                                <span class="text-[var(--accent)] text-sm font-semibold">Read Answer</span>
                                <svg class="w-4 h-4 text-[var(--muted)] group-hover:text-[var(--accent2)] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            </div>
                        </a>
                    ))}
                </div>
            </section>

            <!-- Browse by Category -->
            <section class="py-12 lg:py-16 border-t border-[var(--line)]">
                <div class="flex items-center gap-3 mb-10">
                    <div class="w-8 h-8 rounded-lg bg-[var(--paper2)] flex items-center justify-center">
                        <svg class="w-4 h-4 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    </div>
                    <h2 class="text-2xl font-bold text-[var(--ink)]">Browse by Topic</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {Object.entries(categories).map(([key, cat]) => {
                        const questions = groupedQuestions[key] || [];
                        const iconColors = { basics: 'bg-[var(--paper2)] text-[var(--accent)]', cost: 'bg-emerald-50 text-emerald-600', conditions: 'bg-[rgba(10,22,40,0.08)] text-[var(--accent)]', comparisons: 'bg-amber-50 text-amber-600' };
                        const colorClass = iconColors[key as keyof typeof iconColors] || 'bg-[rgba(10,22,40,0.08)] text-[var(--accent)]';
                        return (
                            <div class="bg-[var(--paper)] rounded-2xl border border-[var(--line)] shadow-sm overflow-hidden hover:shadow-md transition-shadow">
                                <div class="p-6 border-b border-[var(--line)]">
                                    <div class="flex items-center gap-3">
                                        <div class={`w-10 h-10 rounded-xl ${colorClass} flex items-center justify-center shrink-0`}>
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                        </div>
                                        <div>
                                            <h3 class="text-lg font-bold text-[var(--ink)]">{cat.name}</h3>
                                            <p class="text-[var(--muted)] text-xs">{cat.description}</p>
                                        </div>
                                        <span class="ml-auto text-xs font-semibold text-[var(--muted)] bg-[var(--paper2)] px-2.5 py-1 rounded-lg">{questions.length}</span>
                                    </div>
                                </div>
                                <div class="p-4">
                                    <div class="space-y-0.5">
                                        {questions.slice(0, 5).map((q) => (
                                            <a href={`/questions/${q.slug}/`} class="flex items-center gap-3 py-2.5 px-3 rounded-xl hover:bg-[var(--paper2)] text-[var(--ink2)] hover:text-[var(--accent)] transition-colors group/q">
                                                <svg class="w-4 h-4 text-[var(--muted)] group-hover/q:text-[var(--accent2)] shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                                <span class="text-sm leading-snug">{q.question}</span>
                                            </a>
                                        ))}
                                    </div>
                                    {questions.length > 5 && (
                                        <a href={`/questions/category/${key}/`} class="flex items-center gap-2 mt-3 px-3 py-2 text-[var(--accent)] font-semibold text-sm hover:bg-[rgba(10,22,40,0.08)] rounded-xl transition-colors">
                                            View all {questions.length} questions
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                                        </a>
                                    )}
                                </div>
                            </div>
                        );
                    })}
                </div>
            </section>

            <!-- CTA -->
            <section class="py-12 lg:py-16 border-t border-[var(--line)]">
                <div class="bg-gradient-to-br from-[#0A1628] to-[#0A1628] rounded-2xl p-10 lg:p-14 text-center relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-64 h-64 bg-[var(--paper)]/5 rounded-full blur-[80px]"></div>
                    <div class="relative z-10">
                        <div class="w-14 h-14 rounded-2xl bg-[var(--paper)]/10 flex items-center justify-center mx-auto mb-5">
                            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                        </div>
                        <h2 class="text-2xl lg:text-3xl font-bold text-white mb-3">Can't find your answer?</h2>
                        <p class="text-[rgba(10,22,40,0.2)] mb-8 max-w-lg mx-auto">
                            Talk to a TMS specialist for free. Our network of verified providers can answer your specific questions.
                        </p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <button
                                onclick="document.dispatchEvent(new Event('open-enquiry-modal'))"
                                class="px-8 py-3.5 bg-[var(--paper)] text-[var(--accent)] font-semibold rounded-xl hover:bg-[rgba(10,22,40,0.08)] transition-colors shadow-lg"
                            >
                                Talk to a Specialist
                            </button>
                            <a href="/us/" class="px-8 py-3.5 bg-[var(--paper)]/10 border border-white/20 text-white font-semibold rounded-xl hover:bg-[var(--paper)]/20 transition-all">
                                Find a TMS Clinic
                            </a>
                        </div>
                        <p class="text-xs text-[rgba(10,22,40,0.3)] mt-4">Or <a href="/tms-cost-guide/" class="underline hover:text-white">download the free TMS Buyer's Guide</a> for comprehensive answers to all your questions.</p>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <script>
        import Fuse from "fuse.js";
        import questionsData from "../../data/questions-comprehensive.json";

        // Define types
        interface Question {
            question: string;
            quickAnswer: string;
            slug: string;
            category: string;
            keywords: string[];
        }

        interface FuseResult {
            item: Question;
            score?: number;
            matches?: readonly any[];
        }

        // Initialize Fuse.js for fuzzy search
        const fuse = new Fuse(questionsData, {
            keys: ["question", "quickAnswer", "keywords"],
            threshold: 0.3,
            minMatchCharLength: 2,
            includeScore: true,
            includeMatches: true,
        });

        const searchInput = document.getElementById(
            "question-search",
        ) as HTMLInputElement;
        const resultsContainer = document.getElementById(
            "autocomplete-results",
        );
        let selectedIndex = -1;
        let currentResults: FuseResult[] = [];

        // Debounce function
        function debounce<T extends (...args: any[]) => void>(
            func: T,
            wait: number,
        ) {
            let timeout: NodeJS.Timeout;
            return function (this: any, ...args: Parameters<T>) {
                const later = () => {
                    clearTimeout(timeout);
                    func.apply(this, args);
                };
                clearTimeout(timeout);
                timeout = setTimeout(later, wait);
            };
        }

        // Highlight matching text
        function highlightMatch(text: string, query: string): string {
            if (!query) return text;
            const regex = new RegExp(`(${query})`, "gi");
            return text.replace(
                regex,
                '<mark class="bg-yellow-200 text-[var(--ink)] font-semibold">$1</mark>',
            );
        }

        // Display search results
        function displayResults(results: FuseResult[]) {
            if (!resultsContainer) return;

            if (results.length === 0) {
                resultsContainer.style.display = "none";
                currentResults = [];
                return;
            }

            currentResults = results;
            selectedIndex = -1;

            const html = results
                .slice(0, 7)
                .map((result, index) => {
                    const item = result.item;
                    const categoryBadgeColors: Record<string, string> = {
                        basics: "bg-[rgba(10,22,40,0.1)] text-[var(--accent)]",
                        cost: "bg-green-100 text-green-700",
                        conditions: "bg-[rgba(201,101,74,0.1)] text-[var(--warm)]",
                        comparisons: "bg-orange-100 text-orange-700",
                        location: "bg-[rgba(10,22,40,0.1)] text-[var(--accent)]",
                        safety: "bg-red-100 text-red-700",
                        timeline: "bg-[rgba(10,22,40,0.08)] text-[var(--accent)]",
                        experience: "bg-[rgba(201,101,74,0.1)] text-[var(--warm)]",
                        technology: "bg-[var(--paper2)] text-[var(--ink2)]",
                        procedure: "bg-yellow-100 text-yellow-700",
                    };

                    const badgeColor =
                        categoryBadgeColors[item.category] ||
                        "bg-[var(--paper2)] text-[var(--ink2)]";

                    return `
                    <a 
                        href="/questions/${item.slug}/" 
                        class="autocomplete-item block px-6 py-4 hover:bg-[rgba(10,22,40,0.08)] border-b border-[var(--line)] last:border-b-0 transition-colors"
                        data-index="${index}"
                    >
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex-1">
                                <div class="font-semibold text-[var(--ink)] mb-1">
                                    ${highlightMatch(item.question, searchInput?.value || "")}
                                </div>
                                <div class="text-sm text-[var(--muted)] line-clamp-2">
                                    ${item.quickAnswer.slice(0, 120)}...
                                </div>
                            </div>
                            <span class="flex-shrink-0 px-2 py-1 rounded-full text-xs font-semibold ${badgeColor}">
                                ${item.category}
                            </span>
                        </div>
                    </a>
                `;
                })
                .join("");

            resultsContainer.innerHTML = html;
            resultsContainer.style.display = "block";

            // Add click handlers
            document.querySelectorAll(".autocomplete-item").forEach((item) => {
                item.addEventListener("mouseenter", (e) => {
                    document
                        .querySelectorAll(".autocomplete-item")
                        .forEach((el) => {
                            el.classList.remove("bg-[rgba(10,22,40,0.08)]");
                        });
                    (e.currentTarget as HTMLElement).classList.add(
                        "bg-[rgba(10,22,40,0.08)]",
                    );
                });
            });
        }

        // Perform search
        const performSearch = debounce((query: string) => {
            if (!query || query.length < 2) {
                if (resultsContainer) resultsContainer.style.display = "none";
                return;
            }

            const results = fuse.search(query);
            displayResults(results);
        }, 300);

        // Keyboard navigation
        function handleKeyboardNav(e: KeyboardEvent) {
            if (!currentResults.length) return;

            const items = document.querySelectorAll(".autocomplete-item");

            if (e.key === "ArrowDown") {
                e.preventDefault();
                selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
                updateSelection(items);
            } else if (e.key === "ArrowUp") {
                e.preventDefault();
                selectedIndex = Math.max(selectedIndex - 1, -1);
                updateSelection(items);
            } else if (e.key === "Enter") {
                e.preventDefault();
                if (selectedIndex >= 0 && items[selectedIndex]) {
                    (items[selectedIndex] as HTMLAnchorElement).click();
                }
            } else if (e.key === "Escape") {
                if (resultsContainer) resultsContainer.style.display = "none";
                searchInput?.blur();
            }
        }

        function updateSelection(items: NodeListOf<Element>) {
            items.forEach((item, index) => {
                if (index === selectedIndex) {
                    item.classList.add("bg-[rgba(10,22,40,0.08)]");
                    item.scrollIntoView({
                        block: "nearest",
                        behavior: "smooth",
                    });
                } else {
                    item.classList.remove("bg-[rgba(10,22,40,0.08)]");
                }
            });
        }

        // Event listeners
        searchInput?.addEventListener("input", (e) => {
            const query = (e.target as HTMLInputElement).value;
            performSearch(query);
        });

        searchInput?.addEventListener("keydown", handleKeyboardNav);

        searchInput?.addEventListener("focus", () => {
            if (searchInput.value.length >= 2 && currentResults.length > 0 && resultsContainer) {
                resultsContainer.style.display = "block";
            }
        });

        // Close on click outside
        document.addEventListener("click", (e) => {
            if (
                !searchInput?.contains(e.target as Node) &&
                !resultsContainer?.contains(e.target as Node)
            ) {
                if (resultsContainer) resultsContainer.style.display = "none";
            }
        });
    </script>
</Layout>
