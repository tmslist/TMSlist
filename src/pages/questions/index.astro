---
import Layout from "../../layouts/Layout.astro";
import { getAllQuestions } from "../../db/queries";

const questionsData = await getAllQuestions();

const title = "TMS Therapy Questions & Expert Answers | TMS List";
const description =
    "Find expert answers to all your TMS therapy questions. Browse 100+ topics covering cost, effectiveness, side effects, insurance coverage, and more.";

// Group questions by category
const categories = {
    basics: {
        name: "TMS Basics",
        icon: "basics",
        description: "Understanding TMS therapy fundamentals",
    },
    cost: {
        name: "Cost & Insurance",
        icon: "cost",
        description: "Pricing, coverage, and payment options",
    },
    conditions: {
        name: "Conditions Treated",
        icon: "conditions",
        description: "Effectiveness for different mental health conditions",
    },
    comparisons: {
        name: "Treatment Comparisons",
        icon: "comparisons",
        description: "How TMS compares to other therapies",
    },
};

const groupedQuestions = questionsData.reduce<
    Record<string, (typeof questionsData)[0][]>
>((acc, q) => {
    if (!acc[q.category]) acc[q.category] = [];
    acc[q.category].push(q);
    return acc;
}, {});

// Featured/trending questions
const featured = questionsData.slice(0, 6);
---

<Layout title={title} description={description} canonical="https://tmslist.com/questions/">
    {questionsData.length > 0 && (
        <FAQSchema faqs={questionsData.slice(0, 10).map(q => ({ question: q.question, answer: (q.quickAnswer || q.answer || '').replace(/<[^>]*>/g, '') }))} />
    )}
    <main class="min-h-screen">
        <!-- Hero Section -->
        <section class="relative bg-white border-b border-slate-100 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
            <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                    <span class="text-slate-300">/</span>
                    <span class="text-slate-700 font-medium">Questions</span>
                </nav>

                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-100 text-violet-700 text-sm font-medium mb-6">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                    100+ Expert Answers
                </div>

                <h1 class="text-5xl md:text-6xl font-semibold tracking-tight text-slate-900 mb-6 text-center">
                    TMS Therapy <span class="text-violet-600">Questions & Answers</span>
                </h1>
                <p class="text-xl text-slate-500 max-w-3xl mx-auto mb-8 text-center">
                    Expert answers to your TMS therapy questions. Evidence-based
                    information you can trust.
                </p>

                {/* Search Bar with Autocomplete */}
                <div class="max-w-2xl mx-auto">
                    <div class="relative" id="search-container">
                        <input
                            type="text"
                            id="question-search"
                            placeholder="Ask any question about TMS therapy..."
                            class="w-full px-6 py-4 rounded-2xl text-gray-900 text-lg pr-12 shadow-[0_4px_20px_rgb(0,0,0,0.03)] border border-slate-200 focus:outline-none focus:ring-4 focus:ring-violet-200"
                            autocomplete="off"
                        />
                        <svg
                            class="absolute right-4 top-1/2 -translate-y-1/2 w-6 h-6 text-gray-400 pointer-events-none"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                            ></path>
                        </svg>

                        {/* Autocomplete Dropdown */}
                        <div
                            id="autocomplete-results"
                            class="absolute top-full left-0 right-0 mt-2 bg-white rounded-xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-200 max-h-96 overflow-y-auto hidden z-50"
                        >
                            {/* Results populated by JS */}
                        </div>
                    </div>
                    <p class="text-slate-400 text-sm mt-3 text-center">
                        Try: "How much does TMS cost?" or "Is TMS FDA
                        approved?"
                    </p>
                </div>
            </div>
        </section>

        <div class="container mx-auto px-4 max-w-6xl">
            <!-- Featured Questions -->
            <section class="py-12 lg:py-16">
                <div class="flex items-center gap-3 mb-8">
                    <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center">
                        <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                    </div>
                    <h2 class="text-2xl font-bold text-slate-900">Most Asked Questions</h2>
                </div>

                {/* Featured first question — larger card */}
                {featured.length > 0 && (
                    <a href={`/questions/${featured[0].slug}/`} class="group block bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md hover:border-violet-200 transition-all mb-6 overflow-hidden">
                        <div class="p-8 lg:flex lg:items-start lg:gap-8">
                            <div class="w-14 h-14 rounded-2xl bg-violet-50 flex items-center justify-center text-violet-600 shrink-0 mb-4 lg:mb-0">
                                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            </div>
                            <div class="flex-1">
                                <h3 class="text-xl lg:text-2xl font-bold text-slate-900 group-hover:text-violet-600 transition-colors mb-3">{featured[0].question}</h3>
                                <p class="text-slate-500 leading-relaxed mb-4 line-clamp-3">{(featured[0].quickAnswer || featured[0].answer || '').replace(/<[^>]*>/g, '').substring(0, 200)}</p>
                                <span class="text-violet-600 font-semibold text-sm inline-flex items-center gap-1">Read Full Answer <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg></span>
                            </div>
                        </div>
                    </a>
                )}

                {/* Remaining featured questions */}
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                    {featured.slice(1).map((q) => (
                        <a href={`/questions/${q.slug}/`} class="group block bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md hover:border-violet-200 transition-all hover:-translate-y-0.5">
                            <h3 class="font-bold text-slate-900 group-hover:text-violet-600 transition-colors mb-3 leading-snug">{q.question}</h3>
                            <p class="text-slate-500 text-sm line-clamp-2 mb-4 leading-relaxed">{(q.quickAnswer || q.answer || '').replace(/<[^>]*>/g, '').substring(0, 120)}</p>
                            <div class="flex items-center justify-between pt-3 border-t border-slate-50">
                                <span class="text-violet-600 text-sm font-semibold">Read Answer</span>
                                <svg class="w-4 h-4 text-slate-400 group-hover:text-violet-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                            </div>
                        </a>
                    ))}
                </div>
            </section>

            <!-- Browse by Category -->
            <section class="py-12 lg:py-16 border-t border-slate-100">
                <div class="flex items-center gap-3 mb-10">
                    <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
                        <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    </div>
                    <h2 class="text-2xl font-bold text-slate-900">Browse by Topic</h2>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {Object.entries(categories).map(([key, cat]) => {
                        const questions = groupedQuestions[key] || [];
                        const iconColors = { basics: 'bg-blue-50 text-blue-600', cost: 'bg-emerald-50 text-emerald-600', conditions: 'bg-violet-50 text-violet-600', comparisons: 'bg-amber-50 text-amber-600' };
                        const colorClass = iconColors[key as keyof typeof iconColors] || 'bg-violet-50 text-violet-600';
                        return (
                            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
                                <div class="p-6 border-b border-slate-50">
                                    <div class="flex items-center gap-3">
                                        <div class={`w-10 h-10 rounded-xl ${colorClass} flex items-center justify-center shrink-0`}>
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                        </div>
                                        <div>
                                            <h3 class="text-lg font-bold text-slate-900">{cat.name}</h3>
                                            <p class="text-slate-500 text-xs">{cat.description}</p>
                                        </div>
                                        <span class="ml-auto text-xs font-semibold text-slate-400 bg-slate-50 px-2.5 py-1 rounded-lg">{questions.length}</span>
                                    </div>
                                </div>
                                <div class="p-4">
                                    <div class="space-y-0.5">
                                        {questions.slice(0, 5).map((q) => (
                                            <a href={`/questions/${q.slug}/`} class="flex items-center gap-3 py-2.5 px-3 rounded-xl hover:bg-slate-50 text-slate-700 hover:text-violet-700 transition-colors group/q">
                                                <svg class="w-4 h-4 text-slate-300 group-hover/q:text-violet-500 shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                                                <span class="text-sm leading-snug">{q.question}</span>
                                            </a>
                                        ))}
                                    </div>
                                    {questions.length > 5 && (
                                        <a href={`/questions/category/${key}/`} class="flex items-center gap-2 mt-3 px-3 py-2 text-violet-600 font-semibold text-sm hover:bg-violet-50 rounded-xl transition-colors">
                                            View all {questions.length} questions
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                                        </a>
                                    )}
                                </div>
                            </div>
                        );
                    })}
                </div>
            </section>

            <!-- CTA -->
            <section class="py-12 lg:py-16 border-t border-slate-100">
                <div class="bg-gradient-to-br from-violet-600 to-violet-700 rounded-2xl p-10 lg:p-14 text-center relative overflow-hidden">
                    <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full blur-[80px]"></div>
                    <div class="relative z-10">
                        <div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center mx-auto mb-5">
                            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                        </div>
                        <h2 class="text-2xl lg:text-3xl font-bold text-white mb-3">Can't find your answer?</h2>
                        <p class="text-violet-200 mb-8 max-w-lg mx-auto">
                            Talk to a TMS specialist for free. Our network of verified providers can answer your specific questions.
                        </p>
                        <button
                            onclick="document.dispatchEvent(new Event('open-enquiry-modal'))"
                            class="px-8 py-3.5 bg-white text-violet-600 font-semibold rounded-xl hover:bg-violet-50 transition-colors shadow-lg"
                        >
                            Talk to a Specialist
                        </button>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <script>
        import Fuse from "fuse.js";
        import questionsData from "../../data/questions-comprehensive.json";

        // Define types
        interface Question {
            question: string;
            quickAnswer: string;
            slug: string;
            category: string;
            keywords: string[];
        }

        interface FuseResult {
            item: Question;
            score?: number;
            matches?: readonly any[];
        }

        // Initialize Fuse.js for fuzzy search
        const fuse = new Fuse(questionsData, {
            keys: ["question", "quickAnswer", "keywords"],
            threshold: 0.3,
            minMatchCharLength: 2,
            includeScore: true,
            includeMatches: true,
        });

        const searchInput = document.getElementById(
            "question-search",
        ) as HTMLInputElement;
        const resultsContainer = document.getElementById(
            "autocomplete-results",
        );
        let selectedIndex = -1;
        let currentResults: FuseResult[] = [];

        // Debounce function
        function debounce<T extends (...args: any[]) => void>(
            func: T,
            wait: number,
        ) {
            let timeout: NodeJS.Timeout;
            return function (this: any, ...args: Parameters<T>) {
                const later = () => {
                    clearTimeout(timeout);
                    func.apply(this, args);
                };
                clearTimeout(timeout);
                timeout = setTimeout(later, wait);
            };
        }

        // Highlight matching text
        function highlightMatch(text: string, query: string): string {
            if (!query) return text;
            const regex = new RegExp(`(${query})`, "gi");
            return text.replace(
                regex,
                '<mark class="bg-yellow-200 text-gray-900 font-semibold">$1</mark>',
            );
        }

        // Display search results
        function displayResults(results: FuseResult[]) {
            if (!resultsContainer) return;

            if (results.length === 0) {
                resultsContainer.classList.add("hidden");
                currentResults = [];
                return;
            }

            currentResults = results;
            selectedIndex = -1;

            const html = results
                .slice(0, 7)
                .map((result, index) => {
                    const item = result.item;
                    const categoryBadgeColors: Record<string, string> = {
                        basics: "bg-blue-100 text-blue-700",
                        cost: "bg-green-100 text-green-700",
                        conditions: "bg-purple-100 text-purple-700",
                        comparisons: "bg-orange-100 text-orange-700",
                        location: "bg-cyan-100 text-cyan-700",
                        safety: "bg-red-100 text-red-700",
                        timeline: "bg-violet-100 text-violet-700",
                        experience: "bg-pink-100 text-pink-700",
                        technology: "bg-gray-100 text-gray-700",
                        procedure: "bg-yellow-100 text-yellow-700",
                    };

                    const badgeColor =
                        categoryBadgeColors[item.category] ||
                        "bg-gray-100 text-gray-700";

                    return `
                    <a 
                        href="/questions/${item.slug}/" 
                        class="autocomplete-item block px-6 py-4 hover:bg-violet-50 border-b border-gray-100 last:border-b-0 transition-colors"
                        data-index="${index}"
                    >
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex-1">
                                <div class="font-semibold text-gray-900 mb-1">
                                    ${highlightMatch(item.question, searchInput?.value || "")}
                                </div>
                                <div class="text-sm text-gray-600 line-clamp-2">
                                    ${item.quickAnswer.slice(0, 120)}...
                                </div>
                            </div>
                            <span class="flex-shrink-0 px-2 py-1 rounded-full text-xs font-semibold ${badgeColor}">
                                ${item.category}
                            </span>
                        </div>
                    </a>
                `;
                })
                .join("");

            resultsContainer.innerHTML = html;
            resultsContainer.classList.remove("hidden");

            // Add click handlers
            document.querySelectorAll(".autocomplete-item").forEach((item) => {
                item.addEventListener("mouseenter", (e) => {
                    document
                        .querySelectorAll(".autocomplete-item")
                        .forEach((el) => {
                            el.classList.remove("bg-violet-50");
                        });
                    (e.currentTarget as HTMLElement).classList.add(
                        "bg-violet-50",
                    );
                });
            });
        }

        // Perform search
        const performSearch = debounce((query: string) => {
            if (!query || query.length < 2) {
                resultsContainer?.classList.add("hidden");
                return;
            }

            const results = fuse.search(query);
            displayResults(results);
        }, 300);

        // Keyboard navigation
        function handleKeyboardNav(e: KeyboardEvent) {
            if (!currentResults.length) return;

            const items = document.querySelectorAll(".autocomplete-item");

            if (e.key === "ArrowDown") {
                e.preventDefault();
                selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
                updateSelection(items);
            } else if (e.key === "ArrowUp") {
                e.preventDefault();
                selectedIndex = Math.max(selectedIndex - 1, -1);
                updateSelection(items);
            } else if (e.key === "Enter") {
                e.preventDefault();
                if (selectedIndex >= 0 && items[selectedIndex]) {
                    (items[selectedIndex] as HTMLAnchorElement).click();
                }
            } else if (e.key === "Escape") {
                resultsContainer?.classList.add("hidden");
                searchInput?.blur();
            }
        }

        function updateSelection(items: NodeListOf<Element>) {
            items.forEach((item, index) => {
                if (index === selectedIndex) {
                    item.classList.add("bg-violet-50");
                    item.scrollIntoView({
                        block: "nearest",
                        behavior: "smooth",
                    });
                } else {
                    item.classList.remove("bg-violet-50");
                }
            });
        }

        // Event listeners
        searchInput?.addEventListener("input", (e) => {
            const query = (e.target as HTMLInputElement).value;
            performSearch(query);
        });

        searchInput?.addEventListener("keydown", handleKeyboardNav);

        searchInput?.addEventListener("focus", () => {
            if (searchInput.value.length >= 2 && currentResults.length > 0) {
                resultsContainer?.classList.remove("hidden");
            }
        });

        // Close on click outside
        document.addEventListener("click", (e) => {
            if (
                !searchInput?.contains(e.target as Node) &&
                !resultsContainer?.contains(e.target as Node)
            ) {
                resultsContainer?.classList.add("hidden");
            }
        });
    </script>
</Layout>
