---
export const prerender = false;
const title = "Who Qualifies for TMS Therapy? | TMS List";
const description = "Candidates typically have treatment-resistant depression having failed 1-2 antidepressant medications. Learn about TMS qualification requirements.";

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "Who qualifies for TMS therapy?",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "Candidates typically have treatment-resistant depression, meaning they have not responded adequately to at least one or two antidepressant medications. Patients must be adults (18+) without contraindications such as epilepsy, brain tumors, or metallic implants near the head."
    }
  }]
});
import Layout from "../../layouts/Layout.astro";
---
<Layout title={title} description={description} schema={faqSchema}>

  <main class="container mx-auto px-4 py-12 max-w-3xl">
    <article itemscope itemtype="https://schema.org/Article">
      <header class="mb-8">
        <h1 class="text-3xl lg:text-4xl font-bold text-[var(--ink)] mb-4" itemprop="headline">
          Who Qualifies for TMS Therapy?
        </h1>
        <div class="flex items-center gap-4 text-sm text-[var(--muted)]">
          <span>Reviewed by Dr. Karan Narwal, Mental Health Specialist</span>
          <span>|</span>
          <time datetime="2026-04-15">April 15, 2026</time>
        </div>
      </header>

      <div class="prose prose-lg prose-slate max-w-none" itemprop="articleBody">
        <p class="text-xl text-[var(--ink2)] leading-relaxed font-medium">
          Candidates typically have treatment-resistant depression, meaning they have not responded adequately to at least one or two antidepressant medications from different classes.
        </p>

        <p>
          Most insurance plans require documentation of prior treatment attempts before authorizing TMS. This typically includes trials of antidepressants from different medication classes at adequate doses and durations. A psychiatric evaluation is required to confirm the diagnosis and assess suitability for TMS.
        </p>

        <p>
          Contraindications include epilepsy or seizure disorders, brain tumors, metallic implants near the head (such as aneurysm coils or deep brain stimulators), and cochlear implants. Pregnant women and patients under 18 generally do not qualify for TMS outside of clinical trials.
        </p>

        <div class="bg-[rgba(10,22,40,0.08)] border border-[rgba(10,22,40,0.1)] rounded-2xl p-6 my-8">
          <h2 class="text-lg font-semibold text-[var(--ink)] mb-2">Take Our TMS Candidacy Quiz</h2>
          <p class="text-[var(--accent)] mb-4">
            Find out if TMS therapy might be right for you with our quick assessment.
          </p>
          <a href="/quiz/am-i-a-candidate/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-colors">
            Take the Quiz
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </article>

      <!-- End-of-page CTA -->
      <div class="mt-12 p-8 bg-gradient-to-br from-[#0A1628] to-[#0A1628] rounded-2xl text-center">
        <h2 class="text-xl font-bold text-white mb-2">Ready to explore TMS treatment?</h2>
        <p class="text-white/80 text-sm mb-6 leading-relaxed">Find a TMS provider near you and take our free eligibility quiz to see if TMS is right for your situation.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/quiz/am-i-a-candidate/" class="px-6 py-3 bg-[var(--paper)] text-[var(--accent)] font-semibold rounded-xl hover:bg-[rgba(10,22,40,0.08)] transition-colors shadow-md">
            Take the Eligibility Quiz
          </a>
          <a href="/us/" class="px-6 py-3 bg-[var(--paper)]/10 border border-white/30 text-white font-semibold rounded-xl hover:bg-[var(--paper)]/20 transition-all">
            Find a TMS Clinic
          </a>
        </div>
        <p class="text-xs text-white/60 mt-4">Also: <a href="/tms-cost-guide/" class="underline hover:text-white">download the free TMS Buyer's Guide</a> for comprehensive answers.</p>
      </div>
    
  </main>
</Layout>