---
export const prerender = false;
const title = "How Long Does TMS Take? Treatment Duration Guide | TMS List";
const description = "A standard TMS course involves 20-36 sessions over 4-6 weeks. Learn about treatment duration, session length, and what to expect.";

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "How long does TMS take?",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "A standard TMS course involves 20-36 sessions delivered over 4-6 weeks, with each session lasting approximately 19-37 minutes. Most patients begin noticing improvement by weeks 2-3 of treatment."
    }
  }]
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href="https://tmslist.com/answers/how-long-does-tms-take/">
  <script type="application/ld+json" set:html={faqSchema}></script>
</head>
<body class="bg-slate-50 min-h-screen">
  <header class="bg-white border-b border-slate-200">
    <div class="container mx-auto px-4 py-4">
      <a href="/" class="text-xl font-bold text-violet-600">TMS List</a>
    </div>
  </header>

  <main class="container mx-auto px-4 py-12 max-w-3xl">
    <article itemscope itemtype="https://schema.org/Article">
      <header class="mb-8">
        <h1 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4" itemprop="headline">
          How Long Does TMS Take?
        </h1>
        <div class="flex items-center gap-4 text-sm text-slate-500">
          <span>TMS List Editorial Team</span>
          <span>|</span>
          <time datetime="2026-04-15">April 15, 2026</time>
        </div>
      </header>

      <div class="prose prose-lg prose-slate max-w-none" itemprop="articleBody">
        <p class="text-xl text-slate-700 leading-relaxed font-medium">
          A standard TMS course involves 20-36 sessions delivered over 4-6 weeks, with each session lasting approximately 19-37 minutes depending on the protocol used.
        </p>

        <p>
          TMS treatment is typically administered five days per week (Monday through Friday) for 4-6 weeks. During each session, you will sit in a comfortable chair while the TMS coil is positioned against your scalp. The machine delivers magnetic pulses in short bursts, and you may feel a tapping or clicking sensation.
        </p>

        <p>
          Most patients begin noticing improvements by weeks 2-3 of treatment. After completing the initial course, some patients may benefit from maintenance sessions or periodic "booster" treatments to sustain their improvement over time.
        </p>

        <div class="bg-violet-50 border border-violet-100 rounded-2xl p-6 my-8">
          <h2 class="text-lg font-semibold text-violet-900 mb-2">Find TMS Providers Near You</h2>
          <p class="text-violet-700 mb-4">
            Start your TMS treatment journey today by finding certified providers in your area.
          </p>
          <a href="/us/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-violet-600 text-white font-semibold rounded-xl hover:bg-violet-700 transition-colors">
            Find TMS Clinics
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </article>

      <!-- End-of-page CTA -->
      <div class="mt-12 p-8 bg-gradient-to-br from-violet-600 to-indigo-600 rounded-2xl text-center">
        <h2 class="text-xl font-bold text-white mb-2">Ready to explore TMS treatment?</h2>
        <p class="text-violet-100 text-sm mb-6 leading-relaxed">Find a TMS provider near you and take our free eligibility quiz to see if TMS is right for your situation.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/quiz/am-i-a-candidate/" class="px-6 py-3 bg-white text-violet-700 font-semibold rounded-xl hover:bg-violet-50 transition-colors shadow-md">
            Take the Eligibility Quiz
          </a>
          <a href="/us/" class="px-6 py-3 bg-white/10 border border-white/30 text-white font-semibold rounded-xl hover:bg-white/20 transition-all">
            Find a TMS Clinic
          </a>
        </div>
        <p class="text-xs text-violet-200 mt-4">Also: <a href="/resources/buyers-guide/" class="underline hover:text-white">download the free TMS Buyer's Guide</a> for comprehensive answers.</p>
      </div>
    </article>
  </main>

  <footer class="bg-white border-t border-slate-200 mt-16">
    <div class="container mx-auto px-4 py-8 text-center text-sm text-slate-500">
      <p>&copy; 2026 TMS List. All rights reserved. | <a href="/about-us/" class="hover:text-violet-600">About Us</a> | <a href="/contact/" class="hover:text-violet-600">Contact</a></p>
    </div>
  </footer>
</body>
</html>
