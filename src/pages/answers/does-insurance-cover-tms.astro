---
export const prerender = false;
const title = "Does Insurance Cover TMS Therapy? | TMS List";
const description = "Most major insurers cover TMS for FDA-cleared indications including major depressive disorder and OCD. Learn about insurance coverage requirements.";

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "Does insurance cover TMS?",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "Most major insurers cover TMS for FDA-cleared indications. Medicare and most commercial plans cover TMS for treatment-resistant major depressive disorder. Coverage typically requires prior authorization and documentation of failed medication trials."
    }
  }]
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href="https://tmslist.com/answers/does-insurance-cover-tms/">
  <script type="application/ld+json" set:html={faqSchema}></script>
</head>
<body class="bg-slate-50 min-h-screen">
  <header class="bg-white border-b border-slate-200">
    <div class="container mx-auto px-4 py-4">
      <a href="/" class="text-xl font-bold text-violet-600">TMS List</a>
    </div>
  </header>

  <main class="container mx-auto px-4 py-12 max-w-3xl">
    <article itemscope itemtype="https://schema.org/Article">
      <header class="mb-8">
        <h1 class="text-3xl lg:text-4xl font-bold text-slate-900 mb-4" itemprop="headline">
          Does Insurance Cover TMS Therapy?
        </h1>
        <div class="flex items-center gap-4 text-sm text-slate-500">
          <span>TMS List Editorial Team</span>
          <span>|</span>
          <time datetime="2026-04-15">April 15, 2026</time>
        </div>
      </header>

      <div class="prose prose-lg prose-slate max-w-none" itemprop="articleBody">
        <p class="text-xl text-slate-700 leading-relaxed font-medium">
          Most major insurers cover TMS for FDA-cleared indications including treatment-resistant major depressive disorder, OCD, and smoking cessation.
        </p>

        <p>
          Medicare covers TMS for patients with major depressive disorder who have failed at least four antidepressant medications. Most Blue Cross Blue Shield, Aetna, Cigna, and United Healthcare plans also provide coverage for FDA-cleared TMS indications.
        </p>

        <p>
          Insurance typically requires prior authorization, which your TMS provider will handle. Requirements usually include documentation of failed medication trials and a psychiatric evaluation confirming the diagnosis. Deductibles and copays vary by plan.
        </p>

        <div class="bg-emerald-50 border border-emerald-100 rounded-2xl p-6 my-8">
          <h2 class="text-lg font-semibold text-emerald-900 mb-2">Insurance & Payment Guide</h2>
          <p class="text-emerald-700 mb-4">
            Learn more about insurance coverage, Medicare, and payment options for TMS therapy.
          </p>
          <a href="/insurance/" class="inline-flex items-center gap-2 px-5 py-2.5 bg-emerald-600 text-white font-semibold rounded-xl hover:bg-emerald-700 transition-colors">
            View Insurance Guide
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </article>

      <!-- End-of-page CTA -->
      <div class="mt-12 p-8 bg-gradient-to-br from-violet-600 to-indigo-600 rounded-2xl text-center">
        <h2 class="text-xl font-bold text-white mb-2">Ready to explore TMS treatment?</h2>
        <p class="text-violet-100 text-sm mb-6 leading-relaxed">Find a TMS provider near you and take our free eligibility quiz to see if TMS is right for your situation.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/quiz/am-i-a-candidate/" class="px-6 py-3 bg-white text-violet-700 font-semibold rounded-xl hover:bg-violet-50 transition-colors shadow-md">
            Take the Eligibility Quiz
          </a>
          <a href="/us/" class="px-6 py-3 bg-white/10 border border-white/30 text-white font-semibold rounded-xl hover:bg-white/20 transition-all">
            Find a TMS Clinic
          </a>
        </div>
        <p class="text-xs text-violet-200 mt-4">Also: <a href="/resources/buyers-guide/" class="underline hover:text-white">download the free TMS Buyer's Guide</a> for comprehensive answers.</p>
      </div>
    </article>
  </main>

  <footer class="bg-white border-t border-slate-200 mt-16">
    <div class="container mx-auto px-4 py-8 text-center text-sm text-slate-500">
      <p>&copy; 2026 TMS List. All rights reserved. | <a href="/about-us/" class="hover:text-violet-600">About Us</a> | <a href="/contact/" class="hover:text-violet-600">Contact</a></p>
    </div>
  </footer>
</body>
</html>
