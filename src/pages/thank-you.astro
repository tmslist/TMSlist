---
import Layout from "../layouts/Layout.astro";

const title = "Thank You | TMS List";
const description = "Thank you for your submission.";
---

<Layout title={title} description={description} noindex={true}>
    <main class="min-h-[70vh] flex items-center justify-center bg-[var(--paper2)]">
        <div class="text-center p-8 max-w-lg mx-auto">
            <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
                <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            <h1 class="text-4xl font-semibold text-[var(--ink2)] mb-4">Thank You!</h1>
            <p class="text-lg text-[var(--muted)] mb-8">
                Your submission has been received. We appreciate your interest and will get back to you shortly.
            </p>
            <a
                href="/"
                class="inline-block bg-[var(--ink)] text-white font-semibold px-6 py-3 rounded-lg hover:bg-[var(--ink2)] transition"
            >
                Return to Homepage
            </a>
        </div>
    </div>

    <!-- End-of-page CTA -->
    <section class="pb-16 bg-[var(--paper2)]">
        <div class="container mx-auto px-4 max-w-3xl">
            <div class="bg-gradient-to-br from-[#0A1628] to-[#0A1628] rounded-2xl p-8 text-center">
                <h2 class="text-xl font-bold text-white mb-2">While you wait, explore your TMS options</h2>
                <p class="text-white/80 text-sm mb-6 leading-relaxed">Take our free eligibility quiz or browse verified TMS providers near you.</p>
                <div class="flex flex-col sm:flex-row gap-3 justify-center">
                    <a href="/quiz/am-i-a-candidate/" class="px-6 py-3 bg-[var(--paper)] text-[var(--accent)] font-semibold rounded-xl hover:bg-[rgba(10,22,40,0.08)] transition-colors shadow-md">
                        Take the Eligibility Quiz
                    </a>
                    <a href="/us/" class="px-6 py-3 bg-[var(--paper)]/10 border border-white/30 text-white font-semibold rounded-xl hover:bg-[var(--paper)]/20 transition-all">
                        Find a TMS Clinic
                    </a>
                </div>
                <p class="text-xs text-white/60 mt-4">Or <a href="/tms-cost-guide/" class="underline hover:text-white">download the free TMS Buyer's Guide</a>.</p>
            </div>
        </div>
    </section>

    <!-- Conversion tracking -->
    <script is:inline>
        if (typeof window !== 'undefined') {
            try {
                fetch('/api/analytics/track', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ clinicId: 'site', event: 'lead_submit' }),
                }).catch(() => {});
            } catch {}
        }
    </script>
</Layout>
