---
import Layout from "../../layouts/Layout.astro";
import GoogleReviews from "../../components/GoogleReviews.astro";
import BookingWidget from "../../components/react/BookingWidget";
import HealthScoreBadge from "../../components/react/HealthScoreBadge";
import ClinicTracking from "../../components/ClinicTracking.astro";
import { STATE_NAMES, getAllClinics, getStateSlug } from "../../utils/clinicData";
import { getDoctorPhoto, COUNTRY_NAMES, COUNTRY_URL_PREFIXES } from "../../utils/dataHelpers";
import { getClinicLogoUrl } from "../../utils/images";

const { slug } = Astro.params;

const allClinics = await getAllClinics();
const clinic = allClinics.find((c: any) => c.slug === slug);
if (!clinic) return Astro.redirect("/us/");

// Handle data access robustly
const city = clinic.address_obj?.city || clinic.city;
const state = clinic.address_obj?.state || clinic.state;
const countryCode = clinic.country || 'US';
const stateName = STATE_NAMES[state] || state;
const countryName = COUNTRY_NAMES[countryCode] || countryCode;
const countryUrlPrefix = COUNTRY_URL_PREFIXES[countryCode] || countryCode.toLowerCase();
const isUS = countryCode === 'US';
const county = clinic.address_obj?.county || null;
const street = clinic.address_obj?.street || clinic.address;
const zip = clinic.address_obj?.zip || clinic.zip;
const landmarks = clinic.address_obj?.nearby_landmarks || [];
const machines = clinic.machines || [];
const treatments = clinic.specialties || clinic.treatments || [];
const doctors = clinic.doctors_data || [];
const insurances = clinic.insurances || clinic.insurance_accepted || [];
const faqs = clinic.faqs || [];

// Rating handling
const getRating = () => {
    if (typeof clinic.rating === "number") return clinic.rating;
    return clinic.rating?.aggregate || null;
};
const getReviewCount = () => {
    if (typeof clinic.rating === "object") return clinic.rating?.count || 0;
    return clinic.review_count || 0;
};
const getSentiment = () => {
    if (typeof clinic.rating === "object" && clinic.rating?.sentiment_summary)
        return clinic.rating.sentiment_summary;
    return null;
};

// SEO & Schema
const pageTitle = `${clinic.name} | Top Rated TMS Therapy in ${city}, ${state}`;
const seoSnippet = clinic.seo_article ? clinic.seo_article.split('\n\n')[0].substring(0, 140) + '...' : '';
const metaDescription = seoSnippet || `Looking for TMS Therapy in ${city}? ${clinic.name} offers FDA-cleared treatment for depression. ${getRating()} stars from ${getReviewCount()} reviews. Book a consultation today.`;

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalClinic",
    "@id": `https://tmslist.com/clinic/${clinic.slug}`,
    name: clinic.name,
    image: clinic.hero_image_url || "https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&q=80&w=1200",
    logo: clinic.logo_url || clinic.media?.logo_url || undefined,
    url: `https://tmslist.com/clinic/${clinic.slug}`,
    telephone: clinic.phone,
    address: {
        "@type": "PostalAddress",
        streetAddress: street,
        addressLocality: city,
        addressRegion: stateName, 
        postalCode: zip,
        addressCountry: countryCode,
    },
    geo: {
        "@type": "GeoCoordinates",
        latitude: clinic.geo?.lat,
        longitude: clinic.geo?.lng,
    },
    ...(clinic.service_area || clinic.serviceArea || clinic.area_served ? {
        areaServed: clinic.service_area || clinic.serviceArea || clinic.area_served,
    } : {
        areaServed: `${city}, ${stateName}`,
    }),
    ...(clinic.accepting_new_patients !== undefined ? {
        acceptsNewPatients: clinic.accepting_new_patients,
    } : {}),
    ...(getRating() ? {
        aggregateRating: {
            "@type": "AggregateRating",
            ratingValue: getRating(),
            reviewCount: getReviewCount(),
        },
    } : {}),
    priceRange: clinic.price_range || "$$",
    ...((clinic.opening_hours && clinic.opening_hours.length > 0) ? {
        openingHoursSpecification: clinic.opening_hours.map((h: string) => {
            // Parse "Mon-Fri: 9:00 AM - 5:00 PM" style strings
            const match = h.match(/^([^:]+):\s*(\d{1,2}:\d{2}\s*[AP]?M?)\s*[-–]\s*(\d{1,2}:\d{2}\s*[AP]?M?)$/i);
            if (match) {
                return {
                    "@type": "OpeningHoursSpecification",
                    dayOfWeek: match[1].trim(),
                    opens: match[2].trim(),
                    closes: match[3].trim(),
                };
            }
            return { "@type": "OpeningHoursSpecification", description: h };
        }),
    } : {}),
});

// FAQPage schema for clinic-specific FAQs
const faqSchema = faqs.length > 0 ? JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((faq: any) => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
            "@type": "Answer",
            "text": faq.answer,
        },
    })),
}) : null;

// Clinic Hero Selection
const clinicHeroImages = [
    "https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&q=80&w=1200",
    "https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&q=80&w=1200",
    "https://images.unsplash.com/photo-1631549916768-4119b2e5f926?auto=format&fit=crop&q=80&w=1200",
    "https://images.unsplash.com/photo-1551076805-e1869033e561?auto=format&fit=crop&q=80&w=1200",
    "https://images.unsplash.com/photo-1579684385127-1ef15d508118?auto=format&fit=crop&q=80&w=1200"
];
const displayHero = clinic.hero_image_url || clinicHeroImages[clinic.name.length % clinicHeroImages.length];
const logoUrl = getClinicLogoUrl(clinic);
const galleryImages = clinic.gallery_urls || [];

// Pre-compute all optional chaining for template safety (esbuild cannot parse ?. in Astro templates)
const hasLogoUrl = !!(clinic.logo_url || clinic.media?.logo_url);
const displayLogoUrl = clinic.logo_url || clinic.media?.logo_url;
const displayRating = getRating();
const formattedRating = displayRating ? displayRating.toFixed(1) : '—';
const acceptsInsurance = clinic.cost_info?.accepts_insurance;
const cashPrice = clinic.cost_info?.cash_price_per_session;
const financingAvailable = clinic.cost_info?.financing_available;
const websiteUrl = clinic.contact?.website_url || clinic.website;
const phoneNumber = clinic.contact?.phone || clinic.phone;
const embedUrl = clinic.google_business_profile?.embed_url;
const layoutImage = clinic.hero_image_url || clinic.logo_url || clinic.media?.logo_url || clinic.media?.hero_image_url || undefined;
---

<Layout title={pageTitle} description={metaDescription} schema={schema} canonical={`https://tmslist.com/clinic/${clinic.slug}/`} image={layoutImage}>
    <!-- Clean Premium Light Hero -->
    <section class="relative bg-white pt-16 pb-24 overflow-hidden" style="background: var(--paper); border-bottom: 1px solid var(--line);">
        <div class="absolute inset-x-0 top-0 h-[600px] pointer-events-none" style="background: linear-gradient(to bottom, color-mix(in srgb, var(--warm) 4%, var(--paper)), transparent);"></div>

        <div class="container mx-auto px-6 lg:px-12 relative z-10">
            <!-- Breadcrumbs -->
            <nav class="flex text-xs font-semibold tracking-widest uppercase mb-10" style="color: var(--muted);" aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-2">
                    <li><a href="/" class="hover:text-[var(--warm)] transition-colors">Home</a></li>
                    <li><span class="mx-2" style="color: var(--line);">/</span></li>
                    <li><a href={`/${countryUrlPrefix}/`} class="hover:text-[var(--warm)] transition-colors">{isUS ? 'US' : countryName}</a></li>
                    <li><span class="mx-2" style="color: var(--line);">/</span></li>
                    <li>
                        <a href={`/${countryUrlPrefix}/${stateName.toLowerCase().replace(/\s+/g, "-")}/`} class="hover:text-[var(--warm)] transition-colors">{stateName}</a>
                    </li>
                    <li><span class="mx-2" style="color: var(--line);">/</span></li>
                    <li>
                        <a href={`/${countryUrlPrefix}/${stateName.toLowerCase().replace(/\s+/g, "-")}/${city.toLowerCase().replace(/\s+/g, "-").replace(/\./g, "")}/`} class="hover:text-[var(--warm)] transition-colors">{city}</a>
                    </li>
                </ol>
            </nav>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <!-- Hero Content -->
                <div class="max-w-2xl">
                    {clinic.verified && (
                    <div class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 mb-6" style="background: color-mix(in srgb, var(--accent) 8%, white); border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);">
                        <svg class="w-3.5 h-3.5" style="color: var(--accent);" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        <span class="text-xs font-bold tracking-widest uppercase" style="color: var(--accent);">Verified Clinic</span>
                    </div>
                    )}

                    <div class="flex items-center gap-3 mb-4">
                        <HealthScoreBadge client:idle clinicId={clinic.id} size="md" />
                    </div>

                    <div class="flex items-start gap-4 mb-6">
                        {hasLogoUrl ? (
                            <img
                                src={displayLogoUrl}
                                alt={`${clinic.name} logo`}
                                width="64"
                                height="64"
                                class="w-16 h-16 rounded-2xl object-cover shrink-0 mt-1"
                                loading="eager"
                                fetchpriority="high"
                                decoding="async"
                                style="border: 1px solid var(--line);"
                            />
                        ) : (
                            <div class="w-16 h-16 rounded-2xl flex items-center justify-center shrink-0 text-white text-2xl font-extrabold" style="background: linear-gradient(135deg, var(--warm), color-mix(in srgb, var(--warm) 80%, var(--accent)));">
                                {clinic.name.charAt(0).toUpperCase()}
                            </div>
                        )}
                        <h1 class="serif text-2xl sm:text-3xl lg:text-5xl font-normal tracking-tight leading-tight" style="color: var(--ink); letter-spacing: -0.02em;">
                            {clinic.name}
                        </h1>
                    </div>

                    <p class="text-xl leading-relaxed font-light" style="color: var(--muted);">
                        Specialized TMS Therapy and Neuromodulation right here in <strong class="font-semibold" style="color: var(--ink2);">{city}, {stateName}</strong>. {isUS ? 'FDA-cleared' : 'Clinically approved'} treatment for depression with proven clinical excellence.
                    </p>

                    <div class="flex flex-col sm:flex-row gap-4 mt-10">
                        <a href="#contact" class="flex-1 sm:flex-none inline-flex justify-center items-center px-4 sm:px-8 py-3 sm:py-4 text-white text-[15px] font-bold rounded-xl shadow-lg transition-all" style="background: var(--ink);">
                            Book Consultation
                        </a>
                        <button data-request-callback data-clinic-name={clinic.name} data-clinic-id={clinic.slug}
                            class="flex-1 sm:flex-none inline-flex justify-center items-center gap-2 px-4 sm:px-8 py-3 sm:py-4 text-[15px] font-bold rounded-xl transition-all cursor-pointer"
                            style="background: white; border: 1px solid var(--line); color: var(--ink2); box-shadow: 0 2px 8px rgba(0,0,0,0.04);">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                            Request Callback
                        </button>
                    </div>
                </div>

                <!-- Hero Image -->
                <div class="relative w-full aspect-[4/3] rounded-3xl overflow-hidden" style="box-shadow: 0 20px 60px rgba(10,22,40,0.08); border: 1px solid var(--line);">
                    <img
                        src={displayHero}
                        alt={`Clinical environment at ${clinic.name}`}
                        width="800"
                        height="600"
                        class="w-full h-full object-cover"
                        loading="eager"
                        fetchpriority="high"
                        decoding="async"
                    />
                    {clinic.hero_image_url && (
                        <div class="absolute top-4 right-4 inline-flex items-center gap-1.5 px-3 py-1.5 backdrop-blur-sm rounded-full text-xs font-semibold" style="background: color-mix(in srgb, white 90%, transparent); box-shadow: 0 2px 8px rgba(0,0,0,0.06); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);">
                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/></svg>
                            Verified Photo
                        </div>
                    )}
                </div>
            </div>
        </div>
    </section>

    <!-- Clinic Dashboard Layout -->
    <main class="py-16" style="background: var(--paper2);">
        <div class="container mx-auto px-6 lg:px-12 grid grid-cols-1 xl:grid-cols-12 gap-12">

            <!-- Left Column: Core Details -->
            <div class="xl:col-span-8 space-y-12">
                <!-- Stats Bento -->
                <section class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4">
                    {getReviewCount() > 0 && (
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border" style="border-color: var(--line); box-shadow: 0 2px 12px rgba(10,22,40,0.04);">
                        <div class="text-2xl sm:text-3xl font-bold tracking-tight" style="color: var(--ink);">{getReviewCount().toLocaleString()}</div>
                        <div class="text-xs font-semibold uppercase tracking-widest mt-1" style="color: var(--muted);">Patient Reviews</div>
                    </div>
                    )}
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border" style="border-color: var(--line); box-shadow: 0 2px 12px rgba(10,22,40,0.04);">
                        <div class="text-2xl sm:text-3xl font-bold tracking-tight" style="color: var(--ink);">{machines.length || '—'}</div>
                        <div class="text-xs font-semibold uppercase tracking-widest mt-1" style="color: var(--muted);">TMS Devices</div>
                    </div>
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border" style="border-color: var(--line); box-shadow: 0 2px 12px rgba(10,22,40,0.04);">
                        <div class="text-2xl sm:text-3xl font-bold tracking-tight" style="color: var(--ink);">{doctors.length || 1}</div>
                        <div class="text-xs font-semibold uppercase tracking-widest mt-1" style="color: var(--muted);">Specialists</div>
                    </div>
                    {displayRating && (
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border" style="border-color: var(--line); box-shadow: 0 2px 12px rgba(10,22,40,0.04);">
                        <div class="text-2xl sm:text-3xl font-bold tracking-tight" style="color: var(--ink);">{formattedRating}</div>
                        <div class="text-xs font-semibold uppercase tracking-widest mt-1" style="color: var(--muted);">Patient Rating</div>
                    </div>
                    )}
                </section>

                <!-- About Overview -->
                <section class="bg-white rounded-3xl p-8 border" style="border-color: var(--line); box-shadow: 0 4px 20px rgba(10,22,40,0.04);">
                    <h2 class="serif text-2xl mb-6" style="color: var(--ink); letter-spacing: -0.02em;">About the Clinic</h2>
                    <div class="leading-loose font-light" style="color: var(--muted);">
                        {clinic.seo_article ? (
                            clinic.seo_article.split('\n\n').map((paragraph: string) => (
                                <p class="mb-4">{paragraph}</p>
                            ))
                        ) : (
                            <>
                                <p class="mb-4">{clinic.description_long}</p>
                                <p class="mb-4">
                                    Located in {city}, {stateName}, our clinic serves
                                    patients throughout {county || city} and the surrounding areas.
                                    We understand that mental health treatment is deeply personal,
                                    which is why we take a patient-centered approach to every
                                    consultation.
                                </p>
                            </>
                        )}
                    </div>
                </section>

                <!-- Photo Gallery -->
                {galleryImages.length > 0 && (
                    <section>
                        <h2 class="serif text-2xl mb-6" style="color: var(--ink);">Clinic Gallery</h2>
                        <div class={`grid gap-3 ${galleryImages.length === 1 ? 'grid-cols-1' : galleryImages.length === 2 ? 'grid-cols-2' : 'grid-cols-2 md:grid-cols-3'}`}>
                            {galleryImages.map((imgUrl: string, i: number) => (
                                <div class={`relative rounded-2xl overflow-hidden border ${i === 0 && galleryImages.length >= 3 ? 'col-span-2 row-span-2' : ''}`} style="border-color: var(--line); box-shadow: 0 2px 12px rgba(10,22,40,0.04);">
                                    <img
                                        src={imgUrl}
                                        alt={`${clinic.name} TMS clinic in ${city}, ${state} - gallery image ${i + 1}`}
                                        width="600"
                                        height="450"
                                        class="w-full h-full object-cover aspect-[4/3]"
                                        loading="lazy"
                                    />
                                </div>
                            ))}
                        </div>
                    </section>
                )}

                <!-- Technology & Machines -->
                <section>
                    <h2 class="serif text-2xl mb-6" style="color: var(--ink);">Advanced TMS Devices</h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {machines.map((machine: string) => (
                            <div class="bg-white p-6 rounded-2xl border flex items-start gap-4" style="border-color: var(--line); box-shadow: 0 2px 12px rgba(10,22,40,0.04);">
                                <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background: color-mix(in srgb, var(--accent) 10%, white); color: var(--accent);">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                                </div>
                                <div>
                                    <h3 class="text-[15px] font-bold" style="color: var(--ink2);">{machine}</h3>
                                    <p class="text-xs mt-1" style="color: var(--muted);">FDA-Cleared Technology</p>
                                </div>
                            </div>
                        ))}
                        {machines.length === 0 && (
                            <div class="col-span-full rounded-2xl border p-6" style="background: var(--paper2); border-color: var(--line); color: var(--muted);">
                                TMS device information not yet verified for this clinic. Contact the clinic directly for details about their equipment.
                            </div>
                        )}
                    </div>
                </section>

                <!-- Treatments Grid -->
                <section>
                    <h2 class="serif text-2xl mb-6" style="color: var(--ink);">Conditions Treated</h2>
                    <div class="flex flex-wrap gap-3">
                        {treatments.map((treatment: string) => (
                            <span class="px-5 py-2.5 font-semibold text-sm rounded-full border transition-colors" style="background: white; border-color: var(--line); color: var(--ink2);">
                                {treatment}
                            </span>
                        ))}
                        {treatments.length === 0 && (
                            <p class="text-sm" style="color: var(--muted);">
                                Specific treatment conditions not yet listed. TMS is FDA-cleared for depression, OCD, and smoking cessation. <a href="/treatments/" class="font-medium underline underline-offset-2" style="color: var(--warm);">View all treatable conditions</a>.
                            </p>
                        )}
                    </div>
                </section>

                <!-- Medical Staff -->
                {doctors.length > 0 && (
                    <section id="team">
                        <h2 class="serif text-2xl mb-6" style="color: var(--ink);">Medical Team</h2>
                        <div class="grid gap-4">
                            {doctors.map((doctor: any) => (
                                <div class="bg-white p-6 rounded-3xl border flex flex-col sm:flex-row items-start sm:items-center gap-6" style="border-color: var(--line); box-shadow: 0 2px 12px rgba(10,22,40,0.04);">
                                    <img
                                        src={getDoctorPhoto(doctor)}
                                        alt={doctor.name}
                                        class="w-20 h-20 rounded-full object-cover"
                                        loading="lazy"
                                        style="border: 2px solid var(--line);"
                                    />
                                    <div class="flex-1">
                                        <a href={`/doctor/${doctor.slug}`} class="text-lg font-bold hover:italic" style="color: var(--ink); transition: font-style 0.2s;">
                                            {doctor.name}
                                        </a>
                                        <p class="text-[13px] font-semibold tracking-wider uppercase mt-0.5 mb-2" style="color: var(--warm);">{doctor.title}</p>
                                        <div class="flex items-center gap-4 text-xs font-medium" style="color: var(--muted);">
                                            <span>{doctor.years_experience}+ Years Exp.</span>
                                            <span class="w-1 h-1 rounded-full" style="background: var(--line);"></span>
                                            <span>{doctor.school}</span>
                                        </div>
                                    </div>
                                    <a href={`/doctor/${doctor.slug}`} class="shrink-0 px-5 py-2.5 text-sm font-bold rounded-xl transition-all" style="background: var(--paper2); border: 1px solid var(--line); color: var(--ink2);">
                                        Profile
                                    </a>
                                </div>
                            ))}
                        </div>
                    </section>
                )}

                <!-- Insurance Block -->
                <section class="bg-white rounded-3xl p-8 border" style="border-color: var(--line); box-shadow: 0 4px 20px rgba(10,22,40,0.04);">
                    <h2 class="serif text-2xl mb-6" style="color: var(--ink);">Insurance and Cost Details</h2>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8 pb-8 border-b" style="border-color: var(--line);">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color: var(--muted);">Accepts Insurance</p>
                            <p class="text-lg font-bold" style="color: var(--ink);">{acceptsInsurance ? "Yes" : "Contact Clinic"}</p>
                        </div>
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color: var(--muted);">Cash Price</p>
                            <p class="text-lg font-bold" style="color: var(--ink);">{cashPrice || "Request Info"}</p>
                        </div>
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color: var(--muted);">Financing</p>
                            <p class="text-lg font-bold" style="color: var(--ink);">{financingAvailable ? "Available" : "Contact Clinic"}</p>
                        </div>
                    </div>

                    <h3 class="text-sm font-bold mb-4" style="color: var(--ink2);">Recognized Networks</h3>
                    <div class="flex flex-wrap gap-2">
                        {insurances.map((ins: string) => (
                            <span class="px-3 py-1.5 rounded text-[13px] font-medium" style="background: var(--paper2); border: 1px solid var(--line); color: var(--ink2);">
                                {ins}
                            </span>
                        ))}
                        {insurances.length === 0 && <span class="text-sm" style="color: var(--muted);">Insurance information not yet listed. Most TMS clinics accept Medicare and major insurers — <a href="/insurance/" class="font-medium" style="color: var(--warm);">check our coverage guide</a>.</span>}
                    </div>
                </section>

                <GoogleReviews
                    aggregateRating={getRating()}
                    totalCount={getReviewCount()}
                    entityName={clinic.name}
                    clinicId={clinic.id}
                />

                {faqSchema && <script type="application/ld+json" set:html={faqSchema} />}

                {faqs.length > 0 && (
                    <section>
                        <h2 class="serif text-2xl mb-6" style="color: var(--ink);">Frequently Asked Questions</h2>
                        <div class="space-y-3">
                            {faqs.map((faq: any) => (
                                <details class="group bg-white rounded-2xl border" style="border-color: var(--line); box-shadow: 0 2px 12px rgba(10,22,40,0.04);">
                                    <summary class="flex justify-between items-center p-6 cursor-pointer list-none text-[15px] font-bold outline-none" style="color: var(--ink2);">
                                        <span>{faq.question}</span>
                                        <svg class="w-5 h-5 transition-transform group-open:rotate-180" style="color: var(--muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                    </summary>
                                    <div class="p-6 pt-0 leading-relaxed" style="color: var(--muted);">
                                        {faq.answer}
                                    </div>
                                </details>
                            ))}
                        </div>
                    </section>
                )}
            </div>

            <!-- Right Column: Sidebar -->
            <div class="xl:col-span-4">
                <div class="sticky top-24 space-y-6">

                    <!-- Contact Box -->
                    <div id="contact" class="bg-white rounded-3xl p-6 border text-center" style="border-color: var(--line); box-shadow: 0 8px 30px rgba(10,22,40,0.06);">
                        <img
                            src={logoUrl}
                            alt={`${clinic.name} logo`}
                            class="w-16 h-16 mx-auto rounded-2xl object-cover mb-4"
                            loading="lazy"
                            style="border: 1px solid var(--line);"
                        />
                        <h3 class="text-lg font-bold mb-1" style="color: var(--ink);">{clinic.name}</h3>
                        <p class="text-sm mb-6 font-light" style="color: var(--muted);">{street}<br/>{city}, {state} {zip}</p>

                        <div class="space-y-3">
                            <button data-request-callback data-clinic-name={clinic.name} data-clinic-id={clinic.slug}
                                class="flex items-center justify-center gap-2 w-full py-3.5 text-white rounded-xl text-sm font-bold transition-all shadow-md cursor-pointer"
                                style="background: var(--warm);">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                Request Callback
                            </button>
                            <div id="phone-reveal-gate" class="text-center">
                                <button id="reveal-phone-btn" data-trigger-enquiry
                                    class="text-sm font-semibold underline underline-offset-2 cursor-pointer"
                                    style="color: var(--warm);">
                                    Enquire to reveal phone number
                                </button>
                            </div>
                            {websiteUrl && (
                            <a href={websiteUrl} target="_blank" rel="noopener" class="flex items-center justify-center gap-2 w-full py-3.5 bg-white rounded-xl text-sm font-bold transition-all"
                                style="border: 1px solid var(--line); color: var(--ink2);">
                                Visit Website
                            </a>
                            )}
                            <BookingWidget client:idle clinicId={clinic.id} clinicName={clinic.name} clinicPhone={phoneNumber} />
                        </div>
                    </div>

                    <!-- Map Card -->
                    {embedUrl && (
                        <div class="bg-white rounded-3xl p-2 border h-[300px] overflow-hidden" style="border-color: var(--line); box-shadow: 0 4px 20px rgba(10,22,40,0.04);">
                            <iframe
                                src={embedUrl}
                                width="100%"
                                height="100%"
                                style="border:0;"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade"
                                class="rounded-2xl"
                                title={`Map of ${clinic.name}`}
                            ></iframe>
                        </div>
                    )}

                    <!-- Hours Card -->
                    <div class="bg-white rounded-3xl p-6 border" style="border-color: var(--line); box-shadow: 0 4px 20px rgba(10,22,40,0.04);">
                        <h3 class="text-[15px] font-bold mb-4 flex items-center gap-2" style="color: var(--ink2);">
                            <svg class="w-4 h-4" style="color: var(--muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            Hours of Operation
                        </h3>
                        <div class="space-y-3">
                            {(clinic.opening_hours || ["Hours not yet verified — please call to confirm"]).map((hours: string) => (
                                <div class="flex justify-between items-center text-[13px] font-medium border-b pb-2 last:border-0 last:pb-0" style="border-color: var(--paper2);">
                                    <span style="color: var(--muted);">{hours.split(' ')[0]}</span>
                                    <span class="px-2 py-1 rounded" style="background: var(--paper2); color: var(--ink2);">{hours.split(' ').slice(1).join(' ')}</span>
                                </div>
                            ))}
                        </div>
                    </div>

                    <!-- Ownership Label -->
                    {clinic.created_by && (
                        <div class="flex items-center gap-3 justify-center py-4 text-xs font-medium" style="color: var(--muted);">
                            Verified listing managed by {clinic.created_by.name}
                        </div>
                    )}
                </div>
            </div>

        </div>

        <!-- Medical Disclaimer -->
        <div class="container mx-auto px-6 lg:px-12 mt-12 mb-8">
            <div class="rounded-2xl p-6 border" style="background: color-mix(in srgb, var(--warm) 5%, white); border-color: color-mix(in srgb, var(--warm) 30%, transparent);">
                <p class="text-sm leading-relaxed" style="color: color-mix(in srgb, var(--ink2) 80%, black);">
                    <strong>Medical Disclaimer:</strong> The information on this page is for informational purposes only and does not constitute medical advice.
                    TMS therapy should only be administered under the supervision of a qualified healthcare provider. Always consult your doctor before starting any new treatment.
                    <a href="/legal/medical-disclaimer/" class="underline hover:font-medium" style="color: var(--warm);">Read full disclaimer</a>.
                </p>
            </div>
        </div>

        <!-- Related Pages -->
        <div class="container mx-auto px-6 lg:px-12 mb-16">
            <h2 class="text-lg font-bold mb-4" style="color: var(--ink);">Explore More</h2>
            <div class="flex flex-wrap gap-3">
                <a href={`/${countryUrlPrefix}/${isUS ? getStateSlug(state) : ''}`} class="px-4 py-2 text-sm font-medium rounded-xl transition-colors" style="background: white; border: 1px solid var(--line); color: var(--ink2);">
                    More clinics in {stateName} &#8594;
                </a>
                <a href="/treatments/" class="px-4 py-2 text-sm font-medium rounded-xl transition-colors" style="background: white; border: 1px solid var(--line); color: var(--ink2);">
                    Conditions treated &#8594;
                </a>
                <a href="/insurance/" class="px-4 py-2 text-sm font-medium rounded-xl transition-colors" style="background: white; border: 1px solid var(--line); color: var(--ink2);">
                    Insurance coverage &#8594;
                </a>
                <a href="/compare-clinics/" class="px-4 py-2 text-sm font-medium rounded-xl transition-colors" style="background: white; border: 1px solid var(--line); color: var(--ink2);">
                    Compare clinics &#8594;
                </a>
            </div>

            <!-- Share -->
            <div class="mt-6 flex items-center gap-3">
                <span class="text-sm font-medium" style="color: var(--muted);">Share:</span>
                <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`${clinic.name} - TMS Therapy in ${city}, ${state}`)}&url=${encodeURIComponent(`https://tmslist.com/clinic/${clinic.slug}`)}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full flex items-center justify-center transition-colors" style="background: var(--paper2); color: var(--muted);" aria-label="Share on X (Twitter)">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
                </a>
                <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`https://tmslist.com/clinic/${clinic.slug}`)}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full flex items-center justify-center transition-colors" style="background: var(--paper2); color: var(--muted);" aria-label="Share on Facebook">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.77 7.46H14.5v-1.9c0-.9.6-1.1 1-1.1h3V.5h-4.33C10.24.5 9.5 3.44 9.5 5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4z"/></svg>
                </a>
                <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://tmslist.com/clinic/${clinic.slug}`)}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full flex items-center justify-center transition-colors" style="background: var(--paper2); color: var(--muted);" aria-label="Share on LinkedIn">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
            </div>
        </div>

    </main>
    <ClinicTracking clinicId={clinic.id} />
</Layout>

<style>
  .serif { font-family: 'Instrument Serif', Georgia, serif; font-weight: 400; letter-spacing: -0.02em; }
  summary::-webkit-details-marker { display: none; }
  summary::marker { display: none; }
</style>

<script>
  // Wire up enquiry/callback buttons to open the modal
  document.querySelectorAll('[data-trigger-enquiry], [data-request-callback]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      document.dispatchEvent(new CustomEvent('open-enquiry-modal'));
    });
  });
</script>
