---
import Layout from "../../layouts/Layout.astro";
import GoogleReviews from "../../components/GoogleReviews.astro";
import BookingWidget from "../../components/react/BookingWidget";
import HealthScoreBadge from "../../components/react/HealthScoreBadge";
import ClinicTracking from "../../components/ClinicTracking.astro";
import { STATE_NAMES, getAllClinics, getStateSlug } from "../../utils/clinicData";
import { getDoctorPhoto, COUNTRY_NAMES, COUNTRY_URL_PREFIXES } from "../../utils/dataHelpers";
import { getClinicLogoUrl } from "../../utils/images";

const { slug } = Astro.params;

const allClinics = await getAllClinics();
const clinic = allClinics.find((c: any) => c.slug === slug);
if (!clinic) return Astro.redirect("/us/");

// Handle data access robustly
const city = clinic.address_obj?.city || clinic.city;
const state = clinic.address_obj?.state || clinic.state;
const countryCode = clinic.country || 'US';
const stateName = STATE_NAMES[state] || state;
const countryName = COUNTRY_NAMES[countryCode] || countryCode;
const countryUrlPrefix = COUNTRY_URL_PREFIXES[countryCode] || countryCode.toLowerCase();
const isUS = countryCode === 'US';
const county = clinic.address_obj?.county || null;
const street = clinic.address_obj?.street || clinic.address;
const zip = clinic.address_obj?.zip || clinic.zip;
const landmarks = clinic.address_obj?.nearby_landmarks || [];
const machines = clinic.machines || [];
const treatments = clinic.specialties || clinic.treatments || [];
const doctors = clinic.doctors_data || [];
const insurances = clinic.insurances || clinic.insurance_accepted || [];
const faqs = clinic.faqs || [];

// Rating handling
const getRating = () => {
    if (typeof clinic.rating === "number") return clinic.rating;
    return clinic.rating?.aggregate || null;
};
const getReviewCount = () => {
    if (typeof clinic.rating === "object") return clinic.rating?.count || 0;
    return clinic.review_count || 0;
};
const getSentiment = () => {
    if (typeof clinic.rating === "object" && clinic.rating?.sentiment_summary)
        return clinic.rating.sentiment_summary;
    return null;
};

// SEO & Schema
const pageTitle = `${clinic.name} | Top Rated TMS Therapy in ${city}, ${state}`;
const seoSnippet = clinic.seo_article ? clinic.seo_article.split('\n\n')[0].substring(0, 140) + '...' : '';
const metaDescription = seoSnippet || `Looking for TMS Therapy in ${city}? ${clinic.name} offers FDA-cleared treatment for depression. ${getRating()} stars from ${getReviewCount()} reviews. Book a consultation today.`;

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "MedicalClinic",
    "@id": `https://tmslist.com/clinic/${clinic.slug}`,
    name: clinic.name,
    image: clinic.hero_image_url || "https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&q=80&w=1200",
    logo: clinic.logo_url || clinic.media?.logo_url || undefined,
    url: `https://tmslist.com/clinic/${clinic.slug}`,
    telephone: clinic.phone,
    address: {
        "@type": "PostalAddress",
        streetAddress: street,
        addressLocality: city,
        addressRegion: stateName, 
        postalCode: zip,
        addressCountry: countryCode,
    },
    geo: {
        "@type": "GeoCoordinates",
        latitude: clinic.geo?.lat,
        longitude: clinic.geo?.lng,
    },
    ...(getRating() ? {
        aggregateRating: {
            "@type": "AggregateRating",
            ratingValue: getRating(),
            reviewCount: getReviewCount(),
        },
    } : {}),
    priceRange: clinic.price_range || "$$",
    ...((clinic.opening_hours && clinic.opening_hours.length > 0) ? {
        openingHoursSpecification: clinic.opening_hours.map((h: string) => {
            // Parse "Mon-Fri: 9:00 AM - 5:00 PM" style strings
            const match = h.match(/^([^:]+):\s*(\d{1,2}:\d{2}\s*[AP]?M?)\s*[-–]\s*(\d{1,2}:\d{2}\s*[AP]?M?)$/i);
            if (match) {
                return {
                    "@type": "OpeningHoursSpecification",
                    dayOfWeek: match[1].trim(),
                    opens: match[2].trim(),
                    closes: match[3].trim(),
                };
            }
            return { "@type": "OpeningHoursSpecification", description: h };
        }),
    } : {}),
});

// Clinic Hero Selection
const clinicHeroImages = [
    "https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&q=80&w=1200",
    "https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&q=80&w=1200",
    "https://images.unsplash.com/photo-1631549916768-4119b2e5f926?auto=format&fit=crop&q=80&w=1200",
    "https://images.unsplash.com/photo-1551076805-e1869033e561?auto=format&fit=crop&q=80&w=1200",
    "https://images.unsplash.com/photo-1579684385127-1ef15d508118?auto=format&fit=crop&q=80&w=1200"
];
const displayHero = clinic.hero_image_url || clinicHeroImages[clinic.name.length % clinicHeroImages.length];
const logoUrl = getClinicLogoUrl(clinic);
const galleryImages = clinic.gallery_urls || [];
---

<Layout title={pageTitle} description={metaDescription} schema={schema} image={clinic.hero_image_url || clinic.logo_url || clinic.media?.logo_url || clinic.media?.hero_image_url || undefined}>
    <!-- Clean Premium Light Hero -->
    <section class="relative bg-white pt-16 pb-24 border-b border-slate-100 overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-[600px] bg-gradient-to-b from-blue-50/50 to-white/0 pointer-events-none"></div>
        
        <div class="container mx-auto px-6 lg:px-12 relative z-10">
            <!-- Breadcrumbs -->
            <nav class="flex text-xs font-semibold tracking-widest uppercase text-slate-400 mb-10" aria-label="Breadcrumb">
                <ol class="inline-flex items-center space-x-2">
                    <li><a href="/" class="hover:text-blue-600 transition-colors">Home</a></li>
                    <li><span class="mx-2 text-slate-300">/</span></li>
                    <li><a href={`/${countryUrlPrefix}/`} class="hover:text-blue-600 transition-colors">{isUS ? 'US' : countryName}</a></li>
                    <li><span class="mx-2 text-slate-300">/</span></li>
                    <li>
                        <a href={`/${countryUrlPrefix}/${stateName.toLowerCase().replace(/\s+/g, "-")}/`} class="hover:text-blue-600 transition-colors">{stateName}</a>
                    </li>
                    <li><span class="mx-2 text-slate-300">/</span></li>
                    <li>
                        <a href={`/${countryUrlPrefix}/${stateName.toLowerCase().replace(/\s+/g, "-")}/${city.toLowerCase().replace(/\s+/g, "-").replace(/\./g, "")}/`} class="hover:text-blue-600 transition-colors">{city}</a>
                    </li>
                </ol>
            </nav>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <!-- Hero Content -->
                <div class="max-w-2xl">
                    {clinic.verified && (
                    <div class="inline-flex items-center gap-2 bg-emerald-50 border border-emerald-100 rounded-full px-4 py-1.5 mb-6">
                        <svg class="w-3.5 h-3.5 text-emerald-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        <span class="text-xs font-bold text-emerald-700 tracking-widest uppercase">Verified Clinic</span>
                    </div>
                    )}

                    <div class="flex items-center gap-3 mb-4">
                        <HealthScoreBadge client:idle clinicId={clinic.id} size="md" />
                    </div>

                    <div class="flex items-start gap-4 mb-6">
                        {clinic.logo_url || clinic.media?.logo_url ? (
                            <img
                                src={logoUrl}
                                alt={`${clinic.name} logo`}
                                width="64"
                                height="64"
                                class="w-16 h-16 rounded-2xl object-cover border border-slate-100 shadow-sm shrink-0 mt-1"
                                loading="eager"
                                fetchpriority="high"
                                decoding="async"
                            />
                        ) : (
                            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center shrink-0 text-white text-2xl font-extrabold">
                                {clinic.name.charAt(0).toUpperCase()}
                            </div>
                        )}
                        <h1 class="text-2xl sm:text-3xl lg:text-5xl font-bold tracking-tight text-slate-900 leading-tight">
                            {clinic.name}
                        </h1>
                    </div>
                    
                    <p class="text-xl text-slate-500 mb-10 leading-relaxed font-light">
                        Specialized TMS Therapy and Neuromodulation right here in <strong class="font-semibold text-slate-800">{city}, {stateName}</strong>. {isUS ? 'FDA-cleared' : 'Clinically approved'} treatment for depression with proven clinical excellence.
                    </p>

                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href="#contact" class="flex-1 sm:flex-none inline-flex justify-center items-center px-4 sm:px-8 py-3 sm:py-4 bg-blue-600 hover:bg-blue-700 text-white text-[15px] font-bold rounded-xl shadow-[0_8px_30px_rgb(37,99,235,0.2)] transition-all">
                            Book Consultation
                        </a>
                        <button data-request-callback data-clinic-name={clinic.name} data-clinic-id={clinic.slug}
                            class="flex-1 sm:flex-none inline-flex justify-center items-center gap-2 px-4 sm:px-8 py-3 sm:py-4 bg-white hover:bg-slate-50 text-slate-700 text-[15px] font-bold rounded-xl border border-slate-200 shadow-sm transition-all cursor-pointer">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                            Request Callback
                        </button>
                    </div>
                </div>

                <!-- Hero Image -->
                <div class="relative w-full aspect-[4/3] rounded-3xl overflow-hidden shadow-[0_20px_50px_rgb(0,0,0,0.06)] border border-slate-100/50">
                    <img
                        src={displayHero}
                        alt={`Clinical environment at ${clinic.name}`}
                        width="800"
                        height="600"
                        class="w-full h-full object-cover"
                        loading="eager"
                        fetchpriority="high"
                        decoding="async"
                    />
                    {clinic.hero_image_url && (
                        <div class="absolute top-4 right-4 inline-flex items-center gap-1.5 px-3 py-1.5 bg-white/90 backdrop-blur-sm rounded-full text-xs font-semibold text-emerald-700 border border-emerald-100 shadow-sm">
                            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"/></svg>
                            Verified Photo
                        </div>
                    )}
                </div>
            </div>
        </div>
    </section>

    <!-- Clinic Dashboard Layout -->
    <main class="bg-slate-50/50 py-16">
        <div class="container mx-auto px-6 lg:px-12 grid grid-cols-1 xl:grid-cols-12 gap-12">
            
            <!-- Left Column: Core Details -->
            <div class="xl:col-span-8 space-y-12">
                <!-- Stats Bento -->
                <section class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4">
                    {getReviewCount() > 0 && (
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-slate-100 shadow-[0_4px_20px_rgb(0,0,0,0.02)]">
                        <div class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900 mb-1">{getReviewCount()}</div>
                        <div class="text-xs font-semibold text-slate-400 uppercase tracking-widest">Patient Reviews</div>
                    </div>
                    )}
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-slate-100 shadow-[0_4px_20px_rgb(0,0,0,0.02)]">
                        <div class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900 mb-1">{machines.length || '—'}</div>
                        <div class="text-xs font-semibold text-slate-400 uppercase tracking-widest">TMS Devices</div>
                    </div>
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-slate-100 shadow-[0_4px_20px_rgb(0,0,0,0.02)]">
                        <div class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900 mb-1">{doctors.length || 1}</div>
                        <div class="text-xs font-semibold text-slate-400 uppercase tracking-widest">Specialists</div>
                    </div>
                    {getRating() && (
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-slate-100 shadow-[0_4px_20px_rgb(0,0,0,0.02)]">
                        <div class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900 mb-1">{getRating()?.toFixed(1) ?? '—'}</div>
                        <div class="text-xs font-semibold text-slate-400 uppercase tracking-widest">Patient Rating</div>
                    </div>
                    )}
                </section>

                <!-- About Overview -->
                <section class="bg-white rounded-3xl p-8 border border-slate-100 shadow-[0_8px_30px_rgb(0,0,0,0.03)]">
                    <h2 class="text-2xl font-bold text-slate-900 mb-6">About the Clinic</h2>
                    <div class="prose prose-slate max-w-none font-light leading-loose text-slate-600">
                        {clinic.seo_article ? (
                            clinic.seo_article.split('\n\n').map((paragraph: string) => (
                                <p>{paragraph}</p>
                            ))
                        ) : (
                            <>
                                <p>{clinic.description_long}</p>
                                <p>
                                    Located in {city}, {stateName}, our clinic serves
                                    patients throughout {county ?? city} and the surrounding areas.
                                    We understand that mental health treatment is deeply personal,
                                    which is why we take a patient-centered approach to every
                                    consultation.
                                </p>
                            </>
                        )}
                    </div>
                </section>

                <!-- Photo Gallery -->
                {galleryImages.length > 0 && (
                    <section>
                        <h2 class="text-2xl font-bold text-slate-900 mb-6">Clinic Gallery</h2>
                        <div class={`grid gap-3 ${galleryImages.length === 1 ? 'grid-cols-1' : galleryImages.length === 2 ? 'grid-cols-2' : 'grid-cols-2 md:grid-cols-3'}`}>
                            {galleryImages.map((imgUrl: string, i: number) => (
                                <div class={`relative rounded-2xl overflow-hidden border border-slate-100 shadow-[0_4px_20px_rgb(0,0,0,0.02)] ${i === 0 && galleryImages.length >= 3 ? 'col-span-2 row-span-2' : ''}`}>
                                    <img
                                        src={imgUrl}
                                        alt={`${clinic.name} TMS clinic in ${city}, ${state} - gallery image ${i + 1}`}
                                        width="600"
                                        height="450"
                                        class="w-full h-full object-cover aspect-[4/3]"
                                        loading="lazy"
                                    />
                                </div>
                            ))}
                        </div>
                    </section>
                )}

                <!-- Technology & Machines -->
                <section>
                    <h2 class="text-2xl font-bold text-slate-900 mb-6">Advanced TMS Devices</h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {machines.map((machine: string) => (
                            <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-[0_4px_20px_rgb(0,0,0,0.02)] flex items-start gap-4">
                                <div class="w-12 h-12 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center shrink-0">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                                </div>
                                <div>
                                    <h3 class="text-[15px] font-bold text-slate-900">{machine}</h3>
                                    <p class="text-xs text-slate-500 mt-1">Approved Technology</p>
                                </div>
                            </div>
                        ))}
                        {machines.length === 0 && (
                            <div class="col-span-full bg-slate-50 p-6 rounded-2xl border border-slate-100 text-slate-500 text-sm">
                                TMS device information not yet verified for this clinic. Contact the clinic directly for details about their equipment.
                            </div>
                        )}
                    </div>
                </section>

                <!-- Treatments Grid -->
                <section>
                    <h2 class="text-2xl font-bold text-slate-900 mb-6">Conditions Treated</h2>
                    <div class="flex flex-wrap gap-3">
                        {treatments.map((treatment: string) => (
                            <span class="px-5 py-2.5 bg-slate-100 text-slate-700 font-semibold text-sm rounded-full border border-slate-200 hover:border-blue-200 hover:bg-blue-50 transition-colors">
                                {treatment}
                            </span>
                        ))}
                        {treatments.length === 0 && (
                            <p class="text-slate-500 text-sm">
                                Specific treatment conditions not yet listed. TMS is FDA-cleared for depression, OCD, and smoking cessation. <a href="/treatments/" class="text-violet-600 font-medium hover:underline">View all treatable conditions</a>.
                            </p>
                        )}
                    </div>
                </section>

                <!-- Medical Staff -->
                {doctors.length > 0 && (
                    <section id="team">
                        <h2 class="text-2xl font-bold text-slate-900 mb-6">Medical Team</h2>
                        <div class="grid gap-4">
                            {doctors.map((doctor: any) => (
                                <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-[0_4px_20px_rgb(0,0,0,0.02)] flex flex-col sm:flex-row items-start sm:items-center gap-6">
                                    <img
                                        src={getDoctorPhoto(doctor)}
                                        alt={doctor.name}
                                        class="w-20 h-20 rounded-full object-cover shadow-sm border-2 border-slate-100"
                                        loading="lazy"
                                    />
                                    <div class="flex-1">
                                        <a href={`/doctor/${doctor.slug}`} class="text-lg font-bold text-slate-900 hover:text-blue-600 transition-colors">
                                            {doctor.name}
                                        </a>
                                        <p class="text-[13px] font-semibold tracking-wider uppercase text-blue-600 mt-0.5 mb-2">{doctor.title}</p>
                                        <div class="flex items-center gap-4 text-xs font-medium text-slate-500">
                                            <span>{doctor.years_experience}+ Years Exp.</span>
                                            <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                                            <span>{doctor.school}</span>
                                        </div>
                                    </div>
                                    <a href={`/doctor/${doctor.slug}`} class="shrink-0 px-5 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg text-sm font-bold transition-all">
                                        Profile
                                    </a>
                                </div>
                            ))}
                        </div>
                    </section>
                )}

                <!-- Insurance Block -->
                <section class="bg-white rounded-3xl p-8 border border-slate-100 shadow-[0_8px_30px_rgb(0,0,0,0.03)]">
                    <h2 class="text-2xl font-bold text-slate-900 mb-6">Insurance & Cost Details</h2>
                    
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8 pb-8 border-b border-slate-100">
                        <div>
                            <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-1">Accepts Insurance</p>
                            <p class="text-lg font-bold text-slate-900">{clinic.cost_info?.accepts_insurance ? "Yes ✓" : "Contact Clinic"}</p>
                        </div>
                        <div>
                            <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-1">Cash Price</p>
                            <p class="text-lg font-bold text-slate-900">{clinic.cost_info?.cash_price_per_session || "Request Info"}</p>
                        </div>
                        <div>
                            <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-1">Financing</p>
                            <p class="text-lg font-bold text-slate-900">{clinic.cost_info?.financing_available ? "Available ✓" : "Contact Clinic"}</p>
                        </div>
                    </div>

                    <h3 class="text-sm font-bold text-slate-900 mb-4">Recognized Networks</h3>
                    <div class="flex flex-wrap gap-2">
                        {insurances.map((ins: string) => (
                            <span class="px-3 py-1.5 bg-slate-50 text-slate-600 rounded border border-slate-200 text-[13px] font-medium">
                                {ins}
                            </span>
                        ))}
                        {insurances.length === 0 && <span class="text-slate-500 text-sm">Insurance information not yet listed. Most TMS clinics accept Medicare and major insurers — <a href="/insurance/" class="text-violet-600 font-medium hover:underline">check our coverage guide</a>.</span>}
                    </div>
                </section>

                <GoogleReviews
                    aggregateRating={getRating()}
                    totalCount={getReviewCount()}
                    entityName={clinic.name}
                    clinicId={clinic.id}
                />

                {faqs.length > 0 && (
                    <section>
                        <h2 class="text-2xl font-bold text-slate-900 mb-6">Frequently Asked Questions</h2>
                        <div class="space-y-3">
                            {faqs.map((faq: any) => (
                                <details class="group bg-white rounded-2xl border border-slate-100 shadow-[0_4px_20px_rgb(0,0,0,0.02)]">
                                    <summary class="flex justify-between items-center p-6 cursor-pointer list-none text-[15px] font-bold text-slate-900 group-open:text-blue-600 outline-none">
                                        <span>{faq.question}</span>
                                        <svg class="w-5 h-5 text-slate-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                    </summary>
                                    <div class="p-6 pt-0 text-slate-600 font-light leading-relaxed">
                                        {faq.answer}
                                    </div>
                                </details>
                            ))}
                        </div>
                    </section>
                )}
            </div>

            <!-- Right Column: Sidebar -->
            <div class="xl:col-span-4">
                <div class="sticky top-24 space-y-6">
                    
                    <!-- Contact Box -->
                    <div id="contact" class="bg-white rounded-3xl p-6 border border-slate-100 shadow-[0_8px_30px_rgb(0,0,0,0.05)] text-center">
                        <img
                            src={logoUrl}
                            alt={`${clinic.name} logo`}
                            class="w-16 h-16 mx-auto rounded-2xl object-cover border border-slate-100 shadow-sm mb-4"
                            loading="lazy"
                        />
                        <h3 class="text-lg font-bold text-slate-900 mb-1">{clinic.name}</h3>
                        <p class="text-sm text-slate-500 mb-6 font-light">{street}<br/>{city}, {state} {zip}</p>
                        
                        <div class="space-y-3">
                            <button data-request-callback data-clinic-name={clinic.name} data-clinic-id={clinic.slug}
                                class="flex items-center justify-center gap-2 w-full py-3.5 bg-violet-600 hover:bg-violet-700 text-white rounded-xl text-sm font-bold transition-all shadow-md cursor-pointer">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                                Request Callback
                            </button>
                            <!-- Phone number revealed only after enquiry -->
                            <div id="phone-reveal-gate" class="text-center">
                                <button id="reveal-phone-btn" data-trigger-enquiry
                                    class="text-sm text-violet-600 hover:text-violet-700 font-semibold underline underline-offset-2 cursor-pointer">
                                    Enquire to reveal phone number
                                </button>
                            </div>
                            {(clinic.contact?.website_url || clinic.website) && (
                            <a href={clinic.contact?.website_url || clinic.website} target="_blank" rel="noopener" class="flex items-center justify-center gap-2 w-full py-3.5 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 rounded-xl text-sm font-bold transition-all">
                                Visit Website
                            </a>
                            )}
                            <BookingWidget client:idle clinicId={clinic.id} clinicName={clinic.name} clinicPhone={clinic.contact?.phone || clinic.phone} />
                        </div>
                    </div>

                    <!-- Map Card -->
                    {clinic.google_business_profile?.embed_url && (
                        <div class="bg-white rounded-3xl p-2 border border-slate-100 shadow-[0_8px_30px_rgb(0,0,0,0.03)] h-[300px] overflow-hidden">
                            <iframe
                                src={clinic.google_business_profile.embed_url}
                                width="100%"
                                height="100%"
                                style="border:0;"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade"
                                class="rounded-2xl"
                                title={`Map of ${clinic.name}`}
                            ></iframe>
                        </div>
                    )}

                    <!-- Hours Card -->
                    <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-[0_8px_30px_rgb(0,0,0,0.03)]">
                        <h3 class="text-[15px] font-bold text-slate-900 mb-4 flex items-center gap-2">
                            <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            Hours of Operation
                        </h3>
                        <div class="space-y-3">
                            {(clinic.opening_hours || ["Hours not yet verified — please call to confirm"]).map((hours: string) => (
                                <div class="flex justify-between items-center text-[13px] font-medium border-b border-slate-50 pb-2 last:border-0 last:pb-0">
                                    <span class="text-slate-500">{hours.split(' ')[0]}</span>
                                    <span class="text-slate-900 bg-slate-100 px-2 py-1 rounded">{hours.split(' ').slice(1).join(' ')}</span>
                                </div>
                            ))}
                        </div>
                    </div>

                    <!-- Ownership Label -->
                    {clinic.created_by && (
                        <div class="flex items-center gap-3 justify-center py-4 text-xs font-medium text-slate-400">
                            Verified listing managed by {clinic.created_by.name}
                        </div>
                    )}
                </div>
            </div>

        </div>

        <!-- Medical Disclaimer -->
        <div class="container mx-auto px-6 lg:px-12 mt-12 mb-8">
            <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6">
                <p class="text-sm text-amber-800 leading-relaxed">
                    <strong>Medical Disclaimer:</strong> The information on this page is for informational purposes only and does not constitute medical advice.
                    TMS therapy should only be administered under the supervision of a qualified healthcare provider. Always consult your doctor before starting any new treatment.
                    <a href="/legal/medical-disclaimer/" class="underline hover:text-amber-900 font-medium">Read full disclaimer</a>.
                </p>
            </div>
        </div>

        <!-- Related Pages -->
        <div class="container mx-auto px-6 lg:px-12 mb-16">
            <h2 class="text-lg font-bold text-slate-900 mb-4">Explore More</h2>
            <div class="flex flex-wrap gap-3">
                <a href={`/${countryUrlPrefix}/${isUS ? getStateSlug(state) : ''}`} class="px-4 py-2 bg-slate-100 text-slate-700 rounded-lg text-sm font-medium hover:bg-slate-200 transition-colors">
                    More clinics in {stateName} →
                </a>
                <a href="/treatments/" class="px-4 py-2 bg-slate-100 text-slate-700 rounded-lg text-sm font-medium hover:bg-slate-200 transition-colors">
                    Conditions treated →
                </a>
                <a href="/insurance/" class="px-4 py-2 bg-slate-100 text-slate-700 rounded-lg text-sm font-medium hover:bg-slate-200 transition-colors">
                    Insurance coverage →
                </a>
                <a href="/compare-clinics/" class="px-4 py-2 bg-slate-100 text-slate-700 rounded-lg text-sm font-medium hover:bg-slate-200 transition-colors">
                    Compare clinics →
                </a>
            </div>

            <!-- Share -->
            <div class="mt-6 flex items-center gap-3">
                <span class="text-sm font-medium text-slate-500">Share:</span>
                <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`${clinic.name} - TMS Therapy in ${city}, ${state}`)}&url=${encodeURIComponent(`https://tmslist.com/clinic/${clinic.slug}`)}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 hover:bg-blue-50 hover:text-blue-500 transition-colors" aria-label="Share on X (Twitter)">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
                </a>
                <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`https://tmslist.com/clinic/${clinic.slug}`)}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 hover:bg-blue-50 hover:text-blue-600 transition-colors" aria-label="Share on Facebook">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.77 7.46H14.5v-1.9c0-.9.6-1.1 1-1.1h3V.5h-4.33C10.24.5 9.5 3.44 9.5 5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4z"/></svg>
                </a>
                <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://tmslist.com/clinic/${clinic.slug}`)}`} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-500 hover:bg-blue-50 hover:text-blue-700 transition-colors" aria-label="Share on LinkedIn">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
            </div>
        </div>

    </main>
    <ClinicTracking clinicId={clinic.id} />
</Layout>

<script>
  // Wire up enquiry/callback buttons to open the modal
  document.querySelectorAll('[data-trigger-enquiry], [data-request-callback]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      document.dispatchEvent(new CustomEvent('open-enquiry-modal'));
    });
  });
</script>
