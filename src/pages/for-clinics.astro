---
import Layout from "../layouts/Layout.astro";

const pageTitle = "List Your TMS Clinic | Get More Patients | TMS List";
const metaDescription = "List your TMS clinic on the leading directory. Get verified, receive patient leads, and grow your practice with our Pro and Premium plans.";
---

<Layout title={pageTitle} description={metaDescription}>
  <section class="relative bg-slate-50 overflow-hidden pt-24 pb-20 lg:pt-32 lg:pb-28">
    <!-- Ambient Blurs -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-100/60 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-emerald-50/60 rounded-full blur-[100px] translate-y-1/3 -translate-x-1/3 pointer-events-none"></div>
    <div class="absolute inset-0 opacity-[0.02] pointer-events-none" style="background-image: radial-gradient(circle at center, #000 1px, transparent 1px); background-size: 24px 24px;"></div>

    <div class="container mx-auto px-6 lg:px-12 max-w-5xl text-center relative z-10">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white border border-slate-200/60 rounded-full mb-8 shadow-sm">
        <div class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></div>
        <span class="text-[11px] font-bold text-slate-700 tracking-widest uppercase">For Clinic Owners</span>
      </div>

      <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tight text-slate-900 leading-[1.05] mb-6">
        Grow Your TMS Practice<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-indigo-600 to-violet-600">with TMS List</span>
      </h1>
      <p class="text-lg lg:text-xl text-slate-500 font-light max-w-2xl mx-auto mb-14 leading-relaxed">
        Join 1,100+ TMS clinics on the leading patient directory. Get verified, receive high-intent patient leads, and scale your practice.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left max-w-4xl mx-auto">
        <div class="bg-white border border-slate-200/60 rounded-3xl p-8 hover:shadow-xl hover:shadow-slate-200/40 hover:-translate-y-1 transition-all duration-300">
          <div class="w-12 h-12 bg-blue-50 rounded-2xl flex items-center justify-center text-blue-600 mb-6 border border-blue-100/50">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          </div>
          <div class="text-4xl font-black text-slate-900 mb-2 tracking-tight">1,100+</div>
          <div class="text-sm font-medium text-slate-500">Verified clinics listed</div>
        </div>
        <div class="bg-white border border-slate-200/60 rounded-3xl p-8 hover:shadow-xl hover:shadow-slate-200/40 hover:-translate-y-1 transition-all duration-300">
          <div class="w-12 h-12 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-600 mb-6 border border-emerald-100/50">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </div>
          <div class="text-4xl font-black text-slate-900 mb-2 tracking-tight">50K+</div>
          <div class="text-sm font-medium text-slate-500">Monthly patient searches</div>
        </div>
        <div class="bg-white border border-slate-200/60 rounded-3xl p-8 hover:shadow-xl hover:shadow-slate-200/40 hover:-translate-y-1 transition-all duration-300">
          <div class="w-12 h-12 bg-violet-50 rounded-2xl flex items-center justify-center text-violet-600 mb-6 border border-violet-100/50">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div class="text-4xl font-black text-slate-900 mb-2 tracking-tight">Free</div>
          <div class="text-sm font-medium text-slate-500">Basic listing forever</div>
        </div>
      </div>
    </div>
  </section>

  <main class="bg-white py-16 lg:py-24 relative overflow-hidden">
    <!-- Subtle background accent -->
    <div class="absolute inset-0 bg-slate-50/50 [mask-image:linear-gradient(to_bottom,white,transparent)] z-0"></div>
    
    <div class="container mx-auto px-6 lg:px-12 max-w-3xl relative z-10">
      <div class="bg-white rounded-[2rem] border border-slate-200 shadow-xl shadow-slate-200/50 p-8 lg:p-12 relative overflow-hidden">
        <!-- Inner Glow -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-50 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
        
        <div class="relative z-10">
          <h2 class="text-3xl font-extrabold text-slate-900 mb-3 tracking-tight">Register Your Clinic</h2>
          <p class="text-slate-500 mb-8 font-light text-lg">Provide your details below and our partnerships team will get your clinic listed within 24 hours.</p>

          <form id="clinic-signup-form" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Your Name <span class="text-red-400">*</span></label>
                <input type="text" name="name" required placeholder="Jane Doe" class="w-full px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-200 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 text-sm text-slate-900 placeholder-slate-400 transition-all" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Email <span class="text-red-400">*</span></label>
                <input type="email" name="email" required placeholder="jane@clinic.com" class="w-full px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-200 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 text-sm text-slate-900 placeholder-slate-400 transition-all" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-2">Clinic Name <span class="text-red-400">*</span></label>
              <input type="text" name="clinicName" required placeholder="TMS Institute of America" class="w-full px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-200 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 text-sm text-slate-900 placeholder-slate-400 transition-all" />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">City <span class="text-red-400">*</span></label>
                <input type="text" name="city" required placeholder="Los Angeles" class="w-full px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-200 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 text-sm text-slate-900 placeholder-slate-400 transition-all" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">State <span class="text-red-400">*</span></label>
                <input type="text" name="state" required maxlength="2" placeholder="CA" class="w-full px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-200 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 text-sm text-slate-900 placeholder-slate-400 transition-all" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-2">Phone</label>
              <input type="tel" name="phone" placeholder="(555) 123-4567" class="w-full px-4 py-3.5 bg-slate-50 rounded-xl border border-slate-200 focus:bg-white focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 text-sm text-slate-900 placeholder-slate-400 transition-all" />
            </div>

            <div id="form-message" class="hidden px-5 py-4 rounded-xl text-sm font-medium"></div>

            <button type="submit" class="w-full py-4 bg-gradient-to-r from-blue-600 to-violet-600 hover:from-blue-700 hover:to-violet-700 text-white font-bold rounded-xl text-[15px] transition-all shadow-lg shadow-blue-600/20 hover:shadow-blue-600/30 active:scale-[0.98]">
              Register My Clinic (Free)
            </button>
            <p class="text-sm text-slate-500 text-center font-medium mt-4">Already listed? <a href="/admin/login?redirect=/owner/dashboard" class="text-blue-600 hover:text-blue-700 transition-colors">Log in to your dashboard</a></p>
          </form>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  document.getElementById('clinic-signup-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const msgEl = document.getElementById('form-message')!;

    const data = {
      segment: 'clinic_owner',
      name: (form.querySelector('[name="name"]') as HTMLInputElement).value,
      email: (form.querySelector('[name="email"]') as HTMLInputElement).value,
      clinicName: (form.querySelector('[name="clinicName"]') as HTMLInputElement).value,
      city: (form.querySelector('[name="city"]') as HTMLInputElement).value,
      state: (form.querySelector('[name="state"]') as HTMLInputElement).value,
      source: 'for-clinics-page',
    };

    try {
      const res = await fetch('/api/funnel/enter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.classList.add('hidden');
        msgEl.textContent = 'Registration received! Check your email for next steps.';
        msgEl.className = 'px-4 py-3 rounded-xl text-sm font-medium bg-emerald-50 text-emerald-700 border border-emerald-100';
        msgEl.classList.remove('hidden');
      } else {
        msgEl.textContent = 'Something went wrong. Please try again.';
        msgEl.className = 'px-4 py-3 rounded-xl text-sm font-medium bg-red-50 text-red-700 border border-red-100';
        msgEl.classList.remove('hidden');
      }
    } catch {
      msgEl.textContent = 'Network error. Please try again.';
      msgEl.className = 'px-4 py-3 rounded-xl text-sm font-medium bg-red-50 text-red-700 border border-red-100';
      msgEl.classList.remove('hidden');
    }
  });
</script>
