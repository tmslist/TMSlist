---
import Layout from "../layouts/Layout.astro";

const pageTitle = "List Your TMS Clinic | Get More Patients | TMS List";
const metaDescription = "List your TMS clinic on the leading directory. Get verified, receive patient leads, and grow your practice with our Pro and Premium plans.";
---

<Layout title={pageTitle} description={metaDescription}>
  <section class="bg-gradient-to-b from-slate-900 to-slate-800 text-white pt-20 pb-24">
    <div class="container mx-auto px-6 lg:px-12 max-w-5xl text-center">
      <span class="inline-block px-4 py-1.5 bg-white/10 text-blue-300 text-xs font-bold rounded-full uppercase tracking-wider mb-6">For Clinic Owners</span>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">
        Grow Your TMS Practice with TMS List
      </h1>
      <p class="text-lg text-slate-300 font-light max-w-2xl mx-auto mb-10">
        Join 1,100+ TMS clinics on the leading patient directory. Get verified, receive leads, and convert more patients.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left mb-12">
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
          <div class="text-3xl font-bold text-white mb-2">1,100+</div>
          <div class="text-sm text-slate-400">Verified TMS clinics listed</div>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
          <div class="text-3xl font-bold text-white mb-2">50K+</div>
          <div class="text-sm text-slate-400">Monthly patient searches</div>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
          <div class="text-3xl font-bold text-white mb-2">Free</div>
          <div class="text-sm text-slate-400">Basic listing forever</div>
        </div>
      </div>
    </div>
  </section>

  <main class="bg-slate-50/50 py-12">
    <div class="container mx-auto px-6 lg:px-12 max-w-3xl">
      <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-8">
        <h2 class="text-2xl font-bold text-slate-900 mb-2">Register Your Clinic</h2>
        <p class="text-slate-500 mb-6">Fill out the form below and we'll get your clinic listed within 24 hours.</p>

        <form id="clinic-signup-form" class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">Your Name *</label>
              <input type="text" name="name" required class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">Email *</label>
              <input type="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">Clinic Name *</label>
            <input type="text" name="clinicName" required class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">City *</label>
              <input type="text" name="city" required class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1.5">State *</label>
              <input type="text" name="state" required maxlength="2" placeholder="e.g. CA" class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">Phone</label>
            <input type="tel" name="phone" class="w-full px-4 py-3 rounded-xl border border-slate-200 text-sm focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
          </div>

          <div id="form-message" class="hidden px-4 py-3 rounded-xl text-sm font-medium"></div>

          <button type="submit" class="w-full py-3.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl text-sm transition-all shadow-sm">
            Register My Clinic (Free)
          </button>
          <p class="text-xs text-slate-400 text-center">Already listed? <a href="/admin/login?redirect=/owner/dashboard" class="text-blue-600 font-semibold">Log in to your dashboard</a></p>
        </form>
      </div>
    </div>
  </main>
</Layout>

<script>
  document.getElementById('clinic-signup-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const msgEl = document.getElementById('form-message')!;

    const data = {
      segment: 'clinic_owner',
      name: (form.querySelector('[name="name"]') as HTMLInputElement).value,
      email: (form.querySelector('[name="email"]') as HTMLInputElement).value,
      clinicName: (form.querySelector('[name="clinicName"]') as HTMLInputElement).value,
      city: (form.querySelector('[name="city"]') as HTMLInputElement).value,
      state: (form.querySelector('[name="state"]') as HTMLInputElement).value,
      source: 'for-clinics-page',
    };

    try {
      const res = await fetch('/api/funnel/enter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.classList.add('hidden');
        msgEl.textContent = 'Registration received! Check your email for next steps.';
        msgEl.className = 'px-4 py-3 rounded-xl text-sm font-medium bg-emerald-50 text-emerald-700 border border-emerald-100';
        msgEl.classList.remove('hidden');
      } else {
        msgEl.textContent = 'Something went wrong. Please try again.';
        msgEl.className = 'px-4 py-3 rounded-xl text-sm font-medium bg-red-50 text-red-700 border border-red-100';
        msgEl.classList.remove('hidden');
      }
    } catch {
      msgEl.textContent = 'Network error. Please try again.';
      msgEl.className = 'px-4 py-3 rounded-xl text-sm font-medium bg-red-50 text-red-700 border border-red-100';
      msgEl.classList.remove('hidden');
    }
  });
</script>
