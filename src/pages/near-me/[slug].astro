---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import ClinicCard from "../../components/ClinicCard.astro";
import {
  getAllClinics,
  STATE_NAMES,
  COUNTRY_NAMES,
  COUNTRY_URL_PREFIXES,
} from "../../utils/dataHelpers";
import { getVisitorCountry } from "../../utils/visitorCountry";
import { TREATMENT_SLUGS } from "../../utils/seo_slugs";
import { calculateClinicScore } from "../../utils/ranking";

const VISITOR_COUNTRY = getVisitorCountry(Astro.cookies, Astro.url);
const visitorCountryName = COUNTRY_NAMES[VISITOR_COUNTRY] || 'United States';
const visitorCountryUrl = `/${COUNTRY_URL_PREFIXES[VISITOR_COUNTRY] || VISITOR_COUNTRY.toLowerCase()}/`;
import {
  generateBreadcrumbSchema,
  generateMedicalClinicListSchema,
} from "../../utils/schema";

const { slug } = Astro.params;

// ── Route dispatch ──────────────────────────────────────────
// Pattern 1: treatment slug — "depression-tms-near-san-diego" or "tms-near-me"
// Pattern 2: provider type slug — "psychologist-near-new-york" or "therapist-near-anchorage"

const isGenericNearMe = slug === 'tms-near-me';
const providerMatch = !isGenericNearMe ? (slug || '').match(/^(psychologist|therapist)-near-(.+)$/) : null;
const isProviderRoute = !!providerMatch;

// Provider route: psychologist-near-[city] or therapist-near-[city]
if (isProviderRoute) {
  const providerType = providerMatch![1] as 'psychologist' | 'therapist';
  const citySlugPart = providerMatch![2];
  const cityName = citySlugPart.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
  const provider = providerType === 'psychologist'
    ? { plural: 'Psychologists', singular: 'Psychologist', type: 'psychologists' as const }
    : { plural: 'Therapists', singular: 'Therapist', type: 'therapists' as const };

  const allClinics = (await import('../../utils/clinicData')).getAllClinics();
  const cityClinics = (await allClinics).filter(c => c.verified && c.city.toLowerCase() === cityName.toLowerCase());
  const { filterDoctorsByType } = await import('../../utils/providerFilter');
  const allDoctors = cityClinics.flatMap((c: any) => (c.doctors_data || []).map((d: any) => ({ ...d, clinic: c })));
  const providers = filterDoctorsByType(allDoctors, provider.type);
  const stateName = cityClinics.length > 0 ? ((await import('../../utils/clinicData')).STATE_NAMES[cityClinics[0].state] || cityClinics[0].state) : '';

  const title = `Find ${provider.plural} Near ${cityName} | TMS Therapy Specialists`;
  const description = `Looking for ${provider.singular.toLowerCase()} offering TMS therapy near ${cityName}? Browse ${providers.length} verified ${provider.singular.toLowerCase()}s in ${stateName} and book a consultation.`;

  const { default: Layout } = await import('../../layouts/Layout.astro');
  const { PROVIDER_TYPES } = await import('../../utils/cityData');
  const providerMeta = PROVIDER_TYPES.find(p => p.slug === provider.type)!;

  const avatarUrl = (d: any) => d.image_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(d.name)}&background=0A1628&color=fff&size=80`;
  const stateSlug = (c: any) => (c.state || '').toLowerCase();
  const citySlug = (c: any) => (c.city || '').toLowerCase().replace(/\s+/g, '-');

  return new Response(`
<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>${title}</title></head>
<body>
<script type="application/ld+json">${JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${providerMeta.label} in ${cityName}, ${stateName}`,
  "description": description,
  "url": `https://tmslist.com/near-me/${slug}/`,
})}</script>
<main class="min-h-screen">
  <section class="relative bg-[var(--paper)] border-b border-[var(--line)] overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[rgba(10,22,40,0.08)]/60 via-white to-[rgba(10,22,40,0.40)] pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-[rgba(10,22,40,0.06)] rounded-full blur-[100px]"></div>
    <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
      <nav class="flex items-center gap-2 text-sm text-[var(--muted)] mb-8">
        <a href="/">Home</a><span>/</span><a href="/near-me/tms-near-me">Near Me</a><span>/</span>
        <span class="text-[var(--ink2)] font-medium">${providerMeta.plural} near ${cityName}</span>
      </nav>
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-[rgba(10,22,40,0.08)] border border-[rgba(10,22,40,0.1)] rounded-full mb-6">
          <span class="flex h-2 w-2 rounded-full bg-[var(--ink2)]"></span>
          <span class="text-xs font-semibold text-[var(--accent)] tracking-wide">Near Me</span>
        </div>
        <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-[var(--ink)] mb-4 leading-tight">
          ${providerMeta.plural} Near <span class="text-[var(--accent)]">${cityName}</span>
        </h1>
        <p class="text-lg text-[var(--muted)] leading-relaxed">
          ${providers.length > 0
            ? `Found ${providers.length} ${providerMeta.singular.toLowerCase()}${providers.length !== 1 ? 's' : ''} with TMS training serving ${cityName}, ${stateName}.`
            : `Find ${providerMeta.singular.toLowerCase()}s with TMS therapy training in ${cityName}, ${stateName}.`}
        </p>
      </div>
    </div>
  </section>

  <section class="bg-[var(--paper)] border-b border-[var(--line)] py-6">
    <div class="container mx-auto px-6">
      <div class="flex flex-wrap justify-center gap-8 md:gap-16">
        <div class="text-center"><div class="text-3xl font-semibold tracking-tight text-[var(--accent)]">${providers.length}</div><div class="text-sm text-[var(--muted)] font-medium">${providerMeta.plural}</div></div>
        <div class="text-center"><div class="text-3xl font-semibold tracking-tight text-[var(--accent)]">${cityClinics.length}</div><div class="text-sm text-[var(--muted)] font-medium">TMS Clinics</div></div>
        <div class="text-center"><div class="text-3xl font-semibold tracking-tight text-[var(--accent)]">${stateName}</div><div class="text-sm text-[var(--muted)] font-medium">State</div></div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-6 max-w-4xl">
      ${providers.length > 0 ? `
      <h2 class="text-2xl font-semibold text-[var(--ink)] mb-8">All ${providerMeta.plural} in ${cityName}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        ${providers.map((p: any, idx: number) => `
        <article class="bg-[var(--paper)] rounded-2xl shadow-sm border border-[var(--line)] p-6">
          <div class="flex items-start gap-4">
            <img src="${avatarUrl(p)}" alt="${p.name}" class="w-16 h-16 rounded-full" loading="lazy" />
            <div class="flex-1">
              <div class="flex flex-wrap gap-1 mb-1">
                <span class="px-2 py-0.5 bg-emerald-100 text-emerald-700 text-[10px] font-bold uppercase tracking-wider rounded-full">Verified</span>
                <span class="px-2 py-0.5 bg-[rgba(10,22,40,0.08)] text-[var(--accent)] text-[10px] font-bold uppercase tracking-wider rounded-full">#${idx + 1}</span>
              </div>
              <h3 class="text-lg font-bold text-[var(--ink)]">${p.name}</h3>
              <p class="text-[var(--accent)] text-sm font-medium">${p.title}</p>
            </div>
          </div>
          ${p.bio ? `<p class="text-[var(--muted)] text-sm mt-3 line-clamp-2">${p.bio}</p>` : ''}
          ${(p.specialties || []).length > 0 ? `
          <div class="flex flex-wrap gap-1.5 mb-4 mt-3">
            ${(p.specialties as string[]).slice(0, 3).map((s: string) => `<span class="px-2.5 py-1 bg-[rgba(10,22,40,0.08)] text-[var(--accent)] rounded-full text-xs font-medium">${s}</span>`).join('')}
          </div>` : ''}
          <div class="mt-4 flex items-center justify-between pt-4 border-t border-[var(--line)]">
            <span class="text-xs text-[var(--muted)]">${p.clinic?.name || ''}</span>
            <a href="/us/${stateSlug(p.clinic)}/${citySlug(p.clinic)}/${provider.type}/" class="px-4 py-2 bg-[var(--ink)] text-white text-sm font-semibold rounded-lg hover:bg-[var(--ink2)] transition-colors">View Profile</a>
          </div>
        </article>`).join('')}
      </div>` : `
      <div class="text-center py-12">
        <div class="w-20 h-20 mx-auto mb-6 bg-[rgba(10,22,40,0.08)] rounded-2xl flex items-center justify-center">
          <svg class="w-10 h-10 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-[var(--ink)] mb-3">No ${providerMeta.singular}s Listed in ${cityName} Yet</h2>
        <p class="text-[var(--muted)] mb-6">We're expanding our ${providerMeta.singular.toLowerCase()} network. Browse nearby cities or take our eligibility quiz.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/us/" class="px-5 py-2.5 bg-[var(--ink)] text-white rounded-xl text-sm font-semibold hover:bg-[var(--ink2)] transition-colors">Browse All Cities</a>
          <a href="/quiz/am-i-a-candidate/" class="px-5 py-2.5 bg-[var(--paper)] border border-[var(--line)] rounded-xl text-sm font-semibold hover:border-[rgba(10,22,40,0.2)] transition-colors">Take Eligibility Quiz</a>
        </div>
      </div>`}
    </div>
  </section>

  <section class="py-8 bg-[var(--paper2)]">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
        <a href="/us/" class="p-4 bg-[var(--paper)] rounded-xl border border-[var(--line)] text-center text-sm font-semibold text-[var(--ink)] hover:border-[rgba(10,22,40,0.2)] transition-all">Browse All Cities</a>
        <a href="/near-me/depression-tms-near-me" class="p-4 bg-[var(--paper)] rounded-xl border border-[var(--line)] text-center text-sm font-semibold text-[var(--ink)] hover:border-[rgba(10,22,40,0.2)] transition-all">TMS Near Me</a>
        <a href="/psychologists/" class="p-4 bg-[var(--paper)] rounded-xl border border-[var(--line)] text-center text-sm font-semibold text-[var(--ink)] hover:border-[rgba(10,22,40,0.2)] transition-all">All Psychologists</a>
        <a href="/therapists/" class="p-4 bg-[var(--paper)] rounded-xl border border-[var(--line)] text-center text-sm font-semibold text-[var(--ink)] hover:border-[rgba(10,22,40,0.2)] transition-all">All Therapists</a>
      </div>
    </div>
  </section>

  <!-- Learn More -->
  <section class="py-8 bg-[var(--paper)] border-t border-[var(--line)]">
    <div class="container mx-auto px-6">
      <div class="flex flex-wrap justify-center gap-2">
        <a href="/blog/tms-for-depression/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">TMS for Depression</a>
        <a href="/blog/tms-cost-insurance-guide-2026/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Cost &amp; Insurance</a>
        <a href="/blog/questions-to-ask-tms-clinic/" class="px-3 py-1.5 text-xs font-medium border border-[var(--line)] text-[var(--ink)] rounded-lg hover:bg-[var(--paper2)] transition-colors">Questions to Ask</a>
        <a href="/blog/" class="px-3 py-1.5 text-xs font-medium text-[var(--accent)] hover:underline">View all articles →</a>
      </div>
    </div>
  </section>
</main>
</body>
</html>`, {
    headers: { 'Content-Type': 'text/html; charset=utf-8' }
  });
}

// Treatment route: [condition]-tms-near-[city]
const nearMatch = !isGenericNearMe ? (slug || '').match(/^(.+)-tms-near-(.+)$/) : null;
const treatmentSlugPart = nearMatch?.[1] || '';
const citySlugPart = nearMatch?.[2] || '';

const treatmentEntry = TREATMENT_SLUGS.find(t =>
  t.slug === treatmentSlugPart || t.slug === `tms-for-${treatmentSlugPart}`
);
const treatmentTitle = isGenericNearMe
  ? 'TMS Therapy'
  : (treatmentEntry?.title || `TMS for ${treatmentSlugPart.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}`);
const cityName = isGenericNearMe
  ? 'You'
  : citySlugPart.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());

const verifiedClinics = (await getAllClinics()).filter(c => c.verified);
// Scope to visitor's country (US fallback if their country has none)
const matchesVisitorCountry = (c: any) =>
  VISITOR_COUNTRY === 'US' ? (!c.country || c.country === 'US') : c.country === VISITOR_COUNTRY;
const inCountry = verifiedClinics.filter(matchesVisitorCountry);
const allClinics = inCountry.length > 0
  ? inCountry
  : verifiedClinics.filter(c => !c.country || c.country === 'US');
const cityClinics = isGenericNearMe
  ? allClinics.slice(0, 50)
  : allClinics.filter(c => c.city.toLowerCase() === cityName.toLowerCase());
const stateName = cityClinics.length > 0 ? (STATE_NAMES[cityClinics[0].state] || cityClinics[0].state) : '';

const sortedClinics = [...cityClinics].sort(
  (a, b) => calculateClinicScore(b) - calculateClinicScore(a),
);

const title = isGenericNearMe
  ? (VISITOR_COUNTRY === 'US'
      ? 'Find TMS Therapy Near You | Top Verified Clinics'
      : `Find TMS Therapy in ${visitorCountryName} | Top Verified Clinics`)
  : `${treatmentTitle} Near ${cityName} | Find Top Providers`;
const description = isGenericNearMe
  ? (VISITOR_COUNTRY === 'US'
      ? `Find verified TMS therapy clinics near you. Compare ${allClinics.length}+ providers by ratings, insurance, and technology.`
      : `Find verified TMS therapy clinics in ${visitorCountryName}. Compare ${allClinics.length}+ providers by ratings, insurance, and technology.`)
  : `Looking for ${treatmentTitle} near ${cityName}, ${stateName}? Compare top-rated clinics nearby. Verified reviews and photos.`;

// Schema
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", item: "https://tmslist.com" },
  { name: "Near Me", item: "https://tmslist.com/near-me/" },
  { name: `${treatmentTitle} near ${cityName}`, item: Astro.url.href },
]);

const listingSchema = generateMedicalClinicListSchema(
  sortedClinics,
  `${treatmentTitle} near ${cityName}, ${stateName}`,
  description,
);

const combinedSchema = `[${breadcrumbSchema}, ${listingSchema}]`;
---

<Layout title={title} description={description} schema={combinedSchema}>
  <main>
    <section class="relative bg-[var(--paper)] border-b border-[var(--line)] overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[rgba(10,22,40,0.08)]/60 via-white to-[rgba(10,22,40,0.40)] pointer-events-none"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-[rgba(10,22,40,0.5)] rounded-full blur-[100px]"></div>
      <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
        <nav class="flex items-center gap-2 text-sm text-[var(--muted)] mb-8" aria-label="Breadcrumb">
          <a href="/" class="hover:text-[var(--accent)] transition-colors">Home</a>
          <span class="text-[var(--muted)]">/</span>
          <span class="text-[var(--ink2)] font-medium">{treatmentTitle} near {cityName}</span>
        </nav>
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-[rgba(10,22,40,0.08)] border border-[rgba(10,22,40,0.1)] rounded-full mb-6">
            <span class="flex h-2 w-2 rounded-full bg-[var(--ink2)]"></span>
            <span class="text-xs font-semibold text-[var(--accent)] tracking-wide">Local Care</span>
          </div>
          <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-[var(--ink)] mb-4 leading-tight">
            {treatmentTitle} near <span class="text-[var(--accent)]">{cityName}</span>
          </h1>
          <p class="text-lg text-[var(--muted)] leading-relaxed">
            We found {sortedClinics.length} verified TMS centers serving the <strong class="text-[var(--ink2)]">{cityName}</strong> area.
          </p>
        </div>
      </div>
    </section>

    <div class="container mx-auto px-4 py-12">

    <!-- Clinic Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        sortedClinics.map((clinic) => (
          <div class="clinic-item">
            <ClinicCard clinic={clinic} />
          </div>
        ))
      }
    </div>

    {
      sortedClinics.length === 0 && (
        <div class="text-center py-12 bg-[var(--paper2)] rounded-xl border border-[var(--line)] mt-8">
          <p class="text-[var(--muted)] mb-4">
            No clinics found specifically using this location filter.
          </p>
          <a
            id="near-me-fallback"
            href={visitorCountryUrl}
            class="inline-block px-6 py-2 bg-[var(--ink)] text-white font-semibold rounded-lg hover:bg-[var(--ink2)] transition-colors"
          >
            Browse Clinic Directory
          </a>
        </div>
      )
    }

    <!-- SEO Content Section -->
    {sortedClinics.length > 0 && (
    <section class="mt-16 border-t border-[var(--line)] pt-12">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-bold text-[var(--ink)] mb-4">Finding {treatmentTitle} near {cityName}</h2>
        <div class="prose prose-slate max-w-none text-[var(--muted)]">
          <p>
            If you're looking for {treatmentTitle.toLowerCase()} providers near {cityName}, {stateName}, the clinics above have been verified and include real patient reviews,
            insurance information, and treatment details. TMS therapy is FDA-cleared for treatment-resistant depression
            and uses focused magnetic pulses to stimulate specific brain regions involved in mood regulation.
          </p>
          <h3 class="text-lg font-semibold text-[var(--ink2)] mt-6">What to consider when choosing a local TMS provider</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li>Verify the clinic accepts your insurance — call ahead to confirm coverage for TMS</li>
            <li>Check which TMS device the clinic uses (NeuroStar, BrainsWay, MagVenture) and session duration</li>
            <li>Ask about the treating psychiatrist's experience with TMS specifically</li>
            <li>Read patient reviews to understand the experience at each clinic</li>
            <li>Consider location and parking — you'll visit daily for 6-9 weeks</li>
          </ul>
          <p class="mt-4">
            Most patients begin noticing improvement after 2-4 weeks of treatment. Sessions are brief (3-37 minutes depending on protocol)
            and require no anesthesia or downtime — you can drive yourself and return to normal activities immediately.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 mt-6">
          <a href="/treatments/" class="text-sm font-medium text-[var(--accent)] hover:text-[var(--accent)]">Conditions Treated →</a>
          <a href="/insurance/" class="text-sm font-medium text-[var(--accent)] hover:text-[var(--accent)]">Insurance Coverage →</a>
          <a href="/quiz/am-i-a-candidate/" class="text-sm font-medium text-[var(--accent)] hover:text-[var(--accent)]">Am I a Candidate? →</a>
        </div>
      </div>
    </section>
    )}

    </div>
  </main>
</Layout>

<!-- geo.js (loaded in Layout head) handles /us/ link updates automatically -->
