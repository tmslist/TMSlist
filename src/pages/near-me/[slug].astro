---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import ClinicCard from "../../components/ClinicCard.astro";
import {
  getAllClinics,
  STATE_NAMES,
} from "../../utils/dataHelpers";
import { TREATMENT_SLUGS } from "../../utils/seo_slugs";
import { calculateClinicScore } from "../../utils/ranking";
import {
  generateBreadcrumbSchema,
  generateMedicalClinicListSchema,
} from "../../utils/schema";

const { slug } = Astro.params;

// Parse slug: "depression-tms-near-san-diego" -> treatment + city
const nearMatch = (slug || '').match(/^(.+)-tms-near-(.+)$/);
const treatmentSlugPart = nearMatch?.[1] || '';
const citySlugPart = nearMatch?.[2] || '';

const treatmentEntry = TREATMENT_SLUGS.find(t =>
  t.slug === treatmentSlugPart || t.slug === `tms-for-${treatmentSlugPart}`
);
const treatmentTitle = treatmentEntry?.title || `TMS for ${treatmentSlugPart.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}`;
const cityName = citySlugPart.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());

const allClinics = getAllClinics().filter(c => c.verified);
const cityClinics = allClinics.filter(c => c.city.toLowerCase() === cityName.toLowerCase());
const stateName = cityClinics.length > 0 ? (STATE_NAMES[cityClinics[0].state] || cityClinics[0].state) : '';

const sortedClinics = [...cityClinics].sort(
  (a, b) => calculateClinicScore(b) - calculateClinicScore(a),
);

const title = `${treatmentTitle} Near ${cityName} | Find Top Providers`;
const description = `Looking for ${treatmentTitle} near ${cityName}, ${stateName}? Compare top-rated clinics nearby. Verified reviews and photos.`;

// Schema
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: "Home", item: "https://tmslist.com" },
  { name: "Near Me", item: "https://tmslist.com/near-me/" },
  { name: `${treatmentTitle} near ${cityName}`, item: Astro.url.href },
]);

const listingSchema = generateMedicalClinicListSchema(
  sortedClinics,
  `${treatmentTitle} near ${cityName}, ${stateName}`,
  description,
);

const combinedSchema = `[${breadcrumbSchema}, ${listingSchema}]`;
---

<Layout title={title} description={description} schema={combinedSchema}>
  <main class="container mx-auto px-4 py-8">
    <div class="max-w-4xl mx-auto mb-12 text-center">
      <span
        class="inline-block px-4 py-1.5 bg-indigo-50 text-indigo-700 rounded-full text-sm font-semibold uppercase tracking-wider mb-4"
      >
        Local Care
      </span>
      <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-gray-900 mb-6">
        {treatmentTitle} near {cityName}
      </h1>
      <p class="text-xl text-gray-600">
        We found {sortedClinics.length} verified TMS centers serving the <strong
          >{cityName}</strong
        > area.
      </p>
    </div>

    <!-- Clinic Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        sortedClinics.map((clinic) => (
          <div class="clinic-item">
            <ClinicCard clinic={clinic} />
          </div>
        ))
      }
    </div>

    {
      sortedClinics.length === 0 && (
        <div class="text-center py-12 bg-gray-50 rounded-xl border border-gray-200 mt-8">
          <p class="text-gray-500 mb-4">
            No clinics found specifically using this location filter.
          </p>
          <a
            href="/us/"
            class="inline-block px-6 py-2 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition-colors"
          >
            Browse National Directory
          </a>
        </div>
      )
    }
  </main>
</Layout>
