---
import Layout from "../layouts/Layout.astro";
import AdvancedSearch from "../components/react/AdvancedSearch";

export const prerender = false;

const pageTitle = "Search TMS Clinics | Advanced Filters | TMS List";
const metaDescription = "Search and filter TMS therapy clinics by insurance, condition, device, rating, and location. Find the perfect provider for your needs.";
---

<Layout title={pageTitle} description={metaDescription}>
  <section class="bg-white pt-12 pb-6 border-b border-slate-100">
    <div class="container mx-auto px-6 lg:px-12">
      <h1 class="text-3xl lg:text-4xl font-bold tracking-tight text-slate-900 mb-2">
        Find Your TMS Clinic
      </h1>
      <p class="text-slate-500 font-light">
        Search 1,100+ verified TMS providers with advanced filters.
      </p>
    </div>
  </section>

  <main class="bg-slate-50/50 py-8">
    <div class="container mx-auto px-6 lg:px-12">
      <AdvancedSearch client:load />
    </div>
  </main>
</Layout>
