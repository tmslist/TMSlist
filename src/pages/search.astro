---
import Layout from "../layouts/Layout.astro";
import AdvancedSearch from "../components/react/AdvancedSearch";
import { db } from "../db";
import { clinics } from "../db/schema";
import { eq, sql } from "drizzle-orm";

export const prerender = false;

let clinicCount = 1100;
try {
  const result = await db.select({ count: sql<number>`count(*)` }).from(clinics).where(eq(clinics.verified, true));
  clinicCount = Number(result[0]?.count || 1100);
} catch { /* fallback to approximate */ }

const pageTitle = "Search TMS Clinics | Advanced Filters | TMS List";
const metaDescription = `Search and filter ${clinicCount}+ TMS therapy clinics by insurance, condition, device, rating, and location.`;
---

<Layout title={pageTitle} description={metaDescription}>
  <section class="bg-white pt-12 pb-6 border-b border-slate-100">
    <div class="container mx-auto px-6 lg:px-12">
      <h1 class="text-3xl lg:text-4xl font-bold tracking-tight text-slate-900 mb-2">
        Find Your TMS Clinic
      </h1>
      <p class="text-slate-500 font-light">
        Search {clinicCount.toLocaleString()}+ verified TMS providers with advanced filters.
      </p>
    </div>
  </section>

  <main class="bg-slate-50/50 py-8">
    <div class="container mx-auto px-6 lg:px-12">
      <AdvancedSearch client:idle />
      <noscript>
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-center mt-4">
          <p class="text-amber-800">Search requires JavaScript. <a href="/us/" class="underline font-medium">Browse clinics by state instead</a>.</p>
        </div>
      </noscript>
    </div>
  </main>
</Layout>
