---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import EditorialHero from '../components/editorial/EditorialHero.astro';
import PatientJourneyTracker from '../components/react/PatientJourneyTracker';

const title = "Your TMS Treatment Journey | 6-Week Timeline & What to Expect";
const description = "From first consultation to lasting results — understand every phase of TMS treatment, what happens during each session, and what to expect over 6 weeks.";

const phases = [
  {
    phase: 1,
    title: "Consultation & Evaluation",
    subtitle: "Week 0",
    tone: "accent" as const,
    sessions: "1–2 appointments",
    duration: "~2–3 hours total",
    items: [
      "Psychiatric evaluation and diagnosis confirmation",
      "PHQ-9 / HAM-D baseline assessment scores",
      "Review of medical history, medications, and prior treatments",
      "Discussion of TMS mechanism, expected outcomes, and treatment timeline",
      "Insurance pre-authorization (1–2 weeks typical)",
      "Review of contraindications and safety screening",
    ],
    question: "Is TMS right for me? What outcomes can I expect?",
  },
  {
    phase: 2,
    title: "Motor Threshold Finding",
    subtitle: "Day 1",
    tone: "ink" as const,
    sessions: "1 calibration session",
    duration: "45–60 minutes",
    items: [
      "No treatment pulses are delivered during this session",
      "Coil placed over motor cortex (M1) — area controlling hand movement",
      "Intensity gradually increased until a visible thumb twitch is observed",
      "This \"motor threshold\" sets the treatment intensity (typically 80–120% MT)",
      "Coil repositioned to treatment target (DLPFC) for the remaining sessions",
      "You may feel mild tapping sensations on the scalp — this is normal",
    ],
    question: "Will it hurt? What's the motor threshold?",
  },
  {
    phase: 3,
    title: "Early Treatment Phase",
    subtitle: "Weeks 1–2 (Sessions 1–10)",
    tone: "warm" as const,
    sessions: "5 sessions per week",
    duration: "20–37 minutes per session",
    items: [
      "Daily sessions, Monday through Friday",
      "Each session: seated in a recliner, coil positioned on scalp",
      "You hear rhythmic clicking sounds and feel a tapping sensation",
      "Most patients read, watch, or use a phone during sessions",
      "Resume normal activities immediately after — no downtime",
      "Early side effects may include: mild headache, scalp tenderness, fatigue",
      "No immediate mood change expected — this is normal",
    ],
    question: "Will I feel anything right away?",
  },
  {
    phase: 4,
    title: "Building Response",
    subtitle: "Weeks 3–5 (Sessions 11–25)",
    tone: "success" as const,
    sessions: "5 sessions per week",
    duration: "20–37 minutes per session",
    items: [
      "Most patients notice first signs of improvement between weeks 2–3",
      "Common early improvements: better sleep, more energy, improved concentration",
      "Mood may gradually lift — progress is often subtle at first",
      "Side effects (headache, tenderness) typically diminish",
      "Week 10 checkpoint: PHQ-9 reassessment, medication review if applicable",
      "Continue daily sessions — consistency is key for optimal outcomes",
      "Some patients experience temporary worsening before improving — discuss with your provider",
    ],
    question: "When will I start feeling better?",
  },
  {
    phase: 5,
    title: "Consolidation",
    subtitle: "Week 6 (Sessions 26–36)",
    tone: "amber" as const,
    sessions: "5 sessions per week",
    duration: "20–37 minutes per session",
    items: [
      "Continued improvement in mood, energy, and cognition",
      "PHQ-9 score reassessed — often significantly reduced from baseline",
      "Side effects minimal to none at this stage",
      "Discussion of maintenance plan — some patients benefit from periodic booster sessions",
      "Transition planning: what happens after the acute treatment phase",
      "Discuss long-term follow-up schedule (1-month, 3-month, 6-month check-ins)",
    ],
    question: "Is treatment complete? What about maintenance?",
  },
  {
    phase: 6,
    title: "Maintenance & Follow-up",
    subtitle: "Month 2+",
    tone: "muted" as const,
    sessions: "As needed",
    duration: "Variable",
    items: [
      "Optional maintenance sessions: 1–2 per month for 6–12 months",
      "Regular follow-up assessments (PHQ-9, clinical interview)",
      "Long-term outcome tracking — most patients maintain gains for 6–12+ months",
      "If symptoms return, discuss options: booster TMS, medication adjustment, therapy",
      "Lifestyle factors: continued exercise, sleep, therapy to support gains",
      "Some patients require retreatment — TMS can be safely repeated",
    ],
    question: "How long do results last?",
  },
];

const toneStyles: Record<string, { badgeBg: string; badgeColor: string; badgeBorder: string; numBg: string; numColor: string; qBg: string; qColor: string; qBorder: string }> = {
  accent: {
    badgeBg: "rgba(10,22,40,0.06)", badgeColor: "var(--accent)", badgeBorder: "rgba(10,22,40,0.15)",
    numBg: "linear-gradient(135deg, var(--accent), var(--accent2))", numColor: "#fff",
    qBg: "rgba(10,22,40,0.04)", qColor: "var(--accent)", qBorder: "rgba(10,22,40,0.12)",
  },
  ink: {
    badgeBg: "rgba(10,22,40,0.06)", badgeColor: "var(--ink)", badgeBorder: "rgba(10,22,40,0.15)",
    numBg: "linear-gradient(135deg, var(--ink), var(--ink2))", numColor: "#fff",
    qBg: "rgba(10,22,40,0.04)", qColor: "var(--ink)", qBorder: "rgba(10,22,40,0.12)",
  },
  warm: {
    badgeBg: "rgba(201,101,74,0.10)", badgeColor: "var(--warm)", badgeBorder: "rgba(201,101,74,0.25)",
    numBg: "linear-gradient(135deg, var(--warm), var(--warm-light))", numColor: "#fff",
    qBg: "rgba(201,101,74,0.06)", qColor: "var(--warm)", qBorder: "rgba(201,101,74,0.20)",
  },
  success: {
    badgeBg: "rgba(34,197,94,0.10)", badgeColor: "#15803d", badgeBorder: "rgba(34,197,94,0.25)",
    numBg: "linear-gradient(135deg, #16a34a, #22c55e)", numColor: "#fff",
    qBg: "rgba(34,197,94,0.06)", qColor: "#15803d", qBorder: "rgba(34,197,94,0.20)",
  },
  amber: {
    badgeBg: "rgba(245,158,11,0.10)", badgeColor: "#b45309", badgeBorder: "rgba(245,158,11,0.30)",
    numBg: "linear-gradient(135deg, #d97706, #f59e0b)", numColor: "#fff",
    qBg: "rgba(245,158,11,0.06)", qColor: "#b45309", qBorder: "rgba(245,158,11,0.25)",
  },
  muted: {
    badgeBg: "rgba(90,107,130,0.10)", badgeColor: "var(--muted)", badgeBorder: "rgba(90,107,130,0.20)",
    numBg: "linear-gradient(135deg, var(--muted), #7a8ba2)", numColor: "#fff",
    qBg: "rgba(90,107,130,0.06)", qColor: "var(--muted)", qBorder: "rgba(90,107,130,0.18)",
  },
};

const sessionFlow = [
  {
    title: "Before",
    tone: "accent",
    items: ["Arrive with clean, dry hair", "No conditioner or hair products", "Remove metal jewelry near head", "Inform provider of any changes since last session", "Brief check-in with TMS technician"],
  },
  {
    title: "During",
    tone: "warm",
    items: ["Seated comfortably in recliner", "Coil positioned on scalp", "Rhythmic clicking sounds (~10 Hz)", "Gentle tapping sensation on scalp", "20–40 minutes of stimulation", "Read, watch, or relax during session"],
  },
  {
    title: "After",
    tone: "success",
    items: ["Resume normal activities immediately", "No driving restrictions", "Mild headache possible (responds to Tylenol)", "Most patients return to work same day", "Track any side effects to discuss with provider"],
  },
];

const faqs = [
  { q: "Will I feel anything during TMS?", a: "Most patients feel a tapping sensation on the scalp where the coil is placed. You will hear rhythmic clicking sounds — this is the magnetic pulse being generated. The sensation varies from person to person; some describe it as a mild knock or tapping, others barely notice it. Pain is not typical — if you experience significant pain, inform your TMS technician immediately." },
  { q: "Can I drive after a TMS session?", a: "Yes. TMS does not require sedation or anesthesia, and there are no driving restrictions after treatment. You can resume normal activities including driving, working, and exercising immediately after your session." },
  { q: "What if I miss a session?", a: "Missing an occasional session (e.g., once per week) is generally acceptable and unlikely to significantly impact treatment outcomes. However, consistent daily attendance is associated with better response rates. If you need to miss multiple sessions, discuss a plan with your provider — some clinics offer weekend catch-up sessions." },
  { q: "Will I need maintenance TMS sessions?", a: "Many patients benefit from periodic \"booster\" TMS sessions after completing the initial 36-session course. The maintenance schedule varies: some patients come monthly, others quarterly, and some not at all. Your provider will discuss a maintenance plan based on your response and long-term goals." },
  { q: "How long do TMS results last?", a: "Clinical studies show that most patients maintain significant improvement for 6–12 months after completing TMS. About 30–40% of patients eventually experience a return of symptoms and may benefit from retreatment. Ongoing therapy and medication management can help sustain gains." },
  { q: "Does insurance cover TMS?", a: "Most commercial insurance plans cover TMS for treatment-resistant depression (typically defined as failure of 1–4 antidepressants). Medicare covers TMS for depression. Medicaid coverage varies by state. Your clinic will typically handle insurance authorization before treatment begins." },
  { q: "Is TMS safe for everyone?", a: "TMS has an excellent safety profile, but is not appropriate for people with metal implants in or near the head (pacemakers, cochlear implants, aneurysm clips), a history of seizures, or other conditions. Your provider will conduct a safety screening before treatment." },
];

const sessionToneStyle: Record<string, string> = {
  accent: "rgba(10,22,40,0.06)",
  warm: "rgba(201,101,74,0.10)",
  success: "rgba(34,197,94,0.10)",
};
const sessionToneColor: Record<string, string> = {
  accent: "var(--accent)",
  warm: "var(--warm)",
  success: "#16a34a",
};
---

<Layout title={title} description={description}>
  <EditorialHero
    eyebrow="Patient Guide"
    eyebrowDot="#22c55e"
    title="Your TMS treatment"
    titleAccent="journey."
    description="From first consultation to lasting results — what to expect at every stage of your 6-week TMS treatment course."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "TMS Journey" }]}
    ctas={[
      { label: "Take the Eligibility Quiz", href: "/quiz/am-i-a-candidate/" },
      { label: "Find a TMS Clinic", href: "/us/", variant: "outline" },
    ]}
    stats={[
      { value: "6", label: "Weeks", color: "ink" },
      { value: "30–36", label: "Sessions", color: "accent" },
      { value: "5/wk", label: "Cadence", color: "warm" },
    ]}
  />

  <!-- Phase Timeline -->
  <section class="phases">
    <div class="phases-inner">
      <div class="phases-head">
        <h2 class="serif phases-title">The 6 phases of treatment</h2>
        <p class="phases-intro">A typical TMS course unfolds across six distinct stages — from initial evaluation through long-term follow-up.</p>
      </div>

      <ol class="phase-list">
        {phases.map((phase, idx) => {
          const t = toneStyles[phase.tone];
          return (
            <li class="phase-item">
              <div class="phase-card">
                <div class="phase-num" style={`background:${t.numBg}; color:${t.numColor};`}>
                  <span>{phase.phase}</span>
                </div>
                <div class="phase-body">
                  <div class="phase-header">
                    <h3 class="serif phase-title">{phase.title}</h3>
                    <span class="phase-badge" style={`background:${t.badgeBg}; color:${t.badgeColor}; border-color:${t.badgeBorder};`}>{phase.subtitle}</span>
                  </div>
                  <div class="phase-meta">
                    <span class="phase-meta-item">
                      <svg class="phase-meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                      {phase.sessions}
                    </span>
                    <span class="phase-meta-dot" aria-hidden="true">·</span>
                    <span class="phase-meta-item">
                      <svg class="phase-meta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                      {phase.duration}
                    </span>
                  </div>
                  <ul class="phase-items">
                    {phase.items.map(item => (
                      <li class="phase-list-item">
                        <svg class="phase-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                  <div class="phase-question" style={`background:${t.qBg}; color:${t.qColor}; border-color:${t.qBorder};`}>
                    <svg class="phase-question-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <span>{phase.question}</span>
                  </div>
                </div>
              </div>
              {idx < phases.length - 1 && <div class="phase-connector" aria-hidden="true"></div>}
            </li>
          );
        })}
      </ol>
    </div>
  </section>

  <!-- Interactive Journey Tracker -->
  <section class="tracker-section">
    <div class="tracker-inner">
      <div class="tracker-head">
        <span class="tracker-eyebrow">Interactive</span>
        <h2 class="serif tracker-title">Track a simulated treatment journey</h2>
        <p class="tracker-intro">Explore a sample 36-session TMS course — click sessions, view details, and see how response builds week by week.</p>
      </div>
      <div class="tracker-frame">
        <PatientJourneyTracker client:only="react" />
      </div>
    </div>
  </section>

  <!-- Session Flow -->
  <section class="flow-section">
    <div class="flow-inner">
      <div class="flow-head">
        <h2 class="serif flow-title">What happens at each session</h2>
        <p class="flow-intro">A typical TMS appointment takes about 30 minutes from arrival to departure.</p>
      </div>
      <div class="flow-grid">
        {sessionFlow.map(bucket => (
          <div class="flow-card">
            <div class="flow-card-header">
              <span class="flow-card-badge" style={`background:${sessionToneStyle[bucket.tone]}; color:${sessionToneColor[bucket.tone]};`}>{bucket.title}</span>
              <span class="flow-card-label">the session</span>
            </div>
            <ul class="flow-list">
              {bucket.items.map(item => (
                <li class="flow-list-item">
                  <span class="flow-bullet" style={`background:${sessionToneColor[bucket.tone]};`}></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="faq-inner">
      <div class="faq-head">
        <h2 class="serif faq-title">Frequently asked questions</h2>
        <p class="faq-intro">Common questions from patients starting TMS treatment.</p>
      </div>
      <div class="faq-list">
        {faqs.map(faq => (
          <details class="faq-item">
            <summary class="faq-summary">
              <span class="faq-question">{faq.q}</span>
              <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="faq-answer">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-inner">
      <h2 class="serif cta-title">Ready to begin?</h2>
      <p class="cta-intro">Take the first step toward understanding TMS and finding a provider that fits.</p>
      <div class="cta-buttons">
        <a href="/simulation/" class="cta-button cta-button-primary">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Try the TMS Simulation
        </a>
        <a href="/quiz/am-i-a-candidate/" class="cta-button cta-button-outline">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Am I a Candidate?
        </a>
      </div>
      <p class="cta-secondary">Also: <a href="/us/" class="cta-link">find a TMS clinic near you</a> or <a href="/tms-cost-guide/" class="cta-link">read the TMS Cost Guide</a>.</p>
      <p class="cta-disclaimer">
        This page is for educational purposes only and does not constitute medical advice. TMS treatment decisions should be made in consultation with a qualified healthcare provider. Results vary by individual. Always consult your physician before starting or changing any treatment.
      </p>
    </div>
  </section>
</Layout>

<style>
  @reference "../styles/global.css";

  /* ── Phases ──────────────────────────────────────────────── */
  .phases {
    padding: 4rem 0 3rem;
    background: var(--paper);
  }
  .phases-inner {
    max-width: 920px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .phases-head {
    text-align: center;
    margin-bottom: 3rem;
  }
  .phases-title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    color: var(--ink);
    margin: 0 0 0.75rem;
    line-height: 1.15;
  }
  .phases-intro {
    color: var(--muted);
    font-size: 15px;
    max-width: 38rem;
    margin: 0 auto;
    line-height: 1.6;
  }

  .phase-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .phase-item {
    position: relative;
  }

  .phase-card {
    display: flex;
    gap: 1.25rem;
    background: var(--paper2);
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    padding: 1.5rem;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .phase-card:hover {
    box-shadow: 0 16px 40px -20px rgba(10,22,40,0.18);
    transform: translateY(-1px);
  }
  @media (min-width: 768px) {
    .phase-card { padding: 1.75rem 2rem; gap: 1.5rem; }
  }

  .phase-num {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    border-radius: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.125rem;
    box-shadow: 0 6px 18px -6px rgba(10,22,40,0.25);
  }
  .phase-num span { line-height: 1; }

  .phase-body {
    flex: 1;
    min-width: 0;
  }

  .phase-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .phase-title {
    font-size: 1.25rem;
    color: var(--ink);
    margin: 0;
    line-height: 1.2;
  }
  @media (min-width: 768px) {
    .phase-title { font-size: 1.375rem; }
  }
  .phase-badge {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    border: 1px solid;
  }

  .phase-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    color: var(--muted);
    font-size: 12px;
    margin-bottom: 1rem;
  }
  .phase-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }
  .phase-meta-icon {
    width: 0.875rem;
    height: 0.875rem;
  }
  .phase-meta-dot {
    color: var(--line);
  }

  .phase-items {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: grid;
    gap: 0.5rem;
  }
  .phase-list-item {
    display: flex;
    gap: 0.5rem;
    color: var(--ink);
    font-size: 14px;
    line-height: 1.55;
  }
  .phase-check {
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
    margin-top: 0.25rem;
    color: var(--warm);
  }

  .phase-question {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid;
    border-radius: 0.625rem;
    padding: 0.5rem 0.75rem;
    font-size: 12px;
    font-weight: 600;
  }
  .phase-question-icon {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
  }

  .phase-connector {
    width: 2px;
    height: 1.5rem;
    background: var(--line);
    margin: 0 auto;
  }

  /* ── Tracker ──────────────────────────────────────────────── */
  .tracker-section {
    padding: 4rem 0;
    background: var(--paper2);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .tracker-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .tracker-head {
    text-align: center;
    margin-bottom: 2rem;
  }
  .tracker-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--warm);
    margin-bottom: 0.5rem;
  }
  .tracker-title {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: var(--ink);
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }
  .tracker-intro {
    color: var(--muted);
    font-size: 14px;
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.6;
  }
  .tracker-frame {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    padding: 1.25rem;
    box-shadow: 0 12px 40px -20px rgba(10,22,40,0.15);
  }
  @media (min-width: 768px) {
    .tracker-frame { padding: 1.75rem; }
  }

  /* ── Session flow ─────────────────────────────────────────── */
  .flow-section {
    padding: 4rem 0;
    background: var(--paper);
  }
  .flow-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .flow-head {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .flow-title {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    color: var(--ink);
    margin: 0 0 0.5rem;
  }
  .flow-intro {
    color: var(--muted);
    font-size: 14px;
    margin: 0;
  }

  .flow-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .flow-grid { grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  }

  .flow-card {
    background: var(--paper2);
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    padding: 1.5rem;
  }

  .flow-card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
