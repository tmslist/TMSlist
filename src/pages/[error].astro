---
export const prerender = false;

import Layout from "../layouts/Layout.astro";

// Map common error codes to friendly messages
const ERROR_MESSAGES: Record<string, { title: string; description: string }> = {
  '401': {
    title: 'Sign in required',
    description: 'You need to be signed in to access this page. Please sign in and try again.',
  },
  '403': {
    title: 'Access denied',
    description: "You don't have permission to view this page. If you believe this is a mistake, please contact support.",
  },
  '404': {
    title: 'Page not found',
    description: "The page you were looking for has moved or doesn't exist.",
  },
  '500': {
    title: 'Something went wrong',
    description: "We're having trouble loading this page. Please try again in a moment.",
  },
  '502': {
    title: 'Service temporarily unavailable',
    description: "We're doing some maintenance. Please try again shortly.",
  },
  '503': {
    title: 'Service temporarily unavailable',
    description: "We're doing some maintenance. Please try again shortly.",
  },
  '504': {
    title: 'Request timed out',
    description: 'The request took too long to complete. Please refresh the page or try again.',
  },
};

const statusCode = Astro.params.error || '500';
const errorInfo = ERROR_MESSAGES[statusCode] || {
  title: 'Something went wrong',
  description: 'An unexpected error occurred. Please try again or return to the homepage.',
};
---

<Layout
  title={`${errorInfo.title} | TMS List`}
  description={errorInfo.description}
  noindex={true}
>
  <main class="container mx-auto px-4 py-24 text-center min-h-[60vh] flex flex-col items-center justify-center">
    <div class="max-w-lg mx-auto">
      <!-- Decorative icon -->
      <div class="mb-6 flex justify-center">
        <svg class="w-24 h-24" viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="48" cy="48" r="48" fill="#F4F1EA"/>
          {statusCode === '401' && (
            <g transform="translate(28,24)">
              <circle cx="20" cy="14" r="10" stroke="var(--ink)" stroke-width="3" fill="none"/>
              <path d="M20 28v12M12 40h16" stroke="var(--ink)" stroke-width="3" stroke-linecap="round"/>
              <rect x="10" y="42" width="20" height="14" rx="4" stroke="var(--ink)" stroke-width="3" fill="none"/>
            </g>
          )}
          {statusCode === '403' && (
            <g transform="translate(26,22)">
              <circle cx="22" cy="22" r="20" stroke="var(--ink)" stroke-width="3" fill="none"/>
              <path d="M22 14v14M22 34l8-8" stroke="var(--ink)" stroke-width="3" stroke-linecap="round"/>
            </g>
          )}
          {statusCode !== '401' && statusCode !== '403' && (
            <g>
              <circle cx="48" cy="48" r="20" stroke="var(--ink)" stroke-width="3" fill="none"/>
              <path d="M48 36v14M48 56l6-6" stroke="var(--ink)" stroke-width="3" stroke-linecap="round"/>
            </g>
          )}
        </svg>
      </div>

      <p class="text-7xl font-semibold tracking-tight text-[var(--accent)] mb-4">{statusCode}</p>
      <h1 class="text-3xl font-semibold text-[var(--ink)] mb-4">{errorInfo.title}</h1>
      <p class="text-lg text-[var(--muted)] mb-8">{errorInfo.description}</p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="px-6 py-3 bg-[var(--ink)] text-white font-semibold rounded-xl hover:bg-[var(--ink2)] transition-colors"
        >
          Go to Homepage
        </a>
        <a
          href="/us/"
          class="px-6 py-3 bg-[var(--paper)] text-[var(--ink2)] font-semibold border border-[var(--line)] rounded-xl hover:bg-[var(--paper2)] transition-colors"
        >
          Browse Clinics
        </a>
      </div>
    </div>
  </main>
</Layout>