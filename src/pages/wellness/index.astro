---
import Layout from '../../layouts/Layout.astro';
import EditorialHero from '../../components/editorial/EditorialHero.astro';
import EditorialSection from '../../components/editorial/EditorialSection.astro';
import EditorialCard from '../../components/editorial/EditorialCard.astro';
import EditorialCTA from '../../components/editorial/EditorialCTA.astro';
import { getWellnessClinics } from '../../data/verified-clinics';

const wellnessClinics = getWellnessClinics();

const title = "Wellness TMS | Exomind, Cognitive Enhancement & Brain Optimization";
const description = "Discover wellness TMS clinics offering Exomind therapy for cognitive enhancement, focus improvement, and mood optimization. An emerging category beyond clinical TMS.";
---

<Layout title={title} description={description} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Technology", url: "/technology/" },
    { name: "Wellness TMS", url: "/wellness/" },
]}>

<main style="background:var(--paper)">
  <EditorialHero
    eyebrow="Emerging Category"
    eyebrowDot="#22c55e"
    title="TMS for"
    titleAccent="peak performance."
    description="Beyond clinical treatment, wellness TMS uses technologies like Exomind for cognitive enhancement, focus improvement, and mood optimization — without a medical diagnosis requirement."
    breadcrumbs={[{ label: "Home", href: "/" }, { label: "Technology", href: "/technology/" }, { label: "Wellness TMS" }]}
    ctas={[
      { label: "Browse Wellness Clinics", href: "#clinics" },
      { label: "Compare Clinical vs Wellness", href: "#compare", variant: "outline" },
    ]}
    stats={[
      { value: wellnessClinics.length, label: "Wellness Clinics", color: "ink" },
      { value: "20-30", label: "Min/Session", color: "accent" },
      { value: "HSA", label: "Eligible", color: "warm" },
    ]}
  />

  <EditorialSection
    title="What is Wellness TMS?"
    intro="A new category of neuromodulation focused on cognitive enhancement — separate from clinical TMS for diagnosed conditions."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>'
    tone="warm"
  >
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      <div style="background:var(--paper2); border:1px solid var(--line); border-radius:1.5rem; padding:1.5rem;">
        <h3 class="serif" style="font-size:1.125rem; color:var(--ink); margin:0 0 0.5rem;">Improve Focus</h3>
        <p style="font-size:13px; color:var(--muted); line-height:1.6; margin:0;">Cognitive performance protocols designed to sharpen attention and concentration.</p>
      </div>
      <div style="background:var(--paper2); border:1px solid var(--line); border-radius:1.5rem; padding:1.5rem;">
        <h3 class="serif" style="font-size:1.125rem; color:var(--ink); margin:0 0 0.5rem;">Boost Cognition</h3>
        <p style="font-size:13px; color:var(--muted); line-height:1.6; margin:0;">Enhance mental processing speed and memory recall through targeted brain training.</p>
      </div>
      <div style="background:var(--paper2); border:1px solid var(--line); border-radius:1.5rem; padding:1.5rem;">
        <h3 class="serif" style="font-size:1.125rem; color:var(--ink); margin:0 0 0.5rem;">Optimize Mood</h3>
        <p style="font-size:13px; color:var(--muted); line-height:1.6; margin:0;">Mental clarity and mood elevation without the requirement of a clinical diagnosis.</p>
      </div>
      <div style="background:var(--paper2); border:1px solid var(--line); border-radius:1.5rem; padding:1.5rem;">
        <h3 class="serif" style="font-size:1.125rem; color:var(--ink); margin:0 0 0.5rem;">Peak Performance</h3>
        <p style="font-size:13px; color:var(--muted); line-height:1.6; margin:0;">Trusted by executives and professionals for cognitive optimization.</p>
      </div>
    </div>
  </EditorialSection>

  <EditorialSection
    title="Wellness TMS Clinics"
    intro="Verified providers offering Exomind and other wellness TMS protocols."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/>'
    tone="success"
    background="paper2"
  >
    <div id="clinics">
      {wellnessClinics.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {wellnessClinics.map(clinic => (
            <EditorialCard
              href={`/clinic/${clinic.slug}`}
              tag="Wellness · Verified"
              tagTone="success"
              title={clinic.name}
              description={`${clinic.address.city}, ${clinic.address.state} — ${(clinic.description || '').slice(0, 120)}${(clinic.description || '').length > 120 ? '…' : ''}`}
              size="lg"
            />
          ))}
        </div>
      ) : (
        <div style="background:var(--paper); border:1px solid var(--line); border-radius:1.5rem; padding:3rem; text-align:center;">
          <p style="font-size:15px; color:var(--muted); margin:0;">Wellness TMS clinic data is being compiled. Check back soon.</p>
        </div>
      )}
    </div>
  </EditorialSection>

  <EditorialSection
    title="Clinical vs Wellness TMS"
    intro="Both use magnetic stimulation, but the goals, regulation, and payment models differ."
    icon='<path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>'
    tone="accent"
    noBorder
  >
    <div id="compare" style="background:var(--paper2); border:1px solid var(--line); border-radius:1.5rem; overflow:hidden;">
      <div style="overflow-x:auto;">
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr style="background:var(--paper);">
              <th style="text-align:left; padding:1rem 1.25rem; font-family:'Instrument Serif', Georgia, serif; font-size:14px; color:var(--ink); border-bottom:1px solid var(--line);">Aspect</th>
              <th style="text-align:left; padding:1rem 1.25rem; font-family:'Instrument Serif', Georgia, serif; font-size:14px; color:var(--ink); border-bottom:1px solid var(--line);">Clinical TMS</th>
              <th style="text-align:left; padding:1rem 1.25rem; font-family:'Instrument Serif', Georgia, serif; font-size:14px; color:var(--ink); border-bottom:1px solid var(--line);">Wellness TMS</th>
            </tr>
          </thead>
          <tbody>
            <tr><td style="padding:1rem 1.25rem; color:var(--ink2); font-size:14px; font-weight:500; border-bottom:1px solid var(--line);">Diagnosis</td><td style="padding:1rem 1.25rem; color:var(--muted); font-size:14px; border-bottom:1px solid var(--line);">Required (MDD, OCD, etc.)</td><td style="padding:1rem 1.25rem; color:var(--muted); font-size:14px; border-bottom:1px solid var(--line);">Not required</td></tr>
            <tr><td style="padding:1rem 1.25rem; color:var(--ink2); font-size:14px; font-weight:500; border-bottom:1px solid var(--line);">FDA Status</td><td style="padding:1rem 1.25rem; color:var(--muted); font-size:14px; border-bottom:1px solid var(--line);">Cleared for specific conditions</td><td style="padding:1rem 1.25rem; color:var(--muted); font-size:14px; border-bottom:1px solid var(--line);">Not FDA-cleared</td></tr>
            <tr><td style="padding:1rem 1.25rem; color:var(--ink2); font-size:14px; font-weight:500; border-bottom:1px solid var(--line);">Insurance</td><td style="padding:1rem 1.25rem; color:var(--muted); font-size:14px; border-bottom:1px solid var(--line);">Often covered</td><td style="padding:1rem 1.25rem; color:var(--muted); font-size:14px; border-bottom:1px solid var(--line);">Self-pay only</td></tr>
            <tr><td style="padding:1rem 1.25rem; color:var(--ink2); font-size:14px; font-weight:500; border-bottom:1px solid var(--line);">Goal</td><td style="padding:1rem 1.25rem; color:var(--muted); font-size:14px; border-bottom:1px solid var(--line);">Treat specific condition</td><td style="padding:1rem 1.25rem; color:var(--muted); font-size:14px; border-bottom:1px solid var(--line);">Enhance cognitive performance</td></tr>
            <tr><td style="padding:1rem 1.25rem; color:var(--ink2); font-size:14px; font-weight:500;">Devices</td><td style="padding:1rem 1.25rem; color:var(--muted); font-size:14px;">NeuroStar, BrainsWay, MagVenture</td><td style="padding:1rem 1.25rem; color:var(--muted); font-size:14px;">Exomind, others</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </EditorialSection>

  <EditorialCTA
    title="Try wellness TMS."
    description="Find a verified wellness TMS clinic offering Exomind protocols and cognitive enhancement programs."
    ctas={[
      { label: "Browse Wellness Clinics", href: "#clinics" },
      { label: "Explore Clinical TMS", href: "/treatments/", variant: "outline" },
    ]}
  />
</main>

</Layout>
