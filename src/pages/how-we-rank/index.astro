---
import Layout from '../../layouts/Layout.astro';

const title = "How We Rank TMS Clinics | Our Methodology | TMS List";
const description = "Learn how TMS List ranks and scores clinics. Our transparent methodology considers verified status, patient reviews, doctor credentials, technology, insurance coverage, and more.";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "How We Rank TMS Clinics",
    "description": description,
    "publisher": {
        "@type": "Organization",
        "name": "TMS List",
        "url": "https://tmslist.com"
    }
});

const factors = [
    { name: "Patient Reviews", weight: 25, color: "violet", icon: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z", desc: "Aggregated patient ratings, review volume, recency, and sentiment analysis across multiple platforms." },
    { name: "Verified Status", weight: 20, color: "emerald", icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", desc: "Whether the clinic has claimed and verified their listing, confirming accuracy of contact details and services." },
    { name: "Doctor Credentials", weight: 20, color: "blue", icon: "M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z", desc: "Board certifications, specialty training, years of TMS experience, publications, and professional affiliations." },
    { name: "Technology & Equipment", weight: 15, color: "cyan", icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z", desc: "FDA-cleared devices used (NeuroStar, BrainsWay, MagVenture), protocol options, and equipment maintenance." },
    { name: "Insurance Coverage", weight: 10, color: "amber", icon: "M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z", desc: "Breadth of accepted insurance plans, Medicare/Medicaid participation, and financial assistance programs." },
    { name: "Response Time", weight: 5, color: "rose", icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z", desc: "How quickly the clinic responds to patient inquiries, appointment requests, and follow-up communications." },
    { name: "Years in Practice", weight: 5, color: "orange", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4", desc: "Clinic longevity, treatment volume, and track record of consistent patient outcomes over time." },
];

const colorMap: Record<string, { bg: string; text: string; bar: string; ring: string }> = {
    violet: { bg: 'bg-violet-50', text: 'text-violet-600', bar: 'bg-violet-500', ring: 'ring-violet-200' },
    emerald: { bg: 'bg-emerald-50', text: 'text-emerald-600', bar: 'bg-emerald-500', ring: 'ring-emerald-200' },
    blue: { bg: 'bg-blue-50', text: 'text-blue-600', bar: 'bg-blue-500', ring: 'ring-blue-200' },
    cyan: { bg: 'bg-cyan-50', text: 'text-cyan-600', bar: 'bg-cyan-500', ring: 'ring-cyan-200' },
    amber: { bg: 'bg-amber-50', text: 'text-amber-600', bar: 'bg-amber-500', ring: 'ring-amber-200' },
    rose: { bg: 'bg-rose-50', text: 'text-rose-600', bar: 'bg-rose-500', ring: 'ring-rose-200' },
    orange: { bg: 'bg-orange-50', text: 'text-orange-600', bar: 'bg-orange-500', ring: 'ring-orange-200' },
};
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "How We Rank", url: "/how-we-rank/" },
]}>
    <main>
        <!-- Hero -->
        <section class="relative bg-slate-950 overflow-hidden">
            <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
            <div class="absolute top-[-10%] right-[20%] w-[500px] h-[500px] bg-violet-600/12 rounded-full blur-[150px]"></div>
            <div class="absolute bottom-[5%] left-[10%] w-[350px] h-[350px] bg-cyan-500/8 rounded-full blur-[100px]"></div>

            <div class="container mx-auto px-4 pt-12 pb-20 lg:pt-16 lg:pb-28 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-500 mb-12" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-400 transition-colors">Home</a>
                    <span class="text-slate-700">/</span>
                    <span class="text-slate-300">How We Rank</span>
                </nav>

                <div class="max-w-3xl">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/5 border border-white/10 rounded-full mb-6">
                        <span class="flex h-2 w-2 rounded-full bg-emerald-400"></span>
                        <span class="text-xs font-semibold text-slate-300 tracking-wide">Full Transparency</span>
                    </div>
                    <h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-white leading-[0.95] mb-6">
                        How We<br/>
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-400 via-cyan-400 to-emerald-400">Rank Clinics</span>
                    </h1>
                    <p class="text-lg text-slate-400 leading-relaxed max-w-xl">
                        Our ranking methodology is built on data, not advertising dollars. Every clinic is scored across seven transparent criteria so you can find the best TMS provider with confidence.
                    </p>
                </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-16 bg-white" style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"></div>
        </section>

        <!-- Scoring Overview -->
        <section class="py-16 lg:py-24 bg-white">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="text-center mb-16">
                    <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 tracking-tight mb-4">Seven Pillars of Our Ranking</h2>
                    <p class="text-slate-500 max-w-2xl mx-auto">Each clinic receives a composite score from 0 to 100 based on weighted factors. Here is exactly how we calculate it.</p>
                </div>

                <!-- Visual Weight Breakdown -->
                <div class="mb-16">
                    <div class="flex rounded-2xl overflow-hidden h-6 shadow-inner">
                        {factors.map((f) => (
                            <div class={`${colorMap[f.color].bar} relative group`} style={`width: ${f.weight}%`}>
                                <div class="absolute -top-10 left-1/2 -translate-x-1/2 bg-slate-900 text-white text-xs font-bold px-2.5 py-1 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
                                    {f.name} ({f.weight}%)
                                </div>
                            </div>
                        ))}
                    </div>
                    <div class="flex flex-wrap justify-center gap-4 mt-6">
                        {factors.map((f) => (
                            <div class="flex items-center gap-2">
                                <div class={`w-3 h-3 rounded-sm ${colorMap[f.color].bar}`}></div>
                                <span class="text-xs text-slate-500 font-medium">{f.name} ({f.weight}%)</span>
                            </div>
                        ))}
                    </div>
                </div>

                <!-- Factor Cards -->
                <div class="space-y-6">
                    {factors.map((f, i) => (
                        <div class="bg-white rounded-2xl border border-slate-100 p-8 hover:shadow-md hover:border-slate-200 transition-all">
                            <div class="flex flex-col md:flex-row md:items-start gap-6">
                                <div class={`w-14 h-14 rounded-2xl ${colorMap[f.color].bg} ${colorMap[f.color].text} flex items-center justify-center shrink-0`}>
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={f.icon}/></svg>
                                </div>
                                <div class="flex-1">
                                    <div class="flex items-center gap-3 mb-2">
                                        <h3 class="text-xl font-bold text-slate-900">{f.name}</h3>
                                        <span class={`px-2.5 py-0.5 ${colorMap[f.color].bg} ${colorMap[f.color].text} text-xs font-bold rounded-full`}>{f.weight}% weight</span>
                                    </div>
                                    <p class="text-slate-500 leading-relaxed">{f.desc}</p>
                                </div>
                                <div class="shrink-0 w-24">
                                    <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
                                        <div class={`h-full ${colorMap[f.color].bar} rounded-full`} style={`width: ${f.weight * 4}%`}></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Trust & Transparency -->
        <section class="py-16 lg:py-24 bg-slate-50">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-bold text-slate-900 tracking-tight mb-4">Trust & Transparency</h2>
                    <p class="text-slate-500 max-w-2xl mx-auto">We believe patients deserve full transparency about how clinics are ranked and recommended.</p>
                </div>

                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <div class="bg-white rounded-2xl border border-slate-100 p-8">
                        <div class="w-12 h-12 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center mb-5">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">No Pay-to-Rank</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Clinics cannot pay for higher placement. Rankings are determined solely by our algorithmic scoring across all seven factors.</p>
                    </div>
                    <div class="bg-white rounded-2xl border border-slate-100 p-8">
                        <div class="w-12 h-12 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center mb-5">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">Updated Monthly</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Scores are recalculated monthly using the latest review data, verified credentials, and clinic activity to ensure accuracy.</p>
                    </div>
                    <div class="bg-white rounded-2xl border border-slate-100 p-8">
                        <div class="w-12 h-12 rounded-xl bg-violet-50 text-violet-600 flex items-center justify-center mb-5">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">Fully Auditable</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Every clinic profile shows the individual scores that contribute to their overall ranking so patients can evaluate for themselves.</p>
                    </div>
                    <div class="bg-white rounded-2xl border border-slate-100 p-8">
                        <div class="w-12 h-12 rounded-xl bg-amber-50 text-amber-600 flex items-center justify-center mb-5">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">Fraud Detection</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Our systems detect and filter fake reviews, suspicious patterns, and misleading credentials to protect the integrity of rankings.</p>
                    </div>
                    <div class="bg-white rounded-2xl border border-slate-100 p-8">
                        <div class="w-12 h-12 rounded-xl bg-cyan-50 text-cyan-600 flex items-center justify-center mb-5">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">Clinic Appeals</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Clinics can dispute their score and provide additional documentation. We review all appeals within 5 business days.</p>
                    </div>
                    <div class="bg-white rounded-2xl border border-slate-100 p-8">
                        <div class="w-12 h-12 rounded-xl bg-rose-50 text-rose-600 flex items-center justify-center mb-5">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                        </div>
                        <h3 class="text-lg font-bold text-slate-900 mb-2">Editorial Independence</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">Our editorial and ranking teams operate independently from our business team. Commercial relationships never influence scores.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- FAQ -->
        <section class="py-16 lg:py-24 bg-white">
            <div class="container mx-auto px-4 max-w-3xl">
                <h2 class="text-3xl font-bold text-slate-900 tracking-tight mb-10 text-center">Common Questions</h2>
                <div class="space-y-4">
                    <details class="group bg-white rounded-2xl border border-slate-100 overflow-hidden">
                        <summary class="p-6 cursor-pointer flex items-center justify-between font-semibold text-slate-900 hover:text-violet-600 transition-colors">
                            Can clinics pay to improve their ranking?
                            <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="px-6 pb-6 text-slate-500 leading-relaxed">No. TMS List rankings are purely algorithmic. While clinics can claim their listing and verify their information (which contributes to their verified status score), no amount of payment will influence ranking position. Sponsored listings are always clearly labeled.</div>
                    </details>
                    <details class="group bg-white rounded-2xl border border-slate-100 overflow-hidden">
                        <summary class="p-6 cursor-pointer flex items-center justify-between font-semibold text-slate-900 hover:text-violet-600 transition-colors">
                            How often are rankings updated?
                            <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="px-6 pb-6 text-slate-500 leading-relaxed">Rankings are recalculated on a monthly cycle. Review data is aggregated in near real-time, while credential verification and technology audits happen quarterly.</div>
                    </details>
                    <details class="group bg-white rounded-2xl border border-slate-100 overflow-hidden">
                        <summary class="p-6 cursor-pointer flex items-center justify-between font-semibold text-slate-900 hover:text-violet-600 transition-colors">
                            How can my clinic improve its score?
                            <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="px-6 pb-6 text-slate-500 leading-relaxed">Claim and verify your listing, encourage satisfied patients to leave reviews, keep your insurance and technology information current, and ensure your team responds promptly to inquiries. These are all measurable factors in our scoring system.</div>
                    </details>
                    <details class="group bg-white rounded-2xl border border-slate-100 overflow-hidden">
                        <summary class="p-6 cursor-pointer flex items-center justify-between font-semibold text-slate-900 hover:text-violet-600 transition-colors">
                            What if I believe my clinic's ranking is inaccurate?
                            <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </summary>
                        <div class="px-6 pb-6 text-slate-500 leading-relaxed">You can submit an appeal by contacting us at <a href="mailto:tmslistofficial@gmail.com?subject=Ranking Appeal" class="inline-flex items-center gap-2 px-4 py-2 bg-violet-600 hover:bg-violet-500 text-white text-sm font-semibold rounded-lg transition-colors">Email Us</a>. Include any supporting documentation such as updated credentials, corrected insurance information, or evidence of review fraud. We review all appeals within 5 business days.</div>
                    </details>
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="relative py-20 bg-slate-950 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-violet-600/10 via-transparent to-cyan-600/10"></div>
            <div class="container mx-auto px-4 text-center relative z-10">
                <p class="text-sm font-semibold text-violet-400 tracking-wider uppercase mb-4">Find Your Provider</p>
                <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4 tracking-tight">Ready to find a top-ranked clinic?</h2>
                <p class="text-slate-400 max-w-lg mx-auto mb-10">Browse our directory of verified TMS providers or take our candidacy quiz to see if TMS therapy is right for you.</p>
                <div class="flex items-center justify-center gap-4 flex-wrap">
                    <a href="/quiz/am-i-a-candidate/" class="px-8 py-4 bg-violet-600 hover:bg-violet-500 text-white font-semibold rounded-xl transition-colors shadow-lg shadow-violet-600/25">
                        Am I a Candidate?
                    </a>
                    <a href="/us/" class="px-8 py-4 bg-white/5 border border-white/10 hover:border-white/25 text-white font-semibold rounded-xl transition-all backdrop-blur">
                        Browse Clinics
                    </a>
                </div>
            </div>
        </section>
    </main>
</Layout>
