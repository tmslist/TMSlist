---
import Layout from '../../../../layouts/Layout.astro';
import ClinicCard from '../../../../components/ClinicCard.astro';
import { getClinicsByCountry } from '../../../../utils/dataHelpers';
import { t } from '../../utils/i18n';
import { COUNTRY_META } from '../../../../utils/countryData';
import { calculateClinicScore } from '../../../../utils/ranking';

export async function getStaticPaths() {
    const clinics = await getClinicsByCountry('AE');
    const regionCityMap = new Map<string, Map<string, typeof clinics>>();
    clinics.forEach(c => {
        if (!c.state || !c.city) return;
        if (!regionCityMap.has(c.state)) regionCityMap.set(c.state, new Map());
        const cityMap = regionCityMap.get(c.state)!;
        if (!cityMap.has(c.city)) cityMap.set(c.city, []);
        cityMap.get(c.city)!.push(c);
    });

    const paths: any[] = [];
    regionCityMap.forEach((cityMap, regionName) => {
        const regionSlug = regionName.toLowerCase().replace(/\s+/g, '-');
        cityMap.forEach((cityClinics, cityName) => {
            const citySlug = cityName.toLowerCase().replace(/\s+/g, '-').replace(/\./g, '');
            if (cityClinics.length > 0) {
                const sortedClinics = [...cityClinics].sort((a, b) => calculateClinicScore(b) - calculateClinicScore(a));
                paths.push({
                    params: { region: regionSlug, city: citySlug },
                    props: { regionName, regionSlug, cityName, clinics: sortedClinics },
                });
            }
        });
    });

    return paths;
}

const { regionName, regionSlug, cityName, clinics: cityClinics } = Astro.props;
const meta = COUNTRY_META['AE'];

const title = `TMS Clinics in ${cityName}, ${regionName} United Arab Emirates | Find Providers Near You`;
const description = `Compare ${cityClinics.length} TMS therapy clinics in ${cityName}, ${regionName}. View ratings, treatment technology, and book consultations.`;

const getRating = (clinic: any) => typeof clinic.rating === 'number' ? clinic.rating : clinic.rating?.aggregate || 4.5;

const citySchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `TMS Clinics in ${cityName}, ${regionName}, United Arab Emirates`,
    "description": description,
    "url": `https://tmslist.com/ae/${regionSlug}/${Astro.params.city}/`,
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": cityClinics.length,
        "itemListElement": cityClinics.slice(0, 10).map((c: any, i: number) => ({
            "@type": "ListItem",
            "position": i + 1,
            "item": {
                "@type": "MedicalClinic",
                "name": c.name,
                "url": `https://tmslist.com/clinic/${c.slug}`,
                "address": {
                    "@type": "PostalAddress",
                    "streetAddress": c.address,
                    "addressLocality": cityName,
                    "addressRegion": regionName,
                    "addressCountry": "AE"
                },
                "telephone": c.contact?.phone || c.phone,
                ...(getRating(c) > 0 ? {
                    "aggregateRating": {
                        "@type": "AggregateRating",
                        "ratingValue": getRating(c),
                        "reviewCount": typeof c.rating === 'object' ? c.rating?.count || 0 : c.review_count || 0
                    }
                } : {})
            }
        }))
    }
});
---

<Layout title={title} description={description} schema={citySchema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "United Arab Emirates", url: "/ae/" },
    { name: regionName, url: `/ae/${regionSlug}/` },
    { name: cityName, url: `/ae/${regionSlug}/${Astro.params.city}/` },
]}>
    <main class="min-h-screen">
        <section class="relative bg-white border-b border-slate-100 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
            <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <a href="/ae/" class="hover:text-violet-600 transition-colors">United Arab Emirates</a>
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <a href={`/ae/${regionSlug}/`} class="hover:text-violet-600 transition-colors">{regionName}</a>
                    <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    <span class="text-slate-700 font-medium">{cityName}</span>
                </nav>

                <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-slate-900 mb-6">
                    TMS <span class="text-violet-600">Clinics</span> in {cityName}
                </h1>
                <p class="text-xl text-slate-500 max-w-3xl mb-8">
                    Compare {cityClinics.length} TMS therapy {cityClinics.length === 1 ? 'clinic' : 'clinics'} in {cityName}, {regionName}.
                    View ratings, treatment options, and find the right provider for you.
                </p>
            </div>
        </section>

        <section class="bg-white border-b border-gray-100 py-6">
            <div class="container mx-auto px-6">
                <div class="flex flex-wrap justify-center gap-8 md:gap-16">
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-violet-600">{cityClinics.length}</div>
                        <div class="text-sm text-gray-500 font-medium">TMS Clinics</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-violet-600">{cityClinics.reduce((acc: number, c: any) => acc + (c.doctors_data?.length || 0), 0)}</div>
                        <div class="text-sm text-gray-500 font-medium">Specialists</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-violet-600">{cityClinics.filter((c: any) => c.verified).length}</div>
                        <div class="text-sm text-gray-500 font-medium">Verified</div>
                    </div>
                </div>
            </div>
        </section>

        <section class="py-16">
            <div class="container mx-auto px-6">
                <h2 class="text-3xl font-semibold text-gray-900 mb-10">All TMS Clinics in {cityName}</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {cityClinics.map((clinic: any) => (
                        <ClinicCard clinic={clinic} />
                    ))}
                </div>
            </div>
        </section>

        <section class="py-16 bg-white">
            <div class="container mx-auto px-6 max-w-4xl">
                <h2 class="text-3xl font-semibold text-gray-900 mb-8">TMS Therapy in {cityName}, {regionName}</h2>
                <div class="prose prose-lg max-w-none text-gray-600">
                    <p>
                        {cityName}, {regionName} is home to {cityClinics.length} TMS (Transcranial Magnetic Stimulation) therapy {cityClinics.length === 1 ? 'clinic' : 'clinics'}, offering advanced treatment for depression, anxiety, OCD, and other mental health conditions.
                    </p>
                    <h3 class="text-xl font-semibold text-gray-900 mt-8 mb-4">Costs and Insurance in United Arab Emirates</h3>
                    <p>{meta.insuranceNote} Sessions typically cost {meta.sessionCostRange}.</p>
                    <h3 class="text-xl font-semibold text-gray-900 mt-8 mb-4">What to Expect</h3>
                    <p>
                        Your TMS journey begins with a psychiatric consultation to evaluate suitability. A standard course involves 20-30 sessions over 4-6 weeks, with each session lasting 20-40 minutes depending on the protocol.
                    </p>
                </div>
            </div>
        </section>

        <section class="py-16 bg-gradient-to-r from-violet-600 to-blue-600">
            <div class="container mx-auto px-6 text-center">
                <h2 class="text-3xl font-semibold text-slate-900 mb-6">Find Your TMS Clinic in {cityName}</h2>
                <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
                    Compare {cityClinics.length} verified {cityClinics.length === 1 ? 'clinic' : 'clinics'} and start your journey to mental wellness.
                </p>
                <a href="/quiz/am-i-a-candidate/" class="inline-block px-8 py-4 bg-white text-violet-600 font-semibold rounded-xl hover:bg-gray-100 transition-colors shadow-[0_4px_20px_rgb(0,0,0,0.03)]">
                    Am I a Candidate?
                </a>
            </div>
        </section>
    </main>
</Layout>
