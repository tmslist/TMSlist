---
import Layout from '../../layouts/Layout.astro';
import { getClinicsByCountry, COUNTRY_NAMES } from '../../utils/dataHelpers';
import { COUNTRY_META } from '../../utils/countryData';
import { t } from '../../utils/i18n';
const locale = 'es' as const;

const countryCode = 'ES';
const meta = COUNTRY_META[countryCode];
const clinics = await getClinicsByCountry(countryCode);
const totalClinics = clinics.length;

const regionMap = new Map<string, number>();
clinics.forEach(c => {
    if (!c.state) return;
    regionMap.set(c.state, (regionMap.get(c.state) || 0) + 1);
});

const regions = [...regionMap.entries()]
    .map(([name, count]) => ({
        name,
        slug: name.toLowerCase().replace(/\s+/g, '-'),
        count,
    }))
    .sort((a, b) => a.name.localeCompare(b.name));

const title = `TMS Therapy Clinics in Spain | ${totalClinics} Verified Providers`;
const description = `Browse ${totalClinics} TMS therapy clinics across ${regions.length} regions in Spain. ${meta.seoDescription}`;

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "TMS Therapy Clinics in Spain",
    "description": description,
    "url": "https://tmslist.com/es/",
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": regions.length,
        "itemListElement": regions.map((r, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "name": `TMS Clinics in ${r.name}, Spain`,
            "url": `https://tmslist.com/es/${r.slug}/`
        }))
    }
});
---

<Layout title={title} description={description} schema={schema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Spain", url: "/es/" },
]}>
    <main>
        <!-- Hero Section -->
        <section class="relative bg-white border-b border-slate-100 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
            <div
                class="ai-hero-image absolute inset-0 opacity-20"
                data-subject="Spain"
                data-type="city"
                data-cache-key="ai-img:city:es"
                data-alt={`Illustration of Spain`}
            >
                <div class="ai-img-placeholder absolute inset-0"></div>
                <img class="ai-img-result hidden w-full h-full object-cover" alt="" loading="lazy" />
                <div class="ai-img-fallback hidden"></div>
            </div>
            <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8" aria-label="Breadcrumb">
            <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            <span class="text-slate-700 font-medium">Spain</span>
        </nav>
                <div class="max-w-3xl">
                    <h1 class="text-3xl font-semibold mb-2">TMS Therapy in <span class="text-violet-600">Spain</span></h1>
                    <p class="text-gray-600 mb-8 max-w-3xl">Browse {totalClinics} verified TMS providers across {regions.length} regions in Spain. TMS is {meta.tmsStatus}, with sessions costing {meta.sessionCostRange} per session.</p>
                </div>
            </div>
        </section>

        <!-- Content -->
        <div class="container mx-auto px-4 py-8">

        <!-- Key Facts -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-violet-600">{totalClinics}</div>
                <div class="text-sm text-gray-500 font-medium">Clinics</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-violet-600">{regions.length}</div>
                <div class="text-sm text-gray-500 font-medium">Regions</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-violet-600">{meta.publicHealthSystem}</div>
                <div class="text-sm text-gray-500 font-medium">Public Health</div>
            </div>
            <div class="bg-white rounded-xl border border-gray-100 p-4 text-center shadow-sm">
                <div class="text-2xl font-semibold text-violet-600">{meta.sessionCostRange}</div>
                <div class="text-sm text-gray-500 font-medium">Per Session</div>
            </div>
        </div>

        <div class="flex items-center mb-8">
            <h2 class="text-2xl font-semibold text-gray-900">Explorar por región</h2>
            <div class="ml-4 h-px flex-1 bg-gray-200"></div>
            <span class="ml-4 text-sm font-medium text-gray-400">{regions.length} regions</span>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {regions.map((region) => (
                <a href={`/es/${region.slug}/`} class="block p-4 bg-white rounded-lg border border-gray-200 hover:border-violet-500 hover:shadow-md transition-all group">
                    <span class="text-lg font-medium text-gray-800 group-hover:text-violet-600">{region.name}</span>
                    <span class="block text-sm text-gray-500 mt-1">{region.count} {region.count === 1 ? 'clinic' : 'clinics'}</span>
                </a>
            ))}
        </div>

        <!-- SEO Content -->
        <section class="mt-16 pt-12 border-t border-gray-100 prose prose-lg max-w-none text-gray-600">
            <h2>La terapia TMS en España</h2>
            <p>España dispone de TMS en los principales hospitales universitarios, incluyendo el Hospital Clínic de Barcelona, el Hospital Universitario 12 de Octubre en Madrid y el Hospital La Fe en Valencia. Las clínicas privadas en Madrid y Barcelona ofrecen protocolos avanzados. La investigación española en TMS se ha centrado en la depresión resistente al tratamiento y aplicaciones para la fibromialgia.</p>
            <p>La terapia TMS está disponible en hospitales universitarios y clínicas privadas de toda España. Madrid, Barcelona, Valencia y Sevilla ofrecen protocolos rTMS y Deep TMS para la depresión resistente al tratamiento.</p>
            <h3>Seguros y costes</h3>
            <p>El acceso al Sistema Nacional de Salud (SNS) para TMS está limitado a programas hospitalarios específicos y ensayos clínicos. Los seguros privados (Sanitas, Adeslas, MAPFRE) pueden cubrir la TMS con autorización previa. La mayoría de los pacientes en clínicas privadas pagan {meta.sessionCostRange} por sesión.</p>
            <p>El coste típico de una sesión de TMS en España oscila entre {meta.sessionCostRange}. Los tratamientos suelen incluir 20-30 sesiones durante 4-6 semanas.</p>
            <h3>Cómo elegir una clínica TMS en España</h3>
            <p>Al seleccionar un proveedor de TMS en España, considere la acreditación de la clínica, la experiencia del psiquiatra tratante, la tecnología TMS utilizada y si su seguro cubre el tratamiento. Nuestro directorio le ayuda a comparar clínicas por región y encontrar el proveedor adecuado.</p>
            <h3>Recursos relacionados</h3>
            <ul>
                <li><a href="/treatments/">Condiciones tratadas con TMS</a> — depresión, ansiedad, TOC, TEPT y más</li>
                <li><a href="/technology/">Guía de tecnología TMS</a> — comparar NeuroStar, BrainsWay, MagVenture</li>
                <li><a href="/research/">Investigación TMS</a> — últimos clinical studies and outcomes</li>
            </ul>
        </section>
        </div>
    </main>
</Layout>

<script>
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;
    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }
    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });
</script>
