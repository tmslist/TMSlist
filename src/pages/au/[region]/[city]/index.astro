---
import Layout from '../../../../layouts/Layout.astro';
import ClinicCard from '../../../../components/ClinicCard.astro';
import { getClinicsByCountry, COUNTRY_NAMES, getClinicPhoto } from '../../../../utils/dataHelpers';
import { COUNTRY_META } from '../../../../utils/countryData';
import { calculateClinicScore } from '../../../../utils/ranking';
import LocationSEOContent from '../../../../components/LocationSEOContent.astro';

const { region, city } = Astro.params;
const regionSlug = region!;

const allClinics = await getClinicsByCountry('AU');

// Find region name from slug
const regionMatch = allClinics.find(c => c.state && c.state.toLowerCase().replace(/\s+/g, '-') === regionSlug);
if (!regionMatch) return Astro.redirect("/au/");
const regionName = regionMatch.state;

// Find city name from slug
const cityMatch = allClinics.find(c => c.state === regionName && c.city && c.city.toLowerCase().replace(/\s+/g, '-').replace(/\./g, '') === city);
if (!cityMatch) return Astro.redirect(`/au/${regionSlug}/`);
const cityName = cityMatch.city;

const cityClinics = allClinics.filter(c => c.state === regionName && c.city === cityName);
const meta = COUNTRY_META['AU'];

const title = `TMS Clinics in ${cityName}, ${regionName} | TMS List`;
const description = `Compare ${cityClinics.length} TMS therapy clinics in ${cityName}, ${regionName}. View ratings, Medicare rebate eligibility, TMS technology, and book consultations.`;

const getRating = (clinic: any) => typeof clinic.rating === 'number' ? clinic.rating : clinic.rating?.aggregate || 4.5;

const citySchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `TMS Clinics in ${cityName}, ${regionName}, Australia`,
    "description": description,
    "url": `https://tmslist.com/au/${regionSlug}/${Astro.params.city}/`,
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": cityClinics.length,
        "itemListElement": cityClinics.slice(0, 10).map((c: any, i: number) => ({
            "@type": "ListItem",
            "position": i + 1,
            "item": {
                "@type": "MedicalClinic",
                "name": c.name,
                "url": `https://tmslist.com/clinic/${c.slug}`,
                "address": {
                    "@type": "PostalAddress",
                    "streetAddress": c.address,
                    "addressLocality": cityName,
                    "addressRegion": regionName,
                    "addressCountry": "AU"
                },
                "telephone": c.contact?.phone || c.phone,
                ...(getRating(c) > 0 ? {
                    "aggregateRating": {
                        "@type": "AggregateRating",
                        "ratingValue": getRating(c),
                        "reviewCount": typeof c.rating === 'object' ? c.rating?.count || 0 : 50
                    }
                } : {})
            }
        }))
    }
});
---

<Layout title={title} description={description} schema={citySchema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Australia", url: "/au/" },
    { name: regionName, url: `/au/${regionSlug}/` },
    { name: cityName, url: `/au/${regionSlug}/${Astro.params.city}/` },
]}>
    <main class="min-h-screen">
        <!-- Hero Section -->
        <section class="relative bg-white border-b border-slate-100 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
            <div
              class="ai-hero-image absolute inset-0 opacity-20"
              data-subject={`${cityName}, ${regionName}`}
              data-type="city"
              data-cache-key={`ai-img:city:${cityName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}-${regionName.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}
              data-alt={`Watercolor illustration of ${cityName}, ${regionName}`}
            >
              <div class="ai-img-placeholder absolute inset-0"></div>
              <img class="ai-img-result hidden w-full h-full object-cover" alt="TMS clinic illustration" />
              <div class="ai-img-fallback hidden"></div>
            </div>
            <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8 flex-wrap" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                    <span class="text-slate-300">/</span>
                    <a href="/au/" class="hover:text-violet-600 transition-colors">Australia</a>
                    <span class="text-slate-300">/</span>
                    <a href={`/au/${regionSlug}/`} class="hover:text-violet-600 transition-colors">{regionName}</a>
                    <span class="text-slate-300">/</span>
                    <span class="text-slate-700 font-medium">{cityName}</span>
                </nav>

                <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-slate-900 mb-6">
                    TMS <span class="text-violet-600">Clinics</span> in {cityName}
                </h1>
                <p class="text-xl text-slate-500 max-w-3xl mb-8">
                    Compare {cityClinics.length} TGA-approved TMS therapy clinics in {cityName}, {regionName}.
                    View ratings, Medicare rebate eligibility, and find the right provider for you.
                </p>
            </div>
        </section>

        <!-- Stats Bar -->
        <section class="bg-white border-b border-gray-100 py-6">
            <div class="container mx-auto px-6">
                <div class="flex flex-wrap justify-center gap-8 md:gap-16">
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-violet-600">{cityClinics.length}</div>
                        <div class="text-sm text-gray-500 font-medium">TMS Clinics</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-violet-600">{cityClinics.reduce((acc: number, c: any) => acc + (c.doctors_data?.length || 0), 0)}</div>
                        <div class="text-sm text-gray-500 font-medium">Specialists</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-violet-600">{cityClinics.filter((c: any) => c.verified).length}</div>
                        <div class="text-sm text-gray-500 font-medium">Verified</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Clinics Grid -->
        <section class="py-16">
            <div class="container mx-auto px-6">
                <h2 class="text-3xl font-semibold text-gray-900 mb-10">All TMS Clinics in {cityName}</h2>

                <div class="space-y-6">
                    {cityClinics.map((clinic: any, index: number) => (
                        <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all">
                            <div class="p-6 md:p-8">
                                <div class="flex flex-col lg:flex-row lg:items-start gap-6">
                                    <!-- Clinic Image -->
                                    <div class="lg:w-64 lg:shrink-0">
                                        <img
                                            src={getClinicPhoto(clinic)}
                                            alt={clinic.name}
                                            class="w-full h-48 lg:h-40 object-cover rounded-xl"
                                        />
                                    </div>

                                    <!-- Clinic Info -->
                                    <div class="flex-1">
                                        <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                                            <div>
                                                <div class="flex items-center gap-2 mb-2">
                                                    {clinic.verified && (
                                                        <span class="px-2 py-1 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full">Verified</span>
                                                    )}
                                                    <span class="px-2 py-1 bg-violet-100 text-violet-700 text-xs font-semibold rounded-full">#{index + 1} in {cityName}</span>
                                                </div>
                                                <h3 class="text-2xl font-semibold text-gray-900 hover:text-violet-600 transition-colors">
                                                    <a href={`/clinic/${clinic.slug}`}>{clinic.name}</a>
                                                </h3>
                                                <p class="text-gray-500">{clinic.address}, {clinic.city}, {clinic.state}</p>
                                            </div>
                                            <div class="text-right">
                                                <div class="flex items-center gap-2">
                                                    <span class="text-2xl font-semibold tracking-tight text-gray-900">{getRating(clinic).toFixed(1)}</span>
                                                    <div class="text-yellow-400">★★★★★</div>
                                                </div>
                                                <p class="text-sm text-gray-500">{typeof clinic.rating === 'object' ? clinic.rating.count : clinic.review_count || 0} reviews</p>
                                            </div>
                                        </div>

                                        <p class="text-gray-600 mb-4 line-clamp-2">{clinic.description_long}</p>

                                        <div class="flex flex-wrap gap-2 mb-4">
                                            {(clinic.machines || []).slice(0, 3).map((m: string) => (
                                                <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm font-medium">{m}</span>
                                            ))}
                                        </div>

                                        <div class="flex flex-wrap items-center gap-4 pt-4 border-t border-gray-100">
                                            <a href={`/clinic/${clinic.slug}`} class="px-6 py-2.5 bg-violet-600 text-white font-semibold rounded-lg hover:bg-violet-700 transition-colors">
                                                View Clinic
                                            </a>
                                            {(clinic.contact?.phone || clinic.phone) && (
                                                <button data-request-callback data-clinic-name={clinic.name} data-clinic-id={clinic.slug}
                                                    class="px-6 py-2.5 border-2 border-violet-600 text-violet-600 font-semibold rounded-lg hover:bg-violet-50 transition-colors cursor-pointer">
                                                    Request Callback
                                                </button>
                                            )}
                                            <span class="text-sm text-gray-500">{(clinic.doctors_data || []).length} specialists on staff</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </section>

        <LocationSEOContent
            type="city"
            locationName={cityName}
            stateName={regionName}
            clinicCount={cityClinics.length}
            countryCode="AU"
        />
    </main>
</Layout>

<script>
  // AI city hero image with localStorage cache
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;

    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }

    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });
</script>
