---
import Layout from '../../../../layouts/Layout.astro';
import ClinicCard from '../../../../components/ClinicCard.astro';
import { getClinicsByCountry, COUNTRY_NAMES } from '../../../../utils/dataHelpers';
import { COUNTRY_META } from '../../../../utils/countryData';
import { calculateClinicScore } from '../../../../utils/ranking';

export async function getStaticPaths() {
    const countryCode = 'AU';
    const clinics = getClinicsByCountry(countryCode);

    // Group by state -> city
    const regionCityMap = new Map<string, Map<string, typeof clinics>>();
    clinics.forEach(c => {
        if (!c.state || !c.city) return;
        if (!regionCityMap.has(c.state)) regionCityMap.set(c.state, new Map());
        const cityMap = regionCityMap.get(c.state)!;
        if (!cityMap.has(c.city)) cityMap.set(c.city, []);
        cityMap.get(c.city)!.push(c);
    });

    const paths: any[] = [];
    regionCityMap.forEach((cityMap, regionName) => {
        const regionSlug = regionName.toLowerCase().replace(/\s+/g, '-');
        cityMap.forEach((cityClinics, cityName) => {
            const citySlug = cityName.toLowerCase().replace(/\s+/g, '-').replace(/\./g, '');
            if (cityClinics.length > 0) {
                // Sort by clinic score
                const sortedClinics = [...cityClinics].sort((a, b) => calculateClinicScore(b) - calculateClinicScore(a));
                paths.push({
                    params: { region: regionSlug, city: citySlug },
                    props: {
                        regionName,
                        regionSlug,
                        cityName,
                        clinics: sortedClinics,
                    },
                });
            }
        });
    });

    return paths;
}

const { regionName, regionSlug, cityName, clinics: cityClinics } = Astro.props;
const meta = COUNTRY_META['AU'];

const title = `TMS Clinics in ${cityName}, ${regionName} Australia | Find Medicare-Rebated Providers`;
const description = `Compare ${cityClinics.length} TMS therapy clinics in ${cityName}, ${regionName}. View ratings, Medicare rebate eligibility, TMS technology, and book consultations.`;

const getRating = (clinic: any) => typeof clinic.rating === 'number' ? clinic.rating : clinic.rating?.aggregate || 4.5;

const citySchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `TMS Clinics in ${cityName}, ${regionName}, Australia`,
    "description": description,
    "url": `https://tmslist.com/au/${regionSlug}/${Astro.params.city}/`,
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": cityClinics.length,
        "itemListElement": cityClinics.slice(0, 10).map((c: any, i: number) => ({
            "@type": "ListItem",
            "position": i + 1,
            "item": {
                "@type": "MedicalClinic",
                "name": c.name,
                "url": `https://tmslist.com/clinic/${c.slug}`,
                "address": {
                    "@type": "PostalAddress",
                    "streetAddress": c.address,
                    "addressLocality": cityName,
                    "addressRegion": regionName,
                    "addressCountry": "AU"
                },
                "telephone": c.contact?.phone || c.phone,
                ...(getRating(c) > 0 ? {
                    "aggregateRating": {
                        "@type": "AggregateRating",
                        "ratingValue": getRating(c),
                        "reviewCount": typeof c.rating === 'object' ? c.rating?.count || 50 : 50
                    }
                } : {})
            }
        }))
    }
});
---

<Layout title={title} description={description} schema={citySchema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Australia", url: "/au/" },
    { name: regionName, url: `/au/${regionSlug}/` },
    { name: cityName, url: `/au/${regionSlug}/${Astro.params.city}/` },
]}>
    <main class="bg-gray-50 min-h-screen">
        <!-- Hero Section -->
        <section class="bg-gradient-to-br from-slate-900 via-indigo-900 to-blue-900 py-20">
            <div class="container mx-auto px-6">
                <nav class="flex text-sm text-blue-200 mb-8" aria-label="Breadcrumb">
                    <ol class="inline-flex items-center space-x-2">
                        <li><a href="/" class="hover:text-slate-900">Home</a></li>
                        <li><span class="mx-2">/</span></li>
                        <li><a href="/au/" class="hover:text-slate-900">Australia</a></li>
                        <li><span class="mx-2">/</span></li>
                        <li><a href={`/au/${regionSlug}/`} class="hover:text-slate-900">{regionName}</a></li>
                        <li><span class="mx-2">/</span></li>
                        <li class="text-slate-900 font-medium">{cityName}</li>
                    </ol>
                </nav>

                <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-slate-900 mb-6">
                    TMS <span class="text-cyan-400">Clinics</span> in {cityName}
                </h1>
                <p class="text-xl text-blue-100 max-w-3xl mb-8">
                    Compare {cityClinics.length} TGA-approved TMS therapy clinics in {cityName}, {regionName}.
                    View ratings, Medicare rebate eligibility, and find the right provider for you.
                </p>
            </div>
        </section>

        <!-- Stats Bar -->
        <section class="bg-white border-b border-gray-100 py-6">
            <div class="container mx-auto px-6">
                <div class="flex flex-wrap justify-center gap-8 md:gap-16">
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-indigo-600">{cityClinics.length}</div>
                        <div class="text-sm text-gray-500 font-medium">TMS Clinics</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-indigo-600">{cityClinics.reduce((acc: number, c: any) => acc + (c.doctors_data?.length || 0), 0)}</div>
                        <div class="text-sm text-gray-500 font-medium">Specialists</div>
                    </div>
                    <div class="text-center">
                        <div class="text-3xl font-semibold tracking-tight text-indigo-600">{cityClinics.filter((c: any) => c.verified).length}</div>
                        <div class="text-sm text-gray-500 font-medium">Verified</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Clinics Grid -->
        <section class="py-16">
            <div class="container mx-auto px-6">
                <h2 class="text-3xl font-semibold text-gray-900 mb-10">All TMS Clinics in {cityName}</h2>

                <div class="space-y-6">
                    {cityClinics.map((clinic: any, index: number) => (
                        <article class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-[0_4px_20px_rgb(0,0,0,0.03)] transition-all">
                            <div class="p-6 md:p-8">
                                <div class="flex flex-col lg:flex-row lg:items-start gap-6">
                                    <!-- Clinic Image -->
                                    <div class="lg:w-64 lg:shrink-0">
                                        <img
                                            src={clinic.hero_image_url || '/images/tms_chair_luxury_1769446442231.png'}
                                            alt={clinic.name}
                                            class="w-full h-48 lg:h-40 object-cover rounded-xl"
                                        />
                                    </div>

                                    <!-- Clinic Info -->
                                    <div class="flex-1">
                                        <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                                            <div>
                                                <div class="flex items-center gap-2 mb-2">
                                                    {clinic.verified && (
                                                        <span class="px-2 py-1 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full">Verified</span>
                                                    )}
                                                    <span class="px-2 py-1 bg-indigo-100 text-indigo-700 text-xs font-semibold rounded-full">#{index + 1} in {cityName}</span>
                                                </div>
                                                <h3 class="text-2xl font-semibold text-gray-900 hover:text-indigo-600 transition-colors">
                                                    <a href={`/clinic/${clinic.slug}`}>{clinic.name}</a>
                                                </h3>
                                                <p class="text-gray-500">{clinic.address}, {clinic.city}, {clinic.state}</p>
                                            </div>
                                            <div class="text-right">
                                                <div class="flex items-center gap-2">
                                                    <span class="text-2xl font-semibold tracking-tight text-gray-900">{getRating(clinic).toFixed(1)}</span>
                                                    <div class="text-yellow-400">★★★★★</div>
                                                </div>
                                                <p class="text-sm text-gray-500">{typeof clinic.rating === 'object' ? clinic.rating.count : clinic.review_count || 50} reviews</p>
                                            </div>
                                        </div>

                                        <p class="text-gray-600 mb-4 line-clamp-2">{clinic.description_long}</p>

                                        <div class="flex flex-wrap gap-2 mb-4">
                                            {(clinic.machines || []).slice(0, 3).map((m: string) => (
                                                <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm font-medium">{m}</span>
                                            ))}
                                        </div>

                                        <div class="flex flex-wrap items-center gap-4 pt-4 border-t border-gray-100">
                                            <a href={`/clinic/${clinic.slug}`} class="px-6 py-2.5 bg-indigo-600 text-white font-semibold rounded-lg hover:bg-indigo-700 transition-colors">
                                                View Clinic
                                            </a>
                                            {(clinic.contact?.phone || clinic.phone) && (
                                                <a href={`tel:${clinic.contact?.phone || clinic.phone}`} class="px-6 py-2.5 border-2 border-indigo-600 text-indigo-600 font-semibold rounded-lg hover:bg-indigo-50 transition-colors">
                                                    Call Now
                                                </a>
                                            )}
                                            <span class="text-sm text-gray-500">{(clinic.doctors_data || []).length} specialists on staff</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </article>
                    ))}
                </div>
            </div>
        </section>

        <!-- SEO Content Section -->
        <section class="py-16 bg-white">
            <div class="container mx-auto px-6 max-w-4xl">
                <h2 class="text-3xl font-semibold text-gray-900 mb-8">TMS Therapy in {cityName}, {regionName}</h2>

                <div class="prose prose-lg max-w-none text-gray-600">
                    <p>
                        {cityName}, {regionName} is home to {cityClinics.length} TGA-approved TMS (Transcranial Magnetic Stimulation) therapy clinics, offering advanced treatment for depression, anxiety, OCD, and other mental health conditions.
                        Our directory helps you compare facilities, check Medicare rebate eligibility, and find the right provider.
                    </p>

                    <h3 class="text-xl font-semibold text-gray-900 mt-8 mb-4">Medicare Rebates for TMS in {cityName}</h3>
                    <p>
                        Since November 2021, Medicare Australia provides rebates for TMS treatment of treatment-resistant depression. To access rebated TMS in {cityName}, you need a GP referral to a psychiatrist who will assess your eligibility. MBS item numbers cover initial assessments, treatment planning, and a standard course of TMS sessions. After the Medicare rebate, out-of-pocket costs typically range from {meta.sessionCostRange} per session.
                    </p>

                    <h3 class="text-xl font-semibold text-gray-900 mt-8 mb-4">What to Expect at a {cityName} TMS Clinic</h3>
                    <p>
                        Your TMS journey typically begins with a psychiatric consultation to evaluate your treatment history and suitability for TMS. If you're a candidate, the clinic will perform brain mapping to identify the optimal stimulation site. A standard course involves 20-30 sessions over 4-6 weeks, with each session lasting 20-40 minutes depending on the protocol used.
                    </p>

                    <h3 class="text-xl font-semibold text-gray-900 mt-8 mb-4">Choosing the Right TMS Provider</h3>
                    <p>
                        When selecting a TMS clinic in {cityName}, consider the TMS technology available (standard rTMS, theta burst, or Deep TMS), the treating psychiatrist's experience with TMS, whether the clinic bulk-bills or requires a gap payment, and patient reviews. All clinics listed in our directory use TGA-approved devices.
                    </p>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="py-16 bg-gradient-to-r from-indigo-600 to-blue-600">
            <div class="container mx-auto px-6 text-center">
                <h2 class="text-3xl font-semibold text-slate-900 mb-6">Find Your TMS Clinic in {cityName}</h2>
                <p class="text-xl text-blue-100 mb-8 max-w-2xl mx-auto">
                    Compare {cityClinics.length} clinics and start your journey to mental wellness with Medicare-rebated TMS therapy.
                </p>
                <a href="/quiz/am-i-a-candidate/" class="inline-block px-8 py-4 bg-white text-indigo-600 font-semibold rounded-xl hover:bg-gray-100 transition-colors shadow-[0_4px_20px_rgb(0,0,0,0.03)]">
                    Am I a Candidate?
                </a>
            </div>
        </section>
    </main>
</Layout>
