---
export const prerender = false;
import RegionTreatmentPage from "../../../../components/RegionTreatmentPage.astro";

Astro.response.headers.set(
    "Cache-Control",
    "public, max-age=300, s-maxage=86400, stale-while-revalidate=604800",
);

const { region, treatment } = Astro.params;
---
<RegionTreatmentPage
    countryCode="AU"
    countryName="Australia"
    countryUrlPrefix="au"
    regionSlug={region!}
    treatmentSlug={treatment!}
/>
