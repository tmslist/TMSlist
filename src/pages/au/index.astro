---
import Layout from '../../layouts/Layout.astro';
import { getClinicsByCountry, COUNTRY_NAMES } from '../../utils/dataHelpers';
import { t } from '../../utils/i18n';
import { COUNTRY_META } from '../../utils/countryData';

const countryCode = 'AU';
const countryName = COUNTRY_NAMES[countryCode];
const meta = COUNTRY_META[countryCode];
const clinics = await getClinicsByCountry(countryCode);
const totalClinics = clinics.length;

// Group clinics by state/region
const stateMap = new Map<string, number>();
clinics.forEach(c => {
    if (!c.state) return;
    stateMap.set(c.state, (stateMap.get(c.state) || 0) + 1);
});

const states = [...stateMap.entries()]
    .map(([name, count]) => ({
        name,
        slug: name.toLowerCase().replace(/\s+/g, '-'),
        count,
    }))
    .sort((a, b) => a.name.localeCompare(b.name));

const title = `TMS Therapy Clinics in Australia | Medicare-Rebated Providers | TMS List`;
const description = `Browse ${totalClinics}+ TMS therapy clinics across Australia. Compare Medicare-rebated providers in ${states.length} states and territories including NSW, Victoria, and Queensland.`;

const collectionSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "TMS Therapy Clinics in Australia",
    "description": description,
    "url": "https://tmslist.com/au/",
    "mainEntity": {
        "@type": "ItemList",
        "numberOfItems": states.length,
        "itemListElement": states.map((s, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "name": `TMS Clinics in ${s.name}`,
            "url": `https://tmslist.com/au/${s.slug}/`
        }))
    }
});
---

<Layout title={title} description={description} schema={collectionSchema} breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Australia", url: "/au/" },
]}>
    <main>
        <section class="relative bg-white border-b border-slate-100 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-violet-50/60 via-white to-blue-50/40 pointer-events-none"></div>
            <div class="absolute top-0 right-0 w-[500px] h-[400px] bg-violet-500/5 rounded-full blur-[100px]"></div>
            <div
              class="ai-hero-image absolute inset-0 opacity-20"
              data-subject="Australia"
              data-type="city"
              data-cache-key="ai-img:city:au"
              data-alt="Illustration of Australia"
            >
              <div class="ai-img-placeholder absolute inset-0"></div>
              <img class="ai-img-result hidden w-full h-full object-cover" alt="TMS clinic illustration" />
              <div class="ai-img-fallback hidden"></div>
            </div>
            <div class="container mx-auto px-4 py-14 lg:py-18 relative z-10">
                <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8" aria-label="Breadcrumb">
                    <a href="/" class="hover:text-violet-600 transition-colors">Home</a>
                    <span class="text-slate-300">/</span>
                    <span class="text-slate-700 font-medium">Australia</span>
                </nav>
                <div class="max-w-3xl">
                    <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-slate-900 mb-4 leading-tight">
                        TMS Therapy in <span class="text-violet-600">Australia</span>
                    </h1>
                    <p class="text-lg text-slate-500 leading-relaxed">Browse {totalClinics}+ TGA-approved TMS providers across {states.length} states and territories. Australia offers Medicare rebates for TMS therapy, making it one of the most accessible countries for treatment.</p>
                </div>
            </div>
        </section>
        <section class="py-12"><div class="container mx-auto px-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {states.map((state) => (
                <a href={`/au/${state.slug}/`} class="block bg-white rounded-2xl border border-slate-100 p-5 hover:border-violet-200 hover:shadow-[0_4px_20px_rgb(0,0,0,0.04)] transition-all group">
                    <span class="text-lg font-medium text-gray-800 group-hover:text-violet-600">{state.name}</span>
                    <span class="block text-sm text-gray-500 mt-1">{state.count} {state.count === 1 ? 'clinic' : 'clinics'}</span>
                </a>
            ))}
        </div>
        </div></section>

        <!-- SEO Content -->
        <section class="mt-16 pt-12 border-t border-gray-100 prose prose-lg max-w-none text-gray-600">
            <h2>About TMS Therapy in Australia</h2>
            <p>{meta.aboutContent}</p>

            <h3>Medicare Rebates for TMS</h3>
            <p>{meta.insuranceNote}</p>

            <h3>How to Access TMS Therapy in Australia</h3>
            <p>To access Medicare-rebated TMS therapy in Australia, you need a referral from your GP to a psychiatrist who oversees TMS treatment. The psychiatrist must confirm that you have treatment-resistant depression, typically defined as inadequate response to at least two antidepressant medications. Once approved, MBS item numbers cover a standard course of TMS treatment.</p>

            <h3>Finding the Right Clinic</h3>
            <p>When choosing a TMS clinic in Australia, consider the <a href="/technology/">TMS technology</a> used (rTMS vs Deep TMS), the experience of the treating psychiatrist, proximity to your location, and session costs after Medicare rebate. Our directory helps you compare clinics across all Australian states and territories.</p>

            <h3>Related Resources</h3>
            <ul>
                <li><a href="/treatments/">Conditions Treated with TMS</a> -- depression, anxiety, OCD, PTSD and more</li>
                <li><a href="/technology/">TMS Technology Guide</a> -- compare NeuroStar, BrainsWay, MagVenture</li>
                <li><a href="/insurance/">Insurance & Coverage for TMS</a> -- understanding your coverage options</li>
                <li><a href="/specialists/">Find a TMS Specialist</a> -- board-certified psychiatrists</li>
            </ul>
        </section>
    </main>
</Layout>

<script>
  document.querySelectorAll('.ai-hero-image').forEach(async (container) => {
    const el = container as HTMLElement;
    const subject = el.dataset.subject;
    const type = el.dataset.type;
    const cacheKey = el.dataset.cacheKey!;
    const img = el.querySelector('.ai-img-result') as HTMLImageElement;
    if (!subject || !type || !img) return;

    const cached = localStorage.getItem(cacheKey);
    if (cached) {
      try {
        const { image, ts } = JSON.parse(cached);
        if (Date.now() - ts < 7 * 24 * 60 * 60 * 1000 && image) {
          img.src = image;
          img.classList.remove('hidden');
          return;
        }
      } catch { localStorage.removeItem(cacheKey); }
    }

    try {
      const params = new URLSearchParams({ type, subject });
      const res = await fetch(`/api/ai/generate-image?${params}`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.image) return;
      localStorage.setItem(cacheKey, JSON.stringify({ image: data.image, ts: Date.now() }));
      img.src = data.image;
      img.classList.remove('hidden');
    } catch {}
  });
</script>
