---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import AdminSidebar from "../../components/react/AdminSidebar";
import AdminRedirectManager from "../../components/react/AdminRedirectManager";
import { getSessionFromRequest, hasRole } from "../../utils/auth";
const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, 'admin')) return Astro.redirect("/admin/login");
---
<Layout title="Redirects | TMS List Admin" noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <AdminSidebar client:load currentPage="redirects" userEmail={session!.email} />
    <main class="flex-1 lg:ml-64 py-8"><div class="container mx-auto px-4 max-w-7xl"><AdminRedirectManager client:load /></div></main>
  </div>
</Layout>