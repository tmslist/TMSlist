---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import AdminSidebar from "../../components/react/AdminSidebar";
import AdminBulkRunner from "../../components/react/AdminBulkRunner";
import { getSessionFromRequest, hasRole } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, 'admin')) return Astro.redirect("/admin/login");
---

<Layout title="Bulk Operations | TMS List Admin" noindex={true}>
  <div class="flex min-h-screen bg-[var(--paper2)]">
    <AdminSidebar client:load currentPage="bulk" userEmail={session!.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-5xl">
        <AdminBulkRunner client:load />
      </div>
    </main>
  </div>
</Layout>
