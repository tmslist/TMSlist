---
export const prerender = false;

import Layout from "../../../layouts/Layout.astro";
import { getSessionFromRequest, hasRole } from "../../../utils/auth";
import LeadsDashboard from "../../../components/react/LeadsDashboard";

const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, 'admin', 'editor')) {
  return Astro.redirect("/admin/login");
}
---

<Layout title="Lead Management | TMS List Admin" noindex={true}>
  <LeadsDashboard client:load userEmail={session!.email} />
</Layout>
