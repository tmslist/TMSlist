---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import AdminReviews from "../../components/react/AdminReviews";
import { getSessionFromRequest, hasRole } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, 'admin', 'editor')) {
  return Astro.redirect("/admin/login");
}
---

<Layout title="Moderate Reviews | TMS List Admin">
  <main class="bg-gray-50 min-h-screen py-8">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="flex items-center justify-between mb-8">
        <div>
          <nav class="text-sm text-gray-500 mb-1">
            <a href="/admin/dashboard" class="hover:text-indigo-600">Dashboard</a>
            <span class="mx-2">/</span>
            <span class="text-gray-900">Reviews</span>
          </nav>
          <h1 class="text-2xl font-semibold text-gray-900">Moderate Reviews</h1>
        </div>
      </div>

      <AdminReviews client:load />
    </div>
  </main>
</Layout>
