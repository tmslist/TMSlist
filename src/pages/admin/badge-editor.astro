---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import AdminSidebar from "../../components/react/AdminSidebar";
import AdminBadgeEditor from "../../components/react/AdminBadgeEditor";
import { getSessionFromRequest, hasRole } from "../../utils/auth";
const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, 'admin')) return Astro.redirect("/admin/login");
---
<Layout title="Badge Editor | TMS List Admin" noindex={true}>
  <div class="flex min-h-screen bg-gray-50 dark:bg-slate-900">
    <AdminSidebar client:load currentPage="badge-editor" userEmail={session!.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-7xl">
        <AdminBadgeEditor client:load />
      </div>
    </main>
  </div>
</Layout>
