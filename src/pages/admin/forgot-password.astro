---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import ForgotPasswordForm from "../../components/react/ForgotPasswordForm";
import { getSessionFromRequest } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (session) {
  return Astro.redirect("/admin/dashboard");
}
---

<Layout title="Forgot Password | TMS List Admin" noindex={true}>
  <main class="container mx-auto px-4 py-12">
    <ForgotPasswordForm client:load />
  </main>
</Layout>
