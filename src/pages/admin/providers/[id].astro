---
export const prerender = false;

import Layout from "../../../layouts/Layout.astro";
import AdminSidebar from "../../../components/react/AdminSidebar";
import AdminProviderDetail from "../../../components/react/AdminProviderDetail";
import { getSessionFromRequest, hasRole } from "../../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, 'admin', 'editor')) {
  return Astro.redirect("/admin/login");
}

const { id } = Astro.params;
if (!id) return Astro.redirect("/admin/providers");
---

<Layout title="Provider Detail | TMS List Admin" noindex={true}>
  <div class="flex min-h-screen bg-[var(--paper2)]">
    <AdminSidebar client:load currentPage="providers" userEmail={session!.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-5xl">
        <AdminProviderDetail client:idle providerId={id} />
      </div>
    </main>
  </div>
</Layout>
