---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import AdminSidebar from "../../components/react/AdminSidebar";
import AdminLegalDocs from "../../components/react/AdminLegalDocs";
import { getSessionFromRequest, hasRole } from "../../utils/auth";
const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, 'admin')) return Astro.redirect("/admin/login");
---
<Layout title="Legal Documents | TMS List Admin" noindex={true}>
  <div class="flex min-h-screen bg-gray-50 dark:bg-gray-900">
    <AdminSidebar client:load currentPage="legal-docs" userEmail={session!.email} />
    <main class="flex-1 lg:ml-64 py-8"><div class="container mx-auto px-4 max-w-7xl"><AdminLegalDocs client:load /></div></main>
  </div>
</Layout>
