---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import AdminSidebar from "../../components/react/AdminSidebar";
import AdminUsers from "../../components/react/AdminUsers";
import { getSessionFromRequest, hasRole } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, 'admin')) {
  return Astro.redirect("/admin/login");
}
---

<Layout title="User Management | TMS List Admin" noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <AdminSidebar client:load currentPage="users" userEmail={session!.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="mb-8">
          <h1 class="text-2xl font-semibold text-gray-900">User Management</h1>
          <p class="text-gray-500 mt-1">Manage admin, editor, and clinic owner accounts</p>
        </div>
        <AdminUsers client:idle currentUserId={session!.userId} />
      </div>
    </main>
  </div>
</Layout>
