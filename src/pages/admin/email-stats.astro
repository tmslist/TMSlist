---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import AdminSidebar from "../../components/react/AdminSidebar";
import { getSessionFromRequest, hasRole } from "../../utils/auth";
import { getEmailStats } from "../../db/queries";
import { db } from "../../db";
import { emailLogs, bulkEmailCampaigns } from "../../db/schema";
import { desc, eq, sql } from "drizzle-orm";

const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, "admin", "editor")) {
  return Astro.redirect("/admin/login");
}

let stats = { total: 0, delivered: 0, opened: 0, clicked: 0, bounced: 0, recentSends: 0 };
let campaigns: any[] = [];

try {
  [stats] = await Promise.all([getEmailStats()]);
} catch {}

try {
  campaigns = await db.select().from(bulkEmailCampaigns).orderBy(desc(bulkEmailCampaigns.createdAt)).limit(50);
} catch {}
---

<Layout title="Email Stats | TMS List Admin" noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <AdminSidebar client:load currentPage="email-stats" userEmail={session!.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="mb-6">
          <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Email Stats</h1>
          <p class="text-gray-500 mt-1">Email delivery, open, click, and bounce tracking</p>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Total Sent</p>
            <p class="text-2xl font-semibold text-gray-900 mt-1">{stats.total.toLocaleString()}</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Delivered</p>
            <p class="text-2xl font-semibold text-green-600 mt-1">{stats.delivered.toLocaleString()}</p>
            <p class="text-xs text-gray-400 mt-1">{stats.total > 0 ? Math.round(stats.delivered / stats.total * 100) : 0}% rate</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Opened</p>
            <p class="text-2xl font-semibold text-blue-600 mt-1">{stats.opened.toLocaleString()}</p>
            <p class="text-xs text-gray-400 mt-1">{stats.delivered > 0 ? Math.round(stats.opened / stats.delivered * 100) : 0}% of delivered</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Clicked</p>
            <p class="text-2xl font-semibold text-violet-600 mt-1">{stats.clicked.toLocaleString()}</p>
            <p class="text-xs text-gray-400 mt-1">{stats.delivered > 0 ? Math.round(stats.clicked / stats.delivered * 100) : 0}% of delivered</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Bounced</p>
            <p class="text-2xl font-semibold text-red-500 mt-1">{stats.bounced.toLocaleString()}</p>
            <p class="text-xs text-gray-400 mt-1">{stats.total > 0 ? Math.round(stats.bounced / stats.total * 100) : 0}% rate</p>
          </div>
        </div>

        <!-- Delivery Rate Progress Bars -->
        <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm mb-8">
          <h3 class="text-sm font-medium text-gray-700 mb-4">30-Day Performance</h3>
          <p class="text-xs text-gray-500 mb-3">{stats.recentSends} emails sent in last 30 days</p>

          <div class="space-y-4">
            <div>
              <div class="flex justify-between text-xs mb-1">
                <span class="text-gray-600">Delivery Rate</span>
                <span class="font-medium text-gray-700">{stats.total > 0 ? Math.round(stats.delivered / stats.total * 100) : 0}%</span>
              </div>
              <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full bg-green-500 rounded-full" style={`width: ${stats.total > 0 ? Math.round(stats.delivered / stats.total * 100) : 0}%`}></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-xs mb-1">
                <span class="text-gray-600">Open Rate</span>
                <span class="font-medium text-gray-700">{stats.delivered > 0 ? Math.round(stats.opened / stats.delivered * 100) : 0}%</span>
              </div>
              <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full bg-blue-500 rounded-full" style={`width: ${stats.delivered > 0 ? Math.round(stats.opened / stats.delivered * 100) : 0}%`}></div>
              </div>
            </div>
            <div>
              <div class="flex justify-between text-xs mb-1">
                <span class="text-gray-600">Click Rate</span>
                <span class="font-medium text-gray-700">{stats.delivered > 0 ? Math.round(stats.clicked / stats.delivered * 100) : 0}%</span>
              </div>
              <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full bg-violet-500 rounded-full" style={`width: ${stats.delivered > 0 ? Math.round(stats.clicked / stats.delivered * 100) : 0}%`}></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Campaign History -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-sm font-medium text-gray-700">Email Campaigns</h3>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Campaign</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                  <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Sent</th>
                  <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Failed</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sent Date</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
                {campaigns.length === 0 ? (
                  <tr>
                    <td colspan="5" class="px-6 py-12 text-center text-gray-400">No campaigns yet</td>
                  </tr>
                ) : (
                  campaigns.map((c) => (
                    <tr class="hover:bg-gray-50">
                      <td class="px-6 py-4 text-sm font-medium text-gray-900">{c.name}</td>
                      <td class="px-6 py-4">
                        <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${
                          c.status === 'sent' ? 'bg-green-100 text-green-700' :
                          c.status === 'draft' ? 'bg-gray-100 text-gray-600' :
                          c.status === 'failed' ? 'bg-red-100 text-red-700' :
                          'bg-amber-100 text-amber-700'
                        }`}>
                          {c.status}
                        </span>
                      </td>
                      <td class="px-6 py-4 text-sm text-gray-700 text-right">{c.sentCount ?? 0}</td>
                      <td class="px-6 py-4 text-sm text-red-600 text-right">{c.failedCount ?? 0}</td>
                      <td class="px-6 py-4 text-xs text-gray-500 whitespace-nowrap">
                        {c.sentAt ? new Date(c.sentAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '-'}
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>