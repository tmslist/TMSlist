---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import AdminSidebar from "../../components/react/AdminSidebar";
import AdminTreatments from "../../components/react/AdminTreatments";
import { getSessionFromRequest, hasRole } from "../../utils/auth";

const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, 'admin', 'editor')) {
  return Astro.redirect("/admin/login");
}
---
<Layout title="Treatments | TMS List Admin" noindex={true}>
  <div class="flex min-h-screen bg-[var(--paper2)]">
    <AdminSidebar client:load currentPage="treatments" userEmail={session!.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="mb-8">
          <h1 class="text-2xl font-semibold text-[var(--ink)]">Treatments</h1>
          <p class="text-[var(--muted)] mt-1">Manage treatment types and protocols in the TMS directory</p>
        </div>
        <AdminTreatments client:load />
      </div>
    </main>
  </div>
</Layout>