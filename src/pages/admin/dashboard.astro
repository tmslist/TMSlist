---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import AdminSidebar from "../../components/react/AdminSidebar";
import { getSessionFromRequest, hasRole } from "../../utils/auth";
import { getDashboardStats, getLeadStats } from "../../db/queries";

const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, 'admin', 'editor')) {
  return Astro.redirect("/admin/login");
}

let stats = { clinics: 0, doctors: 0, reviews: 0, leads: 0 };
let leadStats: Record<string, number> = { total: 0 };

try {
  [stats, leadStats] = await Promise.all([
    getDashboardStats(),
    getLeadStats(),
  ]);
} catch {
  // DB not connected yet
}
---

<Layout title="Admin Dashboard | TMS List" noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <AdminSidebar client:load currentPage="dashboard" userEmail={session!.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="mb-8">
          <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Dashboard</h1>
          <p class="text-gray-500 mt-1">Welcome back{session?.email ? `, ${session.email.split('@')[0]}` : ''}</p>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Total Clinics</p>
            <p class="text-3xl font-semibold text-gray-900 mt-2">{stats.clinics}</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Doctors</p>
            <p class="text-3xl font-semibold text-gray-900 mt-2">{stats.doctors}</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Reviews</p>
            <p class="text-3xl font-semibold text-amber-600 mt-2">{stats.reviews}</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Total Leads</p>
            <p class="text-3xl font-semibold text-violet-600 mt-2">{stats.leads}</p>
          </div>
        </div>

        <!-- Quick Actions -->
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Quick Actions</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
          <a href="/admin/clinics/" class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:shadow-md transition-shadow group">
            <div class="w-10 h-10 bg-violet-100 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <p class="font-semibold text-gray-900 group-hover:text-violet-600 transition-colors">Clinics</p>
            <p class="text-sm text-gray-500">Manage listings</p>
          </a>

          <a href="/admin/doctors/" class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:shadow-md transition-shadow group">
            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <p class="font-semibold text-gray-900 group-hover:text-blue-600 transition-colors">Doctors</p>
            <p class="text-sm text-gray-500">Manage profiles</p>
          </a>

          <a href="/admin/reviews/" class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:shadow-md transition-shadow group">
            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <p class="font-semibold text-gray-900 group-hover:text-amber-600 transition-colors">Reviews</p>
            <p class="text-sm text-gray-500">Moderate reviews</p>
          </a>

          <a href="/admin/content/" class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:shadow-md transition-shadow group">
            <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center mb-3">
              <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <p class="font-semibold text-gray-900 group-hover:text-emerald-600 transition-colors">Content</p>
            <p class="text-sm text-gray-500">FAQ & treatments</p>
          </a>
        </div>

        <!-- Lead Breakdown -->
        <h2 class="text-xl font-semibold text-gray-900 mb-4">Lead Breakdown</h2>
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Count</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              {Object.entries(leadStats).filter(([k]) => k !== 'total').map(([type, count]) => (
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 text-sm text-gray-900 capitalize">{type.replace(/_/g, ' ')}</td>
                  <td class="px-6 py-4 text-sm text-gray-600 text-right font-medium">{count}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</Layout>
