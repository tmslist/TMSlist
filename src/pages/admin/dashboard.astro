---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { getSessionFromRequest, hasRole } from "../../utils/auth";
import { getLeadStats } from "../../db/queries";
import { getClinicCount } from "../../db/queries";
import { getDoctorCount } from "../../db/queries";

const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, 'admin', 'editor')) {
  return Astro.redirect("/admin/login");
}

let stats = { total: 0 };
let clinicCount = 0;
let doctorCount = 0;

try {
  [stats, clinicCount, doctorCount] = await Promise.all([
    getLeadStats(),
    getClinicCount(),
    getDoctorCount(),
  ]);
} catch {
  // DB not connected yet — show empty dashboard
}
---

<Layout title="Admin Dashboard | TMS List" noindex={true}>
  <main class="container mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-semibold text-gray-900">Dashboard</h1>
        <p class="text-gray-500 mt-1">Welcome, {session?.email}</p>
      </div>
      <form method="POST" action="/api/auth/logout">
        <button type="submit" class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">
          Sign Out
        </button>
      </form>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
        <p class="text-sm font-medium text-gray-500">Total Clinics</p>
        <p class="text-3xl font-semibold text-gray-900 mt-2">{clinicCount}</p>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
        <p class="text-sm font-medium text-gray-500">Doctors</p>
        <p class="text-3xl font-semibold text-gray-900 mt-2">{doctorCount}</p>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
        <p class="text-sm font-medium text-gray-500">Total Leads</p>
        <p class="text-3xl font-semibold text-indigo-600 mt-2">{stats.total || 0}</p>
      </div>
      <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
        <p class="text-sm font-medium text-gray-500">Specialist Enquiries</p>
        <p class="text-3xl font-semibold text-emerald-600 mt-2">{stats.specialist_enquiry || 0}</p>
      </div>
    </div>

    <!-- Quick Actions -->
    <h2 class="text-xl font-semibold text-gray-900 mb-4">Quick Actions</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
      <a href="/admin/clinics" class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm hover:shadow-md transition-shadow group">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-indigo-100 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors">Manage Clinics</p>
            <p class="text-sm text-gray-500">Verify, edit, and review clinics</p>
          </div>
        </div>
      </a>

      <a href="/admin/reviews" class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm hover:shadow-md transition-shadow group">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 group-hover:text-amber-600 transition-colors">Moderate Reviews</p>
            <p class="text-sm text-gray-500">Approve or reject pending reviews</p>
          </div>
        </div>
      </a>

      <a href="/admin/leads-view" class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm hover:shadow-md transition-shadow group">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 group-hover:text-emerald-600 transition-colors">View Leads</p>
            <p class="text-sm text-gray-500">Browse and export lead submissions</p>
          </div>
        </div>
      </a>
    </div>

    <!-- Lead Breakdown -->
    <h2 class="text-xl font-semibold text-gray-900 mb-4">Lead Breakdown</h2>
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Count</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          {Object.entries(stats).filter(([k]) => k !== 'total').map(([type, count]) => (
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 text-sm text-gray-900 capitalize">{type.replace(/_/g, ' ')}</td>
              <td class="px-6 py-4 text-sm text-gray-600 text-right font-medium">{count}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </main>
</Layout>
