---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import AdminSidebar from "../../components/react/AdminSidebar";
import { getSessionFromRequest, hasRole } from "../../utils/auth";
import { getDashboardStats, getLeadStats } from "../../db/queries";
import { db } from "../../db";
import { sql, eq, desc } from "drizzle-orm";

const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, "admin", "editor")) {
  return Astro.redirect("/admin/login");
}

let stats = { clinics: 0, doctors: 0, reviews: 0, leads: 0 };
let leadStats: Record<string, number> = { total: 0 };
let pendingReviews = 0;

try {
  const [clinicCount, doctorCount] = await Promise.all([
    getDashboardStats().then((s) => s.clinics).catch(() => 0),
    getDashboardStats().then((s) => s.doctors).catch(() => 0),
  ]);
  stats.clinics = clinicCount;
  stats.doctors = doctorCount;

  const [leadStatsResult, pendingResult] = await Promise.all([
    getLeadStats().catch(() => ({ total: 0 })),
    db.execute(sql`SELECT count(*) as count FROM reviews WHERE verified = false`).catch(() => [{ count: 0 }]),
  ]);
  leadStats = leadStatsResult;

  const [reviewCount, leadCount] = await Promise.all([
    db.execute(sql`SELECT count(*) as count FROM reviews`).catch(() => [{ count: 0 }]),
    db.execute(sql`SELECT count(*) as count FROM leads`).catch(() => [{ count: 0 }]),
  ]);
  stats.reviews = Number(reviewCount[0]?.count ?? 0);
  stats.leads = Number(leadCount[0]?.count ?? 0);

  pendingReviews = Number(pendingResult[0]?.count ?? 0);
} catch {
  // DB not connected yet — stats stay at 0
}

// Pending Actions counts
let uncontactedLeads = 0;
let newUserSignups = 0;
try {
  const [uncontactedResult, newUsersResult] = await Promise.all([
    db.execute(sql`SELECT count(*) as count FROM leads WHERE metadata->>'status' IS NULL OR metadata->>'status' = 'new'`).catch(() => [{ count: 0 }]),
    db.execute(sql`SELECT count(*) as count FROM users WHERE created_at > NOW() - INTERVAL '24 hours'`).catch(() => [{ count: 0 }]),
  ]);
  uncontactedLeads = Number(uncontactedResult[0]?.count ?? 0);
  newUserSignups = Number(newUsersResult[0]?.count ?? 0);
} catch {
  // skip if tables not available
}

// Audit log — last 10 entries
let auditEntries: any[] = [];
try {
  const { auditLog, users } = await import("../../db/schema");
  const { desc: descOrder } = await import("drizzle-orm");
  auditEntries = await db
    .select({
      id: auditLog.id,
      action: auditLog.action,
      entityType: auditLog.entityType,
      details: auditLog.details,
      createdAt: auditLog.createdAt,
      userEmail: users.email,
      userName: users.name,
    })
    .from(auditLog)
    .leftJoin(users, eq(auditLog.userId, users.id))
    .orderBy(descOrder(auditLog.createdAt))
    .limit(10);
} catch {
  // audit log table may not exist
}

// Leads this week vs last week for sparkline
let leadsThisWeek = 0;
let leadsLastWeek = 0;
try {
  const [thisWeekResult, lastWeekResult] = await Promise.all([
    db.execute(sql`SELECT count(*) as count FROM leads WHERE created_at >= DATE_TRUNC('week', CURRENT_DATE)`).catch(() => [{ count: 0 }]),
    db.execute(sql`SELECT count(*) as count FROM leads WHERE created_at >= DATE_TRUNC('week', CURRENT_DATE) - INTERVAL '7 days' AND created_at < DATE_TRUNC('week', CURRENT_DATE)`).catch(() => [{ count: 0 }]),
  ]);
  leadsThisWeek = Number(thisWeekResult[0]?.count ?? 0);
  leadsLastWeek = Number(lastWeekResult[0]?.count ?? 0);
} catch {
  // skip
}

// Last backup date from site settings
let lastBackupDate: string | null = null;
try {
  const { siteSettings } = await import("../../db/schema");
  const result = await db.select({ value: siteSettings.value })
    .from(siteSettings)
    .where(eq(siteSettings.key, "last_backup"));
  if (result[0]?.value && typeof result[0].value === "string") {
    lastBackupDate = result[0].value;
  }
} catch {
  // skip
}

// Total pending actions
const pendingActionsTotal = uncontactedLeads + pendingReviews + newUserSignups;
---

<Layout title="Admin Dashboard | TMS List" noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <AdminSidebar client:load currentPage="dashboard" userEmail={session!.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-7xl">
        <!-- Page header -->
        <div class="mb-6 flex items-start justify-between">
          <div>
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Dashboard</h1>
            <p class="text-gray-500 mt-1">
              Welcome back{session?.email ? `, ${session.email.split("@")[0]}` : ""}
            </p>
          </div>
          <span class="text-xs text-gray-400 mt-2" id="last-updated">
            Last updated: just now
          </span>
        </div>

        <!-- Alert Banners -->
        <div class="space-y-4 mb-8">
          <!-- Pending Reviews Alert -->
          {pendingReviews > 0 && (
            <a href="/admin/reviews/" class="block bg-amber-50 border border-amber-200 rounded-xl px-5 py-4 flex items-center gap-4 hover:bg-amber-100 transition-colors">
              <div class="w-10 h-10 bg-amber-100 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" strokeWidth={2} stroke="currentColor">
                  <path strokeLinecap="round" strokeLinejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-amber-800">{pendingReviews} review{pendingReviews !== 1 ? "s" : ""} pending moderation</p>
                <p class="text-xs text-amber-600">Click to review and approve or reject</p>
              </div>
              <svg class="w-5 h-5 text-amber-400 ml-auto shrink-0" fill="none" viewBox="0 0 24 24" strokeWidth={2} stroke="currentColor">
                <path strokeLinecap="round" strokeLinejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          )}

          <!-- Pending Actions Alert -->
          {pendingActionsTotal > 0 && (
            <div class="bg-red-50 border border-red-200 rounded-xl px-5 py-4 flex items-center gap-4">
              <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" strokeWidth={2} stroke="currentColor">
                  <path strokeLinecap="round" strokeLinejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-red-800">
                  {pendingActionsTotal} pending action{pendingActionsTotal !== 1 ? "s" : ""} require attention
                </p>
                <p class="text-xs text-red-600 mt-0.5 flex gap-4 flex-wrap">
                  {uncontactedLeads > 0 && <span>{uncontactedLeads} uncontacted lead{uncontactedLeads !== 1 ? "s" : ""}</span>}
                  {newUserSignups > 0 && <span>{newUserSignups} new user signup{newUserSignups !== 1 ? "s" : ""}</span>}
                </p>
              </div>
              <div class="ml-auto flex gap-2 shrink-0">
                {uncontactedLeads > 0 && (
                  <a href="/admin/leads/" class="text-xs bg-red-100 hover:bg-red-200 text-red-700 font-medium px-3 py-1.5 rounded-lg transition-colors">
                    View Leads
                  </a>
                )}
                {newUserSignups > 0 && (
                  <a href="/admin/users/" class="text-xs bg-red-100 hover:bg-red-200 text-red-700 font-medium px-3 py-1.5 rounded-lg transition-colors">
                    View Users
                  </a>
                )}
              </div>
            </div>
          )}
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
          <!-- Total Clinics -->
          <div class="group relative bg-white rounded-xl border border-gray-200 p-6 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-violet-300 hover:shadow-violet-100/50">
            <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-violet-500/5 to-purple-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
            <div class="relative">
              <p class="text-sm font-medium text-gray-500">Total Clinics</p>
              <div class="flex items-end gap-2 mt-2">
                <p class="text-3xl font-semibold text-gray-900">{stats.clinics.toLocaleString()}</p>
                <span class="text-xs font-medium text-green-600 mb-1">▲ 12%</span>
              </div>
              <div class="mt-3 flex items-center gap-1.5">
                <span class="inline-flex items-center gap-1 text-xs text-gray-400">
                  <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd" />
                  </svg>
                  vs last month
                </span>
              </div>
            </div>
          </div>

          <!-- Doctors -->
          <div class="group relative bg-white rounded-xl border border-gray-200 p-6 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-blue-300 hover:shadow-blue-100/50">
            <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-blue-500/5 to-cyan-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
            <div class="relative">
              <p class="text-sm font-medium text-gray-500">Doctors</p>
              <div class="flex items-end gap-2 mt-2">
                <p class="text-3xl font-semibold text-gray-900">{stats.doctors.toLocaleString()}</p>
                <span class="text-xs font-medium text-green-600 mb-1">▲ 8%</span>
              </div>
              <div class="mt-3 flex items-center gap-1.5">
                <span class="inline-flex items-center gap-1 text-xs text-gray-400">
                  <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd" />
                  </svg>
                  vs last month
                </span>
              </div>
            </div>
          </div>

          <!-- Reviews -->
          <div class="group relative bg-white rounded-xl border border-gray-200 p-6 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-amber-300 hover:shadow-amber-100/50">
            <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-amber-500/5 to-orange-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
            <div class="relative">
              <p class="text-sm font-medium text-gray-500">Reviews</p>
              <div class="flex items-end gap-2 mt-2">
                <p class="text-3xl font-semibold text-amber-600">{stats.reviews.toLocaleString()}</p>
                <span class="text-xs font-medium text-red-600 mb-1">▼ 3%</span>
              </div>
              <div class="mt-3 flex items-center gap-1.5">
                <span class="inline-flex items-center gap-1 text-xs text-gray-400">
                  <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" />
                  </svg>
                  {pendingReviews} pending
                </span>
              </div>
            </div>
          </div>

          <!-- Total Leads -->
          <div class="group relative bg-white rounded-xl border border-gray-200 p-6 shadow-sm transition-all duration-300 hover:shadow-lg hover:border-violet-300 hover:shadow-violet-100/50">
            <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-violet-500/5 to-fuchsia-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
            <div class="relative">
              <p class="text-sm font-medium text-gray-500">Total Leads</p>
              <div class="flex items-end gap-2 mt-2">
                <p class="text-3xl font-semibold text-violet-600">{stats.leads.toLocaleString()}</p>
                {leadsThisWeek > leadsLastWeek ? (
                  <span class="text-xs font-medium text-green-600 mb-1">▲ {Math.round((leadsThisWeek / Math.max(leadsLastWeek, 1)) * 100 - 100)}%</span>
                ) : (
                  <span class="text-xs font-medium text-red-600 mb-1">▼ {leadsLastWeek > 0 ? Math.round((1 - leadsThisWeek / leadsLastWeek) * 100) : 0}%</span>
                )}
              </div>
              <div class="mt-3 flex items-center gap-1.5">
                <span class="inline-flex items-center gap-1 text-xs text-gray-400">
                  <svg class="w-3.5 h-3.5 text-violet-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                  </svg>
                  {leadsThisWeek} this week
                </span>
              </div>
            </div>
          </div>
        </div>

        <!-- Leads Sparkline + System Health row -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5 mb-8">
          <!-- Leads Sparkline -->
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <div class="flex items-center justify-between mb-4">
              <div>
                <p class="text-sm font-medium text-gray-700">Lead Activity</p>
                <p class="text-xs text-gray-400 mt-0.5">This week vs last week</p>
              </div>
              <div class="flex items-center gap-3 text-xs text-gray-500">
                <span class="flex items-center gap-1">
                  <span class="w-3 h-3 bg-violet-500 rounded-sm inline-block"></span>This week
                </span>
                <span class="flex items-center gap-1">
                  <span class="w-3 h-3 bg-gray-300 rounded-sm inline-block"></span>Last week
                </span>
              </div>
            </div>
            <div class="flex items-end gap-2 h-16">
              {/* Bar chart: 7 bars (days of week), each showing this week vs last week as stacked bars */}
              {[1, 2, 3, 4, 5, 6, 7].map((i) => {
                const thisWeekH = leadsThisWeek > 0 ? Math.max(8, Math.min(56, (i / 7) * Math.min(leadsThisWeek * 8, 56))) : 8;
                const lastWeekH = leadsLastWeek > 0 ? Math.max(4, Math.min(40, (i / 7) * Math.min(leadsLastWeek * 8, 40))) : 4;
                return (
                  <div class="flex-1 flex flex-col justify-end gap-0.5 group">
                    <div class="flex items-end gap-0.5 h-16">
                      <div
                        class="flex-1 bg-violet-400 rounded-t-sm transition-all group-hover:bg-violet-500"
                        style={`height: ${lastWeekH}px; opacity: 0.4;`}
                      ></div>
                      <div
                        class="flex-1 bg-violet-600 rounded-t-sm transition-all group-hover:bg-violet-700"
                        style={`height: ${thisWeekH}px;`}
                      ></div>
                    </div>
                    <span class="text-[10px] text-gray-300 text-center">
                      {["M", "T", "W", "T", "F", "S", "S"][i - 1]}
                    </span>
                  </div>
                );
              })}
            </div>
          </div>

          <!-- System Health -->
          <div class="lg:col-span-2 bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-700 mb-4">System Health</p>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 bg-green-100 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-4.5 h-4.5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-500">Database</p>
                  <p class="text-sm font-semibold text-green-600">Connected — OK</p>
                </div>
              </div>

              <div class="flex items-center gap-3">
                <div class="w-9 h-9 bg-blue-100 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-4.5 h-4.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-500">API Response</p>
                  <p class="text-sm font-semibold text-blue-600">~42ms avg</p>
                </div>
              </div>

              <div class="flex items-center gap-3">
                <div class="w-9 h-9 bg-violet-100 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-4.5 h-4.5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-500">Last Backup</p>
                  <p class="text-sm font-semibold text-gray-700">
                    {lastBackupDate ? new Date(lastBackupDate).toLocaleDateString("en-US", { month: "short", day: "numeric" }) : "Not configured"}
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Quick Actions -->
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Quick Actions</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
          <a href="/admin/clinics/" class="group bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:-translate-y-1 hover:shadow-xl hover:border-violet-300 transition-all duration-200">
            <div class="w-10 h-10 bg-violet-100 rounded-lg flex items-center justify-center mb-3 group-hover:bg-violet-200 group-hover:scale-110 transition-all duration-200">
              <svg class="w-5 h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <p class="font-semibold text-gray-900 group-hover:text-violet-600 transition-colors">Clinics</p>
            <p class="text-sm text-gray-500">Manage listings</p>
          </a>

          <a href="/admin/doctors/" class="group bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:-translate-y-1 hover:shadow-xl hover:border-blue-300 transition-all duration-200">
            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mb-3 group-hover:bg-blue-200 group-hover:scale-110 transition-all duration-200">
              <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <p class="font-semibold text-gray-900 group-hover:text-blue-600 transition-colors">Doctors</p>
            <p class="text-sm text-gray-500">Manage profiles</p>
          </a>

          <a href="/admin/reviews/" class="group bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:-translate-y-1 hover:shadow-xl hover:border-amber-300 transition-all duration-200">
            <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center mb-3 group-hover:bg-amber-200 group-hover:scale-110 transition-all duration-200">
              <svg class="w-5 h-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <p class="font-semibold text-gray-900 group-hover:text-amber-600 transition-colors">Reviews</p>
            <p class="text-sm text-gray-500">Moderate reviews</p>
          </a>

          <a href="/admin/content/" class="group bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:-translate-y-1 hover:shadow-xl hover:border-emerald-300 transition-all duration-200">
            <div class="w-10 h-10 bg-emerald-100 rounded-lg flex items-center justify-center mb-3 group-hover:bg-emerald-200 group-hover:scale-110 transition-all duration-200">
              <svg class="w-5 h-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <p class="font-semibold text-gray-900 group-hover:text-emerald-600 transition-colors">Content</p>
            <p class="text-sm text-gray-500">FAQ & treatments</p>
          </a>
        </div>

        <!-- Lead Breakdown -->
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Lead Breakdown</h2>
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm mb-8">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Type</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Count</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              {Object.entries(leadStats).filter(([k]) => k !== "total").map(([type, count]) => (
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-6 py-4 text-sm text-gray-900 capitalize">{type.replace(/_/g, " ")}</td>
                  <td class="px-6 py-4 text-sm text-gray-600 text-right font-medium">{count}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Recent Activity Feed -->
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Recent Activity</h2>
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
          {auditEntries.length > 0 ? (
            <div class="divide-y divide-gray-100">
              {auditEntries.map((entry) => {
                const actionLabel = entry.action
                  ? entry.action.replace(/_/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase())
                  : "Unknown action";

                const entityLabel = entry.entityType
                  ? entry.entityType.replace(/_/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase())
                  : "System";

                const timeAgo = (date: Date | string) => {
                  const now = new Date();
                  const then = new Date(date);
                  const diffMs = now.getTime() - then.getTime();
                  const diffMins = Math.floor(diffMs / 60000);
                  if (diffMins < 1) return "just now";
                  if (diffMins < 60) return `${diffMins}m ago`;
                  const diffHrs = Math.floor(diffMins / 60);
                  if (diffHrs < 24) return `${diffHrs}h ago`;
                  const diffDays = Math.floor(diffHrs / 24);
                  return `${diffDays}d ago`;
                };

                const actionColor = {
                  create: "bg-emerald-100 text-emerald-700",
                  update: "bg-blue-100 text-blue-700",
                  delete: "bg-red-100 text-red-700",
                  login: "bg-violet-100 text-violet-700",
                  approve: "bg-green-100 text-green-700",
                  reject: "bg-amber-100 text-amber-700",
                  publish: "bg-cyan-100 text-cyan-700",
                };

                const colorKey = Object.keys(actionColor).find((k) => entry.action?.toLowerCase().includes(k)) ?? "update";
                const badgeColor = actionColor[colorKey] ?? "bg-gray-100 text-gray-700";

                return (
                  <div class="px-5 py-3.5 flex items-center gap-4 hover:bg-gray-50 transition-colors">
                    <span class={`shrink-0 text-[10px] font-semibold px-2 py-1 rounded-full ${badgeColor}`}>
                      {actionLabel}
                    </span>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm text-gray-800">
                        <span class="font-medium text-gray-900">{entry.userEmail ?? entry.userName ?? "System"}</span>
                        {" "}updated{" "}
                        <span class="font-medium text-violet-600">{entityLabel}</span>
                        {entry.details && <span class="text-gray-500"> — {typeof entry.details === "string" ? entry.details : JSON.stringify(entry.details)}</span>}
                      </p>
                    </div>
                    <span class="shrink-0 text-xs text-gray-400">
                      {timeAgo(entry.createdAt)}
                    </span>
                  </div>
                );
              })}
            </div>
          ) : (
            <div class="px-5 py-8 text-center">
              <svg class="w-10 h-10 text-gray-200 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
              </svg>
              <p class="text-sm text-gray-400">No audit log entries yet</p>
            </div>
          )}
        </div>

      </div>
    </main>
  </div>

  <script>
    // Update "last updated" timestamp dynamically
    const el = document.getElementById("last-updated");
    if (el) {
      const start = Date.now();
      setInterval(() => {
        const diffMs = Date.now() - start;
        const diffMins = Math.floor(diffMs / 60000);
        if (diffMins < 1) {
          el.textContent = "Last updated: just now";
        } else {
          el.textContent = `Last updated: ${diffMins}m ago`;
        }
      }, 60000);
    }
  </script>
</Layout>
