---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import AdminSidebar from "../../components/react/AdminSidebar";
import { getSessionFromRequest, hasRole } from "../../utils/auth";
import { getPatientEnquiries, getPatientEnquiryStats } from "../../db/queries";
import { db } from "../../db";
import { doctors, clinics as clinicsTable, users } from "../../db/schema";
import { eq, desc } from "drizzle-orm";

const session = getSessionFromRequest(Astro.request);
if (!hasRole(session, "admin", "editor")) {
  return Astro.redirect("/admin/login");
}

const url = Astro.url;
const search = url.searchParams.get('search') || '';
const statusFilter = url.searchParams.get('status') || '';
const assignedToFilter = url.searchParams.get('assignedTo') || '';
const page = Math.max(0, parseInt(url.searchParams.get('page') || '0'));
const limit = 25;

let stats = { total: 0, new: 0, contacted: 0, converted: 0, unassigned: 0 };
let enquiries: any[] = [];
let totalCount = 0;
let allDoctors: any[] = [];
let allAdmins: any[] = [];

try {
  const [enqResult, statsResult] = await Promise.all([
    getPatientEnquiries({ status: statusFilter || undefined, assignedTo: assignedToFilter || undefined, search: search || undefined, limit, offset: page * limit }),
    getPatientEnquiryStats(),
  ]);
  enquiries = enqResult;
  stats = statsResult;

  // Get total for pagination (re-query with same filters but no limit for count)
  const { patientEnquiries } = await import("../../db/schema");
  const { count } = await import("drizzle-orm");
  const { sql, and } = await import("drizzle-orm");
  const cond = [];
  if (statusFilter) cond.push(eq(patientEnquiries.status, statusFilter));
  if (assignedToFilter) cond.push(eq(patientEnquiries.assignedTo as any, assignedToFilter));
  const countResult = await db.select({ count: count() }).from(patientEnquiries)
    .where(cond.length > 0 ? and(...cond) : undefined);
  totalCount = Number(countResult[0]?.count ?? 0);
} catch {}

try {
  const [doctorsResult, adminsResult] = await Promise.all([
    db.select({ id: doctors.id, name: doctors.name }).from(doctors).limit(200),
    db.select({ id: users.id, name: users.name, email: users.email }).from(users).where(eq(users.role, 'admin')).limit(100),
  ]);
  allDoctors = doctorsResult;
  allAdmins = adminsResult;
} catch {}

const totalPages = Math.ceil(totalCount / limit);
---

<Layout title="Patient Enquiries | TMS List Admin" noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <AdminSidebar client:load currentPage="enquiries" userEmail={session!.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="mb-6 flex items-start justify-between">
          <div>
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Patient Enquiries</h1>
            <p class="text-gray-500 mt-1">Track and manage patient specialist enquiries</p>
          </div>
          <button onclick="openCreateModal()" class="px-4 py-2 bg-[var(--ink)] text-white text-sm font-semibold rounded-lg hover:bg-[var(--ink)]">
            + New Enquiry
          </button>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Total</p>
            <p class="text-2xl font-semibold text-gray-900 mt-1">{stats.total}</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">New</p>
            <p class="text-2xl font-semibold text-amber-600 mt-1">{stats.new}</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Contacted</p>
            <p class="text-2xl font-semibold text-blue-600 mt-1">{stats.contacted}</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Converted</p>
            <p class="text-2xl font-semibold text-green-600 mt-1">{stats.converted}</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Unassigned</p>
            <p class="text-2xl font-semibold text-red-600 mt-1">{stats.unassigned}</p>
          </div>
        </div>

        <!-- Bulk Action Bar -->
        <div id="bulk-bar" class="hidden mb-4 bg-violet-50 border border-violet-200 rounded-xl p-4 flex items-center gap-4 flex-wrap">
          <span class="text-sm font-medium text-violet-700" id="bulk-count">0 selected</span>
          <div class="flex gap-2 flex-wrap">
            <select id="bulk-status" class="px-3 py-1.5 text-sm border border-violet-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-violet-500/20">
              <option value="">Change Status...</option>
              <option value="new">New</option>
              <option value="contacted">Contacted</option>
              <option value="converted">Converted</option>
              <option value="closed">Closed</option>
            </select>
            <select id="bulk-assign" class="px-3 py-1.5 text-sm border border-violet-300 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-violet-500/20">
              <option value="">Assign To...</option>
              <option value="unassign">Unassign</option>
              {allAdmins.map(a => (
                <option value={a.id}>{a.name || a.email}</option>
              ))}
            </select>
            <button onclick="bulkExport()" class="px-3 py-1.5 bg-white border border-violet-300 text-violet-700 text-sm rounded-lg hover:bg-violet-100">Export CSV</button>
            <button onclick="bulkDelete()" class="px-3 py-1.5 bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg hover:bg-red-100">Delete</button>
          </div>
          <button onclick="clearSelection()" class="ml-auto text-sm text-violet-500 hover:text-violet-700">Clear selection</button>
        </div>

        <!-- Enquiries Table -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200 flex items-center gap-4 flex-wrap">
            <form method="GET" class="flex-1 min-w-64 flex gap-2">
              <input
                type="text"
                name="search"
                value={search}
                placeholder="Search by name, email, doctor..."
                class="flex-1 px-3 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500/20 focus:border-violet-500"
              />
              <select name="status" class="px-3 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500/20">
                <option value="">All Status</option>
                <option value="new" selected={statusFilter === 'new'}>New</option>
                <option value="contacted" selected={statusFilter === 'contacted'}>Contacted</option>
                <option value="converted" selected={statusFilter === 'converted'}>Converted</option>
                <option value="closed" selected={statusFilter === 'closed'}>Closed</option>
              </select>
              <select name="assignedTo" class="px-3 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500/20">
                <option value="">All Assignees</option>
                <option value="unassigned" selected={assignedToFilter === 'unassigned'}>Unassigned</option>
                {allAdmins.map(a => (
                  <option value={a.id} selected={assignedToFilter === a.id}>{a.name || a.email}</option>
                ))}
              </select>
              <button type="submit" class="px-4 py-2 bg-[var(--ink)] text-white text-sm rounded-lg">Filter</button>
              <a href="/admin/enquiries" class="px-3 py-2 text-sm text-gray-500 hover:text-gray-700 border border-gray-200 rounded-lg">Clear</a>
            </form>
          </div>

          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200" id="enquiries-table">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left">
                    <input type="checkbox" id="select-all" onchange="toggleSelectAll(this.checked)" class="w-4 h-4 rounded border-gray-300 text-violet-600 cursor-pointer" />
                  </th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Patient</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Doctor</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Clinic</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Assigned To</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                  <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200" id="enquiries-body">
                {enquiries.length === 0 ? (
                  <tr>
                    <td colspan="8" class="px-6 py-12 text-center text-gray-400">No enquiries found</td>
                  </tr>
                ) : (
                  enquiries.map((e) => (
                    <tr class="hover:bg-gray-50 enquiry-row" data-id={e.enquiry?.id} data-name={e.enquiry?.name?.toLowerCase() || ''} data-email={e.enquiry?.email?.toLowerCase() || ''} data-doctor={e.doctor?.name?.toLowerCase() || e.enquiry?.doctorName?.toLowerCase() || ''} data-status={e.enquiry?.status || 'new'}>
                      <td class="px-6 py-4">
                        <input type="checkbox" class="enquiry-checkbox w-4 h-4 rounded border-gray-300 text-violet-600 cursor-pointer" data-id={e.enquiry?.id} onchange="updateBulkBar()" />
                      </td>
                      <td class="px-6 py-4">
                        <div class="text-sm font-medium text-gray-900">{e.enquiry?.name || 'Unknown'}</div>
                        <div class="text-xs text-gray-500">{e.enquiry?.email || 'No email'}</div>
                        {e.enquiry?.phone && <div class="text-xs text-gray-500">{e.enquiry.phone}</div>}
                      </td>
                      <td class="px-6 py-4 text-sm text-gray-700">
                        {e.doctor?.name || e.enquiry?.doctorName || <span class="text-gray-400">Unassigned</span>}
                      </td>
                      <td class="px-6 py-4 text-sm text-gray-700">
                        {e.clinic?.name || e.enquiry?.clinicName || '-'}
                      </td>
                      <td class="px-6 py-4">
                        <select
                          class="enquiry-status text-xs font-semibold px-2.5 py-1 rounded-full border border-transparent cursor-pointer"
                          data-id={e.enquiry?.id}
                          data-current={e.enquiry?.status || 'new'}
                          onchange="updateEnquiryStatus(this)"
                          style={
                            e.enquiry?.status === 'new' ? 'background: rgba(245,158,11,0.1); color: #d97706; border-color: #f59e0b33;' :
                            e.enquiry?.status === 'contacted' ? 'background: rgba(59,130,246,0.1); color: #2563eb; border-color: #3b82f633;' :
                            e.enquiry?.status === 'converted' ? 'background: rgba(34,197,94,0.1); color: #16a34a; border-color: #22c55e33;' :
                            'background: rgba(156,163,175,0.1); color: #6b7280; border-color: #d1d5db33;'
                          }
                        >
                          <option value="new" selected={e.enquiry?.status === 'new'}>New</option>
                          <option value="contacted" selected={e.enquiry?.status === 'contacted'}>Contacted</option>
                          <option value="converted" selected={e.enquiry?.status === 'converted'}>Converted</option>
                          <option value="closed" selected={e.enquiry?.status === 'closed'}>Closed</option>
                        </select>
                      </td>
                      <td class="px-6 py-4">
                        <select class="assign-select text-xs px-2 py-1 border border-gray-200 rounded cursor-pointer" data-id={e.enquiry?.id} onchange="updateAssign(this)">
                          <option value="">Unassigned</option>
                          {allAdmins.map(a => (
                            <option value={a.id} selected={e.enquiry?.assignedTo === a.id}>{a.name || a.email}</option>
                          ))}
                        </select>
                      </td>
                      <td class="px-6 py-4 text-xs text-gray-500 whitespace-nowrap">
                        {e.enquiry?.createdAt ? new Date(e.enquiry.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '-'}
                      </td>
                      <td class="px-6 py-4 text-right">
                        <button
                          class="text-xs text-gray-500 hover:text-gray-700 px-2 py-1 rounded view-enquiry"
                          data-id={e.enquiry?.id}
                          onclick="viewEnquiry(this)"
                        >
                          View
                        </button>
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>

          <!-- Pagination -->
          {totalPages > 1 && (
            <div class="px-6 py-3 border-t border-gray-200 bg-gray-50 flex items-center justify-between">
              <span class="text-sm text-gray-500">Page {page + 1} of {totalPages} ({totalCount} total)</span>
              <div class="flex gap-2">
                <a href={`?search=${encodeURIComponent(search)}&status=${statusFilter}&assignedTo=${assignedToFilter}&page=${page - 1}`}
                   class={`px-3 py-1.5 text-sm border rounded-lg ${page === 0 ? 'text-gray-300 cursor-not-allowed pointer-events-none' : 'text-gray-700 hover:bg-gray-100'}`}>
                  Previous
                </a>
                <a href={`?search=${encodeURIComponent(search)}&status=${statusFilter}&assignedTo=${assignedToFilter}&page=${page + 1}`}
                   class={`px-3 py-1.5 text-sm border rounded-lg ${page >= totalPages - 1 ? 'text-gray-300 cursor-not-allowed pointer-events-none' : 'text-gray-700 hover:bg-gray-100'}`}>
                  Next
                </a>
              </div>
            </div>
          )}
        </div>
      </div>
    </main>
  </div>

  <!-- Detail Modal -->
  <div id="enquiry-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/40" onclick="closeEnquiryModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg bg-white rounded-2xl shadow-2xl max-h-[90vh] overflow-y-auto">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h3 class="text-lg font-semibold text-gray-900" id="modal-title">Enquiry Details</h3>
        <button onclick="closeEnquiryModal()" class="text-gray-400 hover:text-gray-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <div class="p-6" id="modal-body"></div>
    </div>
  </div>

  <!-- Create Enquiry Modal -->
  <div id="create-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/40" onclick="closeCreateModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-white rounded-2xl shadow-2xl max-h-[90vh] overflow-y-auto">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h3 class="text-lg font-semibold text-gray-900">New Enquiry</h3>
        <button onclick="closeCreateModal()" class="text-gray-400 hover:text-gray-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <form id="create-form" onsubmit="submitCreate(event)" class="p-6 space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Patient Name *</label>
          <input type="text" name="name" required class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/20" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
          <input type="email" name="email" required class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/20" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
          <input type="tel" name="phone" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/20" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Doctor</label>
          <select name="doctorId" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-violet-500/20">
            <option value="">Unassigned</option>
            {allDoctors.map(d => (
              <option value={d.id}>{d.name}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Message</label>
          <textarea name="message" rows="3" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-violet-500/20"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
          <select name="status" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-violet-500/20">
            <option value="new">New</option>
            <option value="contacted">Contacted</option>
            <option value="converted">Converted</option>
            <option value="closed">Closed</option>
          </select>
        </div>
        <div class="flex gap-3 pt-2">
          <button type="button" onclick="closeCreateModal()" class="flex-1 px-4 py-2 bg-gray-100 text-gray-700 text-sm rounded-lg hover:bg-gray-200">Cancel</button>
          <button type="submit" class="flex-1 px-4 py-2 bg-[var(--ink)] text-white text-sm font-semibold rounded-lg hover:bg-[var(--ink)]">Create</button>
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ allAdminsData: allAdmins.map(a => ({ id: a.id, name: a.name || a.email })), enquiryRows: enquiries.map(e => ({ id: e.enquiry?.id, name: e.enquiry?.name, email: e.enquiry?.email, phone: e.enquiry?.phone, doctor: e.doctor?.name || e.enquiry?.doctorName, clinic: e.clinic?.name || e.enquiry?.clinicName, status: e.enquiry?.status, message: e.enquiry?.message, createdAt: e.enquiry?.createdAt })) }}>
    const enquiryData: Record<string, any> = Object.fromEntries(enquiryRows.map((r: any) => [r.id, r]));

    function getSelected() {
      return Array.from(document.querySelectorAll<HTMLInputElement>('.enquiry-checkbox:checked')).map(c => c.dataset.id!);
    }

    function updateBulkBar() {
      const selected = getSelected();
      const bar = document.getElementById('bulk-bar')!;
      const count = document.getElementById('bulk-count')!;
      if (selected.length > 0) {
        bar.classList.remove('hidden');
        count.textContent = `${selected.length} selected`;
      } else {
        bar.classList.add('hidden');
      }
    }

    function toggleSelectAll(checked: boolean) {
      document.querySelectorAll('.enquiry-checkbox').forEach(cb => (cb as HTMLInputElement).checked = checked);
      updateBulkBar();
    }

    function clearSelection() {
      document.querySelectorAll('.enquiry-checkbox').forEach(cb => (cb as HTMLInputElement).checked = false);
      document.getElementById('select-all').checked = false;
      updateBulkBar();
    }

    async function applyBulkStatus() {
      const status = (document.getElementById('bulk-status') as HTMLSelectElement).value;
      if (!status) return;
      const ids = getSelected();
      if (!ids.length) return;
      const res = await fetch('/api/admin/enquiries', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids, status }),
      });
      if (res.ok) location.reload();
    }

    async function applyBulkAssign() {
      const assignVal = (document.getElementById('bulk-assign') as HTMLSelectElement).value;
      if (assignVal === '') return;
      const assignedTo = assignVal === 'unassign' ? null : assignVal;
      const ids = getSelected();
      if (!ids.length) return;
      const res = await fetch('/api/admin/enquiries', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids, assignedTo }),
      });
      if (res.ok) location.reload();
    }

    function bulkExport() {
      const selected = getSelected();
      const rows = selected.length > 0
        ? selected.map(id => enquiryData[id]).filter(Boolean)
        : Object.values(enquiryData);
      if (rows.length === 0) return;
      const headers = ['Name', 'Email', 'Phone', 'Doctor', 'Clinic', 'Status', 'Date'];
      const csv = [headers.join(','),
        ...rows.map((r: any) => [r.name, r.email, r.phone, r.doctor, r.clinic, r.status,
          r.createdAt ? new Date(r.createdAt).toLocaleDateString() : ''].map(v => `"${(v || '').toString().replace(/"/g, '""')}"`).join(','))
      ].join('\n');
      const blob = new Blob([csv], { type: 'text/csv' });
      const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
      a.download = `enquiries-${new Date().toISOString().slice(0, 10)}.csv`;
      a.click();
    }

    async function bulkDelete() {
      const ids = getSelected();
      if (!ids.length || !confirm(`Delete ${ids.length} enquiry(ies)?`)) return;
      const res = await fetch(`/api/admin/enquiries?ids=${ids.join(',')}`, { method: 'DELETE' });
      if (res.ok) location.reload();
    }

    async function updateEnquiryStatus(el: HTMLSelectElement) {
      const id = el.dataset.id;
      const status = el.value;
      try {
        const res = await fetch('/api/admin/enquiries', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, status }),
        });
        if (res.ok) {
          el.dataset.current = status;
          const colors: Record<string, string> = {
            new: 'rgba(245,158,11,0.1)|#d97706|#f59e0b33',
            contacted: 'rgba(59,130,246,0.1)|#2563eb|#3b82f633',
            converted: 'rgba(34,197,94,0.1)|#16a34a|#22c55e33',
            closed: 'rgba(156,163,175,0.1)|#6b7280|#d1d5db33',
          };
          const c = colors[status]?.split('|') || colors.closed.split('|');
          el.style.background = c[0];
          el.style.color = c[1];
          el.style.borderColor = c[2];
        }
      } catch (err) {
        console.error('Failed to update status', err);
      }
    }

    async function updateAssign(el: HTMLSelectElement) {
      const id = el.dataset.id;
      const assignedTo = el.value || null;
      try {
        await fetch('/api/admin/enquiries', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, assignedTo }),
        });
      } catch (err) {
        console.error('Failed to update assign', err);
      }
    }

    function viewEnquiry(el: HTMLButtonElement) {
      const id = el.dataset.id;
      const d = enquiryData[id || ''];
      if (!d) return;
      document.getElementById('modal-title')!.textContent = d.name || 'Enquiry Details';
      (document.getElementById('modal-body') as HTMLDivElement).innerHTML = `
        <div class="space-y-4">
          <div><label class="text-xs font-medium text-gray-500 uppercase">Email</label><p class="text-sm text-gray-900">${d.email || '—'}</p></div>
          <div><label class="text-xs font-medium text-gray-500 uppercase">Phone</label><p class="text-sm text-gray-900">${d.phone || 'Not provided'}</p></div>
          <div><label class="text-xs font-medium text-gray-500 uppercase">Doctor</label><p class="text-sm text-gray-900">${d.doctor || 'Unassigned'}</p></div>
          <div><label class="text-xs font-medium text-gray-500 uppercase">Clinic</label><p class="text-sm text-gray-900">${d.clinic || '-'}</p></div>
          <div><label class="text-xs font-medium text-gray-500 uppercase">Status</label><p class="text-sm capitalize">${d.status}</p></div>
          ${d.message ? `<div><label class="text-xs font-medium text-gray-500 uppercase">Message</label><p class="text-sm text-gray-700">${d.message}</p></div>` : ''}
          <div><label class="text-xs font-medium text-gray-500 uppercase">Date</label><p class="text-sm text-gray-700">${d.createdAt ? new Date(d.createdAt).toLocaleString() : '-'}</p></div>
        </div>
      `;
      document.getElementById('enquiry-modal')!.classList.remove('hidden');
    }

    function closeEnquiryModal() {
      document.getElementById('enquiry-modal')!.classList.add('hidden');
    }

    function openCreateModal() {
      document.getElementById('create-modal')!.classList.remove('hidden');
    }

    function closeCreateModal() {
      document.getElementById('create-modal')!.classList.add('hidden');
    }

    async function submitCreate(e: Event) {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const fd = new FormData(form);
      const body: Record<string, any> = {};
      fd.forEach((v, k) => { if (v) body[k] = v; });
      const res = await fetch('/api/admin/enquiries', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (res.ok) { closeCreateModal(); location.reload(); }
    }

    // Wire bulk status/assign selects
    document.getElementById('bulk-status')?.addEventListener('change', applyBulkStatus);
    document.getElementById('bulk-assign')?.addEventListener('change', applyBulkAssign);
  </script>
</Layout>

<Layout title="Patient Enquiries | TMS List Admin" noindex={true}>
  <div class="flex min-h-screen bg-gray-50">
    <AdminSidebar client:load currentPage="enquiries" userEmail={session!.email} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-7xl">
        <div class="mb-6 flex items-start justify-between">
          <div>
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Patient Enquiries</h1>
            <p class="text-gray-500 mt-1">Track and manage patient specialist enquiries</p>
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Total</p>
            <p class="text-2xl font-semibold text-gray-900 mt-1">{stats.total}</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">New</p>
            <p class="text-2xl font-semibold text-amber-600 mt-1">{stats.new}</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Contacted</p>
            <p class="text-2xl font-semibold text-blue-600 mt-1">{stats.contacted}</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Converted</p>
            <p class="text-2xl font-semibold text-green-600 mt-1">{stats.converted}</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
            <p class="text-sm font-medium text-gray-500">Unassigned</p>
            <p class="text-2xl font-semibold text-red-600 mt-1">{stats.unassigned}</p>
          </div>
        </div>

        <!-- Enquiries Table -->
        <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-200 flex items-center gap-4 flex-wrap">
            <input
              type="text"
              id="search"
              placeholder="Search by name, email, doctor..."
              class="flex-1 min-w-64 px-3 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500/20 focus:border-violet-500"
              onkeyup="filterTable(this.value)"
            />
            <select id="status-filter" class="px-3 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-violet-500/20" onchange="filterTable(document.getElementById('search').value)">
              <option value="">All Status</option>
              <option value="new">New</option>
              <option value="contacted">Contacted</option>
              <option value="converted">Converted</option>
              <option value="closed">Closed</option>
            </select>
          </div>

          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200" id="enquiries-table">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Patient</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Doctor</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Clinic</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Assigned To</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
                  <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200" id="enquiries-body">
                {enquiries.length === 0 ? (
                  <tr>
                    <td colspan="7" class="px-6 py-12 text-center text-gray-400">No enquiries yet</td>
                  </tr>
                ) : (
                  enquiries.map((e) => (
                    <tr class="hover:bg-gray-50 enquiry-row" data-name={e.enquiry?.name?.toLowerCase() || ''} data-email={e.enquiry?.email?.toLowerCase() || ''} data-doctor={e.doctor?.name?.toLowerCase() || e.enquiry?.doctorName?.toLowerCase() || ''} data-status={e.enquiry?.status || 'new'}>
                      <td class="px-6 py-4">
                        <div class="text-sm font-medium text-gray-900">{e.enquiry?.name || 'Unknown'}</div>
                        <div class="text-xs text-gray-500">{e.enquiry?.email || 'No email'}</div>
                        {e.enquiry?.phone && <div class="text-xs text-gray-500">{e.enquiry.phone}</div>}
                      </td>
                      <td class="px-6 py-4 text-sm text-gray-700">
                        {e.doctor?.name || e.enquiry?.doctorName || <span class="text-gray-400">Unassigned</span>}
                      </td>
                      <td class="px-6 py-4 text-sm text-gray-700">
                        {e.clinic?.name || e.enquiry?.clinicName || '-'}
                      </td>
                      <td class="px-6 py-4">
                        <select
                          class="enquiry-status text-xs font-semibold px-2.5 py-1 rounded-full border border-transparent cursor-pointer"
                          data-id={e.enquiry?.id}
                          data-current={e.enquiry?.status || 'new'}
                          onchange="updateEnquiryStatus(this)"
                          style={
                            e.enquiry?.status === 'new' ? 'background: rgba(245,158,11,0.1); color: #d97706; border-color: #f59e0b33;' :
                            e.enquiry?.status === 'contacted' ? 'background: rgba(59,130,246,0.1); color: #2563eb; border-color: #3b82f633;' :
                            e.enquiry?.status === 'converted' ? 'background: rgba(34,197,94,0.1); color: #16a34a; border-color: #22c55e33;' :
                            'background: rgba(156,163,175,0.1); color: #6b7280; border-color: #d1d5db33;'
                          }
                        >
                          <option value="new" selected={e.enquiry?.status === 'new'}>New</option>
                          <option value="contacted" selected={e.enquiry?.status === 'contacted'}>Contacted</option>
                          <option value="converted" selected={e.enquiry?.status === 'converted'}>Converted</option>
                          <option value="closed" selected={e.enquiry?.status === 'closed'}>Closed</option>
                        </select>
                      </td>
                      <td class="px-6 py-4 text-sm text-gray-700">
                        {e.assignee?.name || e.assignee?.email || <span class="text-gray-400 text-xs">Unassigned</span>}
                      </td>
                      <td class="px-6 py-4 text-xs text-gray-500 whitespace-nowrap">
                        {e.enquiry?.createdAt ? new Date(e.enquiry.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '-'}
                      </td>
                      <td class="px-6 py-4 text-right">
                        <button
                          class="text-xs text-gray-500 hover:text-gray-700 px-2 py-1 rounded view-enquiry"
                          data-id={e.enquiry?.id}
                          onclick="viewEnquiry(this)"
                        >
                          View
                        </button>
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Detail Modal -->
  <div id="enquiry-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/40" onclick="closeEnquiryModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg bg-white rounded-2xl shadow-2xl max-h-[90vh] overflow-y-auto">
      <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <h3 class="text-lg font-semibold text-gray-900" id="modal-title">Enquiry Details</h3>
        <button onclick="closeEnquiryModal()" class="text-gray-400 hover:text-gray-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <div class="p-6" id="modal-body"></div>
    </div>
  </div>

  <script>
    // Client-side filtering
    function filterTable(query: string) {
      const status = (document.getElementById('status-filter') as HTMLSelectElement)?.value || '';
      const rows = document.querySelectorAll<HTMLTableRowElement>('.enquiry-row');
      const q = query.toLowerCase();
      rows.forEach(row => {
        const match = (!q || row.dataset.name?.includes(q) || row.dataset.email?.includes(q) || row.dataset.doctor?.includes(q))
          && (!status || row.dataset.status === status);
        row.style.display = match ? '' : 'none';
      });
    }

    async function updateEnquiryStatus(el: HTMLSelectElement) {
      const id = el.dataset.id;
      const status = el.value;
      try {
        const res = await fetch('/api/admin/enquiries', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id, status }),
        });
        if (res.ok) {
          el.dataset.current = status;
          // Update badge color
          const colors: Record<string, string> = {
            new: 'rgba(245,158,11,0.1)|#d97706|#f59e0b33',
            contacted: 'rgba(59,130,246,0.1)|#2563eb|#3b82f633',
            converted: 'rgba(34,197,94,0.1)|#16a34a|#22c55e33',
            closed: 'rgba(156,163,175,0.1)|#6b7280|#d1d5db33',
          };
          const c = colors[status]?.split('|') || colors.closed.split('|');
          el.style.background = c[0];
          el.style.color = c[1];
          el.style.borderColor = c[2];
          const row = el.closest<HTMLTableRowElement>('.enquiry-row');
          if (row) row.dataset.status = status;
        }
      } catch (err) {
        console.error('Failed to update status', err);
      }
    }

    function viewEnquiry(el: HTMLButtonElement) {
      const row = el.closest<HTMLTableRowElement>('tr')!;
      const name = row.querySelector('td:nth-child(1) .text-sm')?.textContent || '';
      const email = row.querySelector('td:nth-child(1) .text-xs:last-child')?.textContent || '';
      const phone = row.querySelector<HTMLDivElement>('td:nth-child(1) .text-xs')?.textContent || '';
      const doctor = row.querySelector('td:nth-child(2)')?.textContent?.trim() || '';
      const clinic = row.querySelector('td:nth-child(3)')?.textContent?.trim() || '';
      const status = (row.querySelector('.enquiry-status') as HTMLSelectElement)?.value || '';

      document.getElementById('modal-title')!.textContent = name || 'Enquiry Details';
      (document.getElementById('modal-body') as HTMLDivElement).innerHTML = `
        <div class="space-y-4">
          <div><label class="text-xs font-medium text-gray-500 uppercase">Email</label><p class="text-sm text-gray-900">${email}</p></div>
          <div><label class="text-xs font-medium text-gray-500 uppercase">Phone</label><p class="text-sm text-gray-900">${phone || 'Not provided'}</p></div>
          <div><label class="text-xs font-medium text-gray-500 uppercase">Doctor</label><p class="text-sm text-gray-900">${doctor || 'Unassigned'}</p></div>
          <div><label class="text-xs font-medium text-gray-500 uppercase">Clinic</label><p class="text-sm text-gray-900">${clinic || '-'}</p></div>
          <div><label class="text-xs font-medium text-gray-500 uppercase">Status</label><p class="text-sm capitalize">${status}</p></div>
        </div>
      `;
      document.getElementById('enquiry-modal')!.classList.remove('hidden');
    }

    function closeEnquiryModal() {
      document.getElementById('enquiry-modal')!.classList.add('hidden');
    }
  </script>
</Layout>
