---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import { getSessionFromRequest } from "../utils/auth";

const session = getSessionFromRequest(Astro.request);
const redirectTo = Astro.url.searchParams.get('redirect') || '/community';
const error = Astro.url.searchParams.get('error');

// Already logged in
if (session) {
  return Astro.redirect(redirectTo);
}

const GOOGLE_CLIENT_ID = import.meta.env.GOOGLE_CLIENT_ID || process.env.GOOGLE_CLIENT_ID;
const googleEnabled = !!GOOGLE_CLIENT_ID;

const ERROR_MESSAGES: Record<string, string> = {
  'google-auth-failed': 'Google sign-in was cancelled. Please try again.',
  'google-not-configured': 'Google sign-in is not configured. Please contact support.',
  'google-token-failed': 'Failed to complete Google sign-in. Please try again.',
  'google-userinfo-failed': 'Failed to retrieve your Google profile. Please try again.',
  'email-not-verified': 'Your Google account email must be verified to sign in.',
  'server-error': 'Something went wrong. Please try again.',
};
---

<Layout
  title="Sign In | TMS List"
  description="Sign in with Google to leave reviews and participate in the community."
  noindex={true}
>
  <div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-violet-50 flex items-center justify-center px-4">
    <div class="max-w-sm w-full">
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-indigo-600 mb-6 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
          Back to TMS List
        </a>
        <div class="w-12 h-12 bg-indigo-600 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
        </div>
        <h1 class="text-2xl font-bold text-gray-900">Join TMS List</h1>
        <p class="text-sm text-gray-500 mt-2">Sign in to leave reviews and participate in the community</p>
      </div>

      {error && (
        <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-4">
          <p class="text-sm text-red-700">{ERROR_MESSAGES[error] || 'Something went wrong.'}</p>
        </div>
      )}

      <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
        {googleEnabled ? (
          <div class="space-y-3">
            <a
              href={`/api/auth/google/patient-callback?state=${encodeURIComponent(redirectTo)}`}
              class="flex items-center justify-center gap-3 w-full py-3 px-4 bg-white border border-gray-200 rounded-xl text-gray-700 font-semibold text-sm hover:bg-gray-50 hover:border-gray-300 transition-all shadow-sm"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
              Continue with Google
            </a>
            <p class="text-xs text-gray-400 text-center">Your Google email must be verified. No password needed.</p>
          </div>
        ) : (
          <div class="text-center py-4">
            <p class="text-sm text-gray-500">Google sign-in is not yet configured.</p>
            <p class="text-xs text-gray-400 mt-1">Please contact the site administrator.</p>
          </div>
        )}
      </div>

      <div class="text-center mt-6">
        <p class="text-xs text-gray-400">
          Want to manage your clinic? <a href="/portal/login" class="text-indigo-600 hover:text-indigo-700">Clinic portal sign in</a>
        </p>
      </div>

      <div class="mt-8 bg-white/60 backdrop-blur-sm rounded-xl border border-gray-100 p-4">
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">What you can do with a patient account</h3>
        <ul class="space-y-2">
          <li class="flex items-center gap-2 text-sm text-gray-600">
            <svg class="w-4 h-4 text-indigo-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Leave verified reviews for clinics
          </li>
          <li class="flex items-center gap-2 text-sm text-gray-600">
            <svg class="w-4 h-4 text-indigo-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Ask questions and share experiences
          </li>
          <li class="flex items-center gap-2 text-sm text-gray-600">
            <svg class="w-4 h-4 text-indigo-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Connect with others on TMS therapy journey
          </li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
