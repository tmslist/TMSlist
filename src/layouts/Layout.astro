---
interface BreadcrumbItem {
	name: string;
	url: string;
}

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonical?: string;
	schema?: string; // JSON-LD schema string
	breadcrumbs?: BreadcrumbItem[];
	noindex?: boolean;
	hreflang?: { lang: string; url: string }[];
	contentType?: string; // og:type override, e.g. "article" for blog posts
}

import "../styles/global.css";
import PostHog from "../components/posthog.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import EnquiryModal from "../components/react/EnquiryModal";
import LocationPopup from "../components/LocationPopup.astro";
import CallbackModal from "../components/CallbackModal.astro";
import CookieConsent from "../components/CookieConsent.astro";
import SocialProofToast from "../components/react/SocialProofToast";
import ExitIntent from "../components/react/ExitIntent";
import UTMCapture from "../components/react/UTMCapture";

const { title, description, image, canonical, schema, breadcrumbs, noindex, hreflang, contentType } = Astro.props;

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";

const breadcrumbSchema = breadcrumbs?.length ? JSON.stringify({
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": breadcrumbs.map((item, i) => ({
		"@type": "ListItem",
		"position": i + 1,
		"name": item.name,
		"item": item.url.startsWith('http') ? item.url : `${siteUrl}${item.url || '/'}`,
	})),
}) : null;

const defaultDescription =
	"Find verified TMS therapy clinics near you. Compare providers across 6 countries, read reviews, and start your treatment journey.";
const defaultImage = `${siteUrl}/images/tms_diagram.jpg`;

const metaDescription = description || defaultDescription;
const rawOgImage = image || defaultImage;
const ogImage = rawOgImage.startsWith('http') ? rawOgImage : `${siteUrl}${rawOgImage}`;
const canonicalUrl = canonical || Astro.url.href;

// Detect language from URL path for international pages
const COUNTRY_LANG: Record<string, string> = {
	'de': 'de', 'fr': 'fr', 'es': 'es', 'it': 'it', 'nl': 'nl',
	'br': 'pt-BR', 'mx': 'es-MX', 'jp': 'ja', 'kr': 'ko',
	'uk': 'en-GB', 'au': 'en-AU', 'ca': 'en-CA', 'in': 'en-IN',
	'nz': 'en-NZ', 'za': 'en-ZA', 'ie': 'en-IE', 'sg': 'en-SG',
	'ae': 'en-AE', 'il': 'en-IL', 'se': 'sv',
};
const pathSegment = Astro.url.pathname.split('/')[1];
const pageLang = COUNTRY_LANG[pathSegment] || 'en';

// Auto-generate hreflang for international country pages
const COUNTRY_PREFIXES = ['us', 'uk', 'ca', 'au', 'de', 'in', 'fr', 'es', 'it', 'nl', 'br', 'mx', 'jp', 'kr', 'se', 'nz', 'za', 'ie', 'sg', 'ae', 'il'];
const HREFLANG_MAP: Record<string, string> = {
	'us': 'en-US', 'uk': 'en-GB', 'ca': 'en-CA', 'au': 'en-AU', 'de': 'de-DE', 'in': 'en-IN',
	'fr': 'fr-FR', 'es': 'es-ES', 'it': 'it-IT', 'nl': 'nl-NL', 'br': 'pt-BR', 'mx': 'es-MX',
	'jp': 'ja-JP', 'kr': 'ko-KR', 'se': 'sv-SE', 'nz': 'en-NZ', 'za': 'en-ZA', 'ie': 'en-IE',
	'sg': 'en-SG', 'ae': 'en-AE', 'il': 'en-IL',
};
const isCountryPage = COUNTRY_PREFIXES.includes(pathSegment);
// Get the path after the country prefix (e.g., /uk/london/clinics → /london/clinics)
const subPath = isCountryPage ? Astro.url.pathname.replace(`/${pathSegment}`, '') : '';
// Build hreflang entries for equivalent pages across countries
const autoHreflang = isCountryPage ? COUNTRY_PREFIXES.map(prefix => ({
	lang: HREFLANG_MAP[prefix],
	url: `${siteUrl}/${prefix}${subPath}`,
})) : [];
const allHreflang = hreflang?.length ? hreflang : (autoHreflang.length > 0 ? autoHreflang : undefined);
---

<!doctype html>
<html lang={pageLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/favicon.png" sizes="any" />
		<link rel="apple-touch-icon" href="/favicon.png" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#4f46e5" />

		<!-- Search Console Verification -->
		{import.meta.env.GOOGLE_SITE_VERIFICATION && <meta name="google-site-verification" content={import.meta.env.GOOGLE_SITE_VERIFICATION} />}
		{import.meta.env.BING_SITE_VERIFICATION && <meta name="msvalidate.01" content={import.meta.env.BING_SITE_VERIFICATION} />}

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={metaDescription} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<link rel="canonical" href={canonicalUrl} />
		{allHreflang?.map(({ lang, url }) => (
			<link rel="alternate" hreflang={lang} href={url} />
		))}
		{allHreflang?.length && <link rel="alternate" hreflang="x-default" href={`${siteUrl}/us${subPath || '/'}`} />}
<meta name="google-site-verification" content="qeagmPIKArLizrkNipilA-09Wznqwx0l9uxZWOXd-fs" />
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={contentType || "website"} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content={ogImage?.includes('800/400') || ogImage?.includes('w=800') ? "800" : "1200"} />
		<meta property="og:image:height" content={ogImage?.includes('800/400') || ogImage?.includes('w=800') ? "400" : "630"} />
		<meta property="og:site_name" content="TMS List" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalUrl} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={metaDescription} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Fonts — preloaded for non-blocking render -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&display=swap" />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&display=swap" media="print" onload="this.media='all'" />

		<!-- External CDNs -->
		<link rel="preconnect" href="https://res.cloudinary.com" />
		<link rel="dns-prefetch" href="https://res.cloudinary.com" />
		<link rel="preconnect" href="https://images.unsplash.com" />
		<link rel="dns-prefetch" href="https://images.unsplash.com" />

		<!-- Organization Schema -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "WebSite",
				"name": "TMS List",
				"url": "https://tmslist.com",
				"description": "The leading directory of TMS therapy providers worldwide",
				"potentialAction": {
					"@type": "SearchAction",
					"target": "https://tmslist.com/us/?q={search_term_string}",
					"query-input": "required name=search_term_string"
				}
			}
		</script>

		<!-- Page Specific Schema -->
		{schema && <script type="application/ld+json" set:html={schema} />}

		<!-- Breadcrumb Schema -->
		{breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}

		<!-- Geo Detection (loads before body to avoid FOUC) -->
		<script is:inline src="/js/geo.js"></script>

		<!-- PostHog Analytics -->
		<PostHog />
	</head>
	<body
		class="bg-surface-subtle min-h-screen text-slate-900 font-sans antialiased flex flex-col overflow-x-hidden"
	>
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-violet-600 focus:text-white focus:rounded-lg focus:font-semibold">
			Skip to main content
		</a>
		<Header />
		<div id="main-content" class="pb-20 lg:pb-0">
		<slot />
		</div>
		<Footer />
		<LocationPopup />
		<EnquiryModal client:idle />
		<UTMCapture client:load />
		<CallbackModal />
		<SocialProofToast client:idle />
		<ExitIntent client:idle />
		<CookieConsent />
	<!-- Mobile Bottom Tab Bar -->
	<nav id="mobile-tab-bar" class="fixed bottom-0 left-0 right-0 z-[140] bg-white/95 backdrop-blur-lg border-t border-slate-200/80 shadow-[0_-4px_20px_rgb(0,0,0,0.06)] lg:hidden transition-transform duration-300 translate-y-0" aria-label="Mobile navigation">
		<div class="flex items-center justify-around px-2 pb-[max(0.5rem,env(safe-area-inset-bottom))] pt-2">
			<a href="/us/" class="mobile-tab-item flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors" data-tab="find">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
					<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
				</svg>
				<span class="text-[10px] font-semibold tracking-wide">Find</span>
			</a>
			<a href="/compare/" class="mobile-tab-item flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors" data-tab="compare">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
					<path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
				</svg>
				<span class="text-[10px] font-semibold tracking-wide">Compare</span>
			</a>
			<a href="/" class="mobile-tab-item flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors" data-tab="home">
				<div class="w-11 h-11 -mt-5 rounded-2xl bg-gradient-to-br from-indigo-600 to-fuchsia-500 flex items-center justify-center shadow-lg shadow-indigo-500/30">
					<svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M12 2C9.5 2 7.5 3.2 6.2 5 4.8 4.2 3.2 4.5 2.2 5.8 1 7.2 1.2 9.2 2.5 10.5 1.5 11.5 1 13 1 14.5 1 17 3 19 5.5 19.5 6 20.5 6.8 21.5 8 22c1.5.5 3.2.2 4-1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/>
						<path d="M12 2c2.5 0 4.5 1.2 5.8 3 1.4-.8 3-.5 4 .8 1.2 1.4 1 3.4-.3 4.7 1 1 1.5 2.5 1.5 4 0 2.5-2 4.5-4.5 5-.5 1-1.3 2-2.5 2.5-1.5.5-3.2.2-4-1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/>
					</svg>
				</div>
				<span class="text-[10px] font-semibold tracking-wide mt-0.5">Home</span>
			</a>
			<a href="/treatments/" class="mobile-tab-item flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors" data-tab="treatments">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
					<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
				</svg>
				<span class="text-[10px] font-semibold tracking-wide">Treatments</span>
			</a>
			<a href="/questions/" class="mobile-tab-item flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors" data-tab="help">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
					<path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
				</svg>
				<span class="text-[10px] font-semibold tracking-wide">FAQ</span>
			</a>
		</div>
	</nav>

	<!-- Dark Mode Toggle -->
	<button
		id="theme-toggle"
		class="fixed top-4 left-4 sm:left-auto sm:right-16 z-[150] w-10 h-10 rounded-full bg-white/80 dark:bg-slate-800/80 backdrop-blur border border-slate-200 dark:border-slate-600 shadow-sm flex items-center justify-center hover:scale-110 transition-all"
		aria-label="Toggle dark mode"
	>
		<svg id="sun-icon" class="w-5 h-5 text-amber-500 hidden" fill="currentColor" viewBox="0 0 20 20">
			<path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
		</svg>
		<svg id="moon-icon" class="w-5 h-5 text-slate-600" fill="currentColor" viewBox="0 0 20 20">
			<path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
		</svg>
	</button>

	<script is:inline>
		// Dark mode - check preference before paint
		(function() {
			var theme = localStorage.getItem('theme');
			if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
				document.documentElement.classList.add('dark');
			}
		})();

		// Toggle handler
		document.addEventListener('DOMContentLoaded', function() {
			var toggle = document.getElementById('theme-toggle');
			var sunIcon = document.getElementById('sun-icon');
			var moonIcon = document.getElementById('moon-icon');

			function updateIcons() {
				var isDark = document.documentElement.classList.contains('dark');
				sunIcon.classList.toggle('hidden', !isDark);
				moonIcon.classList.toggle('hidden', isDark);
			}

			updateIcons();

			toggle.addEventListener('click', function() {
				document.documentElement.classList.toggle('dark');
				var isDark = document.documentElement.classList.contains('dark');
				localStorage.setItem('theme', isDark ? 'dark' : 'light');
				updateIcons();
			});
		});

		// Mobile Tab Bar — hide on scroll down, show on scroll up + active state
		(function() {
			var tabBar = document.getElementById('mobile-tab-bar');
			if (!tabBar) return;
			var lastScroll = 0;
			var ticking = false;

			// Highlight active tab
			var path = window.location.pathname;
			var tabs = tabBar.querySelectorAll('.mobile-tab-item');
			tabs.forEach(function(tab) {
				var href = tab.getAttribute('href');
				var isActive = (href === '/' && path === '/') || (href !== '/' && path.startsWith(href));
				if (isActive) {
					tab.classList.add('text-violet-600');
					tab.classList.remove('text-slate-400');
				} else {
					tab.classList.add('text-slate-400');
					tab.classList.remove('text-violet-600');
				}
			});

			window.addEventListener('scroll', function() {
				lastScroll = window.scrollY;
				if (!ticking) {
					window.requestAnimationFrame(function() {
						if (lastScroll > 100 && lastScroll > (window._prevScroll || 0)) {
							tabBar.style.transform = 'translateY(100%)';
						} else {
							tabBar.style.transform = 'translateY(0)';
						}
						window._prevScroll = lastScroll;
						ticking = false;
					});
					ticking = true;
				}
			});
		})();

		window.showToast = function(msg, type) {
			var t = document.createElement('div');
			t.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-[200] px-6 py-3 text-sm font-medium rounded-xl shadow-lg transition-all';
			t.className += type === 'success' ? ' bg-emerald-600 text-white' : ' bg-slate-900 text-white';
			t.textContent = msg;
			document.body.appendChild(t);
			setTimeout(function() { t.style.opacity = '0'; setTimeout(function() { t.remove(); }, 300); }, 3500);
		};

		// Scroll-to-top button
		(function() {
			var btn = document.createElement('button');
			btn.id = 'scroll-top-btn';
			btn.setAttribute('aria-label', 'Scroll to top');
			btn.className = 'fixed bottom-24 right-6 z-[150] w-10 h-10 bg-white border border-slate-200 rounded-full shadow-md flex items-center justify-center text-slate-500 hover:text-violet-600 hover:border-violet-200 hover:shadow-lg transition-all duration-300 opacity-0 invisible translate-y-2 pointer-events-none cursor-pointer focus-visible:ring-2 focus-visible:ring-violet-300 focus-visible:ring-offset-2';
			btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>';
			btn.style.cssText = 'bottom: 6rem; right: 1.5rem;';
			document.body.appendChild(btn);

			var scrollTimer = null;
			function updateBtn() {
				if (window.scrollY > 400) {
					btn.style.opacity = '1';
					btn.style.visibility = 'visible';
					btn.style.transform = 'translateY(0)';
					btn.classList.remove('pointer-events-none', 'opacity-0', 'invisible', 'translate-y-2');
				} else {
					btn.style.opacity = '0';
					btn.style.visibility = 'hidden';
					btn.style.transform = 'translateY(0.5rem)';
					btn.classList.add('pointer-events-none', 'opacity-0', 'invisible', 'translate-y-2');
				}
			}

			window.addEventListener('scroll', function() {
				if (scrollTimer) clearTimeout(scrollTimer);
				scrollTimer = setTimeout(updateBtn, 50);
			}, { passive: true });

			btn.addEventListener('click', function() {
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});

			updateBtn();
		})();
	</script>
	</body>
</html>
