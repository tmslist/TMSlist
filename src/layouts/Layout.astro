---
interface BreadcrumbItem {
	name: string;
	url: string;
}

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonical?: string;
	schema?: string;
	breadcrumbs?: BreadcrumbItem[];
	noindex?: boolean;
	hreflang?: { lang: string; url: string }[];
	contentType?: string;
	extraSchemas?: string[];
	lastReviewed?: string;
}

import "../styles/global.css";
import { getSessionFromRequest } from "../utils/auth";
import PostHog from "../components/posthog.astro";
import TrackingHead from "../components/TrackingHead.astro";
import TrackingBodyOpen from "../components/TrackingBodyOpen.astro";
import TrackingBodyClose from "../components/TrackingBodyClose.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import EnquiryModal from "../components/react/EnquiryModal";
import LocationPopup from "../components/LocationPopup.astro";
import CallbackModal from "../components/CallbackModal.astro";
import LeadMagnetModal from "../components/LeadMagnetModal.astro";
import CookieConsent from "../components/CookieConsent.astro";
import SocialProofToast from "../components/react/SocialProofToast";
import ExitIntent from "../components/react/ExitIntent";
import UTMCapture from "../components/react/UTMCapture";

const { title, description, image, canonical, schema, breadcrumbs, noindex, hreflang, contentType, extraSchemas, lastReviewed } = Astro.props;

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";

// Dashboards (admin/portal/doctor) render their own chrome (sidebars, top bars).
// The marketing Header is `position: fixed; height: 64px;` and would otherwise
// overlap and hide the top of dashboard content. Skip the entire public chrome
// (Header, Footer, marketing modals, popups) on these routes.
const pathname = Astro.url.pathname;
// Only inspect cookies on SSR dashboard routes — prerendered pages don't have headers.
const _isDash = pathname.startsWith('/admin') || pathname.startsWith('/portal') || pathname.startsWith('/doctor');
const layoutSession = _isDash ? getSessionFromRequest(Astro.request) : null;
const isImpersonating = !!layoutSession?.isImpersonation;
const isDashboardRoute = pathname.startsWith('/admin/')
	|| pathname.startsWith('/admin')
	|| pathname.startsWith('/portal/')
	|| pathname.startsWith('/portal')
	|| pathname.startsWith('/doctor/')
	|| pathname.startsWith('/doctor');

const breadcrumbSchema = breadcrumbs?.length ? JSON.stringify({
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": breadcrumbs.map((item, i) => ({
		"@type": "ListItem",
		"position": i + 1,
		"name": item.name,
		"item": item.url.startsWith('http') ? item.url : `${siteUrl}${item.url || '/'}`,
	})),
}) : null;

const defaultDescription =
	"Find verified TMS therapy clinics near you. Compare providers across 6 countries, read reviews, and start your treatment journey.";
const defaultImage = `${siteUrl}/images/tms_diagram.jpg`;

const metaDescription = description || defaultDescription;
const rawOgImage = image || defaultImage;
const ogImage = rawOgImage.startsWith('http') ? rawOgImage : `${siteUrl}${rawOgImage}`;
const canonicalUrl = canonical || (siteUrl + Astro.url.pathname.replace(/\/$/, '') + '/');

// Detect language from URL path for international pages
const COUNTRY_LANG: Record<string, string> = {
	'de': 'de', 'fr': 'fr', 'es': 'es', 'it': 'it', 'nl': 'nl',
	'br': 'pt-BR', 'mx': 'es-MX', 'jp': 'ja', 'kr': 'ko',
	'uk': 'en-GB', 'au': 'en-AU', 'ca': 'en-CA', 'in': 'en-IN',
	'nz': 'en-NZ', 'za': 'en-ZA', 'ie': 'en-IE', 'sg': 'en-SG',
	'ae': 'en-AE', 'il': 'en-IL', 'se': 'sv',
};
const pathSegment = Astro.url.pathname.split('/')[1];
const pageLang = COUNTRY_LANG[pathSegment] || 'en';

// Auto-generate hreflang for international country pages
const COUNTRY_PREFIXES = ['us', 'uk', 'ca', 'au', 'de', 'in', 'fr', 'es', 'it', 'nl', 'br', 'mx', 'jp', 'kr', 'se', 'nz', 'za', 'ie', 'sg', 'ae', 'il'];
const HREFLANG_MAP: Record<string, string> = {
	'us': 'en-US', 'uk': 'en-GB', 'ca': 'en-CA', 'au': 'en-AU', 'de': 'de-DE', 'in': 'en-IN',
	'fr': 'fr-FR', 'es': 'es-ES', 'it': 'it-IT', 'nl': 'nl-NL', 'br': 'pt-BR', 'mx': 'es-MX',
	'jp': 'ja-JP', 'kr': 'ko-KR', 'se': 'sv-SE', 'nz': 'en-NZ', 'za': 'en-ZA', 'ie': 'en-IE',
	'sg': 'en-SG', 'ae': 'en-AE', 'il': 'en-IL',
};
const isCountryPage = COUNTRY_PREFIXES.includes(pathSegment);
// Get the path after the country prefix (e.g., /uk/london/clinics → /london/clinics)
const subPath = isCountryPage ? Astro.url.pathname.replace(`/${pathSegment}`, '') : '';
// Build hreflang entries for equivalent pages across countries
const autoHreflang = isCountryPage ? COUNTRY_PREFIXES.map(prefix => ({
	lang: HREFLANG_MAP[prefix],
	url: `${siteUrl}/${prefix}${subPath}`,
})) : [];
const allHreflang = hreflang?.length ? hreflang : (autoHreflang.length > 0 ? autoHreflang : undefined);
// Add x-default hreflang for international SEO
const xDefaultHreflang = isCountryPage ? { lang: "x-default", url: `${siteUrl}${subPath}` } : undefined;
---

<!doctype html>
<html lang={pageLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/favicon.png" sizes="any" />
		<link rel="apple-touch-icon" href="/favicon.png" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="theme-color" content="#0A1628" />

		<!-- Google Search Console Verification -->
		<meta name="google-site-verification" content="google91457eaa29687448" />

		<!-- Search Console Verification (env fallback; admin-managed values come via TrackingHead below) -->
		{import.meta.env.GOOGLE_SITE_VERIFICATION && <meta name="google-site-verification" content={import.meta.env.GOOGLE_SITE_VERIFICATION} />}
		{import.meta.env.BING_SITE_VERIFICATION && <meta name="msvalidate.01" content={import.meta.env.BING_SITE_VERIFICATION} />}

		<!-- Admin-managed tracking codes (GA4, GTM, Meta Pixel, custom head) -->
		<TrackingHead />

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={metaDescription} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		{lastReviewed && <meta property="article:modified_time" content={lastReviewed} />}
		<link rel="canonical" href={canonicalUrl} />
		{allHreflang?.map(({ lang, url }) => (
			<link rel="alternate" hreflang={lang} href={url} />
		))}
		{xDefaultHreflang && <link rel="alternate" hreflang={xDefaultHreflang.lang} href={xDefaultHreflang.url} />}
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={contentType || "website"} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content={ogImage?.includes('800/400') || ogImage?.includes('w=800') ? "800" : "1200"} />
		<meta property="og:image:height" content={ogImage?.includes('800/400') || ogImage?.includes('w=800') ? "400" : "630"} />
		<meta property="og:site_name" content="TMS List" />
		<meta property="og:locale" content={pageLang} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalUrl} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={metaDescription} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Fonts — preconnect + non-blocking load with font-display:swap -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&display=block" />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&display=block" media="print" onload="this.media='all'" />
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&display=block" /></noscript>

		<!-- External CDNs — preconnect for faster connection -->
		<link rel="preconnect" href="https://res.cloudinary.com" />
		<link rel="dns-prefetch" href="https://res.cloudinary.com" />
		<link rel="preconnect" href="https://images.unsplash.com" />
		<link rel="dns-prefetch" href="https://images.unsplash.com" />
		<!-- PostHog CDN preconnect — reduces handshake time when PostHog defers -->
		<link rel="preconnect" href="https://us.i.posthog.com" />
		<link rel="dns-prefetch" href="https://us.i.posthog.com" />
		<!-- Favicon preload for instant tab icon -->
		<link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml" />

		<!-- Performance hints for external tracking (GTM, GA, Meta Pixel) -->
		<link rel="dns-prefetch" href="https://www.googletagmanager.com" />
		<link rel="dns-prefetch" href="https://www.google-analytics.com" />
		<link rel="dns-prefetch" href="https://connect.facebook.net" />

		<!-- Preload critical above-the-fold assets -->
		<link rel="prefetch" as="image" href="/images/tms_hero.svg" />

		<!-- Organization Schema -->
		<script type="application/ld+json" set:html={`{
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://tmslist.com/#organization",
  "name": "TMS List",
  "url": "https://tmslist.com",
  "logo": "https://tmslist.com/logotmslist.png",
  "description": "The leading directory of TMS (Transcranial Magnetic Stimulation) therapy providers. Find verified TMS clinics, compare treatments, and learn about insurance coverage.",
  "sameAs": [
    "https://twitter.com/tmslist",
    "https://www.linkedin.com/company/tmslist",
    "https://www.facebook.com/tmslist"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "url": "https://tmslist.com/contact/",
    "areaServed": "US"
  },
  "knowsAbout": [
    {
      "@type": "Thing",
      "name": "Transcranial Magnetic Stimulation (TMS)",
      "description": "A non-invasive neuromodulation technique using magnetic pulses to stimulate specific areas of the brain"
    },
    {
      "@type": "Thing",
      "name": "Treatment-Resistant Depression",
      "description": "Depression that has not responded to at least two antidepressant medication trials"
    }
  ]
}`} />

		<!-- WebSite Schema -->
		<script type="application/ld+json" set:html={`{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "TMS List",
  "url": "https://tmslist.com",
  "description": "The leading directory of TMS therapy providers worldwide",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://tmslist.com/us/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}`} />

		<!-- Page Specific Schema -->
		{schema && <script type="application/ld+json" set:html={schema} />}

		<!-- Extra Schemas (from page-level) -->
		{extraSchemas?.map((s: string) => <script type="application/ld+json" set:html={s} />)}

		<!-- Breadcrumb Schema -->
		{breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}

		<!-- Geo Detection (loads before body to avoid FOUC) -->
		<script is:inline src="/js/geo.js"></script>

		<!-- PostHog Analytics -->
		<PostHog />
	</head>
	<body
		class="bg-surface-subtle min-h-screen text-[var(--ink)] font-sans antialiased flex flex-col overflow-x-hidden"
	>
		<TrackingBodyOpen />
		{isImpersonating && (
			<div class="sticky top-0 z-[300] w-full text-white text-sm font-semibold shadow-lg" style="background: linear-gradient(90deg, #b91c1c 0%, #dc2626 100%);">
				<div class="container mx-auto px-4 py-2.5 flex items-center justify-between gap-3 flex-wrap">
					<div class="flex items-center gap-2">
						<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M5 19h14a2 2 0 001.84-2.75L13.74 4a2 2 0 00-3.48 0L3.16 16.25A2 2 0 005 19z"/></svg>
						<span>Impersonating <strong>{layoutSession?.email}</strong> ({layoutSession?.role}) — actions are logged.</span>
					</div>
					<form method="POST" action="/api/admin/stop-impersonate" class="m-0">
						<button type="submit" class="px-3 py-1 rounded bg-white/20 hover:bg-white/30 text-white text-xs font-bold uppercase tracking-wider transition-colors">
							Exit impersonation
						</button>
					</form>
				</div>
			</div>
		)}
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-[var(--ink)] focus:text-white focus:rounded-lg focus:font-semibold">
			Skip to main content
		</a>
		{!isDashboardRoute && <Header />}
		<div id="main-content" class={isDashboardRoute ? '' : 'pb-20 lg:pb-0'}>
		<slot />
		</div>
		{!isDashboardRoute && (
			<>
				<Footer />
				<LocationPopup />
				<EnquiryModal client:idle />
				<UTMCapture client:idle />
				<CallbackModal />
				<LeadMagnetModal />
				<SocialProofToast client:idle />
				<ExitIntent client:idle />
				<CookieConsent />
			</>
		)}
	<!-- Mobile Bottom Tab Bar -->
	<nav id="mobile-tab-bar" class="fixed bottom-0 left-0 right-0 z-[140] backdrop-blur-lg shadow-[0_-4px_20px_rgba(10,22,40,0.06)] lg:hidden transition-transform duration-300 translate-y-0" style="background: rgba(251,250,247,0.92); border-top: 1px solid var(--line);" aria-label="Mobile navigation">
		<div class="flex items-center justify-around px-2 pb-[max(0.5rem,env(safe-area-inset-bottom))] pt-2">
			<a href="/us/" class="mobile-tab-item flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors" data-tab="find">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
					<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
				</svg>
				<span class="text-[10px] font-semibold tracking-wide">Find</span>
			</a>
			<a href="/compare/" class="mobile-tab-item flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors" data-tab="compare">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
					<path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
				</svg>
				<span class="text-[10px] font-semibold tracking-wide">Compare</span>
			</a>
			<a href="/" class="mobile-tab-item flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors" data-tab="home">
				<div class="w-11 h-11 -mt-5 rounded-2xl flex items-center justify-center shadow-lg" style="background: var(--gradient-brand); box-shadow: 0 8px 20px rgba(10,22,40,0.25);">
					<svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M12 2C9.5 2 7.5 3.2 6.2 5 4.8 4.2 3.2 4.5 2.2 5.8 1 7.2 1.2 9.2 2.5 10.5 1.5 11.5 1 13 1 14.5 1 17 3 19 5.5 19.5 6 20.5 6.8 21.5 8 22c1.5.5 3.2.2 4-1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/>
						<path d="M12 2c2.5 0 4.5 1.2 5.8 3 1.4-.8 3-.5 4 .8 1.2 1.4 1 3.4-.3 4.7 1 1 1.5 2.5 1.5 4 0 2.5-2 4.5-4.5 5-.5 1-1.3 2-2.5 2.5-1.5.5-3.2.2-4-1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/>
					</svg>
				</div>
				<span class="text-[10px] font-semibold tracking-wide mt-0.5">Home</span>
			</a>
			<a href="/treatments/" class="mobile-tab-item flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors" data-tab="treatments">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
					<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
				</svg>
				<span class="text-[10px] font-semibold tracking-wide">Treatments</span>
			</a>
			<a href="/questions/" class="mobile-tab-item flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl transition-colors" data-tab="help">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
					<path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
				</svg>
				<span class="text-[10px] font-semibold tracking-wide">FAQ</span>
			</a>
		</div>
	</nav>

	<script is:inline>
		// Ensure no leftover dark class is applied (dark mode removed).
		(function() {
			document.documentElement.classList.remove('dark');
			try { localStorage.removeItem('theme'); } catch (e) {}
		})();

		// Mobile Tab Bar — hide on scroll down, show on scroll up + active state
		(function() {
			var tabBar = document.getElementById('mobile-tab-bar');
			if (!tabBar) return;
			var lastScroll = 0;
			var ticking = false;

			// Highlight active tab
			var path = window.location.pathname;
			var tabs = tabBar.querySelectorAll('.mobile-tab-item');
			tabs.forEach(function(tab) {
				var href = tab.getAttribute('href');
				var isActive = (href === '/' && path === '/') || (href !== '/' && path.startsWith(href));
				if (isActive) {
					tab.classList.add('tab-active');
					tab.classList.remove('tab-inactive');
				} else {
					tab.classList.add('tab-inactive');
					tab.classList.remove('tab-active');
				}
			});

			window.addEventListener('scroll', function() {
				lastScroll = window.scrollY;
				if (!ticking) {
					window.requestAnimationFrame(function() {
						if (lastScroll > 100 && lastScroll > (window._prevScroll || 0)) {
							tabBar.style.transform = 'translateY(100%)';
						} else {
							tabBar.style.transform = 'translateY(0)';
						}
						window._prevScroll = lastScroll;
						ticking = false;
					});
					ticking = true;
				}
			});
		})();

		window.showToast = function(msg, type) {
			var t = document.createElement('div');
			t.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-[200] px-6 py-3 text-sm font-medium rounded-xl shadow-lg transition-all';
			t.className += type === 'success' ? ' bg-emerald-600 text-white' : ' text-white';
			t.style.cssText = 'background: var(--ink); color: white;';
			t.textContent = msg;
			document.body.appendChild(t);
			setTimeout(function() { t.style.opacity = '0'; setTimeout(function() { t.remove(); }, 300); }, 3500);
		};

		// Scroll-to-top button
		(function() {
			var btn = document.createElement('button');
			btn.id = 'scroll-top-btn';
			btn.setAttribute('aria-label', 'Scroll to top');
			btn.style.cssText = 'position: fixed; bottom: 6rem; right: 1.5rem; z-index: 150; width: 2.5rem; height: 2.5rem; border-radius: 9999px; background: var(--paper); border: 1px solid var(--line); box-shadow: 0 4px 12px rgba(10,22,40,0.08); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s ease; color: var(--muted); opacity: 0; visibility: hidden; pointer-events: none;';
			btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>';
			document.body.appendChild(btn);

			var scrollTimer = null;
			function updateBtn() {
				if (window.scrollY > 400) {
					btn.style.opacity = '1';
					btn.style.visibility = 'visible';
					btn.style.transform = 'translateY(0)';
					btn.classList.remove('pointer-events-none', 'opacity-0', 'invisible', 'translate-y-2');
				} else {
					btn.style.opacity = '0';
					btn.style.visibility = 'hidden';
					btn.style.transform = 'translateY(0.5rem)';
					btn.classList.add('pointer-events-none', 'opacity-0', 'invisible', 'translate-y-2');
				}
			}

			window.addEventListener('scroll', function() {
				if (scrollTimer) clearTimeout(scrollTimer);
				scrollTimer = setTimeout(updateBtn, 50);
			}, { passive: true });

			btn.addEventListener('click', function() {
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});

			updateBtn();
		})();

		// Scroll reveal animations
		(function() {
			var reveals = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale, .stagger-children');
			if (!reveals.length) return;

			var observer = new IntersectionObserver(function(entries) {
				entries.forEach(function(entry) {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
						observer.unobserve(entry.target);
					}
				});
			}, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

			reveals.forEach(function(el) { observer.observe(el); });
		})();

		// Ripple effect for buttons
		document.addEventListener('click', function(e) {
			var btn = e.target.closest('.ripple');
			if (!btn) return;

			var rect = btn.getBoundingClientRect();
			var ripple = document.createElement('span');
			ripple.className = 'ripple-effect';
			ripple.style.cssText = 'left:' + (e.clientX - rect.left) + 'px;top:' + (e.clientY - rect.top) + 'px;width:20px;height:20px;';
			btn.appendChild(ripple);
			setTimeout(function() { ripple.remove(); }, 600);
		});
	</script>
	<style>
		.tab-active { color: var(--accent) !important; }
		.tab-inactive { color: var(--muted) !important; }
		.mobile-tab-item { transition: color 0.15s ease, background 0.15s ease; }
		.mobile-tab-item:hover { background: var(--paper2); }
	</style>
		<TrackingBodyClose />
	</body>
