---
interface BreadcrumbItem {
	name: string;
	url: string;
}

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonical?: string;
	schema?: string; // JSON-LD schema string
	breadcrumbs?: BreadcrumbItem[];
}

import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import EnquiryModal from "../components/react/EnquiryModal";
import LocationPopup from "../components/LocationPopup.astro";

const { title, description, image, canonical, schema, breadcrumbs } = Astro.props;

const breadcrumbSchema = breadcrumbs?.length ? JSON.stringify({
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": breadcrumbs.map((item, i) => ({
		"@type": "ListItem",
		"position": i + 1,
		"name": item.name,
		"item": item.url.startsWith('http') ? item.url : `${(import.meta.env.SITE_URL || 'https://tmslist.com')}${item.url}`,
	})),
}) : null;

const siteUrl = import.meta.env.SITE_URL || "https://tmslist.com";
const defaultDescription =
	"Find FDA-cleared TMS therapy clinics near you. Compare verified providers, read reviews, and start your depression treatment journey.";
const defaultImage = `${siteUrl}/images/brain.png`;

const metaDescription = description || defaultDescription;
const rawOgImage = image || defaultImage;
const ogImage = rawOgImage.startsWith('http') ? rawOgImage : `${siteUrl}${rawOgImage}`;
const canonicalUrl = canonical || Astro.url.href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/favicon.png" sizes="any" />
		<link rel="manifest" href="/manifest.json" />

		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={metaDescription} />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:site_name" content="TMS List" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalUrl} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={metaDescription} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Fonts (non-blocking) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="dns-prefetch" href="https://fonts.googleapis.com" />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700&display=swap"
			rel="stylesheet"
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link
				href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700&display=swap"
				rel="stylesheet"
			/>
		</noscript>

		<!-- Generator -->
		<meta name="generator" content={Astro.generator} />

		<!-- Organization Schema -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "WebSite",
				"name": "TMS List",
				"url": "https://tmslist.com",
				"description": "The leading directory of TMS therapy providers in the United States",
				"potentialAction": {
					"@type": "SearchAction",
					"target": "https://tmslist.com/search?q={search_term_string}",
					"query-input": "required name=search_term_string"
				}
			}
		</script>

		<!-- Page Specific Schema -->
		{schema && <script type="application/ld+json" set:html={schema} />}

		<!-- Breadcrumb Schema -->
		{breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}
	</head>
	<body
		class="bg-surface-subtle min-h-screen text-slate-900 font-sans antialiased flex flex-col"
	>
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:bg-indigo-600 focus:text-white focus:rounded-lg focus:font-semibold">
			Skip to main content
		</a>
		<Header />
		<div id="main-content">
		<slot />
		</div>
		<Footer />
		<LocationPopup />
		<EnquiryModal client:idle />
	<script is:inline>
		window.showToast = function(msg, type) {
			var t = document.createElement('div');
			t.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-[200] px-6 py-3 text-sm font-medium rounded-xl shadow-lg transition-all';
			t.className += type === 'success' ? ' bg-emerald-600 text-white' : ' bg-slate-900 text-white';
			t.textContent = msg;
			document.body.appendChild(t);
			setTimeout(function() { t.style.opacity = '0'; setTimeout(function() { t.remove(); }, 300); }, 3500);
		};
	</script>
	</body>
</html>
