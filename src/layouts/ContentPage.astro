---
import Layout from "./Layout.astro";
import ContentHero from "../components/ContentHero.astro";
import FindClinicCTA from "../components/FindClinicCTA.astro";
import SectionLinks from "../components/SectionLinks.astro";

interface BreadcrumbItem {
    name: string;
    url: string;
}

interface Props {
    title: string;
    subtitle?: string;
    description?: string;
    schema?: string;
    reviewerName?: string;
    reviewerTitle?: string;
    imageSubject?: string;
    imageType?: 'treatment' | 'hero' | 'city';
    breadcrumbs?: BreadcrumbItem[];
}

const { title, subtitle, description, schema, reviewerName = "Dr. Karan Narwal", reviewerTitle = "Mental Health Specialist & Consultant", breadcrumbs } = Astro.props;
const reviewerImage = reviewerName === "Dr. Karan Narwal" ? "https://img1.wsimg.com/isteam/ip/f791d9b9-2f6c-4539-b9b3-61b4c8a8a446/Screenshot%202024-11-16%20at%204.26.32%E2%80%AFPM.png/:/cr=t:0%25,l:6.95%25,w:86.1%25,h:100%25/rs=w:600,h:600,cg:true" : null;
const reviewerBio = reviewerName === "Dr. Karan Narwal" ? "Dr. Narwal is a mental health specialist with extensive experience in neuromodulation therapies. He reviews all clinical content on TMS List for medical accuracy." : null;
const reviewerInitials = reviewerName.split(' ').map(n => n[0]).join('');

// Section-aware gradient colors based on URL path
const pathSegment = Astro.url.pathname.split('/')[1] || '';
const sectionColors: Record<string, { from: string; to: string; accent: string }> = {
    protocols: { from: 'from-cyan-600', to: 'to-slate-900', accent: 'cyan' },
    legal: { from: 'from-slate-600', to: 'to-slate-900', accent: 'slate' },
    providers: { from: 'from-violet-600', to: 'to-slate-900', accent: 'violet' },
    research: { from: 'from-blue-600', to: 'to-slate-900', accent: 'blue' },
    stories: { from: 'from-rose-600', to: 'to-slate-900', accent: 'rose' },
    demographic: { from: 'from-teal-600', to: 'to-slate-900', accent: 'cyan' },
    quiz: { from: 'from-emerald-600', to: 'to-slate-900', accent: 'emerald' },
    commercial: { from: 'from-amber-600', to: 'to-slate-900', accent: 'amber' },
    resources: { from: 'from-indigo-600', to: 'to-slate-900', accent: 'blue' },
};
const colors = sectionColors[pathSegment] || { from: 'from-violet-600', to: 'to-slate-900', accent: 'violet' };

// Section-aware badge
const sectionLabels: Record<string, string> = {
    protocols: 'Protocol Guide',
    legal: 'Legal & Compliance',
    providers: 'Provider Guide',
    research: 'Research',
    stories: 'Patient Story',
    demographic: 'Patient Guide',
    quiz: 'Interactive Tool',
    commercial: 'For Providers',
    resources: 'Resource',
};
const sectionLabel = sectionLabels[pathSegment];

// Section-aware related links
const sectionLinks: Record<string, { heading: string; links: { title: string; href: string }[] }[]> = {
    protocols: [
        { heading: 'Protocols', links: [
            { title: 'SAINT Protocol', href: '/protocols/saint-protocol/' },
            { title: 'Theta Burst', href: '/protocols/theta-burst-stimulation/' },
            { title: 'Deep TMS', href: '/protocols/deep-tms/' },
            { title: 'Accelerated TMS', href: '/protocols/accelerated-tms/' },
        ]},
        { heading: 'Treatments', links: [
            { title: 'TMS for Depression', href: '/treatments/depression/' },
            { title: 'TMS for OCD', href: '/treatments/ocd/' },
            { title: 'All Treatments', href: '/treatments/' },
        ]},
        { heading: 'Getting Started', links: [
            { title: 'Am I a Candidate?', href: '/quiz/am-i-a-candidate/' },
            { title: 'Find a Clinic', href: '/us/' },
            { title: 'Insurance Coverage', href: '/insurance/medicare/' },
        ]},
    ],
    legal: [
        { heading: 'Legal Guides', links: [
            { title: 'CPT Codes Guide', href: '/legal/tms-cpt-codes-guide-2026/' },
            { title: 'Malpractice Insurance', href: '/legal/tms-malpractice-insurance-guide/' },
            { title: 'Who Can Administer TMS', href: '/legal/who-can-administer-tms-by-state/' },
            { title: 'Starting a TMS Clinic', href: '/legal/starting-a-tms-clinic-requirements-by-state/' },
        ]},
        { heading: 'For Providers', links: [
            { title: 'Billing Services', href: '/providers/services/billing-services/' },
            { title: 'Insurance Credentialing', href: '/providers/services/insurance-credentialing/' },
            { title: 'Get Listed', href: '/providers/services/get-listed/' },
        ]},
        { heading: 'Insurance', links: [
            { title: 'Medicare Coverage', href: '/insurance/medicare/' },
            { title: 'Prior Authorization', href: '/insurance/prior-authorization-guide/' },
            { title: 'Single Case Agreements', href: '/legal/single-case-agreements-tms/' },
        ]},
    ],
    research: [
        { heading: 'Research', links: [
            { title: 'Clinical Trials', href: '/research/clinical-trials/' },
            { title: 'FDA Clearance History', href: '/research/fda-clearance-history/' },
            { title: 'Depression Meta-Analysis', href: '/research/tms-depression-meta-analysis/' },
            { title: 'TMS vs ECT Evidence', href: '/research/tms-vs-ect-evidence/' },
        ]},
        { heading: 'Treatments', links: [
            { title: 'TMS for Depression', href: '/treatments/depression/' },
            { title: 'TMS for Anxiety', href: '/treatments/anxiety/' },
            { title: 'All Treatments', href: '/treatments/' },
        ]},
        { heading: 'Getting Started', links: [
            { title: 'Am I a Candidate?', href: '/quiz/am-i-a-candidate/' },
            { title: 'Find a Clinic', href: '/us/' },
        ]},
    ],
demographic: [
        { heading: 'Patient Groups', links: [
            { title: 'TMS for Seniors', href: '/demographic/seniors-tms/' },
            { title: 'TMS for Veterans', href: '/demographic/veterans-tms/' },
            { title: 'TMS for Teens', href: '/demographic/teens-adolescents/' },
            { title: 'All Patient Groups', href: '/demographic/' },
        ]},
        { heading: 'Treatments', links: [
            { title: 'TMS for Depression', href: '/treatments/depression/' },
            { title: 'TMS for Anxiety', href: '/treatments/anxiety/' },
            { title: 'All Treatments', href: '/treatments/' },
        ]},
        { heading: 'Getting Started', links: [
            { title: 'Am I a Candidate?', href: '/quiz/am-i-a-candidate/' },
            { title: 'Find a Clinic', href: '/us/' },
            { title: 'Insurance Coverage', href: '/insurance/medicare/' },
        ]},
    ],
    technology: [
        { heading: 'Devices', links: [
            { title: 'NeuroStar', href: '/technology/neurostar/' },
            { title: 'MagVenture', href: '/technology/magventure/' },
            { title: 'Deep TMS (BrainsWay)', href: '/technology/brainsway-deep-tms/' },
            { title: 'All Devices', href: '/technology/' },
        ]},
        { heading: 'Treatments', links: [
            { title: 'TMS for Depression', href: '/treatments/depression/' },
            { title: 'TMS for OCD', href: '/treatments/ocd/' },
            { title: 'All Treatments', href: '/treatments/' },
        ]},
        { heading: 'Getting Started', links: [
            { title: 'Am I a Candidate?', href: '/quiz/am-i-a-candidate/' },
            { title: 'Find a Clinic', href: '/us/' },
        ]},
    ],
    "best-tms-clinics": [
        { heading: 'City Rankings', links: [
            { title: 'New York', href: '/best-tms-clinics/by-city/new-york/' },
            { title: 'Los Angeles', href: '/best-tms-clinics/by-city/los-angeles/' },
            { title: 'Chicago', href: '/best-tms-clinics/by-city/chicago/' },
            { title: 'All Cities', href: '/best-tms-clinics/' },
        ]},
        { heading: 'Resources', links: [
            { title: 'TMS Cost Guide', href: '/tms-cost-guide/' },
            { title: 'Insurance Coverage', href: '/insurance/' },
            { title: 'Am I a Candidate?', href: '/quiz/am-i-a-candidate/' },
        ]},
        { heading: 'Find Care', links: [
            { title: 'Browse All Clinics', href: '/us/' },
            { title: 'Compare Clinics', href: '/compare-clinics/' },
            { title: 'Patient Stories', href: '/stories/' },
        ]},
    ],
};
const relatedSections = sectionLinks[pathSegment] || [
    { heading: 'Popular Topics', links: [
        { title: 'TMS for Depression', href: '/treatments/depression/' },
        { title: 'Insurance Coverage', href: '/insurance/medicare/' },
        { title: 'TMS Cost Guide', href: '/tms-cost-guide/' },
        { title: 'Am I a Candidate?', href: '/quiz/am-i-a-candidate/' },
    ]},
    { heading: 'Compare Options', links: [
        { title: 'TMS vs. Medication', href: '/compare/tms-vs-antidepressants/' },
        { title: 'TMS vs. ECT', href: '/compare/tms-vs-ect/' },
        { title: 'TMS vs. Ketamine', href: '/compare/tms-vs-ketamine/' },
    ]},
    { heading: 'Find Care', links: [
        { title: 'Find a Clinic', href: '/us/' },
        { title: 'Patient Stories', href: '/stories/' },
        { title: 'Blog', href: '/blog/' },
    ]},
];
---

<Layout title={`${title} | TMS List`} description={description} schema={schema} breadcrumbs={breadcrumbs}>
    <ContentHero
        title={title}
        subtitle={subtitle || "What you need to know, without the medical jargon."}
        breadcrumbs={breadcrumbs}
        badges={sectionLabel ? [{ text: sectionLabel, color: colors.accent as any }] : []}
        accentFrom={colors.from}
        accentTo={colors.to}
    />

    <main class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
            <!-- Article Column -->
            <article class="lg:col-span-8 prose prose-lg prose-blue max-w-none prose-headings:font-display prose-headings:tracking-tight prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h3:text-xl prose-a:text-violet-600 prose-a:no-underline hover:prose-a:underline prose-strong:text-slate-900 prose-table:border prose-table:border-slate-200 prose-th:bg-slate-50 prose-th:px-4 prose-th:py-2 prose-td:px-4 prose-td:py-2 prose-td:border-t prose-td:border-slate-200 prose-img:rounded-xl prose-img:shadow-lg">
                <slot>
                    <div class="bg-slate-50 border-l-4 border-violet-500 p-6 mb-8 rounded-r-xl">
                        <h3 class="text-violet-700 font-semibold mt-0">Current as of 2026</h3>
                        <p class="mb-0">This guide reflects the latest information for {title}.</p>
                    </div>

                    <h2>About {title}</h2>
                    <p>TMS (Transcranial Magnetic Stimulation) uses focused magnetic pulses to stimulate specific areas of the brain. It's FDA-cleared for depression, OCD, and smoking cessation, with growing evidence for other conditions.</p>

                    <h2>What to Know</h2>
                    <ul>
                        <li><strong>Non-invasive.</strong> No surgery, no sedation. Sessions take 19–37 minutes.</li>
                        <li><strong>Evidence-based.</strong> Over a million treatments performed globally.</li>
                        <li><strong>Well-tolerated.</strong> Most common side effect is mild scalp discomfort.</li>
                        <li><strong>Covered by insurance.</strong> Medicare and most major plans cover TMS.</li>
                    </ul>

                    <div class="not-prose mt-12 p-8 bg-slate-900 rounded-2xl text-white text-center">
                        <h3 class="text-2xl font-semibold mb-4">Ready to find a clinic?</h3>
                        <p class="text-slate-300 mb-8">Browse verified TMS providers with real reviews and insurance info.</p>
                        <a href="/us/" class="inline-block bg-white text-slate-900 font-semibold py-3 px-8 rounded-xl hover:bg-slate-50 transition-colors">Find a Clinic Near You</a>
                    </div>
                </slot>
            </article>

            <!-- Sidebar -->
            <aside class="lg:col-span-4 space-y-6">
                <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-sm">
                    <h4 class="font-semibold text-slate-900 mb-4 uppercase text-xs tracking-wider">Medically Reviewed By</h4>
                    <div class="flex items-center gap-4">
                        {reviewerImage ? (
                            <img src={reviewerImage} alt={reviewerName} class="w-12 h-12 rounded-full object-cover border-2 border-violet-100" width="48" height="48" loading="lazy" />
                        ) : (
                            <div class="w-12 h-12 rounded-full bg-violet-100 flex items-center justify-center text-violet-600 font-semibold text-sm">
                                {reviewerInitials}
                            </div>
                        )}
                        <div>
                            <div class="font-semibold text-slate-900">{reviewerName}</div>
                            <div class="text-xs text-slate-500">{reviewerTitle}</div>
                        </div>
                    </div>
                    {reviewerBio && (
                        <p class="text-xs text-slate-500 mt-3 leading-relaxed">{reviewerBio}</p>
                    )}
                </div>

                <div class="bg-slate-50 p-6 rounded-2xl">
                    <h4 class="font-semibold text-slate-900 mb-4 uppercase text-xs tracking-wider">Related Topics</h4>
                    <ul class="space-y-3 text-sm">
                        <li><a href="/treatments/depression/" class="text-slate-600 hover:text-violet-600 transition-colors">TMS for Depression</a></li>
                        <li><a href="/insurance/medicare/" class="text-slate-600 hover:text-violet-600 transition-colors">Medicare Coverage</a></li>
                        <li><a href="/compare/tms-vs-antidepressants/" class="text-slate-600 hover:text-violet-600 transition-colors">TMS vs. Medication</a></li>
                        <li><a href="/tms-cost-guide/" class="text-slate-600 hover:text-violet-600 transition-colors">TMS Cost Guide</a></li>
                        <li><a href="/quiz/am-i-a-candidate/" class="text-slate-600 hover:text-violet-600 transition-colors">Am I a Candidate?</a></li>
                    </ul>
                </div>

                <div class="bg-gradient-to-br from-violet-600 to-violet-800 p-6 rounded-2xl text-white">
                    <h4 class="font-semibold mb-2 text-sm">Not sure where to start?</h4>
                    <p class="text-sm text-violet-200 mb-4">Take a 2-minute quiz to see if TMS might be right for you.</p>
                    <a href="/quiz/am-i-a-candidate/" class="inline-block text-sm font-semibold bg-white text-violet-700 px-4 py-2 rounded-lg hover:bg-violet-50 transition-colors">
                        Take the Quiz
                    </a>
                    <p class="text-xs text-violet-300 mt-3">Or <a href="/resources/buyers-guide/" class="underline hover:text-white">download the free Buyer's Guide</a></p>
                </div>
            </aside>
        </div>
    </main>

    <SectionLinks sections={relatedSections} />
    <FindClinicCTA />
</Layout>
