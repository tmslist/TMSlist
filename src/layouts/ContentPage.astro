---
import Layout from "./Layout.astro";
import Hero from "../components/Hero.astro";

interface BreadcrumbItem {
    name: string;
    url: string;
}

interface Props {
    title: string;
    subtitle?: string;
    description?: string;
    schema?: string;
    reviewerName?: string;
    reviewerTitle?: string;
    imageSubject?: string;
    imageType?: 'treatment' | 'hero' | 'city';
    breadcrumbs?: BreadcrumbItem[];
}

const { title, subtitle, description, schema, reviewerName = "Dr. Karan Narwal", reviewerTitle = "Mental Health Specialist & Consultant", imageSubject, imageType = 'hero', breadcrumbs } = Astro.props;
const reviewerImage = reviewerName === "Dr. Karan Narwal" ? "https://img1.wsimg.com/isteam/ip/f791d9b9-2f6c-4539-b9b3-61b4c8a8a446/Screenshot%202024-11-16%20at%204.26.32%E2%80%AFPM.png/:/cr=t:0%25,l:6.95%25,w:86.1%25,h:100%25/rs=w:600,h:600,cg:true" : null;
const reviewerBio = reviewerName === "Dr. Karan Narwal" ? "Dr. Narwal is a mental health specialist with extensive experience in neuromodulation therapies. He reviews all clinical content on TMS List for medical accuracy and alignment with current treatment guidelines." : null;
const reviewerInitials = reviewerName.split(' ').map(n => n[0]).join('');
---

<Layout title={`${title} | TMS List`} description={description} schema={schema} breadcrumbs={breadcrumbs}>
    <Hero
        title={title}
        subtitle={subtitle || "What you need to know, without the medical jargon."}
        imageSubject={imageSubject || title}
        imageType={imageType}
    />

    <main class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
            <!-- Article Column -->
            <article class="lg:col-span-8 prose prose-lg prose-blue max-w-none">
                <p class="lead text-xl text-gray-600 mb-8">
                    Everything you need to know about <strong>{title}</strong> — how it works, what it costs, and how to find a provider who actually knows what they're doing.
                </p>

                <slot>
                    <!-- Fallback content for SEO pages without custom content -->
                    <div
                        class="bg-gray-50 border-l-4 border-primary p-6 mb-8 rounded-r-xl"
                    >
                        <h3 class="text-primary font-semibold mt-0">
                            Current as of 2026
                        </h3>
                        <p class="mb-0">
                            This guide reflects the latest regulatory approvals and clinical data for {title}.
                        </p>
                    </div>

                    <h2>What is {title}?</h2>
                    <p>
                        TMS uses magnetic pulses to wake up parts of the brain that aren't firing the way they should. For depression, that's usually the left dorsolateral prefrontal cortex — a region that tends to be underactive in people with treatment-resistant symptoms.
                    </p>
                    <p>
                        It's not experimental. TMS was first cleared for depression in 2008, later for OCD and smoking cessation. It's now approved by regulatory bodies worldwide including the FDA (US), NICE (UK), TGA (Australia), and Health Canada. Over a million treatments have been performed globally.
                    </p>

                    <h3>What to expect</h3>
                    <ul>
                        <li>
                            <strong>No surgery, no sedation.</strong> You sit in a chair. A coil sits against your head. Sessions take 20-40 minutes.
                        </li>
                        <li>
                            <strong>It works for a lot of people.</strong> About 50-60% of patients with treatment-resistant depression see meaningful improvement. Around a third achieve full remission.
                        </li>
                        <li>
                            <strong>Side effects are mild.</strong> Most people report some scalp discomfort during the first few sessions. It usually fades.
                        </li>
                        <li>
                            <strong>Approved and increasingly covered by insurance.</strong> In the US, Medicare and most major plans cover TMS. In the UK, Australia, and other countries, public and private coverage is expanding.
                        </li>
                    </ul>

                    <figure>
                        <img
                            src="https://images.unsplash.com/photo-1631217868264-e5b90bb7e133?w=800&h=400&fit=crop&auto=format"
                            alt="A modern TMS treatment room with a patient chair and TMS device"
                            class="rounded-xl w-full shadow-lg"
                            width="800"
                            height="400"
                            loading="lazy"
                        />
                        <figcaption>
                            A typical TMS session — you sit in a reclining chair while the device does the work.
                        </figcaption>
                    </figure>

                    <h2>Does insurance cover it?</h2>
                    <p>
                        Short answer: probably, if you meet the criteria. Most plans require:
                    </p>
                    <ul>
                        <li>A diagnosis of Major Depressive Disorder (MDD)</li>
                        <li>You've tried 2-4 antidepressants that didn't work well enough</li>
                        <li>Prior authorization from your insurance company</li>
                    </ul>
                    <p>
                        The prior auth process can take a few days to a couple weeks. Many TMS clinics handle this for you — it's worth asking when you call.
                    </p>

                    <h2>How to pick a provider</h2>
                    <p>
                        Not all TMS clinics are the same. Here's what matters:
                    </p>
                    <ul>
                        <li><strong>The device they use.</strong> NeuroStar, BrainsWay, and MagVenture are the big three. Each has different strengths.</li>
                        <li><strong>Who's supervising treatment.</strong> A board-certified psychiatrist should be involved in your care, not just a technician.</li>
                        <li><strong>Patient reviews.</strong> What do other people say about the experience? That tells you more than any brochure.</li>
                    </ul>

                    <div
                        class="not-prose mt-12 p-8 bg-blue-900 rounded-2xl text-white text-center"
                    >
                        <h3 class="text-2xl font-semibold mb-4">
                            Ready to find a clinic?
                        </h3>
                        <p class="text-blue-100 mb-8">
                            Browse verified TMS providers with real reviews and insurance info.
                        </p>
                        <a
                            href="/us/"
                            class="inline-block bg-white text-blue-900 font-semibold py-3 px-8 rounded-xl hover:bg-blue-50 transition-colors"
                        >
                            Find a Clinic Near You
                        </a>
                    </div>
                </slot>
            </article>

            <!-- Sidebar -->
            <aside class="lg:col-span-4 space-y-8">
                <!-- Author Box -->
                <div
                    class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm"
                >
                    <h4
                        class="font-semibold text-gray-900 mb-4 uppercase text-xs tracking-wider"
                    >
                        Medically Reviewed By
                    </h4>
                    <div class="flex items-center gap-4">
                        {reviewerImage ? (
                            <img src={reviewerImage} alt={reviewerName} class="w-12 h-12 rounded-full object-cover border-2 border-violet-100" width="48" height="48" loading="lazy" />
                        ) : (
                            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary font-semibold text-sm">
                                {reviewerInitials}
                            </div>
                        )}
                        <div>
                            <div class="font-semibold text-gray-900">
                                {reviewerName}
                            </div>
                            <div class="text-xs text-gray-500">
                                {reviewerTitle}
                            </div>
                        </div>
                    </div>
                    {reviewerBio && (
                        <p class="text-xs text-gray-500 mt-3 leading-relaxed">{reviewerBio}</p>
                    )}
                </div>

                <!-- Related Links -->
                <div class="bg-gray-50 p-6 rounded-2xl">
                    <h4
                        class="font-semibold text-gray-900 mb-4 uppercase text-xs tracking-wider"
                    >
                        Related Topics
                    </h4>
                    <ul class="space-y-3 text-sm">
                        <li>
                            <a
                                href="/insurance/medicare/"
                                class="text-gray-600 hover:text-primary transition-colors"
                                >Does Medicare Cover TMS?</a
                            >
                        </li>
                        <li>
                            <a
                                href="/technology/neurostar/"
                                class="text-gray-600 hover:text-primary transition-colors"
                                >How NeuroStar Works</a
                            >
                        </li>
                        <li>
                            <a
                                href="/treatments/anxiety/"
                                class="text-gray-600 hover:text-primary transition-colors"
                                >TMS for Anxiety</a
                            >
                        </li>
                        <li>
                            <a
                                href="/compare/tms-vs-medication/"
                                class="text-gray-600 hover:text-primary transition-colors"
                                >TMS vs. Medication</a
                            >
                        </li>
                        <li>
                            <a
                                href="/quiz/am-i-a-candidate/"
                                class="text-gray-600 hover:text-primary transition-colors"
                                >Am I a Candidate?</a
                            >
                        </li>
                    </ul>
                </div>

                <!-- Quick CTA -->
                <div class="bg-primary/5 p-6 rounded-2xl border border-primary/10">
                    <h4 class="font-semibold text-gray-900 mb-2 text-sm">Not sure where to start?</h4>
                    <p class="text-sm text-gray-600 mb-4">Take a 2-minute quiz to see if TMS might be right for you.</p>
                    <a href="/quiz/am-i-a-candidate/" class="inline-block text-sm font-semibold text-primary hover:text-primary-dark transition-colors">
                        Take the Quiz →
                    </a>
                </div>
            </aside>
        </div>
    </main>
</Layout>
