---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import PortalShell from "../../components/react/PortalShell";
import PortalSidebar from "../../components/react/PortalSidebar";
import { validateSessionStrict, hasRole } from "../../utils/auth";

const session = await validateSessionStrict(Astro.request);
if (!session) {
  return Astro.redirect("/portal/login/");
}
if (!hasRole(session, 'admin', 'editor', 'clinic_owner', 'viewer')) {
  return Astro.redirect("/portal/login/");
}

// Validate session on every portal page for security
const isAuthenticated = !!session;
const userEmail = session.email;
const userId = session.userId;
---

<Layout title="Doctor Portal | TMS List" description="Manage your TMS clinic listing, patient enquiries, and analytics." noindex={true}>
  <div class="flex min-h-screen bg-[var(--paper2)]">
    <PortalSidebar client:load currentPage="dashboard" userEmail={userEmail} userId={userId} />
    <main class="flex-1 lg:ml-64 py-8">
      <div class="container mx-auto px-4 max-w-5xl">
        <slot />
      </div>
    </main>
  </div>
</Layout>