# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/tmslist?sslmode=require

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars
ADMIN_EMAILS=admin@tmslist.com

# Site
SITE_URL=https://tmslist.com

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Image CDN (Cloudinary)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=xxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxx

# Cache & Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxx

# Error Monitoring (Sentry)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx

# Payments (Stripe)
STRIPE_SECRET_KEY=sk_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PRICE_FEATURED=price_xxxxxxxxxxxx
STRIPE_PRICE_VERIFIED=price_xxxxxxxxxxxx

# Analytics (PostHog)
PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# AI (OpenRouter — fallback for Anthropic)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# AI (Google Gemini — image generation)
GEMINI_API_KEY=xxxxxxxxxxxx

# SMS (Twilio — review collection, notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Cron Jobs
CRON_SECRET=your-cron-secret-min-32-chars

# Image Storage (Vercel Blob) — fallback if Cloudinary not configured
BLOB_READ_WRITE_TOKEN=vercel_blob_xxxxxxxxxxxx

# Google Custom Search (for bulk-fetching clinic/doctor photos)
GOOGLE_SEARCH_API_KEY=xxxxxxxxxxxx
GOOGLE_SEARCH_CX=xxxxxxxxxxxx
